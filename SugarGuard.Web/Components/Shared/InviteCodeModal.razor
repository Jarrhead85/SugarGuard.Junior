@* Модальное окно для генерации и просмотра инвайт-кода ребёнка. *@
@using InviteCodeVm = SugarGuard.Web.ViewModels.InviteCodeVm
@using SugarGuard.Shared.Constants
@using static SugarGuard.Web.Services.SugarGuardApiService
@inject IJSRuntime JS

@if (IsVisible)
{
    <div class="modal-backdrop" @onclick="HandleBackdropClick" role="dialog"
         aria-modal="true" aria-labelledby="invite-modal-title">

        <div class="modal-panel" @onclick:stopPropagation>

            @* Шапка *@
            <div class="modal-header">
                <h2 id="invite-modal-title" class="modal-title">
                    @(TargetRole == UserRole.Doctor ? "Код для врача" : "Пригласить родителя")
                </h2>
                <button class="modal-close" @onclick="CloseAsync"
                        aria-label="Закрыть окно">
                    <svg viewBox="0 0 20 20" fill="none" width="20" height="20" aria-hidden="true">
                        <path d="M5 5l10 10M15 5L5 15" stroke="currentColor"
                              stroke-width="1.5" stroke-linecap="round" />
                    </svg>
                </button>
            </div>

            @* Тело: загрузка *@
            @if (_isLoading)
            {
                <div class="modal-body modal-body--loading" aria-live="polite" aria-busy="true">
                    <div class="modal-spinner" role="status">
                        <svg viewBox="0 0 24 24" fill="none" width="32" height="32" aria-hidden="true">
                            <circle cx="12" cy="12" r="10" stroke="currentColor"
                                    stroke-width="2" stroke-opacity="0.2" />
                            <path d="M12 2a10 10 0 0 1 10 10" stroke="currentColor"
                                  stroke-width="2" stroke-linecap="round" />
                        </svg>
                    </div>
                    <p class="modal-loading-text">Генерируем код…</p>
                </div>
            }

            @* Тело: ошибка *@
            else if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <div class="modal-body modal-body--error" role="alert">
                    <div class="modal-error-icon" aria-hidden="true">
                        <svg viewBox="0 0 20 20" fill="none" width="28" height="28">
                            <path d="M10 3L2 16h16L10 3Z" stroke="currentColor"
                                  stroke-width="1.5" stroke-linejoin="round"
                                  fill="currentColor" fill-opacity="0.1" />
                            <path d="M10 9v3M10 14.5v.5" stroke="currentColor"
                                  stroke-width="1.5" stroke-linecap="round" />
                        </svg>
                    </div>
                    <p class="modal-error-message">@_errorMessage</p>
                    <button class="btn btn-secondary" @onclick="GenerateAsync">
                        Попробовать снова
                    </button>
                </div>
            }

            @* Тело: код успешно получен *@
            else if (_inviteCode is not null)
            {
                <div class="modal-body">

                    @* Описание *@
                    <p class="modal-description">
                        @if (TargetRole == UserRole.Doctor)
                        {
                            @:Передайте этот код врачу. После ввода кода врач получит
                            @:доступ к данным ребёнка.
                        }
                        else
                        {
                            @:Поделитесь кодом с родителем. После активации он сможет
                            @:следить за показателями ребёнка.
                        }
                    </p>

                    @* Блок с кодом *@
                    <div class="invite-code-box">
                        <span class="invite-code-value" aria-label="Инвайт-код: @_inviteCode.Code"
                              id="invite-code-text">
                            @FormatCodeForDisplay(_inviteCode.Code)
                        </span>
                        <button class="btn-copy @(_copySuccess ? "btn-copy--success" : "")"
                                @onclick="CopyToClipboardAsync"
                                aria-label="Скопировать код в буфер обмена"
                                title="Скопировать">
                            @if (_copySuccess)
                            {
                                @* Иконка «галочка» *@
                                <svg viewBox="0 0 20 20" fill="none" width="18" height="18" aria-hidden="true">
                                    <path d="M4 10l5 5 7-7" stroke="currentColor"
                                          stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                                </svg>
                                <span>Скопировано</span>
                            }
                            else
                            {
                                @* Иконка «копировать» *@
                                <svg viewBox="0 0 20 20" fill="none" width="18" height="18" aria-hidden="true">
                                    <rect x="7" y="7" width="9" height="9" rx="1.5"
                                          stroke="currentColor" stroke-width="1.5" />
                                    <path d="M13 7V5a1.5 1.5 0 0 0-1.5-1.5H5A1.5 1.5 0 0 0 3.5 5v6.5A1.5 1.5 0 0 0 5 13h2"
                                          stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                                </svg>
                                <span>Скопировать</span>
                            }
                        </button>
                    </div>

                    @* Срок действия *@
                    <div class="invite-code-meta">
                        @if (_inviteCode.ExpiresAt > DateTime.UtcNow)
                        {
                            <span class="invite-code-meta__badge invite-code-meta__badge--active"
                                  aria-label="Код действителен">
                                <svg viewBox="0 0 12 12" fill="none" width="10" height="10" aria-hidden="true">
                                    <circle cx="6" cy="6" r="4" fill="currentColor" />
                                </svg>
                                Активен
                            </span>
                            <span class="invite-code-meta__expires">
                                Истекает @FormatExpiry(_inviteCode.ExpiresAt)
                            </span>
                        }
                        else
                        {
                            <span class="invite-code-meta__badge invite-code-meta__badge--expired">
                                Истёк срок действия
                            </span>
                        }
                    </div>

                    @* Кнопка — перегенерировать *@
                    <button class="btn btn-ghost btn-regenerate" @onclick="GenerateAsync"
                            disabled="@_isLoading">
                        <svg viewBox="0 0 20 20" fill="none" width="16" height="16" aria-hidden="true">
                            <path d="M4 4a7 7 0 1 1 0 12" stroke="currentColor"
                                  stroke-width="1.5" stroke-linecap="round" />
                            <path d="M4 2v4h4" stroke="currentColor"
                                  stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                        Сгенерировать новый код
                    </button>

                </div>
            }

            @* Подвал *@
            <div class="modal-footer">
                <button class="btn btn-primary" @onclick="CloseAsync">
                    Готово
                </button>
            </div>

        </div>
    </div>
}

@code {
    // Параметры    
    [Parameter]
    public bool IsVisible { get; set; } // Управляет видимостью модального окна

    [Parameter]
    public EventCallback<bool> IsVisibleChanged { get; set; } // Callback на изменение видимости для двустороннего биндинга

    [Parameter, EditorRequired]
    public Guid ChildId { get; set; } // ID ребёнка, для которого генерируется код

    [Parameter]
    public UserRole TargetRole { get; set; } = UserRole.Parent; // Целевая роль

    [Parameter, EditorRequired]
    public SugarGuardApiService ApiService { get; set; } = default!; // Сервис для вызовов API

    [Parameter]
    public EventCallback<InviteCodeVm> OnCodeGenerated { get; set; } // Вызывается после успешной генерации нового кода

    // Состояние
    private InviteCodeVm? _inviteCode;
    private bool _isLoading;
    private string? _errorMessage;
    private bool _copySuccess;
    private CancellationTokenSource _cts = new();

    // Жизненный цикл
    /// <inheritdoc/>
    protected override async Task OnParametersSetAsync()
    {
        // Каждый раз, когда модальное окно открывается заново — подгружаем/генерируем код
        if (IsVisible && _inviteCode is null && !_isLoading)
        {
            await GenerateAsync();
        }
    }

    // Действия 
    /// <summary>
    /// Генерирует инвайт-код через API
    /// </summary>
    private async Task GenerateAsync()
    {
        _isLoading = true;
        _errorMessage = null;
        _copySuccess = false;
        _inviteCode = null;

        // Отменяем предыдущий запрос, если он ещё идёт
        await _cts.CancelAsync();
        _cts.Dispose();
        _cts = new CancellationTokenSource();

        try
        {
            _inviteCode = await ApiService.GenerateInviteCodeAsync(
                ChildId, TargetRole, _cts.Token);

            if (OnCodeGenerated.HasDelegate)
                await OnCodeGenerated.InvokeAsync(_inviteCode);
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message.Contains("409")
                ? "Активный код уже существует. Попробуйте ещё раз."
                : "Не удалось получить код. Проверьте подключение и попробуйте снова.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    /// <summary>
    /// Копирует код в буфер обмена через JS interop
    /// </summary>
    private async Task CopyToClipboardAsync()
    {
        if (_inviteCode is null) return;

        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", _inviteCode.Code);
            _copySuccess = true;
            StateHasChanged();

            await Task.Delay(2000);
            _copySuccess = false;
        }
        catch
        {
        }
    }

    /// <summary>
    /// Закрывает модальное окно и сбрасывает внутреннее состояние
    /// </summary>
    private async Task CloseAsync()
    {
        _inviteCode = null;
        _errorMessage = null;
        _copySuccess = false;
        IsVisible = false;
        await IsVisibleChanged.InvokeAsync(false);
    }

    private async Task HandleBackdropClick() => await CloseAsync(); // Клик по backdrop закрывает окно

    // помогательные методы
    /// <summary>
    /// Форматирует код в читаемый вид: ABCD1234 - ABCD-1234
    /// </summary>
    private static string FormatCodeForDisplay(string code)
    {
        var normalized = ConnectionCodeFormat.Normalize(code);
        return normalized is null || !ConnectionCodeFormat.IsValid(normalized, normalize: false)
            ? code
            : ConnectionCodeFormat.Format(normalized);
    }

    /// <summary>
    /// Форматирует дату истечения в человекочитаемый вид
    /// </summary>
    private static string FormatExpiry(DateTime? expiresAt)
    {
        if (!expiresAt.HasValue)
            return "неизвестно";

        var value = expiresAt.Value;
        var local = value.ToLocalTime();
        var remaining = value - DateTime.UtcNow;

        return remaining.TotalHours switch
        {
            > 24 => $"{local:d MMM} в {local:HH:mm}",
            > 1 => $"через {(int)remaining.TotalHours} ч",
            >= 1 => "через 1 ч",
            _ => $"через {(int)remaining.TotalMinutes} мин"
        };
    }

    /// <inheritdoc/>
    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }
}
