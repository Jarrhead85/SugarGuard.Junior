@* модальный диалог истечения сессии *@

@namespace SugarGuard.Web.Components.Shared
@rendermode InteractiveServer

@inject NavigationManager Navigation
@inject IJSRuntime JS

@if (_visible)
{
    @* Backdrop — блокирует взаимодействие с UI под диалогом *@
    <div class="sed-backdrop" aria-hidden="true"></div>

    @* Диалог *@
    <div class="sed-overlay"
         role="alertdialog"
         aria-modal="true"
         aria-labelledby="sed-title"
         aria-describedby="sed-description"
         tabindex="-1"
         @ref="_dialogRef">

        <div class="sed-dialog" @onclick:stopPropagation="true">

            @* Иконка предупреждения *@
            <div class="sed-icon-wrap" aria-hidden="true">
                <svg class="sed-icon"
                     width="32" height="32" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor"
                     stroke-width="1.75" stroke-linecap="round"
                     stroke-linejoin="round">
                    <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
                    <line x1="12" y1="9" x2="12" y2="13" />
                    <line x1="12" y1="17" x2="12.01" y2="17" />
                </svg>
            </div>

            @* Заголовок *@
            <h2 class="sed-title" id="sed-title">
                Сессия истекла
            </h2>

            @* Описание *@
            <p class="sed-description" id="sed-description">
                Время сессии вышло или токен был отозван.
                Пожалуйста, войдите снова, чтобы продолжить работу.
            </p>

            @* Таймер автоматического редиректа *@
            @if (_countdown > 0)
            {
                <p class="sed-countdown" aria-live="polite" aria-atomic="true">
                    Автоматический переход через
                    <strong>@_countdown</strong>
                    @GetSecondsLabel(_countdown)
                </p>
            }

            @* Кнопка действия *@
            <div class="sed-actions">
                <button class="sed-btn-primary"
                        type="button"
                        @onclick="GoToLoginAsync"
                        aria-label="Войти снова в систему">
                    @if (_isNavigating)
                    {
                        <span class="sed-spinner" aria-hidden="true"></span>
                        <span>Переход…</span>
                    }
                    else
                    {
                        <svg width="16" height="16" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor"
                             stroke-width="2.25" stroke-linecap="round"
                             stroke-linejoin="round" aria-hidden="true">
                            <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4" />
                            <polyline points="10 17 15 12 10 7" />
                            <line x1="15" y1="12" x2="3" y2="12" />
                        </svg>
                        <span>Войти снова</span>
                    }
                </button>
            </div>

        </div>
    </div>
}

<style>
    /* BACKDROP */
    .sed-backdrop {
        position: fixed;
        inset: 0;
        z-index: 900;
        background: oklch(from var(--color-text) l c h / 0.45);
        backdrop-filter: blur(4px);
        -webkit-backdrop-filter: blur(4px);
        animation: sed-backdrop-in 200ms cubic-bezier(0.16, 1, 0.3, 1) both;
    }

    /* OVERLAY-КОНТЕЙНЕР (центрирование) */
    .sed-overlay {
        position: fixed;
        inset: 0;
        z-index: 901;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: var(--space-16);
        outline: none;
    }

    /* ДИАЛОГ */
    .sed-dialog {
        position: relative;
        width: 100%;
        max-width: 400px;
        background: var(--color-surface-2);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-xl);
        box-shadow: 0 2px 8px oklch(0.1 0.01 80 / 0.08), 0 16px 48px oklch(0.1 0.01 80 / 0.18), 0 32px 80px oklch(0.1 0.01 80 / 0.12);
        padding: var(--space-24) var(--space-24) var(--space-20);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--space-12);
        text-align: center;
        animation: sed-dialog-in 280ms cubic-bezier(0.16, 1, 0.3, 1) both;
    }

    /* ИКОНКА */
    .sed-icon-wrap {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 64px;
        height: 64px;
        border-radius: var(--radius-full);
        background: color-mix(in oklab, var(--color-warning) 12%, var(--color-surface));
        border: 1.5px solid color-mix(in oklab, var(--color-warning) 22%, var(--color-border));
        margin-bottom: var(--space-4);
        flex-shrink: 0;
    }

    .sed-icon {
        color: var(--color-warning);
        flex-shrink: 0;
    }

    /* ТЕКСТ */
    .sed-title {
        font-family: var(--font-display);
        font-size: clamp(1.125rem, 1rem + 0.5vw, 1.375rem);
        font-weight: 700;
        line-height: 1.2;
        color: var(--color-text);
        letter-spacing: -0.01em;
        margin: 0;
    }

    .sed-description {
        font-family: var(--font-body);
        font-size: 14px;
        line-height: 1.6;
        color: var(--color-text-muted);
        max-width: 32ch;
        margin: 0;
    }

    /* Таймер обратного отсчёта */
    .sed-countdown {
        font-family: var(--font-body);
        font-size: 13px;
        color: var(--color-text-faint);
        margin: 0;
        padding: var(--space-6) var(--space-12);
        background: var(--color-surface-offset);
        border-radius: var(--radius-full);
        border: 1px solid var(--color-divider);
    }

        .sed-countdown strong {
            font-weight: 700;
            color: var(--color-warning);
            font-variant-numeric: tabular-nums;
        }

    /* КНОПКИ */
    .sed-actions {
        display: flex;
        gap: var(--space-8);
        width: 100%;
        margin-top: var(--space-8);
    }

    .sed-btn-primary {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: var(--space-8);
        width: 100%;
        min-height: 44px;
        padding: var(--space-10) var(--space-20);
        background: var(--color-primary);
        color: #ffffff;
        border: none;
        border-radius: var(--radius-md);
        font-family: var(--font-body);
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        transition: background 180ms cubic-bezier(0.16, 1, 0.3, 1), box-shadow 180ms cubic-bezier(0.16, 1, 0.3, 1), transform 80ms;
        box-shadow: 0 1px 3px oklch(from var(--color-primary) l c h / 0.3);
    }

        .sed-btn-primary:hover:not(:disabled) {
            background: var(--color-primary-hover);
            box-shadow: 0 4px 12px oklch(from var(--color-primary) l c h / 0.35);
        }

        .sed-btn-primary:active:not(:disabled) {
            transform: scale(0.985);
            background: var(--color-primary-active);
        }

        .sed-btn-primary:focus-visible {
            outline: 2px solid var(--color-primary);
            outline-offset: 3px;
            border-radius: var(--radius-md);
        }

        .sed-btn-primary:disabled {
            opacity: 0.65;
            cursor: not-allowed;
        }

    /* СПИННЕР ЗАГРУЗКИ */
    .sed-spinner {
        display: inline-block;
        width: 16px;
        height: 16px;
        border: 2px solid rgba(255, 255, 255, 0.35);
        border-top-color: #ffffff;
        border-radius: 50%;
        animation: sed-spin 0.7s linear infinite;
        flex-shrink: 0;
    }

    /* АДАПТИВНОСТЬ */
    @@media (max-width: 480px) {
        .sed-dialog

    {
        padding: var(--space-20) var(--space-16) var(--space-16);
        border-radius: var(--radius-lg);
    }

    .sed-icon-wrap {
        width: 52px;
        height: 52px;
    }

    .sed-actions {
        flex-direction: column;
    }

    }

    /* АНИМАЦИИ */
    @@keyframes sed-backdrop-in {
        from

    {
        opacity: 0;
    }

    to {
        opacity: 1;
    }

    }

    @@keyframes sed-dialog-in {
        from

    {
        opacity: 0;
        transform: scale(0.94) translateY(8px);
    }

    to {
        opacity: 1;
        transform: scale(1) translateY(0);
    }

    }

    @@keyframes sed-spin {
        to

    {
        transform: rotate(360deg);
    }

    }

    /* REDUCED MOTION */
    @@media (prefers-reduced-motion: reduce) {
        .sed-backdrop

    {
        animation: none;
    }

    .sed-dialog {
        animation: none;
    }

    .sed-spinner {
        animation: none;
        border-top-color: #ffffff;
    }

    .sed-btn-primary:active {
        transform: none;
    }

    }
</style>

@code {
    // Состояние    
    private bool _visible; // Флаг видимости диалога

    private bool _isNavigating; // Флаг анимации кнопки

    private int _countdown = 5; // Обратный отсчёт в секундах до автоматического редиректа

    private CancellationTokenSource? _countdownCts; // Токен для отмены таймера при закрытии компонента

    private ElementReference _dialogRef; // Ссылка на DOM-элемент диалога для управления фокусом

    // Публичный API
    /// <summary>
    /// Показывает диалог истечения сессии
    /// </summary>
    public async Task ShowAsync()
    {
        // Сбрасываем состояние при повторном показе
        _countdown = 5;
        _isNavigating = false;
        _visible = true;

        // Отменяем предыдущий таймер, если был
        _countdownCts?.Cancel();
        _countdownCts?.Dispose();
        _countdownCts = new CancellationTokenSource();

        await InvokeAsync(StateHasChanged);

        // Фокус на диалог
        await Task.Delay(50, _countdownCts.Token).ContinueWith(
            async _ => await InvokeAsync(async () =>
            {
                try 
                { 
                    await JS.InvokeVoidAsync("eval", "0"); 
                } 
                catch
                {
                    
                }
                StateHasChanged();
            }),
            TaskContinuationOptions.OnlyOnRanToCompletion
        );

        // Запускаем таймер обратного отсчёта
        _ = StartCountdownAsync(_countdownCts.Token);
    }

    // Таймер 
    /// <summary>
    /// Запускает обратный отсчёт
    /// </summary>
    private async Task StartCountdownAsync(CancellationToken cancellationToken)
    {
        try
        {
            while (_countdown > 0 && !cancellationToken.IsCancellationRequested)
            {
                await Task.Delay(1000, cancellationToken);
                _countdown--;
                await InvokeAsync(StateHasChanged);
            }

            if (!cancellationToken.IsCancellationRequested && _countdown <= 0)
            {
                await GoToLoginAsync();
            }
        }
        catch (OperationCanceledException)
        {

        }
    }

    // Навигация
    /// <summary>
    /// Немедленно переходит на страницу входа
    /// </summary>
    private async Task GoToLoginAsync()
    {
        if (_isNavigating)
            return;

        _isNavigating = true;

        // Останавливаем таймер
        _countdownCts?.Cancel();

        await InvokeAsync(StateHasChanged);

        // Небольшая задержка для анимации кнопки
        await Task.Delay(120);

        _visible = false;

        Navigation.NavigateTo("/login", forceLoad: false);
    }

    // Вспомогательные методы
    /// <summary>
    /// Возвращает правильную форму слова "секунда" для таймера
    /// </summary>
    private static string GetSecondsLabel(int seconds)
    {
        var abs = Math.Abs(seconds % 100);
        if (abs is >= 11 and <= 19)
            return "секунд";

        return (abs % 10) switch
        {
            1 => "секунду",
            2 or 3 or 4 => "секунды",
            _ => "секунд"
        };
    }

    // IDisposable 
    /// <inheritdoc/>
    public void Dispose()
    {
        _countdownCts?.Cancel();
        _countdownCts?.Dispose();
    }
}