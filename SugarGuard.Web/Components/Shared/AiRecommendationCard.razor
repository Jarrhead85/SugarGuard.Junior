@* компонент карточки AI-рекомендации *@

@namespace SugarGuard.Web.Components.Shared
@using SugarGuard.Shared.Dto

<div class="ai-card @GetCardCssClass()" role="region" aria-label="Рекомендация AI-ассистента">

    @* Состояние загрузки (скелетон) *@
    @if (IsLoading)
    {
        <div class="ai-card__skeleton" aria-label="Загрузка рекомендации" aria-live="polite">
            <div class="ai-card__skeleton-header">
                <div class="skeleton skeleton--badge"></div>
                <div class="skeleton skeleton--source"></div>
            </div>
            <div class="skeleton skeleton--line skeleton--line-full"></div>
            <div class="skeleton skeleton--line skeleton--line-full"></div>
            <div class="skeleton skeleton--line skeleton--line-80"></div>
            <div class="skeleton skeleton--line skeleton--line-60"></div>
            <div class="ai-card__skeleton-footer">
                <div class="skeleton skeleton--chip"></div>
                <div class="skeleton skeleton--time"></div>
            </div>
        </div>
        return;
    }

    @* Пустое состояние *@
    @if (Recommendation is null)
    {
        <div class="ai-card__empty">
            <div class="ai-card__empty-icon" aria-hidden="true">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2Z" />
                    <path d="M12 8v4l3 3" />
                </svg>
            </div>
            <p class="ai-card__empty-title">Нет рекомендации</p>
            <p class="ai-card__empty-desc">
                Рекомендация появится после следующего измерения глюкозы
            </p>
        </div>
        return;
    }

    @* Основное содержимое *@
    @* Заголовок: иконка + бейдж срочности + источник *@
    <div class="ai-card__header">

        @* Иконка AI *@
        <div class="ai-card__icon @GetIconCssClass()" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="3" />
                <path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83" />
            </svg>
        </div>

        <div class="ai-card__header-text">
            <span class="ai-card__label">AI-рекомендация</span>
            @* Бейдж срочности *@
            <span class="ai-card__urgency-badge @GetUrgencyBadgeCssClass()"
                  role="status"
                  aria-label="Уровень срочности: @GetUrgencyLabel()">
                @GetUrgencyLabel()
            </span>
        </div>

        @* Индикатор кэша *@
        @if (Recommendation.IsFromCache)
        {
            <span class="ai-card__cache-chip" title="Рекомендация из кэша (похожая ситуация)">
                из кэша
            </span>
        }
    </div>

    @* Разделитель *@
    <div class="ai-card__divider" aria-hidden="true"></div>

    @* Текст рекомендации *@
    <div class="ai-card__body">
        <p class="ai-card__text" aria-label="Текст рекомендации">
            @Recommendation.RecommendationText
        </p>
    </div>

    @* Подвал: модель + время + латентность *@
    <div class="ai-card__footer">

        @* Источник (модель GigaChat) *@
        <div class="ai-card__source">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                 aria-hidden="true">
                <path d="M12 2L2 7l10 5 10-5-10-5Z" />
                <path d="M2 17l10 5 10-5" />
                <path d="M2 12l10 5 10-5" />
            </svg>
            <span>@FormatModelName(Recommendation.ModelUsed)</span>
        </div>

        @* Время генерации *@
        <div class="ai-card__meta">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                 aria-hidden="true">
                <circle cx="12" cy="12" r="10" />
                <polyline points="12 6 12 12 16 14" />
            </svg>
            <time datetime="@Recommendation.CreatedAt.ToString("o")"
                  title="@Recommendation.CreatedAt.ToString("dd.MM.yyyy HH:mm:ss")">
                @FormatRelativeTime(Recommendation.CreatedAt)
            </time>

            @* Латентность *@
            @if (!Recommendation.IsFromCache && Recommendation.LatencyMs > 0)
            {
                <span class="ai-card__latency" title="Время генерации ответа GigaChat">
                    · @Recommendation.LatencyMs мс
                </span>
            }
        </div>

    </div>

    @* Кнопка "Обновить" *@
    @if (OnRefresh.HasDelegate)
    {
        <div class="ai-card__actions">
            <button class="btn btn-ghost btn-sm ai-card__refresh-btn"
                    type="button"
                    @onclick="OnRefresh"
                    disabled="@IsRefreshing"
                    aria-label="Обновить рекомендацию">
                <svg class="@(IsRefreshing ? "ai-card__spin" : string.Empty)"
                     width="14" height="14" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                     aria-hidden="true">
                    <polyline points="23 4 23 10 17 10" />
                    <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10" />
                </svg>
                @(IsRefreshing ? "Обновление…" : "Обновить")
            </button>
        </div>
    }

</div>

@* Scoped-стили *@
<style>
    /* Базовая карточка */
    .ai-card {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        padding: var(--space-20);
        box-shadow: var(--shadow-card);
        transition: box-shadow var(--transition-interactive);
        display: flex;
        flex-direction: column;
        gap: var(--space-12);
    }

    /* Карточка Warning */
    .ai-card--warning {
        border-color: color-mix(in oklab, var(--color-glucose-warning) 30%, var(--color-border));
        background: color-mix(in oklab, var(--color-glucose-warning) 4%, var(--color-surface));
    }

    /* Карточка Critical */
    .ai-card--critical {
        border-color: color-mix(in oklab, var(--color-glucose-danger) 35%, var(--color-border));
        background: color-mix(in oklab, var(--color-glucose-danger) 5%, var(--color-surface));
        box-shadow: var(--shadow-hero);
    }

    /* Заголовок */
    .ai-card__header {
        display: flex;
        align-items: center;
        gap: var(--space-8);
        flex-wrap: wrap;
    }

    /* Иконка AI в кружке */
    .ai-card__icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border-radius: var(--radius-full);
        background: color-mix(in oklab, var(--color-primary) 12%, transparent);
        color: var(--color-primary);
        flex-shrink: 0;
        transition: background var(--transition-interactive);
    }

    .ai-card__icon--warning {
        background: color-mix(in oklab, var(--color-glucose-warning) 14%, transparent);
        color: var(--color-glucose-warning);
    }

    .ai-card__icon--critical {
        background: color-mix(in oklab, var(--color-glucose-danger) 14%, transparent);
        color: var(--color-glucose-danger);
    }

    .ai-card__header-text {
        display: flex;
        flex-direction: column;
        gap: 2px;
        flex: 1;
        min-width: 0;
    }

    .ai-card__label {
        font-size: var(--text-xs);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: var(--color-text-muted);
        white-space: nowrap;
    }

    /* Бейджи срочности */
    .ai-card__urgency-badge {
        display: inline-flex;
        align-items: center;
        gap: var(--space-1);
        font-size: var(--text-xs);
        font-weight: 700;
        padding: 2px 8px;
        border-radius: var(--radius-full);
        white-space: nowrap;
        align-self: flex-start;
    }

    .ai-card__urgency-badge--normal {
        background: color-mix(in oklab, var(--color-primary) 12%, transparent);
        color: var(--color-primary);
    }

    .ai-card__urgency-badge--warning {
        background: color-mix(in oklab, var(--color-glucose-warning) 15%, transparent);
        color: var(--color-glucose-warning);
    }

    .ai-card__urgency-badge--critical {
        background: color-mix(in oklab, var(--color-glucose-danger) 15%, transparent);
        color: var(--color-glucose-danger);
    }

    /* Чип "из кэша" */
    .ai-card__cache-chip {
        display: inline-flex;
        align-items: center;
        font-size: var(--text-xs);
        color: var(--color-text-faint);
        background: var(--color-surface-offset);
        border-radius: var(--radius-full);
        padding: 2px 8px;
        white-space: nowrap;
        margin-left: auto;
        cursor: help;
    }

    /* Разделитель */
    .ai-card__divider {
        height: 1px;
        background: var(--color-divider);
        margin: 0;
    }

    /* Тело (текст рекомендации) */
    .ai-card__body {
        flex: 1;
    }

    .ai-card__text {
        font-family: var(--font-body);
        font-size: var(--text-sm);
        line-height: 1.65;
        color: var(--color-text);
        margin: 0;
        white-space: pre-wrap;
        word-break: break-word;
    }

    /* Подвал */
    .ai-card__footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: var(--space-8);
    }

    .ai-card__source,
    .ai-card__meta {
        display: flex;
        align-items: center;
        gap: var(--space-1);
        font-size: var(--text-xs);
        color: var(--color-text-faint);
    }

    .ai-card__latency {
        color: var(--color-text-faint);
        font-size: var(--text-xs);
        font-variant-numeric: tabular-nums;
    }

    /* Кнопка обновления */
    .ai-card__actions {
        display: flex;
        justify-content: flex-end;
        padding-top: var(--space-4);
        border-top: 1px solid var(--color-divider);
    }

    .ai-card__refresh-btn {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        font-size: var(--text-xs);
        color: var(--color-text-muted);
    }

        .ai-card__refresh-btn:hover:not(:disabled) {
            color: var(--color-primary);
        }

        .ai-card__refresh-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

    /* Анимация вращения иконки обновления */
    @@keyframes spin {
        from

    {
        transform: rotate(0deg);
    }

    to {
        transform: rotate(360deg);
    }

    }

    .ai-card__spin {
        animation: spin 0.8s linear infinite;
    }

    /* Скелетон */
    .ai-card__skeleton {
        display: flex;
        flex-direction: column;
        gap: var(--space-12);
    }

    .ai-card__skeleton-header {
        display: flex;
        align-items: center;
        gap: var(--space-8);
    }

    .ai-card__skeleton-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: var(--space-4);
    }

    .skeleton {
        background: linear-gradient( 90deg, var(--color-surface-offset) 25%, var(--color-surface-dynamic, var(--color-surface-2)) 50%, var(--color-surface-offset) 75% );
        background-size: 200% 100%;
        animation: shimmer 1.5s ease-in-out infinite;
        border-radius: var(--radius-sm);
    }

    .skeleton--badge {
        width: 80px;
        height: 20px;
        border-radius: var(--radius-full);
    }

    .skeleton--source {
        width: 60px;
        height: 16px;
        margin-left: auto;
    }

    .skeleton--line {
        height: 14px;
    }

    .skeleton--line-full {
        width: 100%;
    }

    .skeleton--line-80 {
        width: 80%;
    }

    .skeleton--line-60 {
        width: 60%;
    }

    .skeleton--chip {
        width: 50px;
        height: 16px;
        border-radius: var(--radius-full);
    }

    .skeleton--time {
        width: 80px;
        height: 12px;
    }

    @@keyframes shimmer {
        0%

    {
        background-position: -200% 0;
    }

    100% {
        background-position: 200% 0;
    }

    }

    /* Пустое состояние */
    .ai-card__empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        padding: var(--space-24) var(--space-16);
        gap: var(--space-8);
    }

    .ai-card__empty-icon {
        color: var(--color-text-faint);
        margin-bottom: var(--space-4);
    }

    .ai-card__empty-title {
        font-size: var(--text-sm);
        font-weight: 600;
        color: var(--color-text);
        margin: 0;
    }

    .ai-card__empty-desc {
        font-size: var(--text-xs);
        color: var(--color-text-muted);
        margin: 0;
        max-width: 26ch;
    }

    /* Reduced motion */
    @@media (prefers-reduced-motion: reduce) {
        .skeleton

    {
        animation: none;
    }

    .ai-card__spin {
        animation: none;
    }

    }

    /* Мобильная адаптация */
    @@media (max-width: 480px) {
        .ai-card

    {
        padding: var(--space-16);
        gap: var(--space-8);
    }

    .ai-card__footer {
        flex-direction: column;
        align-items: flex-start;
    }

    }
</style>

@code {
    // Параметры   
    [Parameter]
    public AiRecommendationDto? Recommendation { get; set; } // DTO рекомендации от GigaChat

    [Parameter]
    public bool IsLoading { get; set; } // Показывать скелетон-загрузку

    [Parameter]
    public bool IsRefreshing { get; set; } // Идёт ли запрос на обновление

    [Parameter]
    public EventCallback OnRefresh { get; set; } // Событие запроса обновления рекомендации

    // Вспомогательные методы 
    /// <summary>
    /// CSS-класс корневого элемента карточки по уровню срочности
    /// </summary>
    private string GetCardCssClass() =>
        Recommendation?.Urgency switch
        {
            "Warning" => "ai-card--warning",
            "Critical" => "ai-card--critical",
            _ => string.Empty
        };

    /// <summary>
    /// CSS-класс иконки по уровню срочности
    /// </summary>
    private string GetIconCssClass() =>
        Recommendation?.Urgency switch
        {
            "Warning" => "ai-card__icon--warning",
            "Critical" => "ai-card__icon--critical",
            _ => string.Empty
        };

    /// <summary>
    /// CSS-класс бейджа по уровню срочности 
    /// </summary>
    private string GetUrgencyBadgeCssClass() =>
        Recommendation?.Urgency switch
        {
            "Warning" => "ai-card__urgency-badge--warning",
            "Critical" => "ai-card__urgency-badge--critical",
            _ => "ai-card__urgency-badge--normal"
        };

    /// <summary>
    /// Локализованный лейбл уровня срочности
    /// </summary>
    private string GetUrgencyLabel() =>
        Recommendation?.Urgency switch
        {
            "Warning" => "⚠ Внимание",
            "Critical" => "🔴 Критично",
            "Normal" => "✓ Норма",
            _ => "— —"
        };

    /// <summary>
    /// Форматирует имя модели GigaChat в читаемую строку
    /// </summary>
    private static string FormatModelName(string? model) =>
        model switch
        {
            "GigaChat" => "GigaChat",
            "GigaChat-Plus" => "GigaChat Plus",
            "GigaChat-Pro" => "GigaChat Pro",
            null or "" => "AI-ассистент",
            _ => model
        };

    /// <summary>
    /// Форматирует время генерации относительно текущего момента
    /// </summary>
    private static string FormatRelativeTime(DateTime createdAt)
    {
        var diff = DateTime.UtcNow - createdAt.ToUniversalTime();

        if (diff.TotalSeconds < 60)
            return "только что";

        if (diff.TotalMinutes < 60)
        {
            var minutes = (int)diff.TotalMinutes;
            return minutes switch
            {
                1 => "1 минуту назад",
                < 5 => $"{minutes} минуты назад",
                _ => $"{minutes} минут назад"
            };
        }

        if (diff.TotalHours < 24)
        {
            var hours = (int)diff.TotalHours;
            return hours switch
            {
                1 => "1 час назад",
                < 5 => $"{hours} часа назад",
                _ => $"{hours} часов назад"
            };
        }

        return createdAt.ToLocalTime().ToString("dd.MM HH:mm");
    }
}