@using Microsoft.AspNetCore.Components
@using SugarGuard.Web.Services

<div class="article-content">
    @foreach (var block in Parse(Content))
    {
        @switch (block.Kind)
        {
            case ArticleMarkdownBlockKind.Heading:
                <h3>@block.Text</h3>
                break;
            case ArticleMarkdownBlockKind.ListItem:
                <div class="article-content__item">@((MarkupString)_renderer.RenderInline(block.Text))</div>
                break;
            case ArticleMarkdownBlockKind.Image:
                <figure>
                    <img src="@block.Url" alt="@block.Text" loading="lazy" />
                    @if (!string.IsNullOrWhiteSpace(block.Text))
                    {
                        <figcaption>@block.Text</figcaption>
                    }
                </figure>
                break;
            default:
                <p>@((MarkupString)_renderer.RenderInline(block.Text))</p>
                break;
        }
    }
</div>

@code {
    [Parameter]
    public string Content { get; set; } = string.Empty;

    private readonly ArticleMarkdownRenderer _renderer = new();

    private IReadOnlyList<ArticleMarkdownBlock> Parse(string content) => _renderer.Parse(content);
}

<style>
    .article-content { color: var(--color-text-muted, #667694); line-height: 1.7; }
    .article-content > :first-child { margin-top: 0; }
    .article-content > :last-child { margin-bottom: 0; }
    .article-content h3 { margin: 20px 0 8px; color: var(--color-text, #16213e); font-size: 18px; }
    .article-content p { margin: 10px 0; }
    .article-content__item { position: relative; padding-left: 20px; margin: 7px 0; }
    .article-content__item::before { content: ""; position: absolute; left: 3px; top: .72em; width: 7px; height: 7px; border-radius: 50%; background: var(--color-primary, #1b8e8b); }
    .article-content figure { margin: 18px 0; }
    .article-content img { display: block; max-width: min(100%, 720px); border: 1px solid var(--color-border, rgba(22,33,62,.12)); border-radius: 16px; }
    .article-content figcaption { margin-top: 7px; color: var(--color-text-faint, #96a2b8); font-size: 13px; }
</style>
