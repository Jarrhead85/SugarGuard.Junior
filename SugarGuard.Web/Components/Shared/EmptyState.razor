@* компонент пустого состояния *@

<div class="sg-empty-state sg-empty-state--@Size"
     role="status"
     aria-label="@Title">

    @* Иконка — либо переданная SVG-разметка, либо дефолтная *@
    <div class="sg-empty-state__icon" aria-hidden="true">
        @if (Icon is not null)
        {
            @Icon
        }
        else
        {
            @* Дефолтная иконка: папка с вопросом *@
            <svg viewBox="0 0 48 48"
                 fill="none"
                 xmlns="http://www.w3.org/2000/svg"
                 aria-hidden="true">
                <rect x="4" y="14" width="40" height="28"
                      rx="4"
                      stroke="currentColor"
                      stroke-width="2.5"
                      fill="none" />
                <path d="M4 20h40"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round" />
                <path d="M4 14l5-8h12l3 8"
                      stroke="currentColor"
                      stroke-width="2.5"
                      stroke-linejoin="round"
                      fill="none" />
                <circle cx="24" cy="31" r="1.5"
                        fill="currentColor" />
                <path d="M24 24v4"
                      stroke="currentColor"
                      stroke-width="2.5"
                      stroke-linecap="round" />
            </svg>
        }
    </div>

    @* Заголовок *@
    <h3 class="sg-empty-state__title">
        @(Title ?? "Данных нет")
    </h3>

    @* Описание *@
    @if (!string.IsNullOrWhiteSpace(Description))
    {
        <p class="sg-empty-state__description">
            @Description
        </p>
    }

    @* Область действий *@
    @if (ChildContent is not null)
    {
        <div class="sg-empty-state__actions">
            @ChildContent
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(ActionText) && OnAction.HasDelegate)
    {
        @* Одна кнопка-действие через параметры *@
        <div class="sg-empty-state__actions">
            <button class="sg-btn sg-btn--primary sg-btn--@ActionVariant"
                    type="button"
                    onclick="@OnAction"
                    disabled="@IsActionDisabled"
                    aria-busy="@IsActionLoading">

                @if (IsActionLoading)
                {
                    <span class="sg-spinner sg-spinner--sm" aria-hidden="true"></span>
                }
                else if (ActionIcon is not null)
                {
                    <span class="sg-empty-state__btn-icon" aria-hidden="true">
                        @ActionIcon
                    </span>
                }

                <span>@ActionText</span>
            </button>
        </div>
    }

</div>

<style>
    /* Контейнер пустого состояния */
    .sg-empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: clamp(2rem, 6vw, 4rem) clamp(1rem, 4vw, 2rem);
        gap: var(--space-8, 8px);
        color: var(--sg-text-muted, #7a7974);
        width: 100%;
    }

    /* Размеры */
    .sg-empty-state--sm {
        padding: var(--space-24, 24px) var(--space-16, 16px);
        gap: var(--space-4, 4px);
    }

    .sg-empty-state--md {
        padding: clamp(2rem, 6vw, 3rem) clamp(1rem, 4vw, 1.5rem);
        gap: var(--space-8, 8px);
    }

    .sg-empty-state--lg {
        padding: clamp(3rem, 8vw, 5rem) clamp(1.5rem, 5vw, 2.5rem);
        gap: var(--space-12, 12px);
    }

    /* Иконка */
    .sg-empty-state__icon {
        color: var(--sg-text-faint, #bab9b4);
        margin-bottom: var(--space-4, 4px);
        /* Плавное появление при смене состояния */
        animation: sg-empty-appear 0.3s cubic-bezier(0.16, 1, 0.3, 1) both;
    }

    .sg-empty-state--sm .sg-empty-state__icon {
        width: 32px;
        height: 32px;
    }

    .sg-empty-state--md .sg-empty-state__icon {
        width: 48px;
        height: 48px;
    }

    .sg-empty-state--lg .sg-empty-state__icon {
        width: 64px;
        height: 64px;
    }

    .sg-empty-state__icon svg {
        width: 100%;
        height: 100%;
        display: block;
    }

    /* Заголовок */
    .sg-empty-state__title {
        font-family: var(--font-display, var(--sg-font-display, Satoshi, sans-serif));
        font-size: var(--sg-font-section, clamp(1rem, 0.9rem + 0.5vw, 1.25rem));
        font-weight: 600;
        color: var(--sg-text, #28251d);
        margin: 0;
        text-wrap: balance;
        line-height: 1.3;
    }

    .sg-empty-state--sm .sg-empty-state__title {
        font-size: var(--sg-font-body, clamp(0.875rem, 0.8rem + 0.35vw, 1rem));
    }

    .sg-empty-state--lg .sg-empty-state__title {
        font-size: clamp(1.125rem, 1rem + 0.5vw, 1.375rem);
    }

    /* Описание */
    .sg-empty-state__description {
        font-family: var(--font-body, var(--sg-font-body, Satoshi, sans-serif));
        font-size: var(--sg-font-body, clamp(0.875rem, 0.8rem + 0.35vw, 1rem));
        color: var(--sg-text-muted, #7a7974);
        margin: 0;
        max-width: 36ch;
        line-height: 1.5;
        text-wrap: pretty;
    }

    .sg-empty-state--sm .sg-empty-state__description {
        font-size: var(--sg-font-label, clamp(0.75rem, 0.7rem + 0.25vw, 0.875rem));
        max-width: 30ch;
    }

    /* Область действий */
    .sg-empty-state__actions {
        display: flex;
        align-items: center;
        justify-content: center;
        flex-wrap: wrap;
        gap: var(--space-8, 8px);
        margin-top: var(--space-8, 8px);
    }

    .sg-empty-state--sm .sg-empty-state__actions {
        margin-top: var(--space-4, 4px);
    }

    .sg-empty-state--lg .sg-empty-state__actions {
        margin-top: var(--space-16, 16px);
    }

    /* Иконка внутри кнопки */
    .sg-empty-state__btn-icon {
        display: inline-flex;
        align-items: center;
        flex-shrink: 0;
    }

        .sg-empty-state__btn-icon svg {
            width: 16px;
            height: 16px;
        }

    /* Кнопки */
    .sg-empty-state .sg-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: var(--space-8, 8px);
        min-height: 44px;
        padding: 0 var(--space-20, 20px);
        border: none;
        border-radius: var(--sg-radius-full, 9999px);
        font-family: var(--font-body, Satoshi, sans-serif);
        font-size: var(--sg-font-body, 15px);
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        white-space: nowrap;
        transition: background-color var(--sg-transition, 180ms cubic-bezier(0.16,1,0.3,1)), color var(--sg-transition, 180ms cubic-bezier(0.16,1,0.3,1)), box-shadow var(--sg-transition, 180ms cubic-bezier(0.16,1,0.3,1)), transform var(--sg-transition, 180ms cubic-bezier(0.16,1,0.3,1));
    }

        .sg-empty-state .sg-btn:active:not(:disabled) {
            transform: scale(0.97);
        }

        .sg-empty-state .sg-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

    /* Primary */
    .sg-empty-state .sg-btn--primary {
        background-color: var(--sg-primary, #01696f);
        color: var(--sg-text-inverse, #f9f8f4);
    }

        .sg-empty-state .sg-btn--primary:hover:not(:disabled) {
            background-color: var(--sg-primary-hover, #0c4e54);
            box-shadow: var(--sg-shadow-md, 0 4px 12px rgba(0,0,0,0.08));
        }

    /* Secondary */
    .sg-empty-state .sg-btn--secondary {
        background-color: transparent;
        color: var(--sg-primary, #01696f);
        border: 1.5px solid var(--sg-primary, #01696f);
    }

        .sg-empty-state .sg-btn--secondary:hover:not(:disabled) {
            background-color: var(--sg-primary-highlight, #cedcd8);
        }

    /* Ghost */
    .sg-empty-state .sg-btn--ghost {
        background-color: transparent;
        color: var(--sg-text-muted, #7a7974);
        border: none;
    }

        .sg-empty-state .sg-btn--ghost:hover:not(:disabled) {
            background-color: var(--sg-surface-offset, #f3f0ec);
            color: var(--sg-text, #28251d);
        }

    /* Sm-кнопка */
    .sg-empty-state .sg-btn--sm {
        min-height: 36px;
        padding: 0 var(--space-16, 16px);
        font-size: var(--sg-font-label, 13px);
    }

    /* Спиннер внутри кнопки */
    .sg-empty-state .sg-spinner--sm {
        display: inline-block;
        width: 14px;
        height: 14px;
        border-radius: 50%;
        border: 2px solid color-mix(in oklab, currentColor 25%, transparent);
        border-top-color: currentColor;
        animation: sg-spin-empty 0.7s linear infinite;
        flex-shrink: 0;
    }

    @@keyframes sg-spin-empty {
        to

    {
        transform: rotate(360deg);
    }

    }

    /* Появление компонента */
    @@keyframes sg-empty-appear {
        from

    {
        opacity: 0;
        transform: translateY(8px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    /* prefers-reduced-motion */
    @@media (prefers-reduced-motion: reduce) {
        .sg-empty-state__icon

    {
        animation: none;
    }

    .sg-empty-state .sg-spinner--sm {
        animation: none;
        opacity: 0.6;
    }

    }
</style>

@code {      
    [Parameter]
    public RenderFragment? Icon { get; set; } // SVG-иконка в виде RenderFragment

    [Parameter]
    public string? Title { get; set; } // Заголовок пустого состояния

    [Parameter]
    public string? Description { get; set; } // Описание

    [Parameter]
    public string? ActionText { get; set; } // Текст кнопки-действия

    [Parameter]
    public RenderFragment? ActionIcon { get; set; } // SVG-иконка внутри кнопки-действия

    [Parameter]
    public string ActionVariant { get; set; } = "primary"; // Вариант кнопки

    [Parameter]
    public EventCallback OnAction { get; set; } // Callback при нажатии на кнопку-действие

    [Parameter]
    public bool IsActionDisabled { get; set; } // Заблокировать кнопку-действие

    [Parameter]
    public bool IsActionLoading { get; set; } // Показать спиннер внутри кнопки

    [Parameter]
    public string Size { get; set; } = "md"; // Размер компонента

    [Parameter]
    public RenderFragment? ChildContent { get; set; } // Произвольные действия вместо стандартной кнопки
}