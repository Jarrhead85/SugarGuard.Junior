@* карточка пациента *@

@using SugarGuard.Web.Services
@using SugarGuard.Web.ViewModels

@inject NavigationManager NavigationManager

@* Разметка карточки пациента *@

<article class="sg-patient-card @(IsHighlighted ? "sg-patient-card--highlighted" : "")"
         role="article"
         aria-label="@PatientAriaLabel">

    @* Верхняя строка: аватар, данные ребёнка и последнее измерение *@
    <div class="sg-patient-card__header">

        <div class="sg-patient-card__avatar" aria-hidden="true">
            @AvatarInitials
        </div>

        <div class="sg-patient-card__identity">
            <p class="sg-patient-card__name">@FullName</p>
            <p class="sg-patient-card__meta">
                @AgeLabel
                @if (!string.IsNullOrWhiteSpace(Patient.DiabetesType))
                {
                    <span class="sg-patient-card__sep" aria-hidden="true">·</span>
                    <span>@Patient.DiabetesType</span>
                }
            </p>
        </div>

        @* Последний показатель глюкозы — правый угол *@
        <div class="sg-patient-card__glucose-block" aria-label="@GlucoseAriaLabel">
            @if (Patient.LatestGlucose.HasValue)
            {
                <span class="sg-patient-card__glucose-reading">
                    <span class="sg-patient-card__glucose-value sg-glucose--@GlucoseUiStateClass">
                        @Patient.LatestGlucose.Value.ToString("F1")
                    </span>
                    <span class="sg-patient-card__glucose-unit">ммоль/л</span>
                </span>
                <span class="sg-patient-card__glucose-state sg-patient-card__glucose-state--@GlucoseUiStateClass">
                    @GlucoseStateLabel
                </span>
            }
            else
            {
                <span class="sg-patient-card__glucose-empty">—</span>
            }
        </div>
    </div>

    @* TIR-прогресс-бар *@
    <div class="sg-patient-card__tir-row">
        <span class="sg-patient-card__tir-label">
            Время в диапазоне
        </span>
        <span class="sg-patient-card__tir-value @TirValueClass">
            @Patient.TimeInTargetRange.ToString("F0")%
        </span>
    </div>

    <div class="sg-patient-card__tir-bar" role="progressbar"
         aria-valuenow="@((int)Patient.TimeInTargetRange)"
         aria-valuemin="0"
         aria-valuemax="100"
         aria-label="Время в целевом диапазоне: @((int)Patient.TimeInTargetRange)%">
        <div class="sg-patient-card__tir-fill @TirFillClass"
             style="width: @(Math.Clamp((int)Patient.TimeInTargetRange, 0, 100))%">
        </div>
    </div>

    @* Нижняя строка: компактная статистика + переход к карточке *@
    <div class="sg-patient-card__footer">

        <div class="sg-patient-card__stats">
            @if (Patient.CriticalEventsLast7Days > 0)
            {
                <span class="sg-patient-card__stat sg-patient-card__stat--danger"
                      title="Критические события за 7 дней">
                    <span class="sg-patient-card__stat-label">Критических за 7 дней</span>
                    <strong>@Patient.CriticalEventsLast7Days</strong>
                </span>
            }

            <span class="sg-patient-card__stat sg-patient-card__stat--muted"
                  title="Измерений за 7 дней">
                <span class="sg-patient-card__stat-label">Измерений за 7 дней</span>
                <strong>@Patient.MeasurementsLast7Days</strong>
            </span>

            @if (Patient.LatestMeasurementTime.HasValue)
            {
                <span class="sg-patient-card__stat sg-patient-card__stat--muted"
                      title="Последнее измерение">
                    <span class="sg-patient-card__stat-label">Последнее</span>
                    <time datetime="@Patient.LatestMeasurementTime.Value.ToString("yyyy-MM-ddTHH:mm:ssZ")">
                        @FormatLastMeasurementTime(Patient.LatestMeasurementTime.Value)
                    </time>
                </span>
            }
        </div>

        <button class="sg-btn sg-btn--soft sg-btn--sm"
                type="button"
                @onclick="NavigateToDetailAsync"
                aria-label="Открыть карточку пациента @FullName">
            <span>Открыть</span>
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor"
                 stroke-width="1.8" aria-hidden="true">
                <path d="M6 4l4 4-4 4" />
            </svg>
        </button>
    </div>
</article>

@* Scoped-стили карточки *@

<style>
    /* Базовый контейнер карточки */
    .sg-patient-card {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-xl);
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 16px;
        box-shadow: var(--shadow-sm);
        transition: box-shadow var(--transition-interactive), border-color var(--transition-interactive), transform var(--transition-interactive);
        cursor: default;
    }

        .sg-patient-card:hover {
            box-shadow: var(--shadow-md);
            border-color: color-mix(in oklab, var(--color-primary) 30%, var(--color-border));
            transform: translateY(-1px);
        }

    /* Выделенная карточка (например, с критическим статусом) */
    .sg-patient-card--highlighted {
        border-color: color-mix(in oklab, var(--color-danger) 40%, var(--color-border));
        background: color-mix(in oklab, var(--color-danger) 4%, var(--color-surface));
    }

    /* Шапка карточки: аватар + имя + глюкоза */
    .sg-patient-card__header {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr) auto;
        align-items: start;
        gap: 12px;
    }

    /* Круглый аватар с инициалами */
    .sg-patient-card__avatar {
        width: 40px;
        height: 40px;
        min-width: 40px;
        border-radius: var(--radius-full);
        background: color-mix(in oklab, var(--color-primary) 14%, var(--color-surface));
        color: var(--color-primary);
        font-size: var(--text-sm);
        font-weight: 700;
        font-family: var(--font-display);
        display: grid;
        place-items: center;
        letter-spacing: 0.04em;
        user-select: none;
    }

    /* Блок с именем и метаинформацией */
    .sg-patient-card__identity {
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .sg-patient-card__name {
        margin: 0;
        font-size: var(--text-base);
        font-weight: 600;
        color: var(--color-text);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 100%;
    }

    .sg-patient-card__meta {
        margin: 0;
        font-size: var(--text-xs);
        color: var(--color-text-muted);
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: var(--space-1);
    }

    .sg-patient-card__sep {
        color: var(--color-text-faint);
    }

    /* Блок глюкозы — правый угол шапки */
    .sg-patient-card__glucose-block {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 5px;
        flex-shrink: 0;
    }

    .sg-patient-card__glucose-reading {
        display: inline-flex;
        align-items: baseline;
        justify-content: flex-end;
        gap: 4px;
        white-space: nowrap;
    }

    .sg-patient-card__glucose-value {
        font-family: var(--font-display), monospace;
        font-size: var(--text-lg);
        font-weight: 700;
        font-variant-numeric: tabular-nums;
        line-height: 1;
    }

    /* Цвета глюкозы по UI-состоянию */
    .sg-glucose--normal {
        color: var(--color-glucose-normal, #1B8E8B);
    }

    .sg-glucose--warning {
        color: var(--color-glucose-warning, #E3A32B);
    }

    .sg-glucose--danger {
        color: var(--color-glucose-danger, #DB5967);
    }

    .sg-glucose--critical {
        color: var(--color-glucose-danger, #DB5967);
    }

    .sg-patient-card__glucose-unit {
        font-size: var(--text-xs);
        color: var(--color-text-muted);
        line-height: 1.2;
    }

    .sg-patient-card__glucose-state {
        display: inline-flex;
        align-items: center;
        min-height: 22px;
        padding: 2px 8px;
        border: 1px solid transparent;
        border-radius: var(--radius-full);
        font-size: var(--text-xs);
        font-weight: 750;
        line-height: 1;
        white-space: nowrap;
    }

    .sg-patient-card__glucose-state--normal {
        color: var(--color-glucose-normal, #1B8E8B);
        background: color-mix(in oklab, var(--color-glucose-normal, #1B8E8B) 12%, transparent);
        border-color: color-mix(in oklab, var(--color-glucose-normal, #1B8E8B) 22%, transparent);
    }

    .sg-patient-card__glucose-state--warning {
        color: var(--color-glucose-warning, #E3A32B);
        background: color-mix(in oklab, var(--color-glucose-warning, #E3A32B) 12%, transparent);
        border-color: color-mix(in oklab, var(--color-glucose-warning, #E3A32B) 22%, transparent);
    }

    .sg-patient-card__glucose-state--danger,
    .sg-patient-card__glucose-state--critical {
        color: var(--color-glucose-danger, #DB5967);
        background: color-mix(in oklab, var(--color-glucose-danger, #DB5967) 12%, transparent);
        border-color: color-mix(in oklab, var(--color-glucose-danger, #DB5967) 22%, transparent);
    }

    .sg-patient-card__glucose-state--muted {
        color: var(--color-text-muted);
        background: var(--color-surface-offset);
        border-color: var(--color-border);
    }

    .sg-patient-card__glucose-empty {
        font-size: var(--text-lg);
        color: var(--color-text-faint);
        font-weight: 600;
    }

    /* Строка TIR-лейбла */
    .sg-patient-card__tir-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
    }

    .sg-patient-card__tir-label {
        font-size: var(--text-xs);
        color: var(--color-text-muted);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .sg-patient-card__tir-value {
        font-size: var(--text-sm);
        font-weight: 600;
        font-variant-numeric: tabular-nums;
    }

    /* Цвет TIR-значения по порогам */
    .sg-tir--good {
        color: var(--color-success);
    }

    .sg-tir--warning {
        color: var(--color-warning);
    }

    .sg-tir--danger {
        color: var(--color-error);
    }

    /* TIR-прогресс-бар */
    .sg-patient-card__tir-bar {
        height: 6px;
        border-radius: var(--radius-full);
        background: var(--color-surface-offset);
        overflow: hidden;
    }

    .sg-patient-card__tir-fill {
        height: 100%;
        border-radius: var(--radius-full);
        transition: width 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .sg-tir-fill--good {
        background: var(--color-success);
    }

    .sg-tir-fill--warning {
        background: var(--color-warning);
    }

    .sg-tir-fill--danger {
        background: var(--color-error);
    }

    /* Нижняя строка: статистика + кнопка */
    .sg-patient-card__footer {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 14px;
        margin-top: auto;
        padding-top: 14px;
        border-top: 1px solid color-mix(in oklab, var(--color-border) 72%, transparent);
    }

    .sg-patient-card__stats {
        display: flex;
        align-items: center;
        gap: 8px 14px;
        flex-wrap: wrap;
        min-width: 0;
    }

    .sg-patient-card__stat {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        min-height: 24px;
        font-size: var(--text-xs);
        font-variant-numeric: tabular-nums;
        white-space: nowrap;
    }

    .sg-patient-card__stat-label {
        color: var(--color-text-muted);
    }

    .sg-patient-card__stat strong,
    .sg-patient-card__stat time {
        color: currentColor;
        font-weight: 750;
    }

    .sg-patient-card__stat--danger {
        color: var(--color-error);
        font-weight: 600;
    }

    .sg-patient-card__stat--muted {
        color: var(--color-text-muted);
    }

    /* Кнопки */
    .sg-btn {
        min-height: 44px;
        padding: 0 var(--space-6);
        border-radius: var(--radius-full);
        font-size: var(--text-sm);
        font-weight: 600;
        font-family: var(--font-body);
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        cursor: pointer;
        border: none;
        transition: transform var(--transition-interactive), background var(--transition-interactive), opacity var(--transition-interactive);
        white-space: nowrap;
    }

        .sg-btn:hover:not(:disabled) {
            transform: translateY(-1px);
        }

        .sg-btn:active:not(:disabled) {
            transform: translateY(0);
        }

        .sg-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

    .sg-btn--sm {
        min-height: 36px;
        padding: 0 12px;
        font-size: var(--text-xs);
    }

    .sg-btn--soft {
        background: color-mix(in oklab, var(--color-primary) 12%, transparent);
        color: var(--color-primary);
        border: 1px solid color-mix(in oklab, var(--color-primary) 20%, transparent);
    }

        .sg-btn--soft:hover:not(:disabled) {
            background: color-mix(in oklab, var(--color-primary) 18%, transparent);
        }

        .sg-btn--soft svg {
            width: 14px;
            height: 14px;
        }

    @@media (max-width: 560px) {
        .sg-patient-card {
            padding: 18px;
        }

        .sg-patient-card__header {
            grid-template-columns: auto minmax(0, 1fr);
        }

        .sg-patient-card__glucose-block {
            grid-column: 1 / -1;
            flex-direction: row;
            align-items: center;
            justify-content: flex-start;
        }

        .sg-patient-card__glucose-reading {
            justify-content: flex-start;
        }

        .sg-patient-card__footer {
            align-items: stretch;
            flex-direction: column;
        }

        .sg-patient-card__stats {
            align-items: flex-start;
            flex-direction: column;
            gap: 6px;
        }

        .sg-btn--sm {
            justify-content: center;
            width: 100%;
        }
    }
</style>

@* логика компонента *@

@code {
    [Parameter, EditorRequired]
    public DoctorPatientSummaryVm Patient { get; set; } = default!; // ViewModel пациента

    [Parameter]
    public bool IsHighlighted { get; set; } // Выделяет карточку тревожным стилем (критические события за сутки)

    [Parameter]
    public EventCallback OnViewDetail { get; set; } // Внешняя навигация из страницы, если нужна

    // Вычисляемые свойства
    /// <summary>
    /// Полное имя пациента для отображения
    /// </summary>
    private string FullName =>
        $"{Patient.FirstName} {Patient.LastName}".Trim();

    /// <summary>
    /// Инициалы для аватара
    /// </summary>
    private string AvatarInitials
    {
        get
        {
            var first = Patient.FirstName?.Length > 0 ? Patient.FirstName[0].ToString() : string.Empty;
            var last = Patient.LastName?.Length > 0 ? Patient.LastName[0].ToString() : string.Empty;
            var initials = (first + last).ToUpperInvariant();
            return string.IsNullOrEmpty(initials) ? "?" : initials;
        }
    }

    /// <summary>
    /// Возраст пациента в читаемом формате
    /// </summary>
    private string AgeLabel
    {
        get
        {
            var today = DateOnly.FromDateTime(DateTime.Today);
            var age = today.Year - Patient.DateOfBirth.Year;
            if (today < Patient.DateOfBirth.AddYears(age))
                age--;

            return age switch
            {
                1 => "1 год",
                2 or 3 or 4 => $"{age} года",
                _ => $"{age} лет"
            };
        }
    }

    /// <summary>
    /// CSS-класс для значения глюкозы на основе UI-состояния
    /// </summary>
    private string GlucoseUiStateClass =>
        Patient.LatestGlucoseUiState?.ToLowerInvariant() switch
        {
            "normal" => "normal",
            "warning" => "warning",
            "danger" => "danger",
            "critical" => "critical",
            _ => "muted"
        };

    /// <summary>
    /// Короткая текстовая метка состояния последнего измерения.
    /// </summary>
    private string GlucoseStateLabel =>
        GlucoseUiStateClass switch
        {
            "normal" => "В норме",
            "warning" => "Внимание",
            "danger" => "Вне диапазона",
            "critical" => "Критическая",
            _ => "Нет данных"
        };

    /// <summary>
    /// CSS-класс для TIR-значения по порогам качества гликемического контроля
    /// </summary>
    private string TirValueClass =>
        Patient.TimeInTargetRange switch
        {
            >= 70 => "sg-tir--good",
            >= 50 => "sg-tir--warning",
            _ => "sg-tir--danger"
        };

    /// <summary>
    /// CSS-класс для заливки TIR-бара
    /// </summary>
    private string TirFillClass =>
        Patient.TimeInTargetRange switch
        {
            >= 70 => "sg-tir-fill--good",
            >= 50 => "sg-tir-fill--warning",
            _ => "sg-tir-fill--danger"
        };

    /// <summary>
    /// aria-label для карточки — используется скринридерами
    /// </summary>
    private string PatientAriaLabel =>
        $"Пациент {FullName}, {AgeLabel}. " +
        $"TIR: {Patient.TimeInTargetRange:F0}%. " +
        (Patient.LatestGlucose.HasValue
            ? $"Последняя глюкоза: {Patient.LatestGlucose.Value:F1} ммоль/л."
            : "Измерений нет.");

    /// <summary>
    /// aria-label для блока глюкозы
    /// </summary>
    private string GlucoseAriaLabel =>
        Patient.LatestGlucose.HasValue
            ? $"Последнее измерение: {Patient.LatestGlucose.Value:F1} ммоль/л"
            : "Нет данных о глюкозе";

    // Навигация
    /// <summary>
    /// Переходит на страницу детального просмотра пациента
    /// </summary>
    private async Task NavigateToDetailAsync()
    {
        if (OnViewDetail.HasDelegate)
        {
            await OnViewDetail.InvokeAsync();
            return;
        }

        NavigationManager.NavigateTo($"/doctor/patients/{Patient.ChildId}");
    }

    // Форматирование
    /// <summary>
    /// Форматирует время последнего измерения в читаемый вид
    /// </summary>
    private static string FormatLastMeasurementTime(DateTime utcTime)
    {
        var local = utcTime.ToLocalTime();
        var today = DateTime.Today;
        var culture = new System.Globalization.CultureInfo("ru-RU");

        if (local.Date == today)
            return local.ToString("HH:mm", culture);

        if (local.Date == today.AddDays(-1))
            return "вчера";

        return local.ToString("d MMM", culture);
    }
}
