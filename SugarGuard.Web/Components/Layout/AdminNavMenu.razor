@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Routing
@using SugarGuard.Web.Components.Shared

<AuthorizeView Roles="Admin,SupportAdmin">
    <Authorized>
        <div class="admin-nav-block">
            <span class="admin-nav-caption">Управление</span>
            <NavItem Href="/admin/dashboard" Icon="grid" Label="Дашборд" />
            <NavItem Href="/admin/users" Icon="users" Label="Пользователи" Badge="@UserCount" />
            <NavItem Href="/admin/doctor-requests" Icon="user-check" Label="Верификация" Badge="@PendingDoctorCount" BadgeClass="warning" />
            <NavItem Href="/admin/links" Icon="link" Label="Связи" />
            <NavItem Href="/admin/audit" Icon="file-text" Label="Журнал аудита" />
            <NavItem Href="/admin/system" Icon="activity" Label="Система" />
            <NavItem Href="/admin/support" Icon="message-circle" Label="Поддержка" />
            <NavItem Href="/admin/tokens" Icon="key" Label="Токены ИИ" />
        </div>

        <div class="admin-nav-block">
            <span class="admin-nav-caption">Безопасность</span>
            <NavItem Href="/admin/roles" Icon="shield" Label="Права доступа" />
        </div>
    </Authorized>
</AuthorizeView>

@code {
    [Parameter] public string? UserCount { get; set; }
    [Parameter] public string? PendingDoctorCount { get; set; }
}
