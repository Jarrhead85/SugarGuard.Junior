@rendermode InteractiveServer
@inherits LayoutComponentBase
@implements IDisposable
@using Microsoft.AspNetCore.Components.Authorization
@using SugarGuard.Web.Services
@using SugarGuard.Web.ViewModels
@inject NavigationManager Navigation
@inject JwtAuthStateProvider AuthProvider
@inject ICurrentUserService CurrentUser
@inject IJSRuntime JS
@inject SugarGuardApiService Api

<div class="app-shell @PortalClass @(sidebarOpen ? "sidebar-open" : "")">

    <aside class="sidebar" aria-label="Основная навигация">

        <div class="sidebar-logo">
            <img class="sidebar-logo-image" src="/images/sugarguard-icon.png" alt="" aria-hidden="true" />
            <span class="sidebar-logo-copy">
                <span class="sidebar-logo-text">SugarGuard</span>
                <span class="sidebar-logo-subtitle">@GetPortalSubtitle(Navigation.Uri)</span>
            </span>
        </div>

        <nav class="sidebar-nav">
            <AuthorizeView Roles="Parent">
                <Authorized>
                    <div class="parent-child-card" role="region" aria-label="Дети родителя">
                        @if (parentSidebarChildren.Count == 0)
                        {
                            <button class="parent-child-card-empty" @onclick='() => Navigation.NavigateTo("/parent/link-child")'>
                                <span class="parent-child-avatar" aria-hidden="true">+</span>
                                <span>
                                    <strong>Привязать ребёнка</strong>
                                    <small>Код из мобильного приложения</small>
                                </span>
                            </button>
                        }
                        else
                        {
                            <div class="parent-child-list">
                                @foreach (var child in parentSidebarChildren)
                                {
                                    <button class="parent-child-card-button @(child.ChildId == parentSidebarChild?.ChildId ? "active" : "")"
                                            @onclick="() => NavigateToParentChild(child.ChildId)">
                                        <span class="parent-child-avatar" aria-hidden="true">@GetInitials(child.Name)</span>
                                        <span class="parent-child-info">
                                            <strong>@child.Name</strong>
                                            <small>@child.Subtitle</small>
                                        </span>
                                        @if (child.LatestGlucose.HasValue)
                                        {
                                            <span class="parent-child-glucose @child.GlucoseClass">
                                                @child.LatestGlucose.Value.ToString("0.0")
                                            </span>
                                        }
                                    </button>
                                }
                            </div>
                        }
                    </div>

                    <span class="parent-nav-caption">Навигация</span>
                    <a class="parent-nav-item @ParentNavClass("overview")" href="@ParentNavHref("overview")">
                        <span class="parent-nav-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
                        </span>
                        <span>Обзор</span>
                    </a>
                    <a class="parent-nav-item @ParentNavClass("measurements")" href="@ParentNavHref("measurements")">
                        <span class="parent-nav-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                        </span>
                        <span>Измерения</span>
                        @if (parentSidebarChild is { MeasurementsCount: > 0 })
                        {
                            <span class="parent-nav-badge parent-nav-badge--ok">@parentSidebarChild.MeasurementsCount</span>
                        }
                    </a>
                    <a class="parent-nav-item @ParentNavClass("alerts")" href="@ParentNavHref("alerts")">
                        <span class="parent-nav-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                        </span>
                        <span>Уведомления</span>
                        @if (parentSidebarChild is { AlertsCount: > 0 })
                        {
                            <span class="parent-nav-badge parent-nav-badge--danger">@parentSidebarChild.AlertsCount</span>
                        }
                    </a>
                    <a class="parent-nav-item @ParentNavClass("backpack")" href="@ParentNavHref("backpack")">
                        <span class="parent-nav-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 20V10a8 8 0 0 1 16 0v10a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2Z"/><path d="M9 2v2a3 3 0 0 0 6 0V2"/><path d="M8 14h8"/></svg>
                        </span>
                        <span>Рюкзак</span>
                        @if (parentSidebarChild is { LowBackpackCount: > 0 })
                        {
                            <span class="parent-nav-badge parent-nav-badge--warn">@parentSidebarChild.LowBackpackCount</span>
                        }
                    </a>
                    <a class="parent-nav-item @ParentNavClass("nutrition")" href="@ParentNavHref("nutrition")">
                        <span class="parent-nav-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 3h16v18H4z"/><path d="M8 8h8M8 12h3M8 16h5"/></svg>
                        </span>
                        <span>Дневник питания</span>
                    </a>
                    <a class="parent-nav-item @ParentNavClass("ai")" href="@ParentNavHref("ai")">
                        <span class="parent-nav-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="7" width="14" height="11" rx="3"/><path d="M12 3v4"/><path d="M9 12h.01M15 12h.01"/><path d="M9 16h6"/></svg>
                        </span>
                        <span>Контроль ИИ</span>
                    </a>
                    <a class="parent-nav-item @ParentNavClass("doctor")" href="@ParentNavHref("doctor")">
                        <span class="parent-nav-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12h6m-3-3v6m-7 4h14a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2Z"/></svg>
                        </span>
                        <span>Записки врача</span>
                    </a>
                    <a class="parent-nav-item @ParentNavClass("profile")" href="@ParentNavHref("profile")">
                        <span class="parent-nav-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
                        </span>
                        <span>Профиль ребёнка</span>
                    </a>

                    <span class="parent-nav-caption parent-nav-caption--account">Аккаунт</span>
                    <a class="parent-nav-item @(Navigation.Uri.Contains("/support", StringComparison.OrdinalIgnoreCase) ? "active" : "")" href="/support">
                        <span class="parent-nav-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a4 4 0 0 1-4 4H8l-5 3V7a4 4 0 0 1 4-4h10a4 4 0 0 1 4 4z"/><path d="M8 9h8M8 13h5"/></svg>
                        </span>
                        <span>Поддержка</span>
                    </a>
                    <a class="parent-nav-item @ParentNavClass("settings")" href="@ParentNavHref("settings")">
                        <span class="parent-nav-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 1 1 0 4h-.09A1.65 1.65 0 0 0 19.4 15Z"/></svg>
                        </span>
                        <span>Настройки</span>
                    </a>
                </Authorized>
            </AuthorizeView>

            <AuthorizeView Roles="Doctor">
                <Authorized>
                    <div class="doctor-nav-block">
                        <span class="doctor-nav-caption">Рабочее пространство</span>
                        <NavItem Href="/doctor/patients" Icon="users" Label="Мои пациенты" Badge="@doctorPatientCount.ToString()" />
                        <NavItem Href="/doctor/alerts" Icon="bell" Label="Группы риска" Badge="@doctorRiskCount.ToString()" BadgeClass="danger" />
                        <NavItem Href="/doctor/reports" Icon="activity" Label="Аналитика группы" />
                    </div>
                    <div class="doctor-nav-block">
                        <span class="doctor-nav-caption">Клиническая работа</span>
                        <NavItem Href="/doctor/notes" Icon="file-text" Label="Записки врача" />
                        <NavItem Href="/support" Icon="message-circle" Label="Поддержка" />
                        <NavItem Href="/doctor/profile" Icon="settings" Label="Профиль и настройки" />
                    </div>
                </Authorized>
            </AuthorizeView>

            <AdminNavMenu UserCount="@adminUserCount.ToString()"
                          PendingDoctorCount="@adminPendingDoctorCount.ToString()" />
        </nav>

        <div class="sidebar-footer">
            <AuthorizeView>
                <Authorized>
                    <div class="sidebar-user">
                        <div class="sidebar-user-avatar" aria-hidden="true">
                            @if (!string.IsNullOrWhiteSpace(currentAccountProfile?.PhotoUrl))
                            {
                                <img src="@currentAccountProfile.PhotoUrl" alt="" />
                            }
                            else
                            {
                                @GetInitials(GetSidebarUserName(context.User))
                            }
                        </div>
                        <div class="sidebar-user-info">
                            <span class="sidebar-user-name">
                                @GetSidebarUserName(context.User)
                            </span>
                            <span class="sidebar-user-role">
                                @(string.IsNullOrWhiteSpace(currentAccountProfile?.Specialty)
                                    ? GetRoleLabel(context.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value)
                                    : currentAccountProfile.Specialty)
                            </span>
                        </div>
                    </div>
                    <button class="sidebar-theme-btn" @onclick="ToggleTheme" title="Сменить тему" aria-label="Сменить тему">
                        @(isDarkTheme ? "☀" : "☾")
                    </button>
                    <button class="sidebar-logout-btn" @onclick="HandleLogoutAsync" title="Выйти" aria-label="Выйти из системы">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                            <polyline points="16 17 21 12 16 7"/>
                            <line x1="21" y1="12" x2="9" y2="12"/>
                        </svg>
                    </button>
                </Authorized>
            </AuthorizeView>
        </div>
    </aside>

    <div class="main-wrapper">

        <header class="topbar" role="banner">

            <button class="topbar-burger" @onclick="ToggleSidebar"
                    aria-label="@(sidebarOpen ? "Закрыть меню" : "Открыть меню")"
                    aria-expanded="@sidebarOpen.ToString().ToLower()">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    @if (sidebarOpen)
                    {
                        <line x1="18" y1="6" x2="6" y2="18"/>
                        <line x1="6" y1="6" x2="18" y2="18"/>
                    }
                    else
                    {
                        <line x1="3" y1="12" x2="21" y2="12"/>
                        <line x1="3" y1="6" x2="21" y2="6"/>
                        <line x1="3" y1="18" x2="21" y2="18"/>
                    }
                </svg>
            </button>

            <div class="topbar-title">
                <h1 class="topbar-page-title">@pageTitle</h1>
                @if (!string.IsNullOrEmpty(pageSubtitle))
                {
                    <p class="topbar-page-sub">@pageSubtitle</p>
                }
            </div>

            <div class="topbar-actions">

                <div class="notif-wrapper" @onclick:stopPropagation="true">
                    <button class="icon-btn @(HasUnread ? "has-unread" : "")"
                            @onclick="ToggleNotifications"
                            title="Уведомления"
                            aria-label="Уведомления @(unreadCount > 0 ? $"({unreadCount} непрочитанных)" : "")">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/>
                            <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                        </svg>
                        @if (HasUnread)
                        {
                            <span class="notif-badge" aria-hidden="true">@(unreadCount > 9 ? "9+" : unreadCount.ToString())</span>
                        }
                    </button>

                    @if (notifOpen)
                    {
                        <div class="notif-dropdown" role="dialog" aria-label="Уведомления">
                            <div class="notif-dropdown-header">
                                <span class="notif-dropdown-title">Уведомления</span>
                                @if (HasUnread)
                                {
                                    <button class="btn btn-sm btn-ghost" @onclick="MarkAllReadAsync">
                                        Прочитать все
                                    </button>
                                }
                            </div>
                            <div class="notif-dropdown-list" role="list">
                                @if (notifications.Count == 0)
                                {
                                    <div class="notif-empty">
                                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                                            <path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/>
                                            <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                                        </svg>
                                        <p>Нет уведомлений</p>
                                    </div>
                                }
                                else
                                {
                                    @foreach (var n in notifications.Take(6))
                                    {
                                        <div class="notif-item @(n.IsUnread ? "unread" : "")" role="listitem">
                                            <div class="notif-item-dot" aria-hidden="true"></div>
                                            <div class="notif-item-body">
                                                <p class="notif-item-title">@n.Title</p>
                                                <p class="notif-item-desc">@n.Description</p>
                                                <time class="notif-item-time">@n.Time</time>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    }
                </div>

            </div>
        </header>

        @if (sidebarOpen)
        {
            <div class="sidebar-overlay" @onclick="CloseSidebar" aria-hidden="true"></div>
        }

        <main class="page-content" id="main-content" tabindex="-1">
            @Body
        </main>
    </div>
</div>

<div id="blazor-error-ui" role="alert">
    Произошла непредвиденная ошибка.
    <a href="" class="reload">Перезагрузить</a>
    <button class="dismiss" aria-label="Закрыть">✕</button>
</div>

@code {
    private string pageTitle = "SugarGuard";
    private string pageSubtitle = string.Empty;
    private bool notifOpen;
    private bool sidebarOpen;
    private bool isDarkTheme;
    private List<UserNotificationItem> notifications = new();
    private AccountProfileVm? currentAccountProfile;
    private List<ParentSidebarChild> parentSidebarChildren = new();
    private ParentSidebarChild? parentSidebarChild;
    private int doctorPatientCount;
    private int doctorRiskCount;
    private int adminUserCount;
    private int adminPendingDoctorCount;
    private readonly SemaphoreSlim sidebarDataGate = new(1, 1);
    private CancellationTokenSource? sidebarRefreshCts;
    private Task? sidebarRefreshTask;
    private int unreadCount => notifications.Count(n => n.IsUnread);
    private bool HasUnread => unreadCount > 0;
    private string PortalClass => GetPortalClass(Navigation.Uri);

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
        UpdatePageInfo(Navigation.Uri);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await LoadThemeAsync();
        await LoadPortalSidebarDataAsync();
        await LoadNotifications();
        sidebarRefreshCts = new CancellationTokenSource();
        sidebarRefreshTask = RefreshSidebarPeriodicallyAsync(sidebarRefreshCts.Token);
    }

    private async Task RefreshSidebarPeriodicallyAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(30));

        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                await InvokeAsync(LoadPortalSidebarDataAsync);
                await InvokeAsync(LoadNotifications);
            }
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
        {
        }
    }

    private async Task LoadThemeAsync()
    {
        try
        {
            var stored = await JS.InvokeAsync<string>("sugarGuardTheme.getTheme");
            isDarkTheme = stored == "dark";
            StateHasChanged();
        }
        catch
        {
            isDarkTheme = false;
        }
    }

    private async Task SaveThemeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("sugarGuardTheme.setTheme", isDarkTheme ? "dark" : "light");
        }
        catch
        {
            // localStorage недоступен (prerender)
        }
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        notifOpen = false;
        sidebarOpen = false;
        UpdatePageInfo(e.Location);
        _ = InvokeAsync(LoadPortalSidebarDataAsync);
        StateHasChanged();
    }

    private async Task LoadPortalSidebarDataAsync()
    {
        await sidebarDataGate.WaitAsync();
        try
        {
            var role = await CurrentUser.GetRoleAsync();

            try
            {
                currentAccountProfile = await Api.GetAccountProfileAsync();
            }
            catch
            {
                // Keep the last successful snapshot during a transient API failure.
            }

            if (string.Equals(role, "Parent", StringComparison.OrdinalIgnoreCase))
            {
                await LoadParentSidebarChildAsync();
                return;
            }

            parentSidebarChild = null;
            parentSidebarChildren.Clear();

            if (string.Equals(role, "Doctor", StringComparison.OrdinalIgnoreCase))
            {
                await LoadDoctorSidebarDataAsync();
                return;
            }

            if (role is "Admin" or "SupportAdmin")
            {
                await LoadAdminSidebarDataAsync();
            }
        }
        finally
        {
            sidebarDataGate.Release();
        }
    }

    private async Task LoadDoctorSidebarDataAsync()
    {
        try
        {
            var patients = await Api.GetDoctorPatientsAsync("lastmeasurement");
            doctorPatientCount = patients.Count;
            doctorRiskCount = patients.Count(patient =>
                patient.CriticalEventsLast7Days > 0
                || patient.LatestGlucoseUiState is "Critical" or "Danger"
                || patient.TimeInTargetRange is > 0 and < 70
                || patient.MeasurementsLast7Days == 0);
        }
        catch
        {
            doctorPatientCount = 0;
            doctorRiskCount = 0;
        }

        StateHasChanged();
    }

    private async Task LoadAdminSidebarDataAsync()
    {
        try
        {
            var users = await Api.GetAdminUsersAsync(limit: 500);
            adminUserCount = users.Count;
            adminPendingDoctorCount = users.Count(user =>
                string.Equals(user.Role, "DoctorPending", StringComparison.OrdinalIgnoreCase));
        }
        catch
        {
            adminUserCount = 0;
            adminPendingDoctorCount = 0;
        }

        StateHasChanged();
    }

    private async Task LoadParentSidebarChildAsync()
    {
        try
        {
            if (!await CurrentUser.IsParentAsync())
            {
                parentSidebarChild = null;
                parentSidebarChildren.Clear();
                return;
            }

            var children = await Api.GetMyChildrenAsync();
            if (children.Count == 0)
            {
                parentSidebarChild = null;
                parentSidebarChildren.Clear();
                return;
            }

            var selectedChildId = GetParentChildIdFromUri();
            if (!selectedChildId.HasValue || children.All(child => child.ChildId != selectedChildId.Value))
            {
                selectedChildId = children[0].ChildId;
            }

            var notifications = await Api.GetNotificationsAsync();
            var alertsCount = notifications.Count(notification => notification.IsUnread && notification.NotificationId.HasValue);
            var snapshots = new List<ParentSidebarChild>(children.Count);

            foreach (var child in children)
            {
                decimal? latestGlucose = null;
                var glucoseClass = "normal";
                var measurementsCount = 0;
                var lowBackpackCount = 0;

                try
                {
                    var summary = await Api.GetDashboardSummaryAsync(child.ChildId);
                    latestGlucose = summary.LatestGlucose;
                    var recentMeasurements = await Api.GetMeasurementsAsync(
                        child.ChildId,
                        DateTime.UtcNow.AddHours(-1),
                        DateTime.UtcNow);
                    measurementsCount = IsParentMeasurementsTab(child.ChildId) ? 0 : recentMeasurements.Count;
                    glucoseClass = summary.LatestGlucoseUiState switch
                    {
                        "Critical" or "Danger" => "danger",
                        "Warning" or "Elevated" => "warn",
                        _ => "normal"
                    };

                    var backpack = await Api.GetBackpackAsync(child.ChildId);
                    lowBackpackCount = backpack
                        .GroupBy(item => $"{item.SnackName.Trim().ToUpperInvariant()}|{item.BreadUnits:0.###}")
                        .Count(group => group.Count() <= 2);
                }
                catch
                {
                    latestGlucose = null;
                }

                snapshots.Add(new ParentSidebarChild(
                    child.ChildId,
                    string.IsNullOrWhiteSpace(child.FullName) ? "Ребёнок" : child.FullName,
                    $"{GetAge(child.DateOfBirth)} лет",
                    latestGlucose,
                    glucoseClass,
                    measurementsCount,
                    alertsCount,
                    lowBackpackCount));
            }

            parentSidebarChildren = snapshots;
            parentSidebarChild = snapshots.FirstOrDefault(child => child.ChildId == selectedChildId.Value)
                ?? snapshots.FirstOrDefault();

            StateHasChanged();
        }
        catch
        {
            // Preserve the last successful child snapshot while connectivity recovers.
        }
    }

    private void UpdatePageInfo(string uri)
    {
        var currentUri = new Uri(uri);
        var path = currentUri.AbsolutePath.Trim('/').ToLowerInvariant();
        (pageTitle, pageSubtitle) = path switch
        {
            // Родитель
            "parent/dashboard"    => ("Главная",       "Обзор состояния"),
            "parent/measurements" => ("Измерения",     "История глюкозы"),
            "parent/backpack"     => ("Рюкзак",        "Перекусы и хлебные единицы"),
            "parent/doctor"       => ("Врач",          "Связь с врачом"),
            "parent/settings"     => ("Настройки",     "Параметры аккаунта"),
            // Врач
            "doctor/dashboard"    => ("Мои пациенты",  "Кабинет врача"),
            "doctor/patients"     => ("Мои пациенты",  "Кабинет врача"),
            "doctor/alerts"       => ("Группы риска",  "Пациенты, которым нужно внимание"),
            "doctor/reports"      => ("Аналитика группы", "Отчёты и динамика когорты"),
            "doctor/notes"        => ("Записки врача", "Клинические заметки по пациентам"),
            "doctor/profile"      => ("Профиль",       "Мои данные"),
            // Администратор
            "admin"               => ("Дашборд",       "Кабинет администратора"),
            "admin/dashboard"     => ("Дашборд",       "Кабинет администратора"),
            "admin/users"         => ("Пользователи",  "Управление аккаунтами"),
            "admin/doctor-requests" => ("Верификация", "Заявки врачей"),
