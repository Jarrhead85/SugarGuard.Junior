@rendermode InteractiveServer
@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using SugarGuard.Web.Services
@using SugarGuard.Web.ViewModels
@inject NavigationManager Navigation
@inject JwtAuthStateProvider AuthProvider
@inject ICurrentUserService CurrentUser
@inject IJSRuntime JS
@inject SugarGuardApiService Api

<div class="app-shell @PortalClass @(sidebarOpen ? "sidebar-open" : "")">

    <aside class="sidebar" aria-label="Основная навигация">

        <div class="sidebar-logo">
            <img class="sidebar-logo-image" src="/images/sugarguard-icon.png" alt="" aria-hidden="true" />
            <span class="sidebar-logo-copy">
                <span class="sidebar-logo-text">SugarGuard</span>
                <span class="sidebar-logo-subtitle">@GetPortalSubtitle(Navigation.Uri)</span>
            </span>
        </div>

        <nav class="sidebar-nav">
            <AuthorizeView Roles="Parent">
                <Authorized>
                    <NavItem Href="/parent/dashboard"    Icon="home"         Label="Главная" />
                    <NavItem Href="/parent/dashboard?tab=measurements" Icon="activity"     Label="Измерения" />
                    <NavItem Href="/parent/dashboard?tab=backpack"     Icon="shopping-bag" Label="Рюкзак" />
                    <NavItem Href="/parent/dashboard?tab=doctor"       Icon="stethoscope"  Label="Врач" />
                    <NavItem Href="/parent/dashboard?tab=settings"     Icon="settings"     Label="Настройки" />
                    <div class="parent-child-card" role="region" aria-label="Ребёнок родителя">
                        @if (parentSidebarChild is null)
                        {
                            <button class="parent-child-card-empty" @onclick='() => Navigation.NavigateTo("/parent/link-child")'>
                                <span class="parent-child-avatar" aria-hidden="true">+</span>
                                <span>
                                    <strong>Привязать ребёнка</strong>
                                    <small>Код из мобильного приложения</small>
                                </span>
                            </button>
                        }
                        else
                        {
                            <button class="parent-child-card-button" @onclick='() => Navigation.NavigateTo("/parent/dashboard")'>
                                <span class="parent-child-avatar" aria-hidden="true">@GetInitials(parentSidebarChild.Name)</span>
                                <span class="parent-child-info">
                                    <strong>@parentSidebarChild.Name</strong>
                                    <small>@parentSidebarChild.Subtitle</small>
                                </span>
                                @if (parentSidebarChild.LatestGlucose.HasValue)
                                {
                                    <span class="parent-child-glucose @parentSidebarChild.GlucoseClass">
                                        @parentSidebarChild.LatestGlucose.Value.ToString("0.0")
                                    </span>
                                }
                            </button>
                        }
                    </div>
                </Authorized>
            </AuthorizeView>

            <AuthorizeView Roles="Doctor">
                <Authorized>
                    <div class="doctor-nav-block">
                        <span class="doctor-nav-caption">Рабочее пространство</span>
                        <NavItem Href="/doctor/patients" Icon="users" Label="Мои пациенты" />
                        <NavItem Href="/doctor/alerts" Icon="bell" Label="Группы риска" />
                        <NavItem Href="/doctor/reports" Icon="activity" Label="Аналитика группы" />
                    </div>
                    <div class="doctor-nav-block">
                        <span class="doctor-nav-caption">Клиническая работа</span>
                        <NavItem Href="/doctor/notes" Icon="file-text" Label="Записки врача" />
                        <NavItem Href="/doctor/profile" Icon="settings" Label="Профиль и настройки" />
                    </div>
                </Authorized>
            </AuthorizeView>

            <AdminNavMenu />
        </nav>

        <div class="sidebar-footer">
            <AuthorizeView>
                <Authorized>
                    <div class="sidebar-user">
                        <div class="sidebar-user-avatar" aria-hidden="true">
                            @GetInitials(context.User.Identity?.Name ?? context.User.FindFirst("email")?.Value)
                        </div>
                        <div class="sidebar-user-info">
                            <span class="sidebar-user-name">
                                @(context.User.Identity?.Name ?? context.User.FindFirst("email")?.Value ?? "Пользователь")
                            </span>
                            <span class="sidebar-user-role">@GetRoleLabel(context.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value)</span>
                        </div>
                    </div>
                    <button class="sidebar-logout-btn" @onclick="HandleLogoutAsync" title="Выйти" aria-label="Выйти из системы">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                            <polyline points="16 17 21 12 16 7"/>
                            <line x1="21" y1="12" x2="9" y2="12"/>
                        </svg>
                    </button>
                </Authorized>
            </AuthorizeView>
        </div>
    </aside>

    <div class="main-wrapper">

        <header class="topbar" role="banner">

            <button class="topbar-burger" @onclick="ToggleSidebar"
                    aria-label="@(sidebarOpen ? "Закрыть меню" : "Открыть меню")"
                    aria-expanded="@sidebarOpen.ToString().ToLower()">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    @if (sidebarOpen)
                    {
                        <line x1="18" y1="6" x2="6" y2="18"/>
                        <line x1="6" y1="6" x2="18" y2="18"/>
                    }
                    else
                    {
                        <line x1="3" y1="12" x2="21" y2="12"/>
                        <line x1="3" y1="6" x2="21" y2="6"/>
                        <line x1="3" y1="18" x2="21" y2="18"/>
                    }
                </svg>
            </button>

            <div class="topbar-title">
                <h1 class="topbar-page-title">@pageTitle</h1>
                @if (!string.IsNullOrEmpty(pageSubtitle))
                {
                    <p class="topbar-page-sub">@pageSubtitle</p>
                }
            </div>

            <div class="topbar-actions">

                <div class="notif-wrapper" @onclick:stopPropagation="true">
                    <button class="icon-btn @(HasUnread ? "has-unread" : "")"
                            @onclick="ToggleNotifications"
                            title="Уведомления"
                            aria-label="Уведомления @(unreadCount > 0 ? $"({unreadCount} непрочитанных)" : "")">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/>
                            <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                        </svg>
                        @if (HasUnread)
                        {
                            <span class="notif-badge" aria-hidden="true">@(unreadCount > 9 ? "9+" : unreadCount.ToString())</span>
                        }
                    </button>

                    @if (notifOpen)
                    {
                        <div class="notif-dropdown" role="dialog" aria-label="Уведомления">
                            <div class="notif-dropdown-header">
                                <span class="notif-dropdown-title">Уведомления</span>
                                @if (HasUnread)
                                {
                                    <button class="btn btn-sm btn-ghost" @onclick="MarkAllReadAsync">
                                        Прочитать все
                                    </button>
                                }
                            </div>
                            <div class="notif-dropdown-list" role="list">
                                @if (notifications.Count == 0)
                                {
                                    <div class="notif-empty">
                                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                                            <path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/>
                                            <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                                        </svg>
                                        <p>Нет уведомлений</p>
                                    </div>
                                }
                                else
                                {
                                    @foreach (var n in notifications.Take(6))
                                    {
                                        <div class="notif-item @(n.IsUnread ? "unread" : "")" role="listitem">
                                            <div class="notif-item-dot" aria-hidden="true"></div>
                                            <div class="notif-item-body">
                                                <p class="notif-item-title">@n.Title</p>
                                                <p class="notif-item-desc">@n.Description</p>
                                                <time class="notif-item-time">@n.Time</time>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    }
                </div>

                <button class="icon-btn"
                        @onclick="ToggleTheme"
                        title="Сменить тему"
                        aria-label="@(isDarkTheme ? "Переключить на светлую тему" : "Переключить на тёмную тему")">
                    @if (isDarkTheme)
                    {
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <circle cx="12" cy="12" r="5"/>
                            <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
                        </svg>
                    }
                    else
                    {
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                        </svg>
                    }
                </button>
            </div>
        </header>

        @if (sidebarOpen)
        {
            <div class="sidebar-overlay" @onclick="CloseSidebar" aria-hidden="true"></div>
        }

        <main class="page-content" id="main-content" tabindex="-1">
            @Body
        </main>
    </div>
</div>

<div id="blazor-error-ui" role="alert">
    Произошла непредвиденная ошибка.
    <a href="" class="reload">Перезагрузить</a>
    <button class="dismiss" aria-label="Закрыть">✕</button>
</div>

@code {
    private string pageTitle = "SugarGuard";
    private string pageSubtitle = string.Empty;
    private bool notifOpen;
    private bool sidebarOpen;
    private bool isDarkTheme;
    private List<UserNotificationItem> notifications = new();
    private ParentSidebarChild? parentSidebarChild;
    private int unreadCount => notifications.Count(n => n.IsUnread);
    private bool HasUnread => unreadCount > 0;
    private string PortalClass => GetPortalClass(Navigation.Uri);

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
        UpdatePageInfo(Navigation.Uri);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await LoadThemeAsync();
        await LoadParentSidebarChildAsync();
    }

    private async Task LoadThemeAsync()
    {
        try
        {
            var stored = await JS.InvokeAsync<string>("sugarGuardTheme.getTheme");
            isDarkTheme = stored == "dark";
            StateHasChanged();
        }
        catch
        {
            isDarkTheme = false;
        }
    }

    private async Task SaveThemeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("sugarGuardTheme.setTheme", isDarkTheme ? "dark" : "light");
        }
        catch
        {
            // localStorage недоступен (prerender)
        }
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        notifOpen = false;
        sidebarOpen = false;
        UpdatePageInfo(e.Location);
        _ = InvokeAsync(LoadParentSidebarChildAsync);
        StateHasChanged();
    }

    private async Task LoadParentSidebarChildAsync()
    {
        try
        {
            var path = Navigation.ToAbsoluteUri(Navigation.Uri).AbsolutePath;
            if (!path.StartsWith("/parent", StringComparison.OrdinalIgnoreCase)
                || !await CurrentUser.IsParentAsync())
            {
                parentSidebarChild = null;
                return;
            }

            var children = await Api.GetMyChildrenAsync();
            var child = children.FirstOrDefault();
            if (child is null)
            {
                parentSidebarChild = null;
                return;
            }

            decimal? latestGlucose = null;
            var glucoseClass = "normal";
            try
            {
                var summary = await Api.GetDashboardSummaryAsync(child.ChildId);
                latestGlucose = summary.LatestGlucose;
                glucoseClass = summary.LatestGlucoseUiState switch
                {
                    "Critical" or "Danger" => "danger",
                    "Warning" or "Elevated" => "warn",
                    _ => "normal"
                };
            }
            catch
            {
                latestGlucose = null;
            }

            parentSidebarChild = new ParentSidebarChild(
                string.IsNullOrWhiteSpace(child.FullName) ? "Ребёнок" : child.FullName,
                $"{GetAge(child.DateOfBirth)} лет · {child.DiabetesType}",
                latestGlucose,
                glucoseClass);

            StateHasChanged();
        }
        catch
        {
            parentSidebarChild = null;
        }
    }

    private void UpdatePageInfo(string uri)
    {
        var path = new Uri(uri).AbsolutePath.Trim('/').ToLowerInvariant();

        (pageTitle, pageSubtitle) = path switch
        {
            // Родитель
            "parent/dashboard"    => ("Главная",       "Обзор состояния"),
            "parent/measurements" => ("Измерения",     "История глюкозы"),
            "parent/backpack"     => ("Рюкзак",        "Перекусы и хлебные единицы"),
            "parent/doctor"       => ("Врач",          "Связь с врачом"),
            "parent/settings"     => ("Настройки",     "Параметры аккаунта"),
            // Врач
            "doctor/dashboard"    => ("Мои пациенты",  "Кабинет врача"),
            "doctor/patients"     => ("Мои пациенты",  "Кабинет врача"),
            "doctor/alerts"       => ("Группы риска",  "Пациенты, которым нужно внимание"),
            "doctor/reports"      => ("Аналитика группы", "Отчёты и динамика когорты"),
            "doctor/notes"        => ("Записки врача", "Клинические заметки по пациентам"),
            "doctor/profile"      => ("Профиль",       "Мои данные"),
            // Администратор
            "admin"               => ("Дашборд",       "Кабинет администратора"),
            "admin/dashboard"     => ("Дашборд",       "Кабинет администратора"),
            "admin/users"         => ("Пользователи",  "Управление аккаунтами"),
            "admin/doctor-requests" => ("Верификация", "Заявки врачей"),
            "admin/links"         => ("Связи",         "Родители, врачи и дети"),
            "admin/audit"         => ("Журнал аудита", "События системы"),
            "admin/audit-log"     => ("Журнал аудита", "События системы"),
            "admin/system"        => ("Система",       "Состояние сервисов"),
            "admin/system-stats"  => ("Система",       "Состояние сервисов"),
            "admin/sync-logs"     => ("Синхронизация", "Очередь и конфликты"),
            "admin/export-logs"   => ("Экспорт",       "Задачи выгрузки"),
            "admin/faq"           => ("FAQ",           "База знаний"),
            "admin/roles"         => ("Права доступа", "Роли и политики"),
            "admin/tokens"        => ("JWT / Токены",  "Сессии и безопасность"),
            "admin/settings"      => ("Настройки",     "Конфигурация"),
            // Общие
            "login"               => ("Вход",          string.Empty),
            _                     => ("SugarGuard",    string.Empty)
        };
    }

    private void ToggleSidebar() => sidebarOpen = !sidebarOpen;
    private void CloseSidebar()  => sidebarOpen = false;

    private async Task ToggleNotifications()
    {
        notifOpen = !notifOpen;
        if (notifOpen && notifications.Count == 0)
            await LoadNotifications();
        StateHasChanged();
    }

    private async Task LoadNotifications()
    {
        notifications = await Api.GetNotificationsAsync();
    }

    private Task MarkAllReadAsync()
    {
        foreach (var n in notifications)
            n.IsUnread = false;
        return Task.CompletedTask;
    }

    private async Task ToggleTheme()
    {
        isDarkTheme = !isDarkTheme;
        await SaveThemeAsync();
        StateHasChanged();
    }

    private async Task HandleLogoutAsync()
    {
        await AuthProvider.LogoutAsync();
        Navigation.NavigateTo("/login", forceLoad: false);
    }

    private static string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        if (name.Contains('@')) return name[0].ToString().ToUpper();
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[1][0]}".ToUpper()
            : parts[0][0].ToString().ToUpper();
    }

    private static int GetAge(DateOnly dateOfBirth)
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        var age = today.Year - dateOfBirth.Year;
        if (dateOfBirth > today.AddYears(-age))
            age--;
        return Math.Max(age, 0);
    }

    private static string GetRoleLabel(string? role) => role switch
    {
        "Parent" => "Родитель",
        "Doctor" => "Врач",
        "Admin"  => "Администратор",
        _        => "Пользователь"
    };

    private static string GetPortalClass(string uri)
    {
        var path = new Uri(uri).AbsolutePath.Trim('/').ToLowerInvariant();
        if (path.StartsWith("doctor/", StringComparison.Ordinal))
        {
            return "app-shell--care app-shell--doctor";
        }

        return path.StartsWith("parent/", StringComparison.Ordinal)
            ? "app-shell--care"
            : "app-shell--admin";
    }

    private static string GetPortalSubtitle(string uri)
    {
        var path = new Uri(uri).AbsolutePath.Trim('/').ToLowerInvariant();
        if (path.StartsWith("doctor/", StringComparison.Ordinal))
        {
            return "Кабинет врача";
        }

        if (path.StartsWith("parent/", StringComparison.Ordinal))
        {
            return "Кабинет родителя";
        }

        return "Кабинет администратора";
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }

    private sealed record ParentSidebarChild(
        string Name,
        string Subtitle,
        decimal? LatestGlucose,
        string GlucoseClass);
}
