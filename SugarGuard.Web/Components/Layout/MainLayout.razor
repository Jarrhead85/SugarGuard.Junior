    private async Task ToggleNotifications()
    {
        notifOpen = !notifOpen;
        if (notifOpen && notifications.Count == 0)
            await LoadNotifications();
        StateHasChanged();
    }

    private async Task LoadNotifications()
    {
        try
        {
            notifications = await Api.GetNotificationsAsync();
            if (parentSidebarChild is not null)
            {
                parentSidebarChild = parentSidebarChild with { AlertsCount = unreadCount };
                parentSidebarChildren = parentSidebarChildren
                    .Select(child => child.ChildId == parentSidebarChild.ChildId ? child with { AlertsCount = unreadCount } : child)
                    .ToList();
            }
            StateHasChanged();
        }
        catch
        {
            // Keep the previous snapshot when a background refresh fails.
        }
    }

    private static int CountDistinctCriticalEvents(IReadOnlyList<TimelineEventDto> timeline)
    {
        var measurements = timeline
            .Where(entry => entry.EventType is TimelineEventType.Measurement or TimelineEventType.GlucoseMeasurement)
            .ToList();

        return timeline.Count(entry =>
            entry.EventType is TimelineEventType.Measurement or TimelineEventType.GlucoseMeasurement
                ? entry.GlucoseUiState is "Critical" or "Danger"
                : entry.EventType is TimelineEventType.Alert or TimelineEventType.CriticalAlert
                  && !measurements.Any(measurement =>
                      measurement.GlucoseValue == entry.GlucoseValue
                      && Math.Abs((measurement.OccurredAt - entry.OccurredAt).TotalMinutes) <= 2));
    }

    private async Task MarkAllReadAsync()
    {
        try
        {
            await Api.MarkAllNotificationsAsReadAsync();
            foreach (var notification in notifications.Where(item => item.NotificationId.HasValue))
            {
                notification.IsUnread = false;
            }

            if (parentSidebarChild is not null)
            {
                parentSidebarChild = parentSidebarChild with { AlertsCount = unreadCount };
                parentSidebarChildren = parentSidebarChildren
                    .Select(child => child.ChildId == parentSidebarChild.ChildId ? child with { AlertsCount = unreadCount } : child)
                    .ToList();
            }
        }
        catch
        {
            // Keep the current unread state if the API did not persist the change.
        }
    }

