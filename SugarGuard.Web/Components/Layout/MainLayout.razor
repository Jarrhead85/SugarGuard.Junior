    private string ParentNavClass(string tab)
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        if (!uri.AbsolutePath.Equals("/parent/dashboard", StringComparison.OrdinalIgnoreCase))
        {
            return string.Empty;
        }

        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        var activeTab = query["tab"]?.ToLowerInvariant() ?? "overview";
        return activeTab == tab ? "active" : string.Empty;
    }

    private string ParentNavHref(string tab)
    {
        var childId = parentSidebarChild?.ChildId ?? GetParentChildIdFromUri();
        var query = new List<string>();
        if (childId.HasValue)
        {
            query.Add($"childId={childId.Value:D}");
        }

        if (!string.Equals(tab, "overview", StringComparison.OrdinalIgnoreCase))
        {
            query.Add($"tab={Uri.EscapeDataString(tab)}");
        }

        return query.Count == 0 ? "/parent/dashboard" : $"/parent/dashboard?{string.Join('&', query)}";
    }

    private bool IsParentMeasurementsTab(Guid childId)
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        if (!uri.AbsolutePath.Equals("/parent/dashboard", StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        var activeTab = query["tab"]?.ToLowerInvariant() ?? "overview";
        if (activeTab != "measurements")
        {
            return false;
        }

        var selectedChildId = GetParentChildIdFromUri();
        return !selectedChildId.HasValue || selectedChildId.Value == childId;
    }

    private void NavigateToParentChild(Guid childId)
    {
        var selectedChild = parentSidebarChildren.FirstOrDefault(child => child.ChildId == childId);
        if (selectedChild is not null)
        {
            parentSidebarChild = selectedChild;
            StateHasChanged();
        }

        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        var tab = query["tab"];
        var target = string.IsNullOrWhiteSpace(tab)
            ? $"/parent/dashboard?childId={childId:D}"
            : $"/parent/dashboard?childId={childId:D}&tab={Uri.EscapeDataString(tab)}";

        Navigation.NavigateTo(target);
    }

    private Guid? GetParentChildIdFromUri()
    {
        var query = System.Web.HttpUtility.ParseQueryString(Navigation.ToAbsoluteUri(Navigation.Uri).Query);
        return Guid.TryParse(query["childId"], out var childId) ? childId : null;
    }

    private static string GetPortalClass(string uri)
    {
        if (new Uri(uri).AbsolutePath.Trim('/').Equals("support", StringComparison.Ordinal))
        {
            return "app-shell--care app-shell--support";
        }

        var path = new Uri(uri).AbsolutePath.Trim('/').ToLowerInvariant();
        if (path.StartsWith("doctor/", StringComparison.Ordinal))
        {
            return "app-shell--care app-shell--doctor";
        }

        return path.StartsWith("parent/", StringComparison.Ordinal)
            ? "app-shell--care app-shell--parent"
            : "app-shell--admin";
    }

    private static string GetPortalSubtitle(string uri)
    {
        if (new Uri(uri).AbsolutePath.Trim('/').Equals("support", StringComparison.Ordinal))
        {
            return "Центр поддержки";
        }

        var path = new Uri(uri).AbsolutePath.Trim('/').ToLowerInvariant();
        if (path.StartsWith("doctor/", StringComparison.Ordinal))
        {
            return "Кабинет врача";
        }

        if (path.StartsWith("parent/", StringComparison.Ordinal))
        {
            return "Кабинет родителя";
        }

        return "Кабинет администратора";
    }

