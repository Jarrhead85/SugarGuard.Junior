</style>

@code {
    // Состояние   
    private Guid? _activeChildId; // Идентификатор активного ребёнка
   
    private bool _sidebarOpen; // Флаг открытого sidebar на мобайле
   
    private string _theme = "light"; // Текущая тема
       
    private SessionExpiredDialog? _sessionExpiredDialog; // Ссылка на диалог истечения сессии
   
    private bool _disposed; // Флаг: компонент уже уничтожен

    private EventCallback<Guid> _onChildChanged;

    // Жизненный цикл
    /// <inheritdoc/>
    protected override async Task OnInitializedAsync()
    {
        _onChildChanged = EventCallback.Factory.Create<Guid>(this, OnChildChangedAsync);

        JwtAuth.OnSessionExpired += HandleSessionExpiredAsync;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (!(authState.User.Identity?.IsAuthenticated ?? false))
        {
            Navigation.NavigateTo("/login", forceLoad: false);
        }
    }

    // Обработчики событий 
    private void ToggleSidebar() => _sidebarOpen = !_sidebarOpen; // Переключает состояние sidebar на мобайле

    private void CloseSidebar() => _sidebarOpen = false; // Закрывает sidebar при клике на backdrop или после навигации

    /// <summary>
    /// Устанавливает активного ребёнка и закрывает sidebar на мобайле
    /// </summary>
    private async Task OnChildChangedAsync(Guid childId)
    {
        _activeChildId = childId;
        _sidebarOpen = false;
        await InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Синхронизирует текущую тему с ThemeToggle
    /// </summary>
    private void OnThemeChangedHandler(string newTheme)
    {
        _theme = newTheme;
        StateHasChanged();
    }

    /// <summary>
    /// Обрабатывает событие
    /// </summary>
    private async void HandleSessionExpiredAsync()
    {
        if (_disposed)
            return;

        try
        {
            await InvokeAsync(async () =>
            {
                if (_disposed)
                    return;

                if (_sessionExpiredDialog is not null)
                {
                    await _sessionExpiredDialog.ShowAsync();
                }

                StateHasChanged();
            });
        }
        catch (ObjectDisposedException)
        {
        }
    }

    /// <summary>
    /// Выполняет выход
    /// </summary>
    private async Task LogoutAsync()
    {
        await JwtAuth.LogoutAsync();
        Navigation.NavigateTo("/login", forceLoad: false);
    }

    // Вспомогательные методы
    /// <summary>
    /// Формирует инициалы из email или имени
    /// </summary>
    private static string GetUserInitials(string? identity)
    {
        if (string.IsNullOrWhiteSpace(identity))
            return "?";

        var atIndex = identity.IndexOf('@');
        if (atIndex > 0)
            return char.ToUpperInvariant(identity[0]).ToString();

        var parts = identity.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{char.ToUpperInvariant(parts[0][0])}{char.ToUpperInvariant(parts[1][0])}"
            : char.ToUpperInvariant(parts[0][0]).ToString();
    }

    /// <summary>
    /// Обрезает отображаемое имя пользователя до 20 символов
    /// </summary>
    private static string TrimUserName(string? name)
    {
        if (string.IsNullOrWhiteSpace(name))
            return string.Empty;

        return name.Length > 20
            ? string.Concat(name.AsSpan(0, 18), "…")
            : name;
    }

    // IDisposable

    /// <inheritdoc/>
    public void Dispose()
    {
        _disposed = true;
        JwtAuth.OnSessionExpired -= HandleSessionExpiredAsync;
    }
}
