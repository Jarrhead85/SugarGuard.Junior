@page "/admin/roles"
@attribute [Authorize(Roles = "Admin,SupportAdmin")]
@layout DashboardLayout

@using Microsoft.AspNetCore.Authorization

<PageTitle>Роли — SugarGuard Admin</PageTitle>

<div class="admin-ops-page">
    <PageHeader Eyebrow="Администрирование"
                Title="Роли и права"
                Subtitle="Справочник ролей SugarGuard. Роли назначаются на странице пользователей, а доступ к данным дополнительно проверяется API." />

    <section class="admin-kpi-grid" aria-label="Сводка ролей">
        <StatCard Label="Пользовательские роли"
                  Value="4"
                  Subtitle="Parent, Doctor, Admin, SupportAdmin"
                  Status="neutral" />
        <StatCard Label="Сервисные роли"
                  Value="2"
                  Subtitle="ChildDevice и ServiceAccount"
                  Status="neutral" />
        <StatCard Label="Проверка доступа"
                  Value="API"
                  Subtitle="UI не является источником прав"
                  Status="safe" />
        <StatCard Label="Аудит"
                  Value="Да"
                  Subtitle="Смена роли пишется в audit log"
                  Status="safe" />
    </section>

    <section class="admin-panel">
        <SectionHeader Title="Матрица доступа"
                       Description="Короткая рабочая карта ролей для администратора." />

        <div class="admin-table-wrap">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Роль</th>
                        <th>Назначение</th>
                        <th>Основные права</th>
                        <th>Ограничения</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var role in _roles)
                    {
                        <tr>
                            <td>
                                <span class="role-badge role-badge--@role.Tone">@role.Name</span>
                            </td>
                            <td>@role.Purpose</td>
                            <td>@role.Permissions</td>
                            <td>@role.Limits</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section class="admin-panel admin-notes">
        <SectionHeader Title="Правила эксплуатации"
                       Description="Что важно помнить перед изменением ролей." />

        <ul class="admin-note-list">
            <li>Роль меняется только через API и фиксируется в журнале аудита.</li>
            <li>Администратор видит системные страницы, но медицинские данные всё равно проходят проверку доступа к ребёнку.</li>
            <li>Сервисные роли не стоит назначать обычным пользователям без отдельного сценария.</li>
            <li>Если потребуется workflow подтверждения врача, его лучше добавить как отдельный статус заявки, а не подменять текущую роль.</li>
        </ul>
    </section>
</div>

@code {
    private static readonly IReadOnlyList<RoleRow> _roles =
    [
        new("Parent", "Родитель", "Кабинет родителя, просмотр ребёнка, измерения, рюкзак, экспорт, уведомления.", "Доступ только к привязанным детям.", "parent"),
        new("Doctor", "Врач", "Список пациентов, дашборд пациента, заметки, отчёты и оповещения.", "Доступ только к прикреплённым пациентам.", "doctor"),
        new("Admin", "Администратор", "Пользователи, роли, связи, аудит, системные метрики, справочники.", "Не должен использоваться как ежедневная личная роль.", "admin"),
        new("SupportAdmin", "Техподдержка", "Ограниченный административный доступ для поддержки.", "Без лишних операций над медицинскими данными.", "support"),
        new("ChildDevice", "Устройство ребёнка", "Мобильная отправка измерений и синхронизация данных ребёнка.", "Не предназначена для входа в Web.", "device"),
        new("ServiceAccount", "Сервисный аккаунт", "Интеграции, фоновые процессы, бот и системные операции.", "Только для технических сценариев.", "service")
    ];

    private sealed record RoleRow(
        string Name,
        string Purpose,
        string Permissions,
        string Limits,
        string Tone);
}

<style>
    .admin-ops-page {
        display: grid;
        gap: 22px;
    }

    .admin-kpi-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 16px;
    }

    .admin-panel {
        background: var(--color-surface, rgba(255,255,255,.88));
        border: 1px solid var(--color-border, rgba(22,33,62,.10));
        border-radius: 24px;
        padding: 22px;
        box-shadow: var(--shadow-sm, 0 14px 36px rgba(22,33,62,.08));
    }

    .sg-section-header {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 18px;
    }

    .sg-section-header h2 {
        margin: 0;
        font-size: 22px;
        color: var(--color-text, #16213E);
    }

    .sg-section-header p {
        margin: 6px 0 0;
        color: var(--color-text-muted, #667694);
        font-size: 14px;
    }

    .admin-table-wrap {
        overflow-x: auto;
    }

    .admin-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 900px;
    }

    .admin-table th,
    .admin-table td {
        padding: 15px 16px;
        border-bottom: 1px solid var(--color-divider, rgba(22,33,62,.08));
        text-align: left;
        vertical-align: top;
    }

    .admin-table th {
        color: var(--color-text-faint, #96A2B8);
        font-size: 12px;
        letter-spacing: .07em;
        text-transform: uppercase;
    }

    .admin-table td {
        color: var(--color-text, #16213E);
        line-height: 1.45;
    }

    .role-badge {
        display: inline-flex;
        align-items: center;
        min-height: 30px;
        padding: 0 12px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 800;
        background: rgba(27,142,139,.12);
        color: var(--color-primary, #1B8E8B);
    }

    .role-badge--admin,
    .role-badge--support {
        background: rgba(45,126,226,.12);
        color: #2D7EE2;
    }

    .role-badge--doctor {
        background: rgba(110,86,207,.12);
        color: #5A46B8;
    }

    .role-badge--device,
    .role-badge--service {
        background: rgba(102,118,148,.13);
        color: #53627D;
    }

    .admin-note-list {
        margin: 0;
        padding-left: 20px;
        color: var(--color-text-muted, #667694);
        line-height: 1.7;
    }

    @@media (max-width: 1100px) {
        .admin-kpi-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 700px) {
        .admin-kpi-grid {
            grid-template-columns: 1fr;
        }

        .admin-panel {
            padding: 18px;
        }
    }
</style>
