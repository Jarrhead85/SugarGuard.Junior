@page "/admin/tokens"
@attribute [Authorize(Roles = "Admin,SupportAdmin")]
@rendermode InteractiveServer

@using System.Globalization
@using Microsoft.AspNetCore.Authorization
@using SugarGuard.Web.ViewModels

@inject SugarGuardApiService Api

<PageTitle>JWT / Токены - SugarGuard Admin</PageTitle>

<div class="admin-security-page">
    <PageHeader Eyebrow="Безопасность"
                Title="JWT / Токены"
                Subtitle="Контроль сессий, refresh-token событий, признаков подозрительной активности и расхода GigaChat. Секреты и подписи не отображаются в UI.">
        <TrailingContent>
            <button class="admin-btn admin-btn--soft" type="button" @onclick="LoadAsync" disabled="@_isLoading">
                @(_isLoading ? "Обновление..." : "Обновить")
            </button>
        </TrailingContent>
    </PageHeader>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <div class="admin-alert admin-alert--danger">@_message</div>
    }

    <section class="admin-kpi-grid">
        <StatCard Label="Auth-событий"
                  Value="@_authEvents.Count.ToString(CultureInfo.InvariantCulture)"
                  Subtitle="Последние записи audit"
                  Status="neutral" />
        <StatCard Label="Ошибок входа"
                  Value="@FailedAuthEvents.ToString(CultureInfo.InvariantCulture)"
                  Subtitle="По журналу аудита"
                  Status="@(FailedAuthEvents > 0 ? "warning" : "safe")" />
        <StatCard Label="Refresh events"
                  Value="@RefreshEvents.ToString(CultureInfo.InvariantCulture)"
                  Subtitle="Обновление сессий"
                  Status="neutral" />
        <StatCard Label="GigaChat за месяц"
                  Value="@FormatInt(_gigaChatUsage?.Month.TotalTokens)"
                  Subtitle="@FormatGigaChatBudgetSubtitle()"
                  Status="@GetGigaChatStatus()" />
    </section>

    <section class="admin-main-layout">
        <div class="admin-main-column">
            <section class="admin-panel">
                <SectionHeader Title="Расход GigaChat"
                               Description="Учитываются только ответы провайдера, где API вернул usage. Тексты запросов и ответов здесь не отображаются.">
                    <TrailingContent>
                        <span class="admin-pill">@FormatUpdatedAt(_gigaChatUsage?.GeneratedAtUtc)</span>
                    </TrailingContent>
                </SectionHeader>

                @if (_gigaChatUsage is null)
                {
                    <div class="admin-empty">
                        <strong>Нет данных по токенам</strong>
                        <span>Проверьте доступность API или дождитесь первого ответа GigaChat с usage.</span>
                    </div>
                }
                else
                {
                    <div class="gigachat-usage">
                        <div class="usage-card usage-card--accent">
                            <span>Сегодня</span>
                            <strong>@FormatInt(_gigaChatUsage.Today.TotalTokens)</strong>
                            <small>@_gigaChatUsage.Today.ResponsesWithUsage ответов с usage</small>
                        </div>
                        <div class="usage-card">
                            <span>Месяц</span>
                            <strong>@FormatInt(_gigaChatUsage.Month.TotalTokens)</strong>
                            <small>@FormatTokenSplit(_gigaChatUsage.Month)</small>
                        </div>
                        <div class="usage-card">
                            <span>Всего</span>
                            <strong>@FormatInt(_gigaChatUsage.AllTime.TotalTokens)</strong>
                            <small>@_gigaChatUsage.AllTime.ResponsesWithUsage ответов с usage</small>
                        </div>
                    </div>

                    @if (_gigaChatUsage.MonthlyTokenBudget is > 0)
                    {
                        <div class="usage-budget" aria-label="Месячный бюджет GigaChat">
                            <div>
                                <strong>Бюджет месяца</strong>
                                <span>
                                    Использовано @FormatInt(_gigaChatUsage.Month.TotalTokens) из @FormatInt(_gigaChatUsage.MonthlyTokenBudget)
                                </span>
                            </div>
                            <div class="usage-budget__bar">
                                <span style="width:@_gigaChatUsage.MonthlyBudgetUsedPercent.ToString("0.##", CultureInfo.InvariantCulture)%"></span>
                            </div>
                            <small>Осталось: @FormatInt(_gigaChatUsage.MonthlyTokensRemaining)</small>
                        </div>
                    }

                    <div class="usage-child-section">
                        <div class="usage-child-section__title">
                            <strong>Расход по детям</strong>
                            <span>Показано @ChildrenPageStart–@ChildrenPageEnd из @_gigaChatUsage.Children.Count</span>
                        </div>
                        @if (_gigaChatUsage.Children.Count == 0)
                        {
                            <div class="admin-empty admin-empty--compact">
                                <strong>Пока нет usage по детям</strong>
                                <span>Данные появятся после ответов AI, где GigaChat вернул статистику токенов.</span>
                            </div>
                        }
                        else
                        {
                            <div class="admin-table-wrap">
                                <table class="admin-table usage-child-table">
                                    <thead>
                                        <tr>
                                            <th>Ребёнок</th>
                                            <th>Месяц</th>
                                            <th>Всего</th>
                                            <th>Вход / выход</th>
                                            <th>Ответов</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var child in PagedChildren)
                                        {
                                            <tr @key="child.ChildId">
                                                <td>
                                                    <strong>@child.ChildDisplayName</strong>
                                                    <small>@ShortId(child.ChildId.ToString())</small>
                                                </td>
                                                <td>@FormatInt(child.Month.TotalTokens)</td>
                                                <td>@FormatInt(child.AllTime.TotalTokens)</td>
                                                <td>@FormatTokenSplit(child.Month)</td>
                                                <td>@child.Month.ResponsesWithUsage</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>

                            <div class="admin-pagination" aria-label="Страницы расхода токенов по детям">
                                <button class="admin-btn admin-btn--soft" type="button" @onclick="FirstChildrenPage" disabled="@(_childrenPage <= 1)">Первая</button>
                                <button class="admin-btn admin-btn--soft" type="button" @onclick="PreviousChildrenPage" disabled="@(_childrenPage <= 1)">Назад</button>
                                <span>@_childrenPage / @ChildrenPageCount</span>
                                <button class="admin-btn admin-btn--soft" type="button" @onclick="NextChildrenPage" disabled="@(_childrenPage >= ChildrenPageCount)">Далее</button>
                                <button class="admin-btn admin-btn--soft" type="button" @onclick="LastChildrenPage" disabled="@(_childrenPage >= ChildrenPageCount)">Последняя</button>
                            </div>
                        }
                    </div>
                }
            </section>

            <section class="admin-panel">
                <SectionHeader Title="Последние события авторизации"
                               Description="Показываются только метаданные audit log: действие, цель и время. Токены и секреты не раскрываются.">
                    <TrailingContent>
                        <span class="admin-pill">Показано: @_authEvents.Count</span>
                    </TrailingContent>
                </SectionHeader>

                @if (_isLoading)
                {
                    <div class="admin-empty">Загружаем события безопасности...</div>
                }
                else if (_authEvents.Count == 0)
                {
                    <div class="admin-empty">
                        <strong>Событий авторизации нет</strong>
                        <span>В audit log пока нет записей, связанных со входом или refresh token.</span>
                    </div>
                }
                else
                {
                    <div class="admin-table-wrap">
                        <table class="admin-table">
                            <thead>
                                <tr>
                                    <th>Время</th>
                                    <th>Действие</th>
                                    <th>Actor</th>
                                    <th>Target</th>
                                    <th>Детали</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in _authEvents)
                                {
                                    <tr @key="item.AuditLogId">
                                        <td>@FormatDateTime(item.CreatedAt)</td>
                                        <td>
                                            <span class="admin-pill admin-pill--@GetActionTone(item.Action)">
                                                @FormatAction(item.Action)
                                            </span>
                                        </td>
                                        <td><code>@ShortId(item.ActorUserId?.ToString())</code></td>
                                        <td>@(item.TargetType ?? "-") <code>@ShortId(item.TargetId)</code></td>
                                        <td class="admin-muted">@ShortText(item.Details)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </section>
        </div>

        <aside class="admin-side-column">
            <section class="admin-panel">
                <SectionHeader Title="Правила безопасности"
                               Description="Что контролирует эта страница." />
                <ul class="admin-note-list">
                    <li>JWT используется только как bearer-token, refresh token обновляется через API.</li>
                    <li>Секреты подписи и содержимое токенов не отправляются в браузер.</li>
                    <li>Подозрительные auth-события ищите по ошибкам входа, refresh-failed и частым сменам IP.</li>
                    <li>GigaChat usage берется из технических метаданных AI-ответов без текста сообщений.</li>
                </ul>
            </section>
        </aside>
    </section>
</div>

@code {
    private List<AuditLogVm> _authEvents = [];
    private GigaChatUsageVm? _gigaChatUsage;
    private bool _isLoading = true;
    private string? _message;
    private const int ChildrenPageSize = 10;
    private int _childrenPage = 1;

    private int ChildrenPageCount => Math.Max(1, (int)Math.Ceiling((_gigaChatUsage?.Children.Count ?? 0) / (double)ChildrenPageSize));
    private int ChildrenPageStart => _gigaChatUsage is null || _gigaChatUsage.Children.Count == 0
        ? 0
        : ((_childrenPage - 1) * ChildrenPageSize) + 1;
    private int ChildrenPageEnd => Math.Min(_childrenPage * ChildrenPageSize, _gigaChatUsage?.Children.Count ?? 0);
    private IReadOnlyList<GigaChatChildUsageVm> PagedChildren => _gigaChatUsage?.Children
        .Skip((_childrenPage - 1) * ChildrenPageSize)
        .Take(ChildrenPageSize)
        .ToArray()
        ?? [];

    private int FailedAuthEvents => _authEvents.Count(x =>
        x.Action.Contains("failed", StringComparison.OrdinalIgnoreCase)
        || x.Action.Contains("error", StringComparison.OrdinalIgnoreCase));

    private int RefreshEvents => _authEvents.Count(x =>
        x.Action.Contains("refresh", StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            _isLoading = true;
            _message = null;

            var logsTask = Api.GetAdminAuditLogsAsync(limit: 200);
            var usageTask = Api.GetAdminGigaChatUsageAsync();

            var logs = await logsTask;
            _gigaChatUsage = await usageTask;
            _childrenPage = 1;
            _authEvents = logs
                .Where(IsAuthEvent)
                .OrderByDescending(x => x.CreatedAt)
                .Take(80)
                .ToList();
        }
        catch (Exception ex)
        {
            _authEvents = [];
            _gigaChatUsage = null;
            _message = $"Не удалось загрузить данные безопасности: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private static bool IsAuthEvent(AuditLogVm item)
    {
        var action = item.Action ?? string.Empty;
        var target = item.TargetType ?? string.Empty;
        return action.Contains("auth", StringComparison.OrdinalIgnoreCase)
            || action.Contains("login", StringComparison.OrdinalIgnoreCase)
            || action.Contains("logout", StringComparison.OrdinalIgnoreCase)
            || action.Contains("refresh", StringComparison.OrdinalIgnoreCase)
            || target.Contains("token", StringComparison.OrdinalIgnoreCase);
    }

    private void FirstChildrenPage() => _childrenPage = 1;
    private void PreviousChildrenPage() => _childrenPage = Math.Max(1, _childrenPage - 1);
    private void NextChildrenPage() => _childrenPage = Math.Min(ChildrenPageCount, _childrenPage + 1);
    private void LastChildrenPage() => _childrenPage = ChildrenPageCount;

    private string GetGigaChatStatus()
    {
        if (_gigaChatUsage?.MonthlyTokenBudget is not > 0)
        {
            return "neutral";
        }

        return _gigaChatUsage.MonthlyBudgetUsedPercent switch
        {
            >= 90 => "danger",
            >= 70 => "warning",
            _ => "safe"
        };
    }

    private string FormatGigaChatBudgetSubtitle()
    {
        if (_gigaChatUsage?.MonthlyTokenBudget is not > 0)
        {
            return "Бюджет не задан";
        }

        return $"Осталось {FormatInt(_gigaChatUsage.MonthlyTokensRemaining)}";
    }

    private static string GetActionTone(string action)
    {
        if (action.Contains("failed", StringComparison.OrdinalIgnoreCase)
            || action.Contains("error", StringComparison.OrdinalIgnoreCase))
        {
            return "danger";
        }

        if (action.Contains("refresh", StringComparison.OrdinalIgnoreCase))
        {
            return "warning";
        }

        return "success";
    }

    private static string FormatAction(string action) =>
        string.IsNullOrWhiteSpace(action) ? "Событие" : action.Replace('_', ' ');

    private static string FormatDateTime(DateTime value) =>
        value.ToLocalTime().ToString("dd.MM.yyyy HH:mm", CultureInfo.GetCultureInfo("ru-RU"));

    private static string FormatUpdatedAt(DateTime? value) =>
        value.HasValue
            ? $"Обновлено {FormatDateTime(value.Value)}"
            : "Нет данных";

    private static string FormatInt(int? value) =>
        value?.ToString("N0", CultureInfo.GetCultureInfo("ru-RU")) ?? "-";

    private static string FormatTokenSplit(GigaChatUsagePeriodVm period) =>
        $"Вход: {FormatInt(period.InputTokens)} · выход: {FormatInt(period.OutputTokens)}";

    private static string ShortId(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "-";
        }

        return value.Length <= 12 ? value : $"{value[..8]}...{value[^4..]}";
    }

    private static string ShortText(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "-";
        }

        return value.Length <= 120 ? value : $"{value[..120]}...";
    }
}

<style>
    .admin-security-page {
        display: grid;
        gap: 22px;
    }

    .admin-kpi-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 16px;
    }

    .admin-main-layout {
        display: grid;
        grid-template-columns: minmax(0, 1.45fr) minmax(320px, .85fr);
        gap: 20px;
        align-items: start;
    }

    .admin-main-column,
    .admin-side-column {
        display: grid;
        gap: 20px;
    }

    .admin-panel {
        border: 1px solid var(--color-border, rgba(22,33,62,.10));
        border-radius: 24px;
        padding: 22px;
        background: var(--color-surface, rgba(255,255,255,.88));
        box-shadow: var(--shadow-sm, 0 14px 36px rgba(22,33,62,.08));
    }

    .admin-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 42px;
        border: 1px solid transparent;
        border-radius: 999px;
        padding: 0 18px;
        font: inherit;
        font-weight: 850;
        cursor: pointer;
    }

    .admin-btn:disabled {
        opacity: .56;
        cursor: wait;
    }

    .admin-btn--soft {
        color: var(--color-primary, #1b8e8b);
        background: rgba(27,142,139,.12);
    }

    .admin-alert {
        padding: 14px 18px;
        border-radius: 18px;
        font-weight: 750;
    }

    .admin-alert--danger {
        color: #db5967;
        border: 1px solid rgba(219,89,103,.24);
        background: rgba(219,89,103,.12);
    }

    .gigachat-usage {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 14px;
    }

    .usage-card {
        display: grid;
        gap: 7px;
        padding: 18px;
        border: 1px solid var(--color-border, rgba(22,33,62,.10));
        border-radius: 20px;
        background: rgba(248,251,255,.82);
    }

    .usage-card--accent {
        background: linear-gradient(135deg, rgba(27,142,139,.16), rgba(45,126,226,.12));
    }

    .usage-card span {
        color: var(--color-text-faint, #96a2b8);
        font-size: 12px;
        font-weight: 850;
        letter-spacing: .06em;
        text-transform: uppercase;
    }

    .usage-card strong {
        color: var(--color-text, #16213e);
        font-size: 30px;
        line-height: 1;
    }

    .usage-card small {
        color: var(--color-text-muted, #667694);
    }

    .usage-budget {
        display: grid;
        gap: 10px;
        margin-top: 16px;
        padding: 16px;
        border-radius: 18px;
        background: rgba(27,142,139,.08);
    }

    .usage-budget > div:first-child {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        color: var(--color-text, #16213e);
    }

    .usage-budget > div:first-child span,
    .usage-budget small {
        color: var(--color-text-muted, #667694);
    }

    .usage-budget__bar {
        height: 10px;
        overflow: hidden;
        border-radius: 999px;
        background: rgba(102,118,148,.16);
    }

    .usage-budget__bar span {
        display: block;
        height: 100%;
        border-radius: inherit;
        background: linear-gradient(90deg, #1b8e8b, #2d7ee2);
    }

    .usage-child-section {
        display: grid;
        gap: 12px;
        margin-top: 18px;
    }

    .usage-child-section__title {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
    }

    .usage-child-section__title span,
    .usage-child-table small {
        color: var(--color-text-muted, #667694);
    }

    .usage-child-table {
        min-width: 720px;
    }

    .admin-table-wrap {
        overflow-x: auto;
    }

    .admin-table {
        width: 100%;
        min-width: 920px;
        border-collapse: collapse;
    }

    .admin-table th,
    .admin-table td {
        padding: 14px 16px;
        border-bottom: 1px solid var(--color-divider, rgba(22,33,62,.08));
        text-align: left;
        vertical-align: top;
    }

    .admin-table th {
        color: var(--color-text-faint, #96a2b8);
        font-size: 12px;
        letter-spacing: .07em;
        text-transform: uppercase;
    }

    .admin-pill {
        display: inline-flex;
        align-items: center;
        min-height: 28px;
        border-radius: 999px;
        padding: 0 10px;
        color: var(--color-text-muted, #667694);
        background: rgba(102,118,148,.11);
        font-size: 12px;
        font-weight: 850;
    }

    .admin-pill--success {
        color: var(--color-primary, #1b8e8b);
        background: rgba(27,142,139,.12);
    }

    .admin-pill--warning {
        color: #9a6a00;
        background: rgba(227,163,43,.16);
    }

    .admin-pill--danger {
        color: #db5967;
        background: rgba(219,89,103,.13);
    }

    .admin-empty {
        min-height: 180px;
        display: grid;
        place-items: center;
        gap: 8px;
        border: 1px dashed var(--color-border, rgba(22,33,62,.14));
        border-radius: 20px;
        color: var(--color-text-muted, #667694);
        text-align: center;
    }

    .admin-empty--compact {
        min-height: 96px;
    }

    .admin-empty strong {
        color: var(--color-text, #16213e);
        font-size: 18px;
    }

    .admin-muted {
        color: var(--color-text-muted, #667694);
    }

    .admin-note-list {
        display: grid;
        gap: 10px;
        margin: 0;
        padding-left: 18px;
        color: var(--color-text-muted, #667694);
        line-height: 1.65;
    }

    .admin-pagination {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 8px;
        margin-top: 14px;
        color: var(--color-text-muted, #667694);
        font-size: 13px;
        font-weight: 800;
    }

    .admin-pagination .admin-btn {
        min-height: 36px;
        padding-inline: 12px;
    }

    @@media (max-width: 1100px) {
        .admin-kpi-grid,
        .gigachat-usage {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .admin-main-layout {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 700px) {
        .admin-kpi-grid,
        .gigachat-usage {
            grid-template-columns: 1fr;
        }

        .admin-panel {
            padding: 18px;
        }

        .admin-pagination {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .admin-pagination > span {
            display: grid;
            place-items: center;
        }

        .admin-pagination .admin-btn {
            width: 100%;
        }
    }
</style>
