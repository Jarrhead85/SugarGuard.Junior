@page "/parent/articles"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Parent")]
@using Microsoft.AspNetCore.Authorization
@using System.Globalization
@inject SugarGuardApiService Api
@inject NavigationManager Navigation

@if (!Embedded)
{
    <PageTitle>Статьи для родителей — SugarGuard</PageTitle>
}

<section class="parent-articles" aria-label="Статьи для родителей">

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="parent-articles__error" role="alert">@_error</div>
    }

    @if (_isLoading)
    {
        <div class="parent-articles__loading" role="status">Загружаем статьи…</div>
    }
    else if (_articles.Count == 0)
    {
        <div class="parent-articles__empty" role="status">
            <span aria-hidden="true">📚</span>
            <strong>Статьи пока не опубликованы</strong>
            <p>Когда команда добавит материалы, они появятся здесь.</p>
        </div>
    }
    else
    {
        <div class="parent-articles__list">
            @foreach (var article in _articles)
            {
                <details class="parent-article" @key="article.FaqId">
                    <summary>
                        <span class="parent-article__icon" aria-hidden="true">📄</span>
                        <span class="parent-article__heading">
                            <strong>@article.Title</strong>
                            <small>Обновлено @FormatDate(article.UpdatedAt)</small>
                        </span>
                        <span class="parent-article__chevron" aria-hidden="true">⌄</span>
                    </summary>
                    <div class="parent-article__content"><ArticleContent Content="@article.Content" /></div>
                </details>
            }
        </div>
    }
</section>

@code {
    private List<FaqVm> _articles = [];
    private bool _isLoading = true;
    private string? _error;

    [Parameter]
    public bool Embedded { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (!Embedded)
        {
            Navigation.NavigateTo("/parent/dashboard?tab=articles", replace: true);
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            _isLoading = true;
            _error = null;
            _articles = (await Api.GetFaqAsync())
                .OrderByDescending(article => article.UpdatedAt)
                .ToList();
        }
        catch (Exception)
        {
            _articles = [];
            _error = "Не удалось загрузить статьи. Проверьте подключение и повторите попытку.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private static string FormatDate(DateTime value) =>
        value.ToLocalTime().ToString("d MMMM yyyy", CultureInfo.GetCultureInfo("ru-RU"));
}

<style>
    .parent-articles { display: grid; gap: 16px; width: min(100%, 1320px); margin: 0 auto; min-width: 0; }
    .parent-articles__list { display: grid; gap: 12px; }
    .parent-article { overflow: hidden; border: 1px solid var(--color-border, rgba(22,33,62,.12)); border-radius: 18px; background: var(--color-surface, #fff); box-shadow: 0 8px 22px rgba(22,33,62,.04); }
    .parent-article summary { display: grid; grid-template-columns: 42px minmax(0, 1fr) 24px; align-items: center; gap: 14px; min-height: 74px; padding: 14px 18px; cursor: pointer; list-style: none; }
    .parent-article summary::-webkit-details-marker { display: none; }
    .parent-article summary:focus-visible { outline: 3px solid rgba(27,142,139,.25); outline-offset: -3px; }
    .parent-article__icon { display: grid; width: 42px; height: 42px; place-items: center; border-radius: 14px; background: rgba(27,142,139,.11); font-size: 20px; }
    .parent-article__heading { display: grid; gap: 4px; min-width: 0; }
    .parent-article__heading strong { color: var(--color-text, #16213E); font-size: 16px; }
    .parent-article__heading small { color: var(--color-text-faint, #96A2B8); font-size: 12px; }
    .parent-article__chevron { color: var(--color-primary, #1B8E8B); font-size: 24px; line-height: 1; transition: transform 160ms ease; }
    .parent-article[open] .parent-article__chevron { transform: rotate(180deg); }
    .parent-article__content { padding: 0 18px 20px 74px; }
    .parent-articles__loading, .parent-articles__empty { min-height: 180px; display: grid; place-content: center; gap: 8px; padding: 24px; border: 1px dashed var(--color-border, rgba(22,33,62,.18)); border-radius: 20px; color: var(--color-text-muted, #667694); text-align: center; }
    .parent-articles__empty > span { font-size: 32px; }
    .parent-articles__empty strong { color: var(--color-text, #16213E); }
    .parent-articles__empty p { margin: 0; }
    .parent-articles__error { padding: 14px 16px; border: 1px solid rgba(219,89,103,.25); border-radius: 16px; background: rgba(219,89,103,.10); color: var(--color-glucose-danger, #DB5967); font-weight: 650; }
    @@media (max-width: 640px) { .parent-article summary { padding: 12px; gap: 10px; grid-template-columns: 38px minmax(0, 1fr) 20px; } .parent-article__icon { width: 38px; height: 38px; border-radius: 12px; } .parent-article__content { padding: 0 14px 18px; } }
</style>
