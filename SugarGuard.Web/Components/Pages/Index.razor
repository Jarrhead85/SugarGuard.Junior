@code {
    private bool isDarkTheme;

    /// <summary>
    /// При монтировании компонента проверяем аутентификацию
    /// </summary>
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (!user.Identity?.IsAuthenticated ?? true) return;

            // Редирект по роли
            var role = user.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                       ?? user.FindFirst("role")?.Value;

            var target = role switch
            {
                "Admin" or "SupportAdmin" => "/admin/dashboard",
                "Doctor" => "/doctor/patients",
                _ => "/parent/dashboard"
            };

            Navigation.NavigateTo(target, replace: true);
        }
        catch
        {
        }

        try
        {
            var theme = await JS.InvokeAsync<string>("sugarGuardTheme.getTheme");
            isDarkTheme = string.Equals(theme, "dark", StringComparison.OrdinalIgnoreCase);
            StateHasChanged();
        }
        catch
        {
            isDarkTheme = false;
        }
    }

    private async Task ToggleThemeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("sugarGuardTheme.toggle");
            var theme = await JS.InvokeAsync<string>("sugarGuardTheme.getTheme");
            isDarkTheme = string.Equals(theme, "dark", StringComparison.OrdinalIgnoreCase);
        }
        catch
        {
            isDarkTheme = !isDarkTheme;
        }
    }
}
