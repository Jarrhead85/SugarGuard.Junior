@page "/doctor/dashboard"
@attribute [Authorize(Roles = "Doctor")]
@rendermode InteractiveServer

@using System.Globalization
@using Microsoft.AspNetCore.Authorization
@using SugarGuard.Web.Services
@using SugarGuard.Web.ViewModels

@inject SugarGuardApiService ApiService
@inject NavigationManager Navigation
@inject ILogger<Dashboard> Logger

<PageTitle>Дашборд врача — SugarGuard</PageTitle>

<div class="doctor-dashboard" aria-label="Обзор кабинета врача">

    @* Ошибка загрузки *@
    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <AlertBanner Type="error"
                     Title="Не удалось загрузить данные"
                     Message="@_errorMessage"
                     IsDismissible="true"
                     OnDismissed="ClearError"
                     ActionText="Повторить"
                     OnAction="RefreshAsync" />
    }

    @* KPI-карточки когорты *@
    <section class="doctor-dashboard__kpis" aria-label="Сводные показатели">
        @if (_isLoadingCohort)
        {
            @for (var i = 0; i < 4; i++)
            {
                <div class="doctor-dashboard__kpi-skeleton card">
                    <LoadingSkeleton Variant="SkeletonVariant.KpiCard" />
                </div>
            }
        }
        else
        {
            <div class="doctor-dashboard__kpi card @GetKpiClass(_cohort?.TotalPatients, null, KpiVariant.Neutral)">
                <p class="kpi-card__label">Всего пациентов</p>
                <strong class="kpi-card__value">
                    @(_cohort?.TotalPatients.ToString("N0", CultureInfo.InvariantCulture) ?? "—")
                </strong>
                <p class="kpi-card__hint">в моей группе пациентов</p>
            </div>

            <div class="doctor-dashboard__kpi card @GetKpiClass(_cohort?.PatientsWithCriticalToday, 0, KpiVariant.Danger)">
                <p class="kpi-card__label">Критических сегодня</p>
                <strong class="kpi-card__value kpi-card__value--danger">
                    @(_cohort?.PatientsWithCriticalToday.ToString("N0", CultureInfo.InvariantCulture) ?? "—")
                </strong>
                <p class="kpi-card__hint">пациентов с критическим сахаром</p>
            </div>

            <div class="doctor-dashboard__kpi card @GetTirKpiClass(_cohort?.AverageTimeInTargetRange)">
                <p class="kpi-card__label">Средний TIR</p>
                <strong class="kpi-card__value">
                    @FormatPercent(_cohort?.AverageTimeInTargetRange)
                </strong>
                <p class="kpi-card__hint">время в целевом диапазоне</p>
            </div>

            <div class="doctor-dashboard__kpi card @GetKpiClass(_cohort?.PatientsWithoutMeasurementsToday, 0, KpiVariant.Warning)">
                <p class="kpi-card__label">Без измерений</p>
                <strong class="kpi-card__value kpi-card__value--warning">
                    @(_cohort?.PatientsWithoutMeasurementsToday.ToString("N0", CultureInfo.InvariantCulture) ?? "—")
                </strong>
                <p class="kpi-card__hint">пациентов сегодня</p>
            </div>
        }
    </section>

    @* Список пациентов *@
    <section class="doctor-dashboard__patients" aria-labelledby="doctor-dashboard-patients-title">
        <div class="doctor-dashboard__section-header">
            <div>
                <p class="doctor-dashboard__eyebrow">Пациенты</p>
                <h2 id="doctor-dashboard-patients-title">Мои пациенты</h2>
                <p class="doctor-dashboard__description">
                    @if (!_isLoadingPatients)
                    {
                        @(_patients.Count == 0 ? "Пока нет прикреплённых пациентов." : $"Всего: {_patients.Count}")
                    }
                </p>
            </div>

            <div class="doctor-dashboard__controls">
                <label class="sr-only" for="sort-select">Сортировка пациентов</label>
                <select id="sort-select"
                        class="doctor-dashboard__select"
                        @bind="_sortBy"
                        @bind:after="OnSortChangedAsync">
                    <option value="@PatientSortBy.Name">По имени</option>
                    <option value="@PatientSortBy.Tir">По TIR</option>
                    <option value="@PatientSortBy.LastMeasurement">По последнему измерению</option>
                </select>

                <a class="btn btn-ghost" href="/doctor/patients">
                    Все пациенты
                </a>
            </div>
        </div>

        @if (_isLoadingPatients)
        {
            <div class="doctor-dashboard__patient-grid" aria-label="Загрузка пациентов">
                @for (var i = 0; i < 3; i++)
                {
                    <div class="doctor-dashboard__patient-skeleton">
                        <LoadingSkeleton Variant="SkeletonVariant.KpiCard" />
                    </div>
                }
            </div>
        }
        else if (_patients.Count == 0)
        {
            <EmptyState Title="Пациентов нет"
                        Description="Пока ни один ребёнок не привязан к вашему аккаунту. Обратитесь к администратору.">
                <Icon>
                    <span>🩺</span>
                </Icon>
            </EmptyState>
        }
        else
        {
            <div class="doctor-dashboard__patient-grid">
                @foreach (var patient in _patients.Take(MaxPatientsOnDashboard))
                {
                    <PatientCard Patient="@patient"
                                 OnViewDetail="@(() => NavigateToPatient(patient.ChildId))" />
                }

                @if (_patients.Count > MaxPatientsOnDashboard)
                {
                    <div class="doctor-dashboard__more">
                        <a class="btn btn-ghost" href="/doctor/patients">
                            Показать ещё @(_patients.Count - MaxPatientsOnDashboard) пациентов →
                        </a>
                    </div>
                }
            </div>
        }
    </section>

</div>

@code {
    // Константы 
    private const int MaxPatientsOnDashboard = 6; // Максимальное число пациентов на дашборде

    // Состояние загрузки
    private bool _isLoading => _isLoadingCohort || _isLoadingPatients; // Общий флаг загрузки

    private bool _isLoadingCohort = true; // Флаг загрузки данных когорты

    private bool _isLoadingPatients = true; // Флаг загрузки списка пациентов

    private string? _errorMessage; // Сообщение ошибки

    // Данные 
    private DoctorCohortSummaryVm? _cohort; // Сводка по группе

    private readonly List<DoctorPatientSummaryVm> _patients = []; // Список пациентов

    private string _sortBy = PatientSortBy.LastMeasurement; // Текущая сортировка пациентов

    // Lifecycle 
    /// <inheritdoc />
    protected override async Task OnInitializedAsync()
    {
        await LoadCohortAsync(CancellationToken.None);
        await LoadPatientsAsync(CancellationToken.None);
    }

    // Загрузка данных 
    /// <summary>
    /// Загружает сводку по группе
    /// </summary>
    private async Task LoadCohortAsync(CancellationToken cancellationToken)
    {
        _isLoadingCohort = true;

        try
        {
            _cohort = await ApiService.GetDoctorCohortSummaryAsync(cancellationToken);
        }
        catch (OperationCanceledException)
        {
            Logger.LogInformation("Загрузка сводки когорты отменена.");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Ошибка при загрузке сводки когорты.");
            _errorMessage = "Не удалось загрузить сводку когорты. Проверьте подключение к API.";
        }
        finally
        {
            _isLoadingCohort = false;
        }
    }

    /// <summary>
    /// Загружает список пациентов
    /// </summary>
    private async Task LoadPatientsAsync(CancellationToken cancellationToken)
    {
        _isLoadingPatients = true;

        try
        {
            var result = await ApiService.GetDoctorPatientsAsync(_sortBy, cancellationToken);
            _patients.Clear();

            if (result is not null)
            {
                _patients.AddRange(result);
            }
        }
        catch (OperationCanceledException)
        {
            Logger.LogInformation("Загрузка списка пациентов отменена.");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Ошибка при загрузке пациентов.");
            _errorMessage = "Не удалось загрузить список пациентов. Попробуйте обновить страницу.";
        }
        finally
        {
            _isLoadingPatients = false;
        }
    }

    /// <summary>
    /// Обновляет все данные на странице
    /// </summary>
    private async Task RefreshAsync()
    {
        _errorMessage = null;

        await LoadCohortAsync(CancellationToken.None);
        await LoadPatientsAsync(CancellationToken.None);
    }

    /// <summary>
    /// Вызывается при смене сортировки пациентов
    /// </summary>
    private async Task OnSortChangedAsync()
    {
        await LoadPatientsAsync(CancellationToken.None);
    }

    // Навигация 
    /// <summary>
    /// Переходит на страницу детализации пациента
    /// </summary>
    private void NavigateToPatient(Guid childId)
    {
        Navigation.NavigateTo($"/doctor/patients/{childId}");
    }

    private void ClearError()
    {
        _errorMessage = null;
    }

    // Вспомогательные методы
    /// <summary>
    /// Форматирует процент TIR для KPI-карточки
    /// </summary>
    private static string FormatPercent(double? value)
    {
        if (!value.HasValue)
        {
            return "—";
        }

        return value.Value.ToString("N1", CultureInfo.InvariantCulture) + "%";
    }

    /// <summary>
    /// Возвращает CSS-модификатор KPI-карточки по значению и порогу
    /// </summary>
    private static string GetKpiClass(int? value, int? dangerThreshold, KpiVariant variant)
    {
        if (variant == KpiVariant.Neutral || !value.HasValue || !dangerThreshold.HasValue)
        {
            return string.Empty;
        }

        if (value.Value > dangerThreshold.Value && variant == KpiVariant.Danger)
        {
            return "kpi-card--danger";
        }

        if (value.Value > dangerThreshold.Value && variant == KpiVariant.Warning)
        {
            return "kpi-card--warning";
        }

        return string.Empty;
    }

    /// <summary>
    /// Возвращает CSS-модификатор KPI-карточки TIR по значению
    /// </summary>
    private static string GetTirKpiClass(double? tir)
    {
        if (!tir.HasValue)
        {
            return string.Empty;
        }

        return tir.Value switch
        {
            >= 70.0 => "kpi-card--success",
            >= 50.0 => "kpi-card--warning",
            _ => "kpi-card--danger"
        };
    }

    // Вспомогательные типы
    /// <summary>
    /// Вариант цветового состояния KPI-карточки
    /// </summary>
    private enum KpiVariant
    {
        Neutral,
        Warning,
        Danger
    }

    /// <summary>
    /// Константы сортировки пациентов
    /// </summary>
    private static class PatientSortBy
    {       
        public const string Name = "name"; // По имени
       
        public const string Tir = "tir"; // По TIR (Time In Range)
       
        public const string LastMeasurement = "lastMeasurement"; // По времени последнего измерения
    }    
}

<style>
    .doctor-dashboard {
        display: grid;
        gap: 22px;
        width: min(100%, 1440px);
        margin: 0 auto;
        padding-bottom: 24px;
    }

    .doctor-dashboard__kpis {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 14px;
    }

    .doctor-dashboard__kpi,
    .doctor-dashboard__kpi-skeleton {
        min-width: 0;
        min-height: 132px;
        padding: 20px;
        border: 1px solid rgba(22, 33, 62, .10);
        border-radius: 20px;
        background: rgba(255, 255, 255, .92);
        box-shadow: 0 10px 28px rgba(22, 33, 62, .05);
    }

    .doctor-dashboard__kpi {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        gap: 10px;
    }

    .doctor-dashboard__kpi .kpi-card__label {
        margin: 0;
        color: var(--color-text-faint);
        font-size: 11px;
        font-weight: 850;
        letter-spacing: .07em;
        text-transform: uppercase;
    }

    .doctor-dashboard__kpi .kpi-card__value {
        color: var(--color-text);
        font-family: var(--font-display);
        font-size: clamp(30px, 2.5vw, 38px);
        font-weight: 850;
        letter-spacing: -.04em;
        line-height: 1;
    }

    .doctor-dashboard__kpi .kpi-card__hint {
        margin: 0;
        color: var(--color-text-muted);
        font-size: 13px;
        line-height: 1.35;
    }

    .doctor-dashboard__kpi .kpi-card__value--danger { color: var(--color-glucose-danger, #db5967); }
    .doctor-dashboard__kpi .kpi-card__value--warning { color: var(--color-glucose-warning, #e3a32b); }
    .doctor-dashboard__kpi.kpi-card--danger { border-color: rgba(219, 89, 103, .26); background: rgba(255, 249, 250, .94); }
    .doctor-dashboard__kpi.kpi-card--warning { border-color: rgba(227, 163, 43, .28); background: rgba(255, 252, 244, .94); }
    .doctor-dashboard__kpi.kpi-card--success { border-color: rgba(55, 165, 99, .24); background: rgba(248, 253, 250, .94); }

    .doctor-dashboard__patients {
        display: grid;
        gap: 14px;
        min-width: 0;
    }

    .doctor-dashboard__section-header {
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 16px;
    }

    .doctor-dashboard__eyebrow {
        margin: 0 0 4px;
        color: var(--color-primary);
        font-size: 11px;
        font-weight: 850;
        letter-spacing: .08em;
        text-transform: uppercase;
    }

    .doctor-dashboard__section-header h2 {
        margin: 0;
        color: var(--color-text);
        font-family: var(--font-display);
        font-size: clamp(20px, 2vw, 24px);
        letter-spacing: -.025em;
    }

    .doctor-dashboard__description {
        margin: 5px 0 0;
        color: var(--color-text-muted);
        font-size: 13px;
    }

    .doctor-dashboard__controls {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .doctor-dashboard__select {
        min-height: 40px;
        max-width: 240px;
        padding: 0 32px 0 12px;
        border: 1px solid var(--color-border);
        border-radius: 12px;
        background: var(--color-surface);
        color: var(--color-text);
        font: inherit;
        font-size: 13px;
        font-weight: 650;
    }

    .doctor-dashboard__select:focus-visible {
        outline: 3px solid rgba(27, 142, 139, .18);
        outline-offset: 2px;
        border-color: var(--color-primary);
    }

    .doctor-dashboard__patient-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 420px));
        justify-content: start;
        gap: 14px;
        min-width: 0;
    }

    .doctor-dashboard__patient-grid .sg-patient-card {
        box-sizing: border-box;
        width: 100%;
        min-width: 0;
        min-height: 206px;
    }

    .doctor-dashboard__patient-skeleton {
        min-height: 206px;
        padding: 18px;
        border: 1px solid rgba(22, 33, 62, .10);
        border-radius: 20px;
        background: rgba(255, 255, 255, .92);
    }

    .doctor-dashboard__more {
        display: grid;
        min-height: 206px;
        place-items: center;
        padding: 18px;
        border: 1px dashed rgba(27, 142, 139, .28);
        border-radius: 20px;
        background: rgba(27, 142, 139, .04);
        text-align: center;
    }

    @@media (max-width: 1080px) {
        .doctor-dashboard__kpis { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .doctor-dashboard__patient-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }

    @@media (max-width: 700px) {
        .doctor-dashboard { gap: 18px; }
        .doctor-dashboard__section-header { align-items: stretch; flex-direction: column; }
        .doctor-dashboard__controls { width: 100%; }
        .doctor-dashboard__select { flex: 1; max-width: none; min-width: 0; }
        .doctor-dashboard__patient-grid { grid-template-columns: 1fr; }
    }

    @@media (max-width: 520px) {
        .doctor-dashboard__kpis { grid-template-columns: 1fr; }
        .doctor-dashboard__kpi,
        .doctor-dashboard__kpi-skeleton { min-height: 112px; padding: 18px; border-radius: 18px; }
        .doctor-dashboard__controls .btn { flex: 1; justify-content: center; }
    }
</style>
