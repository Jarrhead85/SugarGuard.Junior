<CascadingAuthenticationState>
    <Router AppAssembly="typeof(Program).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)">
                <NotAuthorized>
                    <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:60dvh;gap:16px;color:var(--color-text-muted,#667694);font-family:system-ui,sans-serif;font-size:14px;padding:32px">
                        <div style="width:28px;height:28px;border:3px solid rgba(27,142,139,.18);border-top-color:var(--color-primary,#1B8E8B);border-radius:50%;animation:na-spin .7s linear infinite"></div>
                        <span>Проверка авторизации…</span>
                    </div>
                    <style>@@keyframes na-spin{to{transform:rotate(360deg)}}</style>
                </NotAuthorized>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="routeData" Selector="h1" />
        </Found>
        <NotFound>
            <LayoutView Layout="typeof(Layout.MainLayout)">
                <h1>Not Found</h1>
                <p class="muted-text">The requested route does not exist.</p>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>
