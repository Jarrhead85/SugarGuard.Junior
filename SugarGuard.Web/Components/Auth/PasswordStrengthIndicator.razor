@* Визуальный индикатор надёжности пароля *@

@if (!string.IsNullOrEmpty(Password))
{
    <div class="psi-root" aria-live="polite" aria-label="Надёжность пароля: @_level.Label">

        @* Полоски *@
        <div class="psi-bars" role="presentation">
            @for (int i = 0; i < TotalBars; i++)
            {
                var barIndex = i;
                <div class="psi-bar @GetBarClass(barIndex)"></div>
            }
        </div>

        @* Подпись уровня *@
        <div class="psi-label @_level.CssModifier">
            @_level.Label
        </div>

        @* Список требований *@
        @if (ShowRequirements)
        {
            <ul class="psi-requirements" aria-label="Требования к паролю">
                @foreach (var req in _requirements)
                {
                    <li class="psi-req @(req.IsMet ? "psi-req--met" : "psi-req--unmet")">
                        @if (req.IsMet)
                        {
                            <svg class="psi-req-icon" width="12" height="12"
                                 viewBox="0 0 12 12" fill="none" aria-hidden="true">
                                <circle cx="6" cy="6" r="5.25" fill="currentColor" opacity="0.15"/>
                                <path d="M3 6l2 2 4-4"
                                      stroke="currentColor" stroke-width="1.5"
                                      stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        }
                        else
                        {
                            <svg class="psi-req-icon" width="12" height="12"
                                 viewBox="0 0 12 12" fill="none" aria-hidden="true">
                                <circle cx="6" cy="6" r="5.25"
                                        stroke="currentColor" stroke-width="1.25"
                                        opacity="0.4"/>
                            </svg>
                        }
                        <span>@req.Text</span>
                    </li>
                }
            </ul>
        }

    </div>
}

@code {

    // Константы
    private const int TotalBars = 4;

    // Параметры 
    [Parameter]
    public string Password { get; set; } = string.Empty; // Текущее значение пароля

    [Parameter]
    public bool ShowRequirements { get; set; } = true; // Показывать ли список требований

    [Parameter]
    public EventCallback<int> OnScoreChanged { get; set; } // Вызывается при каждом изменении уровня надёжности

    // Внутреннее состояние
    private StrengthLevel _level  = StrengthLevel.None;
    private int           _score  = 0;
    private List<PasswordRequirement> _requirements = new();

    // Жизненный цикл 
    protected override async Task OnParametersSetAsync()
    {
        var previousScore = _score;

        EvaluatePassword();

        if (_score != previousScore && OnScoreChanged.HasDelegate)
            await OnScoreChanged.InvokeAsync(_score);
    }

    // Оценка пароля 
    /// <summary>
    /// Вычисляет счёт надёжности и обновляет список требований
    /// </summary>
    private void EvaluatePassword()
    {
        var p = Password ?? string.Empty;

        // Требования 
        _requirements = new List<PasswordRequirement>
        {
            new("Не менее 8 символов",             p.Length >= 8),
            new("Заглавная буква (A–Z)",            p.Any(char.IsUpper)),
            new("Строчная буква (a–z)",             p.Any(char.IsLower)),
            new("Цифра (0–9)",                      p.Any(char.IsDigit)),
            new("Спецсимвол (!@#$%^&* и др.)",      p.Any(IsSpecialChar)),
        };

        // Подсчёт очков
        int score = 0;

        if (p.Length >= 8)  score++;
        if (p.Length >= 12) score++; 

        if (p.Any(char.IsUpper) && p.Any(char.IsLower)) score++;
        if (p.Any(char.IsDigit))    score++;
        if (p.Any(IsSpecialChar))   score++;

        _score = Math.Clamp(score, 0, TotalBars);

        _level = _score switch
        {
            0 => StrengthLevel.None,
            1 => StrengthLevel.Weak,
            2 => StrengthLevel.Fair,
            3 => StrengthLevel.Good,
            _ => StrengthLevel.Strong
        };
    }

    // Вспомогательные методы
    /// <summary>
    /// Возвращает CSS-класс полоски по её индексу
    /// </summary>
    private string GetBarClass(int index)
    {
        if (index >= _score)
            return "psi-bar--empty";

        return _level.CssModifier;
    }

    /// <summary>
    /// Проверяет, является ли символ специальным 
    /// </summary>
    private static bool IsSpecialChar(char c)
        => !char.IsLetterOrDigit(c) && !char.IsWhiteSpace(c);

    // Вложенные типы
    /// <summary>
    /// Уровень надёжности пароля
    /// </summary>
    private sealed class StrengthLevel
    {       
        public string Label { get; } // Текстовая метка для пользователя

        public string CssModifier { get; } // CSS-модификатор для цветовой темы

        private StrengthLevel(string label, string cssModifier)
        {
            Label       = label;
            CssModifier = cssModifier;
        }

        public static readonly StrengthLevel None   = new(string.Empty,       "psi--none");
        public static readonly StrengthLevel Weak   = new("Слабый",           "psi--weak");
        public static readonly StrengthLevel Fair   = new("Средний",          "psi--fair");
        public static readonly StrengthLevel Good   = new("Хороший",          "psi--good");
        public static readonly StrengthLevel Strong = new("Надёжный",         "psi--strong");
    }

    /// <summary>
    /// Одно требование к паролю с признаком выполнения
    /// </summary>
    private sealed class PasswordRequirement
    {       
        public string Text  { get; } // Описание требования
       
        public bool   IsMet { get; } // требование выполнено

        public PasswordRequirement(string text, bool isMet)
        {
            Text  = text;
            IsMet = isMet;
        }
    }
}

@* Стили *@

<style>
    /* Корневой контейнер */
    .psi-root {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        width: 100%;
    }

    /* Полоски */
    .psi-bars {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 0.25rem;
    }

    .psi-bar {
        height: 4px;
        border-radius: 2px;
        transition: background-color 250ms cubic-bezier(0.16, 1, 0.3, 1);
    }

    /* Пустая полоска */
    .psi-bar--empty {
        background-color: var(--color-border, #d4d1ca);
    }

    /* Заполненная — цвет зависит от уровня */
    .psi-bar.psi--weak   { background-color: var(--color-error,   #a12c7b); }
    .psi-bar.psi--fair   { background-color: var(--color-warning, #964219); }
    .psi-bar.psi--good   { background-color: var(--color-gold,    #d19900); }
    .psi-bar.psi--strong { background-color: var(--color-success, #437a22); }

    /* Подпись уровня */
    .psi-label {
        font-size: 0.75rem;
        font-weight: 600;
        line-height: 1;
        min-height: 1em;
        transition: color 250ms ease;
    }

    .psi-label.psi--none   { color: transparent; }
    .psi-label.psi--weak   { color: var(--color-error,   #a12c7b); }
    .psi-label.psi--fair   { color: var(--color-warning, #964219); }
    .psi-label.psi--good   { color: var(--color-gold,    #d19900); }
    .psi-label.psi--strong { color: var(--color-success, #437a22); }

    /* Список требований */
    .psi-requirements {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .psi-req {
        display: flex;
        align-items: center;
        gap: 0.375rem;
        font-size: 0.75rem;
        line-height: 1.4;
        transition: color 200ms ease;
    }

    /* Невыполненное требование */
    .psi-req--unmet {
        color: var(--color-text-muted, #7a7974);
    }

    /* Выполненное требование */
    .psi-req--met {
        color: var(--color-success, #437a22);
    }

    /* Иконки */
    .psi-req-icon {
        flex-shrink: 0;
        width: 12px;
        height: 12px;
    }

    .psi-req--met   .psi-req-icon { color: var(--color-success, #437a22); }
    .psi-req--unmet .psi-req-icon { color: var(--color-text-faint, #bab9b4); }

    /* Reduced motion */
    @@media (prefers-reduced-motion: reduce) {
        .psi-bar,
        .psi-label,
        .psi-req {
            transition: none;
        }
    }
</style>