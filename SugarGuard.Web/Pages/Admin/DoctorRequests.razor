@code {
    private const string DoctorPendingRole = "DoctorPending";
    private const string SortNewest = "newest";
    private const string SortOldest = "oldest";
    private const string SortEmail = "email";

    private readonly CancellationTokenSource _disposeCts = new();
    private readonly List<DoctorRequestItem> _requests = [];

    private bool _isLoading = true;
    private bool _isRefreshing;
    private Guid? _approvingUserId;

    private string _searchTerm = string.Empty;
    private string _sortMode = SortNewest;
    private string? _statusMessage;
    private StatusTone _statusTone = StatusTone.Info;

    private OnboardingFunnelResponse? _funnel;

    private IEnumerable<DoctorRequestItem> FilteredRequests =>
        ApplySorting(
            _requests
                .Where(MatchesPendingRole)
                .Where(MatchesSearch));

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        if (_isRefreshing)
        {
            return;
        }

        var cancellationToken = _disposeCts.Token;

        try
        {
            _isRefreshing = true;

            if (_requests.Count == 0)
            {
                _isLoading = true;
            }

            ClearStatus();

            using var requestsResponse = await ApiService.GetDoctorPendingUsersAsync(500, cancellationToken);

            if (!requestsResponse.IsSuccessStatusCode)
            {
                SetStatus(await ReadErrorAsync(requestsResponse, cancellationToken), StatusTone.Danger);
                return;
            }

            var requests =
                await requestsResponse.Content.ReadFromJsonAsync<List<DoctorRequestItem>>(cancellationToken: cancellationToken)
                ?? [];

            _requests.Clear();
            _requests.AddRange(requests.Where(MatchesPendingRole));

            using var funnelResponse = await ApiService.GetOnboardingFunnelAsync("Doctor", cancellationToken);

            if (funnelResponse.IsSuccessStatusCode)
            {
                _funnel =
                    await funnelResponse.Content.ReadFromJsonAsync<OnboardingFunnelResponse>(cancellationToken: cancellationToken)
                    ?? new OnboardingFunnelResponse();
            }
            else
            {
                _funnel = null;
            }
        }
        catch (OperationCanceledException) when (_disposeCts.IsCancellationRequested)
        {
        }
        catch (Exception ex)
        {
            SetStatus($"Не удалось загрузить заявки врачей: {ex.Message}", StatusTone.Danger);
        }
        finally
        {
            _isLoading = false;
            _isRefreshing = false;
        }
    }

    private async Task ApproveDoctorAsync(DoctorRequestItem request)
    {
        if (!CanApprove(request))
        {
            return;
        }

        var cancellationToken = _disposeCts.Token;

        try
        {
            _approvingUserId = request.UserId;
            ClearStatus();

            using var response = await ApiService.UpdateDoctorUserRoleAsync(
                request.UserId,
                Roles.Doctor,
                cancellationToken);

            if (!response.IsSuccessStatusCode)
            {
                SetStatus(await ReadErrorAsync(response, cancellationToken), StatusTone.Danger);
                return;
            }

            _requests.RemoveAll(x => x.UserId == request.UserId);
            SetStatus("Заявка врача подтверждена.", StatusTone.Success);
        }
        catch (OperationCanceledException) when (_disposeCts.IsCancellationRequested)
        {
        }
        catch (Exception ex)
        {
            SetStatus($"Не удалось подтвердить врача: {ex.Message}", StatusTone.Danger);
        }
        finally
        {
            _approvingUserId = null;
        }
    }

    private void OnSearchChanged(ChangeEventArgs args)
    {
        _searchTerm = args.Value?.ToString()?.Trim() ?? string.Empty;
    }

    private void OnSortChanged(ChangeEventArgs args)
    {
        _sortMode = args.Value?.ToString()?.Trim() ?? SortNewest;
    }

    private bool MatchesSearch(DoctorRequestItem item)
    {
        if (string.IsNullOrWhiteSpace(_searchTerm))
        {
            return true;
        }

        var term = _searchTerm.Trim();

        return (item.EmailForLogin?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false)
               || item.UserId.ToString().Contains(term, StringComparison.OrdinalIgnoreCase)
               || (item.TelegramId?.ToString()?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false);
    }

    private static bool MatchesPendingRole(DoctorRequestItem item)
    {
        return string.Equals(item.Role, DoctorPendingRole, StringComparison.OrdinalIgnoreCase);
    }

    private IEnumerable<DoctorRequestItem> ApplySorting(IEnumerable<DoctorRequestItem> items)
    {
        return _sortMode switch
        {
            SortOldest => items.OrderBy(x => x.CreatedAt).ThenBy(x => x.EmailForLogin ?? string.Empty),
            SortEmail => items.OrderBy(x => x.EmailForLogin ?? string.Empty).ThenByDescending(x => x.CreatedAt),
            _ => items.OrderByDescending(x => x.CreatedAt).ThenBy(x => x.EmailForLogin ?? string.Empty)
        };
    }

    private bool CanApprove(DoctorRequestItem item)
    {
        return _approvingUserId is null
               && item.IsActive
               && MatchesPendingRole(item);
    }

    private static string GetRequestTitle(DoctorRequestItem item)
    {
        if (!string.IsNullOrWhiteSpace(item.EmailForLogin))
        {
            return item.EmailForLogin;
        }

        return $"Пользователь {item.UserId}";
    }

    private static string FormatUtc(DateTime value)
    {
        return value.ToUniversalTime().ToString("dd.MM.yyyy HH:mm 'UTC'");
    }

    private static string GetPendingDurationLabel(DateTime createdAt)
    {
        var duration = DateTime.UtcNow - createdAt.ToUniversalTime();

        if (duration.TotalDays >= 1d)
        {
            return $"{Math.Floor(duration.TotalDays):0} д.";
        }

        if (duration.TotalHours >= 1d)
        {
            return $"{Math.Floor(duration.TotalHours):0} ч.";
        }

        return $"{Math.Max(1, Math.Floor(duration.TotalMinutes)):0} мин.";
    }

    private string GetAveragePendingDaysLabel()
    {
        if (_requests.Count == 0)
        {
            return "0 д.";
        }

        var averageDays = _requests
            .Select(x => Math.Max(0d, (DateTime.UtcNow - x.CreatedAt.ToUniversalTime()).TotalDays))
            .DefaultIfEmpty(0d)
            .Average();

        return $"{averageDays:0.0} д.";
    }

    private static string FormatPercent(double value)
    {
        return $"{value * 100d:0.#}%";
    }

    private string GetStatusClass()
    {
        return _statusTone switch
        {
            StatusTone.Success => "sg-alert-success",
            StatusTone.Danger => "sg-alert-danger",
            _ => "sg-alert-info"
        };
    }

    private void SetStatus(string message, StatusTone tone)
    {
        _statusMessage = message;
        _statusTone = tone;
    }

    private void ClearStatus()
    {
        _statusMessage = null;
        _statusTone = StatusTone.Info;
    }

    private async Task<string> ReadErrorAsync(HttpResponseMessage response, CancellationToken cancellationToken)
    {
        try
        {
            var payload = await response.Content.ReadFromJsonAsync<ApiErrorResponse>(cancellationToken: cancellationToken);

            if (!string.IsNullOrWhiteSpace(payload?.Message))
            {
                return payload.Message;
            }

            if (!string.IsNullOrWhiteSpace(payload?.Detail))
            {
                return payload.Detail;
            }

            if (!string.IsNullOrWhiteSpace(payload?.Error))
            {
                return payload.Error;
            }
        }
        catch
        {
        }

        return $"Ошибка API: {(int)response.StatusCode} {response.ReasonPhrase}";
    }

    public void Dispose()
    {
        if (_disposeCts.IsCancellationRequested)
        {
            return;
        }

        _disposeCts.Cancel();
        _disposeCts.Dispose();
    }

    private sealed class DoctorRequestItem
    {
        public Guid UserId { get; set; }
        public string? EmailForLogin { get; set; }
        public long? TelegramId { get; set; }
        public string Role { get; set; } = string.Empty;
        public bool IsActive { get; set; } = true;
        public DateTime CreatedAt { get; set; }
    }

    private sealed class OnboardingFunnelResponse
    {
        public string? FilterRole { get; set; }
        public DateTime? FilterFrom { get; set; }
        public DateTime? FilterTo { get; set; }
        public int TotalStarted { get; set; }
        public int TotalCompleted { get; set; }
        public double ConversionRate { get; set; }
        public List<OnboardingFunnelStepItem> Steps { get; set; } = [];
    }

    private sealed class OnboardingFunnelStepItem
    {
        public int StepNumber { get; set; }
        public int UniqueUsers { get; set; }
        public double RetentionRate { get; set; }
    }

    private sealed class ApiErrorResponse
    {
        public string? Message { get; set; }
        public string? Detail { get; set; }
        public string? Error { get; set; }
    }

    private enum StatusTone
    {
        Info,
        Success,
        Danger
    }
}
