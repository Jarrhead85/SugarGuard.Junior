@page "/admin/doctor-requests"
@attribute [Authorize(Roles = Roles.Admin + "," + Roles.SupportAdmin)]
@implements IDisposable

@using System.Net.Http.Json
@using Microsoft.AspNetCore.Authorization
@using SugarGuard.Shared.Constants

@inject SugarGuardApiService ApiService

<PageTitle>Заявки врачей — SugarGuard Admin</PageTitle>

<div class="doctor-requests-page">
    <PageHeader Eyebrow="Admin / Doctor Requests"
                Title="Заявки врачей"
                Subtitle="Проверка пользователей со статусом DoctorPending, ручное подтверждение роли врача и быстрый просмотр прогресса doctor-onboarding.">
        <TrailingContent>
            <button class="sg-btn sg-btn-soft"
                    type="button"
                    @onclick="LoadDataAsync"
                    disabled="@_isRefreshing">
                @(_isRefreshing ? "Обновление..." : "Обновить")
            </button>
        </TrailingContent>
    </PageHeader>

    @if (!string.IsNullOrWhiteSpace(_statusMessage))
    {
        <div class="sg-alert @GetStatusClass()">
            @_statusMessage
        </div>
    }

    @if (_isLoading)
    {
        <section class="sg-panel sg-loading-panel">
            <div class="sg-spinner"></div>
            <p>Загружаем заявки врачей...</p>
        </section>
    }
    else
    {
        <section class="sg-stats-grid">
            <StatCard Label="Ожидают одобрения"
                      Value="@_requests.Count.ToString()"
                      Subtitle="Роль DoctorPending"
                      Status="warning" />

            <StatCard Label="Активные заявки"
                      Value="@_requests.Count(x => x.IsActive).ToString()"
                      Subtitle="Пользователи не деактивированы"
                      Status="safe" />

            <StatCard Label="Новые за 7 дней"
                      Value="@_requests.Count(x => x.CreatedAt >= DateTime.UtcNow.AddDays(-7)).ToString()"
                      Subtitle="По CreatedAt UTC"
                      Status="neutral" />

            <StatCard Label="Среднее ожидание"
                      Value="@GetAveragePendingDaysLabel()"
                      Subtitle="От даты создания заявки"
                      Status="neutral" />
        </section>

        <section class="sg-main-layout">
            <div class="sg-main-column">
                <section class="sg-panel">
                    <SectionHeader Title="Список заявок"
                                   Description="Подтверждение переводит пользователя из DoctorPending в Doctor.">
                        <TrailingContent>
                            <span class="sg-pill sg-pill-neutral">
                                Показано: @FilteredRequests.Count()
                            </span>
                        </TrailingContent>
                    </SectionHeader>

                    <div class="sg-toolbar">
                        <div class="sg-field">
                            <label class="sg-label" for="doctor-requests-search">Поиск</label>
                            <input id="doctor-requests-search"
                                   class="sg-input"
                                   type="search"
                                   value="@_searchTerm"
                                   @oninput="OnSearchChanged"
                                   placeholder="Email, Telegram ID, GUID" />
                        </div>

                        <div class="sg-field sg-field-compact">
                            <label class="sg-label" for="doctor-requests-sort">Сортировка</label>
                            <select id="doctor-requests-sort"
                                    class="sg-select"
                                    value="@_sortMode"
                                    @onchange="OnSortChanged">
                                <option value="@SortNewest">Сначала новые</option>
                                <option value="@SortOldest">Сначала старые</option>
                                <option value="@SortEmail">По email</option>
                            </select>
                        </div>
                    </div>

                    @if (!FilteredRequests.Any())
                    {
                        <div class="sg-empty-state">
                            <div class="sg-empty-icon">✓</div>
                            <h3>Нет заявок на подтверждение</h3>
                            <p>Сейчас в списке нет пользователей со статусом DoctorPending.</p>
                        </div>
                    }
                    else
                    {
                        <div class="sg-requests-list">
                            @foreach (var request in FilteredRequests)
                            {
                                <article class="sg-request-row" @key="request.UserId">
                                    <div class="sg-request-main">
                                        <div class="sg-request-title-row">
                                            <h3>@GetRequestTitle(request)</h3>

                                            <div class="sg-request-badges">
                                                <span class="sg-pill sg-pill-warning">
                                                    @request.Role
                                                </span>

                                                <span class="sg-pill @(request.IsActive ? "sg-pill-success" : "sg-pill-danger")">
                                                    @(request.IsActive ? "Активен" : "Неактивен")
                                                </span>
                                            </div>
                                        </div>

                                        <div class="sg-request-meta">
                                            <span><strong>ID:</strong> @request.UserId</span>
                                            <span><strong>Telegram:</strong> @(request.TelegramId?.ToString() ?? "—")</span>
                                            <span><strong>Создан:</strong> @FormatUtc(request.CreatedAt)</span>
                                            <span><strong>Ожидание:</strong> @GetPendingDurationLabel(request.CreatedAt)</span>
                                        </div>
                                    </div>

                                    <div class="sg-request-actions">
                                        <button class="sg-btn sg-btn-primary"
                                                type="button"
                                                @onclick="() => ApproveDoctorAsync(request)"
                                                disabled="@(!CanApprove(request))">
                                            @(_approvingUserId == request.UserId ? "Подтверждаем..." : "Подтвердить врача")
                                        </button>
                                    </div>
                                </article>
                            }
                        </div>
                    }
                </section>
            </div>

            <aside class="sg-side-column">
                <section class="sg-panel">
                    <SectionHeader Title="Doctor onboarding"
                                   Description="Агрегированная статистика funnel для роли Doctor.">
                        <TrailingContent>
                            <span class="sg-pill sg-pill-neutral">
                                Funnel
                            </span>
                        </TrailingContent>
                    </SectionHeader>

                    @if (_funnel is null)
                    {
                        <div class="sg-empty-inline">
                            Нет данных по funnel.
                        </div>
                    }
                    else
                    {
                        <div class="sg-funnel-grid">
                            <article class="sg-mini-stat">
                                <span class="sg-mini-stat-label">Начали</span>
                                <strong>@_funnel.TotalStarted</strong>
                            </article>

                            <article class="sg-mini-stat">
                                <span class="sg-mini-stat-label">Завершили</span>
                                <strong>@_funnel.TotalCompleted</strong>
                            </article>

                            <article class="sg-mini-stat">
                                <span class="sg-mini-stat-label">Конверсия</span>
                                <strong>@FormatPercent(_funnel.ConversionRate)</strong>
                            </article>
                        </div>

                        @if (_funnel.Steps.Count == 0)
                        {
                            <div class="sg-empty-inline">
                                По шагам пока ничего нет.
                            </div>
                        }
                        else
                        {
                            <div class="sg-steps-list">
                                @foreach (var step in _funnel.Steps.OrderBy(x => x.StepNumber))
                                {
                                    <div class="sg-step-item" @key="step.StepNumber">
                                        <div class="sg-step-header">
                                            <span class="sg-step-title">Шаг @step.StepNumber</span>
                                            <span class="sg-step-value">@FormatPercent(step.RetentionRate)</span>
                                        </div>

                                        <div class="sg-step-bar">
                                            <div class="sg-step-bar-fill" style="@($"width: {Math.Clamp(step.RetentionRate * 100d, 0d, 100d):0.##}%;")"></div>
                                        </div>

                                        <div class="sg-step-meta">
                                            <span>Пользователей: @step.UniqueUsers</span>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    }
                </section>

                <section class="sg-panel">
                    <SectionHeader Title="Правила проверки"
                                   Description="Короткие ориентиры для ручной модерации." />

                    <ul class="sg-hints-list">
                        <li>Подтверждение меняет роль пользователя на <strong>Doctor</strong>.</li>
                        <li>В списке должны находиться только пользователи со статусом <strong>DoctorPending</strong>.</li>
                        <li>Поиск работает по email, Telegram ID и GUID пользователя.</li>
                        <li>После подтверждения запись сразу исчезает из списка pending-заявок.</li>
                    </ul>
                </section>
            </aside>
        </section>
    }
</div>

