@page "/admin"
@page "/admin/dashboard"
@attribute [Authorize(Roles = "Admin,SupportAdmin")]
@implements IDisposable

@using System.Globalization
@using Microsoft.AspNetCore.Authorization
@using SugarGuard.Web.Services
@using SugarGuard.Web.ViewModels

@inject SugarGuardApiService Api
@inject NavigationManager Navigation
@inject ILogger<Dashboard> Logger

<PageTitle>Дашборд — SugarGuard Admin</PageTitle>

<div class="admin-dashboard-v2">
    <header class="admin-hero">
        <div>
            <div class="admin-eyebrow">Кабинет администратора</div>
            <div class="admin-title-row">
                <h1>Дашборд</h1>
                <span class="admin-health-pill admin-health-pill--@HealthTone">
                    <span></span>
                    @HealthLabel
                </span>
            </div>
            <p>Операционная картина SugarGuard: пользователи, роли, связи, синхронизация и аудит.</p>
        </div>

        <div class="admin-hero-actions">
            <span class="admin-updated">Обновлено: @FormatLocal(_loadedAt)</span>
            <button class="admin-btn admin-btn--soft" type="button" @onclick="() => LoadAsync()" disabled="@_isLoading">
                @(_isLoading ? "Обновление..." : "Обновить")
            </button>
            <a class="admin-btn admin-btn--primary" href="/admin/export-logs">Экспорт</a>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(_statusMessage))
    {
        <div class="admin-alert admin-alert--warning">@_statusMessage</div>
    }

    @if (_isLoading && _stats is null)
    {
        <section class="admin-kpi-row" aria-label="Загрузка метрик">
            @for (var i = 0; i < 4; i++)
            {
                <article class="admin-kpi-card admin-skeleton-card">
                    <span></span>
                    <strong></strong>
                    <small></small>
                </article>
            }
        </section>
    }
    else
    {
        <section class="admin-kpi-row" aria-label="Ключевые метрики">
            <article class="admin-kpi-card">
                <span>Всего пользователей</span>
                <strong>@FormatInt(_stats?.TotalUsers ?? _users.Count)</strong>
                <small>@GetNewUsersLabel()</small>
            </article>

            <article class="admin-kpi-card admin-kpi-card--safe">
                <span>Активных врачей</span>
                <strong>@FormatInt(ActiveDoctors)</strong>
                <small>@GetDoctorsDeltaLabel()</small>
            </article>

            <article class="admin-kpi-card admin-kpi-card--warning">
                <span>Ожидают верификации</span>
                <strong>@FormatInt(PendingDoctors.Count)</strong>
                <small>Требуют проверки</small>
            </article>

            <article class="admin-kpi-card admin-kpi-card--danger">
                <span>Инцидентов синхр.</span>
                <strong>@FormatInt(SecurityIncidentCount)</strong>
                <small>Ошибки и конфликты</small>
            </article>
        </section>

        <section class="admin-dashboard-grid">
            <article class="admin-panel admin-panel--wide">
                <div class="admin-panel-head">
                    <div>
                        <h2>@ChartTitle</h2>
                        <p>@ChartDescription</p>
                    </div>
                    <div class="admin-segment">
                        <button class="@GetChartModeCss("users")" type="button" @onclick='() => SetChartMode("users")'>
                            Пользователи
                        </button>
                        <button class="@GetChartModeCss("activity")" type="button" @onclick='() => SetChartMode("activity")'>
                            Активность
                        </button>
                    </div>
                </div>

                <div class="admin-chart-frame">
                    @if (!HasChartData)
                    {
                        <div class="admin-empty-inline">@EmptyChartMessage</div>
                    }
                    else
                    {
                        <svg class="admin-growth-chart" viewBox="0 0 120 90" role="img" aria-label="@ChartAriaLabel">
                            <defs>
                                <linearGradient id="adminGrowthFill" x1="0" x2="0" y1="0" y2="1">
                                    <stop offset="0%" stop-color="var(--admin-primary)" stop-opacity=".24" />
                                    <stop offset="100%" stop-color="var(--admin-primary)" stop-opacity=".02" />
                                </linearGradient>
                            </defs>
                            <path d="@GrowthAreaPath" fill="url(#adminGrowthFill)" />
                            <polyline points="@GrowthPolyline" fill="none" stroke="var(--admin-blue)" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" />
                            <circle cx="@LastPoint.X.ToString(CultureInfo.InvariantCulture)" cy="@LastPoint.Y.ToString(CultureInfo.InvariantCulture)" r="2.6" fill="var(--admin-blue)" />
                            @foreach (var line in GridLines)
                            {
                                <line x1="10" x2="112" y1="@line.ToString(CultureInfo.InvariantCulture)" y2="@line.ToString(CultureInfo.InvariantCulture)" stroke="var(--admin-line)" />
                            }
                        </svg>
                        <div class="admin-chart-labels">
                            @foreach (var point in GrowthPoints)
                            {
                                <span>@point.Label</span>
                            }
                        </div>
                    }
                </div>
            </article>

            <article class="admin-panel">
                <div class="admin-panel-head">
                    <div>
                        <h2>Роли пользователей</h2>
                        <p>Распределение аккаунтов по ролям.</p>
                    </div>
                </div>
                <div class="admin-role-bars">
                    @foreach (var role in RoleRows)
                    {
                        <div class="admin-role-row" @key="role.Role">
                            <span>@role.Label</span>
                            <div class="admin-role-track">
                                <div style="@($"width:{role.Percent.ToString("0.##", CultureInfo.InvariantCulture)}%")"></div>
                            </div>
                            <strong>@role.Count</strong>
                        </div>
                    }
                </div>
            </article>

            <article class="admin-mini-card">
                <span>Связок активно</span>
                <strong>@FormatInt(ActiveLinks)</strong>
                <small>Родители и врачи с детьми</small>
            </article>

            <article class="admin-mini-card">
                <span>Uptime API</span>
                <strong>@(IsHealthy ? "OK" : "—")</strong>
                <small>@(_health?.Database == true ? "База доступна" : "Проверьте health")</small>
            </article>

            <article class="admin-panel admin-panel--audit">
                <div class="admin-panel-head">
                    <div>
                        <h2>Последние события аудита</h2>
                        <p>Реальные события из audit log.</p>
                    </div>
                    <a class="admin-link" href="/admin/audit">Все</a>
                </div>

                @if (_auditLogs.Count == 0)
                {
                    <div class="admin-empty-inline">Событий аудита пока нет.</div>
                }
                else
                {
                    <div class="admin-audit-list">
                        @foreach (var log in PagedAuditLogs)
                        {
                            <article class="admin-audit-item" @key="log.AuditLogId">
                                <span class="admin-audit-dot"></span>
                                <div>
                                    <strong>@FormatAuditAction(log.Action)</strong>
                                    <p>@FormatAuditMeta(log)</p>
                                </div>
                                <time>@FormatShortTime(log.CreatedAt)</time>
                            </article>
                        }
                    </div>
                    <div class="admin-pagination" aria-label="Страницы событий аудита">
                        <span>@_auditPage из @AuditPageCount</span>
                        <button type="button" @onclick="PreviousAuditPage" disabled="@(_auditPage <= 1)" aria-label="Предыдущая страница">←</button>
                        <button type="button" @onclick="NextAuditPage" disabled="@(_auditPage >= AuditPageCount)" aria-label="Следующая страница">→</button>
                    </div>
                }
            </article>

            <article class="admin-panel admin-panel--verify">
                <div class="admin-panel-head">
                    <div>
                        <h2>Очередь верификации</h2>
                        <p>Пользователи с ролью DoctorPending.</p>
                    </div>
                    <span class="admin-badge">@PendingDoctors.Count ожидают</span>
                </div>

                @if (PendingDoctors.Count == 0)
                {
                    <div class="admin-empty-inline">Нет заявок на проверку врача.</div>
                }
                else
                {
                    <div class="admin-verify-list">
                        @foreach (var user in PendingDoctors.Take(4))
                        {
                            <article class="admin-verify-item" @key="user.UserId">
                                <span class="admin-avatar">@GetInitials(user.EmailForLogin)</span>
                                <div>
                                    <strong>@user.EmailForLogin</strong>
                                    <small>Создан @FormatDate(user.CreatedAt)</small>
                                </div>
                                <span class="admin-badge admin-badge--warning">Врач</span>
                            </article>
                        }
                    </div>
                }

                <a class="admin-wide-link" href="/admin/doctor-requests">Перейти к верификации →</a>
            </article>
        </section>
    }
</div>

@code {
    private static readonly double[] GridLines = [22, 42, 62, 82];
    private static readonly CultureInfo RuCulture = CultureInfo.GetCultureInfo("ru-RU");
    private static readonly TimeZoneInfo MoscowTimeZone = ResolveMoscowTimeZone();
    private readonly CancellationTokenSource _disposeCts = new();
    private readonly SemaphoreSlim _refreshGate = new(1, 1);
    private Task? _refreshTask;
    private bool _isLoading = true;
    private string? _statusMessage;
    private string _chartMode = "users";
    private DateTime _loadedAt = DateTime.UtcNow;
    private AdminSystemStatsVm? _stats;
    private AdminHealthVm? _health;
    private List<AdminUserVm> _users = [];
    private List<AuditLogVm> _auditLogs = [];
    private int _auditPage = 1;
    private const int AuditPageSize = 4;
    private IReadOnlyList<AdminParentChildLinkDto> _parentLinks = [];
    private IReadOnlyList<AdminDoctorChildLinkDto> _doctorLinks = [];
    private IReadOnlyList<SyncLogVm> _syncLogs = [];

    private bool IsHealthy => _health?.DatabaseOk == true
        && string.Equals(_health.Status, "healthy", StringComparison.OrdinalIgnoreCase);

    private string HealthTone => IsHealthy ? "safe" : _health is null ? "warning" : "danger";
    private string HealthLabel => IsHealthy ? "Система в норме" : _health is null ? "Health неизвестен" : "Требуется проверка";
    private int ActiveDoctors => _users.Count(x => x.IsActive && IsRole(x.Role, "Doctor"));
    private int ActiveLinks => _parentLinks.Count + _doctorLinks.Count;
    private int SecurityIncidentCount => (_stats?.UnresolvedConflicts ?? 0)
        + _syncLogs.Count(x => x.IsConflict || !string.IsNullOrWhiteSpace(x.Error));

    private int AuditPageCount => Math.Max(1, (int)Math.Ceiling(_auditLogs.Count / (double)AuditPageSize));
    private IReadOnlyList<AuditLogVm> PagedAuditLogs => _auditLogs
        .Skip((_auditPage - 1) * AuditPageSize)
        .Take(AuditPageSize)
        .ToList();

    private void PreviousAuditPage() => _auditPage = Math.Max(1, _auditPage - 1);
    private void NextAuditPage() => _auditPage = Math.Min(AuditPageCount, _auditPage + 1);

    private List<AdminUserVm> PendingDoctors =>
        _users
            .Where(x => x.IsActive && IsRole(x.Role, "DoctorPending"))
            .OrderBy(x => x.CreatedAt)
            .ToList();

    private IReadOnlyList<RoleRow> RoleRows
    {
        get
        {
            var total = Math.Max(_users.Count, 1);
            return _users
                .GroupBy(x => x.IsAutomationAccount
                    ? "Automation"
                    : IsRole(x.Role, "Parent") && !x.IsEmailVerified
                        ? "UnverifiedParent"
                    : string.IsNullOrWhiteSpace(x.Role) ? "Unknown" : x.Role)
                .OrderByDescending(x => x.Count())
                .Select(x => new RoleRow(GetRoleLabel(x.Key), x.Key, x.Count(), x.Count() * 100d / total))
                .ToList();
        }
    }

    private bool HasChartData => _chartMode == "users" ? _users.Count > 0 : _auditLogs.Count > 0;
    private string ChartTitle => _chartMode == "activity" ? "Активность системы" : "Рост пользователей";
    private string ChartDescription => _chartMode == "activity"
        ? "События аудита за последние 6 месяцев."
        : "За последние 6 месяцев, по реальным аккаунтам в базе.";
    private string ChartAriaLabel => _chartMode == "activity" ? "График активности системы" : "График роста пользователей";
    private string EmptyChartMessage => _chartMode == "activity"
        ? "Пока нет событий аудита для графика."
        : "Пока нет пользователей для графика.";

    private IReadOnlyList<GrowthPoint> GrowthPoints => _chartMode == "activity" ? BuildActivityPoints() : BuildGrowthPoints();
    private string GrowthPolyline => string.Join(" ", GrowthPoints.Select(p => $"{p.X.ToString(CultureInfo.InvariantCulture)},{p.Y.ToString(CultureInfo.InvariantCulture)}"));
    private string GrowthAreaPath => GrowthPoints.Count == 0
        ? string.Empty
        : $"M {GrowthPolyline} L {GrowthPoints[^1].X.ToString(CultureInfo.InvariantCulture)},86 L {GrowthPoints[0].X.ToString(CultureInfo.InvariantCulture)},86 Z";
    private GrowthPoint LastPoint => GrowthPoints.Count == 0 ? new GrowthPoint("—", 112, 82, 0) : GrowthPoints[^1];

    private void SetChartMode(string mode)
    {
        _chartMode = mode == "activity" ? "activity" : "users";
    }

    private string GetChartModeCss(string mode) => _chartMode == mode ? "is-active" : string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        _refreshTask = RunLiveRefreshAsync(_disposeCts.Token);
    }

    private async Task LoadAsync(bool showLoading = true)
    {
        if (!await _refreshGate.WaitAsync(0, _disposeCts.Token))
        {
            return;
        }

        if (showLoading)
        {
            _isLoading = true;
            _statusMessage = null;
        }

        try
        {
            using var cts = CancellationTokenSource.CreateLinkedTokenSource(_disposeCts.Token);
            cts.CancelAfter(TimeSpan.FromSeconds(25));
            var statsTask = Api.GetAdminSystemStatsAsync(cts.Token);
            var healthTask = Api.GetAdminHealthAsync(cts.Token);
            var usersTask = Api.GetAdminUsersAsync(limit: 500, cancellationToken: cts.Token);
            var auditTask = Api.GetAdminAuditLogsAsync(limit: 20, cancellationToken: cts.Token);
            var parentLinksTask = Api.GetAdminParentChildLinksAsync(cts.Token);
            var doctorLinksTask = Api.GetAdminDoctorChildLinksAsync(cts.Token);
            var syncTask = Api.GetSyncLogsAsync(limit: 100, cancellationToken: cts.Token);

            await Task.WhenAll(statsTask, healthTask, usersTask, auditTask, parentLinksTask, doctorLinksTask, syncTask);

            _stats = await statsTask;
            _health = await healthTask;
            _users = (await usersTask).OrderByDescending(x => x.CreatedAt).ToList();
            _auditLogs = (await auditTask).OrderByDescending(x => x.CreatedAt).ToList();
            _auditPage = Math.Clamp(_auditPage, 1, AuditPageCount);
            _parentLinks = await parentLinksTask ?? [];
            _doctorLinks = await doctorLinksTask ?? [];
            _syncLogs = await syncTask ?? [];
            _loadedAt = DateTime.UtcNow;

            if (_stats is null || _health is null)
            {
                _statusMessage = "Часть системных данных недоступна. Основные списки загружены.";
            }
        }
        catch (Exception ex)
        {
            if (showLoading)
            {
                _statusMessage = $"Не удалось полностью обновить дашборд: {ex.Message}";
            }
            else
            {
                Logger.LogWarning(ex, "Не удалось автоматически обновить дашборд администратора.");
            }
        }
        finally
        {
            if (showLoading)
            {
                _isLoading = false;
            }

            _refreshGate.Release();
        }
    }

    private async Task RunLiveRefreshAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(30));

        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                await InvokeAsync(async () =>
                {
                    await LoadAsync(showLoading: false);
                    StateHasChanged();
                });
            }
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
        {
        }
    }

    public void Dispose()
    {
        _disposeCts.Cancel();
        _disposeCts.Dispose();
    }

    private IReadOnlyList<GrowthPoint> BuildGrowthPoints()
    {
        var now = ToMoscowTime(DateTime.UtcNow).Date;
        var monthStarts = Enumerable.Range(0, 6)
            .Select(i => new DateTime(now.Year, now.Month, 1).AddMonths(i - 5))
            .ToList();

        var cumulative = monthStarts
            .Select(month => _users.Count(user => ToMoscowTime(user.CreatedAt).Date < month.AddMonths(1)))
            .ToList();

        var max = Math.Max(cumulative.DefaultIfEmpty(0).Max(), 1);
        var points = new List<GrowthPoint>(monthStarts.Count);

        for (var i = 0; i < monthStarts.Count; i++)
        {
            var x = 12d + i * (96d / Math.Max(monthStarts.Count - 1, 1));
            var y = 80d - cumulative[i] * 55d / max;
            points.Add(new GrowthPoint(monthStarts[i].ToString("MMM", RuCulture), x, y, cumulative[i]));
        }

        return points;
    }

    private IReadOnlyList<GrowthPoint> BuildActivityPoints()
    {
        var now = ToMoscowTime(DateTime.UtcNow).Date;
        var monthStarts = Enumerable.Range(0, 6)
            .Select(i => new DateTime(now.Year, now.Month, 1).AddMonths(i - 5))
            .ToList();

        var monthlyCounts = monthStarts
            .Select(month => _auditLogs.Count(log =>
            {
                var created = ToMoscowTime(log.CreatedAt).Date;
                return created >= month && created < month.AddMonths(1);
            }))
            .ToList();

        var max = Math.Max(monthlyCounts.DefaultIfEmpty(0).Max(), 1);
        var points = new List<GrowthPoint>(monthStarts.Count);

        for (var i = 0; i < monthStarts.Count; i++)
        {
            var x = 12d + i * (96d / Math.Max(monthStarts.Count - 1, 1));
            var y = 80d - monthlyCounts[i] * 55d / max;
            points.Add(new GrowthPoint(monthStarts[i].ToString("MMM", RuCulture), x, y, monthlyCounts[i]));
        }

        return points;
    }

    private string GetNewUsersLabel()
    {
        var weekAgo = DateTime.UtcNow.AddDays(-7);
        var count = _users.Count(x => x.CreatedAt >= weekAgo);
        return count == 0 ? "Без новых за неделю" : $"+{count} за неделю";
    }

    private string GetDoctorsDeltaLabel()
    {
        var pending = PendingDoctors.Count;
        return pending == 0 ? "Верификация пуста" : $"{pending} ждут проверки";
    }

    private static bool IsRole(string? value, string role) =>
        string.Equals(value, role, StringComparison.OrdinalIgnoreCase);

    private static string GetRoleLabel(string role) => role switch
    {
        "Parent" => "Родители",
        "Doctor" => "Врачи",
        "DoctorPending" => "Ожидают врача",
        "Admin" => "Администраторы",
        "SupportAdmin" => "Поддержка",
        "ChildDevice" => "Детские устройства",
        "ServiceAccount" => "Сервисные",
        "Automation" => "Тестовые и автоматизация",
        "UnverifiedParent" => "Родители без подтверждения",
        _ => role
    };

    private static string FormatAuditAction(string action) =>
        string.IsNullOrWhiteSpace(action) ? "Событие" : action.Replace('_', ' ');

    private static string FormatAuditMeta(AuditLogVm log)
    {
        var target = string.IsNullOrWhiteSpace(log.TargetType) ? "система" : log.TargetType;
        return $"{target} · {ShortId(log.TargetId)}";
    }

    private static string ShortId(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "—";
        }

        return value.Length <= 10 ? value : $"{value[..8]}…";
    }

    private static string GetInitials(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "SG";
        }

        var normalized = value.Trim();
        var emailPrefix = normalized.Split('@')[0];
        return new string(emailPrefix.Where(char.IsLetterOrDigit).Take(2).ToArray()).ToUpperInvariant();
    }

    private static string FormatInt(long value) => value.ToString("N0", RuCulture);
    private static string FormatLocal(DateTime value) => $"{ToMoscowTime(value).ToString("dd.MM.yyyy HH:mm", RuCulture)} МСК";
    private static string FormatDate(DateTime value) => ToMoscowTime(value).ToString("dd.MM.yyyy", RuCulture);
    private static string FormatShortTime(DateTime value) => ToMoscowTime(value).ToString("HH:mm", RuCulture);

    private static DateTime ToMoscowTime(DateTime value)
    {
        var utc = value.Kind switch
        {
            DateTimeKind.Utc => value,
            DateTimeKind.Local => value.ToUniversalTime(),
            _ => DateTime.SpecifyKind(value, DateTimeKind.Utc)
        };

        return TimeZoneInfo.ConvertTimeFromUtc(utc, MoscowTimeZone);
    }

    private static TimeZoneInfo ResolveMoscowTimeZone()
    {
        foreach (var id in new[] { "Europe/Moscow", "Russian Standard Time" })
        {
            try
            {
                return TimeZoneInfo.FindSystemTimeZoneById(id);
            }
            catch (TimeZoneNotFoundException)
            {
            }
            catch (InvalidTimeZoneException)
            {
            }
        }

        return TimeZoneInfo.Local;
    }

    private sealed record RoleRow(string Label, string Role, int Count, double Percent);
    private sealed record GrowthPoint(string Label, double X, double Y, int Value);
}

<style>
    .admin-dashboard-v2 {
        display: grid;
        gap: 22px;
        color: var(--admin-ink);
    }

    .admin-pagination {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 8px;
        margin-top: 12px;
        color: var(--admin-muted);
        font-size: 12px;
        font-weight: 800;
    }

    .admin-pagination button {
        width: 34px;
        height: 34px;
        border: 1px solid var(--admin-line);
        border-radius: 10px;
        color: var(--admin-primary);
        background: var(--admin-panel-strong);
        cursor: pointer;
    }

    .admin-pagination button:disabled { opacity: .4; cursor: default; }

    .admin-hero,
    .admin-panel,
    .admin-kpi-card,
    .admin-mini-card {
        border: 1px solid var(--admin-line);
        background: var(--admin-panel);
        box-shadow: var(--admin-shadow);
        backdrop-filter: blur(22px);
        -webkit-backdrop-filter: blur(22px);
    }

    .admin-hero {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        border: 0;
        border-radius: 0;
        padding: 0 0 2px;
        background: transparent;
        box-shadow: none;
        backdrop-filter: none;
        -webkit-backdrop-filter: none;
    }

    .admin-eyebrow {
        display: none;
        color: var(--admin-muted);
        font-size: 12px;
        font-weight: 900;
        letter-spacing: .08em;
        text-transform: uppercase;
    }

    .admin-title-row {
        display: flex;
        align-items: center;
        gap: 14px;
        flex-wrap: wrap;
        margin-top: 0;
    }

    .admin-title-row h1 {
        margin: 0;
        font-size: clamp(26px, 3vw, 34px);
        line-height: 1.05;
    }

    .admin-hero p {
        max-width: 68ch;
        margin: 8px 0 0;
        color: var(--admin-muted);
        line-height: 1.6;
    }

    .admin-hero-actions {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .admin-updated {
        color: var(--admin-faint);
        font-size: 13px;
        white-space: nowrap;
    }

    .admin-btn,
    .admin-wide-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 42px;
        border: 0;
        border-radius: 999px;
        padding: 0 18px;
        font-weight: 900;
        text-decoration: none;
        cursor: pointer;
