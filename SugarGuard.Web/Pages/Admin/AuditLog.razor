@code {
    private readonly CancellationTokenSource _disposeCts = new();

    private readonly List<AuditLogVm> _logs = [];
    private readonly AuditLogFilterModel _filter = new();
    private const int PageSize = 20;
    private int _page = 1;

    private int PageCount => Math.Max(1, (int)Math.Ceiling(_logs.Count / (double)PageSize));
    private IReadOnlyList<AuditLogVm> PagedLogs => _logs
        .Skip((_page - 1) * PageSize)
        .Take(PageSize)
        .ToList();

    private void PreviousPage() => _page = Math.Max(1, _page - 1);
    private void NextPage() => _page = Math.Min(PageCount, _page + 1);

    private static readonly int[] _availableLimits = [50, 100, 200, 500, 1000];

    private static readonly string[] _commonActions =
    [
        "auth.login",
        "auth.login.failed",
        "admin.rolechanged",
        "admin.userdeactivated",
        "admin.parentchildlinkcreated",
        "admin.parentchildlinkdeleted",
        "admin.doctorchildlinkcreated",
        "admin.doctorchildlinkdeleted",
        "measurement.created",
        "sync.batchcompleted"
    ];

    private bool _isLoading = true;
    private bool _isRefreshing;

    private string? _statusMessage;
    private StatusTone _statusTone = StatusTone.Info;

    protected override async Task OnInitializedAsync()
    {
        await LoadAuditLogsAsync();
    }

    private async Task LoadAuditLogsAsync()
    {
        if (_isRefreshing)
        {
            return;
        }

        var cancellationToken = _disposeCts.Token;

        try
        {
            _isRefreshing = true;

            if (_logs.Count == 0)
            {
                _isLoading = true;
            }

            if (!ValidateRange())
            {
                return;
            }

            ClearStatus();

            var actorUserId = string.IsNullOrWhiteSpace(_filter.ActorUserId)
                ? (Guid?)null
                : Guid.Parse(_filter.ActorUserId);

            var logs = await Api.GetAdminAuditLogsAsync(
                actorUserId,
                _filter.Action,
                _filter.FromUtc,
                _filter.ToUtc,
                _filter.Limit,
                cancellationToken);

            _logs.Clear();
            _logs.AddRange(logs.OrderByDescending(x => x.CreatedAt));
            _page = 1;

            SetStatus($"Загружено записей: {_logs.Count}.", StatusTone.Success);
        }
        catch (OperationCanceledException) when (_disposeCts.IsCancellationRequested)
        {
        }
        catch (Exception ex)
        {
            SetStatus($"Не удалось загрузить audit log: {ex.Message}", StatusTone.Danger);
        }
        finally
        {
            _isLoading = false;
            _isRefreshing = false;
        }
    }

    private async Task ApplyFiltersAsync()
    {
        await LoadAuditLogsAsync();
    }

    private async Task ResetFiltersAsync()
    {
        _filter.ActorUserId = string.Empty;
        _filter.Action = string.Empty;
        _filter.FromUtc = null;
        _filter.ToUtc = null;
        _filter.Limit = 200;

        await LoadAuditLogsAsync();
    }

    private async Task ApplyActionAsync(string action)
    {
        _filter.Action = action;
        await LoadAuditLogsAsync();
    }

    private async Task ApplyAuthPresetAsync()
    {
        _filter.Action = "auth.login";
        await LoadAuditLogsAsync();
    }

    private async Task ApplyRoleChangesPresetAsync()
    {
        _filter.Action = "admin.rolechanged";
        await LoadAuditLogsAsync();
    }

    private async Task ApplyParentLinksPresetAsync()
    {
        _filter.Action = "admin.parentchildlink";
        await LoadAuditLogsAsync();
    }

    private async Task ApplyDoctorLinksPresetAsync()
    {
        _filter.Action = "admin.doctorchildlink";
        await LoadAuditLogsAsync();
    }

    private async Task ApplyLast24HoursPresetAsync()
    {
        var nowUtc = DateTime.UtcNow;
        _filter.FromUtc = nowUtc.AddHours(-24);
        _filter.ToUtc = nowUtc;
        await LoadAuditLogsAsync();
    }

    private void OnFromChanged(ChangeEventArgs args)
    {
        _filter.FromUtc = ParseDateTimeLocal(args.Value?.ToString());
    }

    private void OnToChanged(ChangeEventArgs args)
    {
        _filter.ToUtc = ParseDateTimeLocal(args.Value?.ToString());
    }

    private void OnLimitChanged(ChangeEventArgs args)
    {
        if (int.TryParse(args.Value?.ToString(), NumberStyles.Integer, CultureInfo.InvariantCulture, out var limit))
        {
            _filter.Limit = Math.Clamp(limit, 1, 1000);
        }
    }

    private bool ValidateRange()
    {
        if (_filter.FromUtc.HasValue && _filter.ToUtc.HasValue && _filter.FromUtc.Value > _filter.ToUtc.Value)
        {
            SetStatus("Период задан некорректно: from не может быть позже to.", StatusTone.Danger);
            return false;
        }

        if (!string.IsNullOrWhiteSpace(_filter.ActorUserId)
            && !Guid.TryParse(_filter.ActorUserId, out _))
        {
            SetStatus("ActorUserId должен быть корректным GUID.", StatusTone.Danger);
            return false;
        }

        _filter.Limit = Math.Clamp(_filter.Limit, 1, 1000);

        return true;
    }

    private static DateTime? ParseDateTimeLocal(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        if (DateTime.TryParse(
                value,
                CultureInfo.InvariantCulture,
                DateTimeStyles.None,
                out var parsed))
        {
            return TimeZoneInfo.ConvertTimeToUtc(DateTime.SpecifyKind(parsed, DateTimeKind.Unspecified), MoscowTimeZone);
        }

        if (DateTime.TryParse(value, out parsed))
        {
            return TimeZoneInfo.ConvertTimeToUtc(DateTime.SpecifyKind(parsed, DateTimeKind.Unspecified), MoscowTimeZone);
        }

        return null;
    }

    private static string FormatLocal(DateTime value)
    {
        return TimeZoneInfo.ConvertTimeFromUtc(
                value.Kind == DateTimeKind.Utc ? value : value.ToUniversalTime(),
                MoscowTimeZone)
            .ToString("dd.MM.yyyy HH:mm:ss 'МСК'", CultureInfo.InvariantCulture);
    }

    private string GetLatestTimestamp()
    {
        if (_logs.Count == 0)
        {
            return "—";
        }

        return FormatLocal(_logs.Max(x => x.CreatedAt));
    }

    private static string GetActionCategory(string? action)
    {
        if (string.IsNullOrWhiteSpace(action))
        {
            return "Other";
        }

        var normalized = action.Trim().ToLowerInvariant();

        if (normalized.StartsWith("auth.", StringComparison.Ordinal))
        {
            return "Auth";
        }

        if (normalized.StartsWith("admin.", StringComparison.Ordinal))
        {
            return "Admin";
        }

        if (normalized.Contains("link", StringComparison.Ordinal))
        {
            return "Links";
        }

        if (normalized.StartsWith("measurement.", StringComparison.Ordinal)
            || normalized.StartsWith("sync.", StringComparison.Ordinal))
        {
            return "Data";
        }

        return "Other";
    }

    private string GetActionPillClass(string? action)
    {
        return GetActionCategory(action) switch
        {
            "Auth" => "sg-pill-auth",
            "Admin" => "sg-pill-admin",
            "Links" => "sg-pill-link",
            "Data" => "sg-pill-measurement",
            _ => "sg-pill-other"
        };
    }

    private string GetStatusClass()
    {
        return _statusTone switch
        {
            StatusTone.Success => "sg-alert-success",
            StatusTone.Danger => "sg-alert-danger",
            _ => "sg-alert-info"
        };
    }

    private void SetStatus(string message, StatusTone tone)
    {
        _statusMessage = message;
        _statusTone = tone;
    }

    private void ClearStatus()
    {
        _statusMessage = null;
        _statusTone = StatusTone.Info;
    }

    public void Dispose()
    {
        if (_disposeCts.IsCancellationRequested)
        {
            return;
        }

        _disposeCts.Cancel();
        _disposeCts.Dispose();
    }

    private sealed class AuditLogFilterModel
    {
        public string ActorUserId { get; set; } = string.Empty;
        public string Action { get; set; } = string.Empty;
        public DateTime? FromUtc { get; set; }
        public DateTime? ToUtc { get; set; }
        public int Limit { get; set; } = 200;

        public string FromText =>
            FromUtc.HasValue
                ? TimeZoneInfo.ConvertTimeFromUtc(
                        FromUtc.Value.Kind == DateTimeKind.Utc ? FromUtc.Value : FromUtc.Value.ToUniversalTime(),
                        MoscowTimeZone)
                    .ToString("yyyy-MM-ddTHH:mm", CultureInfo.InvariantCulture)
                : string.Empty;

        public string ToText =>
            ToUtc.HasValue
                ? TimeZoneInfo.ConvertTimeFromUtc(
                        ToUtc.Value.Kind == DateTimeKind.Utc ? ToUtc.Value : ToUtc.Value.ToUniversalTime(),
                        MoscowTimeZone)
                    .ToString("yyyy-MM-ddTHH:mm", CultureInfo.InvariantCulture)
                : string.Empty;
    }

    private enum StatusTone
    {
        Info,
        Success,
        Danger
    }

    private static readonly TimeZoneInfo MoscowTimeZone = ResolveMoscowTimeZone();

    private static TimeZoneInfo ResolveMoscowTimeZone()
    {
        foreach (var id in new[] { "Europe/Moscow", "Russian Standard Time" })
        {
            try
            {
                return TimeZoneInfo.FindSystemTimeZoneById(id);
            }
            catch (TimeZoneNotFoundException)
            {
            }
            catch (InvalidTimeZoneException)
            {
            }
        }

        return TimeZoneInfo.Utc;
    }
}
