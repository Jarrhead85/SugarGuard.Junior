@code {
    private readonly CancellationTokenSource _disposeCts = new();
    private readonly List<AdminUserItem> _users = [];
    private readonly Dictionary<Guid, string> _roleDrafts = new();

    private readonly ParentChildLinkFormModel _parentLinkForm = new();
    private readonly DoctorChildLinkFormModel _doctorLinkForm = new();

    private static readonly string[] _assignableRoles =
    [
        Roles.Parent,
        Roles.Doctor,
        Roles.Admin,
        Roles.SupportAdmin
    ];

    private bool _isLoading = true;
    private bool _isRefreshing;
    private bool _isParentLinkSubmitting;
    private bool _isDoctorLinkSubmitting;
    private Guid? _roleSavingUserId;

    private string _searchTerm = string.Empty;
    private string _selectedRoleFilter = string.Empty;
    private string? _statusMessage;
    private StatusTone _statusTone = StatusTone.Info;

    private IEnumerable<AdminUserItem> FilteredUsers =>
        _users
            .Where(MatchesRoleFilter)
            .Where(MatchesSearch)
            .OrderByDescending(x => x.CreatedAt)
            .ThenBy(x => x.EmailForLogin ?? string.Empty);

    private IEnumerable<AdminUserItem> ParentCandidates =>
        _users
            .Where(IsVerifiedParent)
            .OrderBy(x => x.EmailForLogin ?? string.Empty)
            .ThenBy(x => x.CreatedAt);

    private IEnumerable<AdminUserItem> DoctorCandidates =>
        _users
            .Where(x => x.IsActive && IsDoctorLinkRole(x.Role))
            .OrderBy(x => x.EmailForLogin ?? string.Empty)
            .ThenBy(x => x.CreatedAt);

    protected override async Task OnInitializedAsync()
    {
        await LoadUsersAsync();
    }

    private async Task LoadUsersAsync()
    {
        if (_isRefreshing)
        {
            return;
        }

        var cancellationToken = _disposeCts.Token;

        try
        {
            _isRefreshing = true;

            if (_users.Count == 0)
            {
                _isLoading = true;
            }

            ClearStatus();

            var users = await Api.GetAdminUsersAsync(limit: 500, cancellationToken: cancellationToken);

            _users.Clear();
            _users.AddRange(users.Select(AdminUserItem.FromVm).OrderByDescending(x => x.CreatedAt));

            _roleDrafts.Clear();

            foreach (var user in _users)
            {
                _roleDrafts[user.UserId] = user.Role;
            }

            NormalizeForms();
        }
        catch (OperationCanceledException) when (_disposeCts.IsCancellationRequested)
        {
        }
        catch (Exception ex)
        {
            SetStatus($"Не удалось загрузить пользователей: {ex.Message}", StatusTone.Danger);
        }
        finally
        {
            _isLoading = false;
            _isRefreshing = false;
        }
    }

    private async Task UpdateRoleAsync(AdminUserItem user)
    {
        var cancellationToken = _disposeCts.Token;
        var newRole = GetDraftRole(user.UserId, user.Role);

        if (!IsAssignableRole(newRole))
        {
            SetStatus("Выбрана недопустимая роль.", StatusTone.Danger);
            return;
        }

        if (string.Equals(user.Role, newRole, StringComparison.OrdinalIgnoreCase))
        {
            SetStatus("Роль не изменилась.", StatusTone.Info);
            return;
        }

        try
        {
            _roleSavingUserId = user.UserId;
            ClearStatus();

            await Api.UpdateUserRoleAsync(user.UserId, newRole, cancellationToken);

            user.Role = newRole;
            _roleDrafts[user.UserId] = newRole;

            NormalizeForms();
            SetStatus("Роль пользователя обновлена.", StatusTone.Success);
        }
        catch (OperationCanceledException) when (_disposeCts.IsCancellationRequested)
        {
        }
        catch (Exception ex)
        {
            SetStatus($"Не удалось обновить роль: {ex.Message}", StatusTone.Danger);
        }
        finally
        {
            _roleSavingUserId = null;
        }
    }

    private async Task CreateParentChildLinkAsync()
    {
        var cancellationToken = _disposeCts.Token;

        if (!Guid.TryParse(_parentLinkForm.ParentUserId, out var parentUserId))
        {
            SetStatus("Выберите родителя из списка.", StatusTone.Danger);
            return;
        }

        if (!Guid.TryParse(_parentLinkForm.ChildId, out var childId))
        {
            SetStatus("Укажите корректный ChildId в формате GUID.", StatusTone.Danger);
            return;
        }

        var parent = _users.FirstOrDefault(x => x.UserId == parentUserId);

        if (parent is null || !IsRole(parent.Role, Roles.Parent))
        {
            SetStatus("Выбранный пользователь не является родителем.", StatusTone.Danger);
            return;
        }

        try
        {
            _isParentLinkSubmitting = true;
            ClearStatus();

            await Api.CreateAdminParentChildLinkAsync(parentUserId, childId, cancellationToken);

            _parentLinkForm.ChildId = string.Empty;
            SetStatus("Связь parent-child успешно создана.", StatusTone.Success);
        }
        catch (OperationCanceledException) when (_disposeCts.IsCancellationRequested)
        {
        }
        catch (Exception ex)
        {
            SetStatus($"Не удалось создать связь parent-child: {ex.Message}", StatusTone.Danger);
        }
        finally
        {
            _isParentLinkSubmitting = false;
        }
    }

    private async Task CreateDoctorChildLinkAsync()
    {
        var cancellationToken = _disposeCts.Token;

        if (!Guid.TryParse(_doctorLinkForm.DoctorUserId, out var doctorUserId))
        {
            SetStatus("Выберите врача или администратора из списка.", StatusTone.Danger);
            return;
        }

        if (!Guid.TryParse(_doctorLinkForm.ChildId, out var childId))
        {
            SetStatus("Укажите корректный ChildId в формате GUID.", StatusTone.Danger);
            return;
        }

        var doctor = _users.FirstOrDefault(x => x.UserId == doctorUserId);

        if (doctor is null || !IsDoctorLinkRole(doctor.Role))
        {
            SetStatus("Выбранный пользователь не может быть связан как врач.", StatusTone.Danger);
            return;
        }

        try
        {
            _isDoctorLinkSubmitting = true;
            ClearStatus();

            await Api.CreateAdminDoctorChildLinkAsync(doctorUserId, childId, cancellationToken);

            _doctorLinkForm.ChildId = string.Empty;
            SetStatus("Связь doctor-child успешно создана.", StatusTone.Success);
        }
        catch (OperationCanceledException) when (_disposeCts.IsCancellationRequested)
        {
        }
        catch (Exception ex)
        {
            SetStatus($"Не удалось создать связь doctor-child: {ex.Message}", StatusTone.Danger);
        }
        finally
        {
            _isDoctorLinkSubmitting = false;
        }
    }

    private void OnSearchChanged(ChangeEventArgs args)
    {
        _searchTerm = args.Value?.ToString()?.Trim() ?? string.Empty;
    }

    private void OnRoleFilterChanged(ChangeEventArgs args)
    {
        _selectedRoleFilter = args.Value?.ToString()?.Trim() ?? string.Empty;
    }

    private void OnRoleDraftChanged(Guid userId, ChangeEventArgs args)
    {
        _roleDrafts[userId] = args.Value?.ToString()?.Trim() ?? string.Empty;
    }

    private bool CanSaveRole(AdminUserItem user)
    {
        if (_roleSavingUserId.HasValue)
        {
            return false;
        }

        var draftRole = GetDraftRole(user.UserId, user.Role);

        return IsAssignableRole(draftRole)
               && !string.Equals(draftRole, user.Role, StringComparison.OrdinalIgnoreCase);
    }

    private string GetDraftRole(Guid userId, string fallbackRole)
    {
        return _roleDrafts.TryGetValue(userId, out var role) && !string.IsNullOrWhiteSpace(role)
            ? role
            : fallbackRole;
    }

    private bool MatchesSearch(AdminUserItem user)
    {
        if (string.IsNullOrWhiteSpace(_searchTerm))
        {
            return true;
        }

        var term = _searchTerm.Trim();

        return (user.EmailForLogin?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false)
               || user.UserId.ToString().Contains(term, StringComparison.OrdinalIgnoreCase)
               || user.Role.Contains(term, StringComparison.OrdinalIgnoreCase)
               || (user.TelegramId?.ToString()?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false);
    }

    private bool MatchesRoleFilter(AdminUserItem user)
    {
        return string.IsNullOrWhiteSpace(_selectedRoleFilter)
               || string.Equals(user.Role, _selectedRoleFilter, StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsAssignableRole(string? role)
    {
        return _assignableRoles.Contains(role ?? string.Empty, StringComparer.OrdinalIgnoreCase);
    }

    private static bool IsRole(string? left, string? right)
    {
        return string.Equals(left, right, StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsDoctorLinkRole(string? role)
    {
        return IsRole(role, Roles.Doctor)
               || IsRole(role, Roles.Admin)
               || IsRole(role, Roles.SupportAdmin);
    }

    private static string GetUserTitle(AdminUserItem user)
    {
        if (!string.IsNullOrWhiteSpace(user.DisplayName))
        {
            return user.DisplayName;
        }

        if (!string.IsNullOrWhiteSpace(user.EmailForLogin))
        {
            return user.EmailForLogin;
        }

        return $"Пользователь {user.UserId}";
    }

    private static string GetUserInitials(AdminUserItem user)
    {
        var title = GetUserTitle(user);
        var parts = title.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        if (parts.Length >= 2)
        {
            return string.Concat(parts[0][0], parts[1][0]).ToUpperInvariant();
        }

        return title.Length >= 2
            ? title[..2].ToUpperInvariant()
            : title.ToUpperInvariant();
    }

    private static bool IsVerifiedParent(AdminUserItem user) =>
        user.IsActive
        && user.IsEmailVerified
        && !user.IsAutomationAccount
        && IsRole(user.Role, Roles.Parent);

    private static string GetUserOptionText(AdminUserItem user)
    {
        var emailPart = !string.IsNullOrWhiteSpace(user.EmailForLogin)
            ? user.EmailForLogin
            : "Без email";

        return $"{emailPart} · {user.Role} · {ShortId(user.UserId)}";
    }

    private static string ShortId(Guid id)
    {
        var value = id.ToString("N");
        return $"{value[..8]}…{value[^4..]}";
    }

    private static string FormatUtc(DateTime value)
    {
        return value.ToUniversalTime().ToString("dd.MM.yyyy HH:mm 'UTC'");
    }

    private string GetRolePillClass(string role)
    {
        if (IsRole(role, Roles.Parent))
        {
            return "sg-pill-parent";
        }

        if (IsRole(role, Roles.Doctor))
        {
            return "sg-pill-doctor";
        }

        if (IsRole(role, Roles.Admin))
        {
            return "sg-pill-admin";
        }

        if (IsRole(role, Roles.SupportAdmin))
        {
            return "sg-pill-support";
        }

        return "sg-pill-neutral";
    }

    private string GetStatusClass()
    {
        return _statusTone switch
        {
            StatusTone.Success => "sg-alert-success",
            StatusTone.Danger => "sg-alert-danger",
            _ => "sg-alert-info"
        };
    }

    private void ReplaceUser(AdminUserItem updatedUser)
    {
        var index = _users.FindIndex(x => x.UserId == updatedUser.UserId);

        if (index >= 0)
        {
            _users[index] = updatedUser;
        }
        else
        {
            _users.Add(updatedUser);
        }

        _roleDrafts[updatedUser.UserId] = updatedUser.Role;
    }

    private void NormalizeForms()
    {
        if (!string.IsNullOrWhiteSpace(_parentLinkForm.ParentUserId)
            && !ParentCandidates.Any(x => x.UserId.ToString() == _parentLinkForm.ParentUserId))
        {
            _parentLinkForm.ParentUserId = string.Empty;
        }

        if (!string.IsNullOrWhiteSpace(_doctorLinkForm.DoctorUserId)
            && !DoctorCandidates.Any(x => x.UserId.ToString() == _doctorLinkForm.DoctorUserId))
        {
            _doctorLinkForm.DoctorUserId = string.Empty;
        }
    }

    private void SetStatus(string message, StatusTone tone)
    {
        _statusMessage = message;
        _statusTone = tone;
    }

    private void ClearStatus()
    {
        _statusMessage = null;
        _statusTone = StatusTone.Info;
    }

    public void Dispose()
    {
        if (_disposeCts.IsCancellationRequested)
        {
            return;
        }

        _disposeCts.Cancel();
        _disposeCts.Dispose();
    }

    private sealed class AdminUserItem
    {
        public Guid UserId { get; set; }
        public string? EmailForLogin { get; set; }
        public long? TelegramId { get; set; }
        public string Role { get; set; } = string.Empty;
        public bool IsActive { get; set; } = true;
        public DateTime CreatedAt { get; set; }
        public string DisplayName { get; set; } = string.Empty;
        public string? PhotoUrl { get; set; }
        public string? Specialty { get; set; }
        public string? LicenseNumber { get; set; }
        public bool IsEmailVerified { get; set; }
        public bool IsAutomationAccount { get; set; }

        public static AdminUserItem FromVm(AdminUserVm vm) => new()
        {
            UserId = vm.UserId,
            EmailForLogin = vm.EmailForLogin,
            TelegramId = vm.TelegramId,
            Role = vm.Role,
            IsActive = vm.IsActive,
            CreatedAt = vm.CreatedAt,
            DisplayName = vm.DisplayName,
            PhotoUrl = vm.PhotoUrl,
            Specialty = vm.Specialty,
            LicenseNumber = vm.LicenseNumber,
            IsEmailVerified = vm.IsEmailVerified,
            IsAutomationAccount = vm.IsAutomationAccount
        };
    }

    private sealed class ParentChildLinkFormModel
    {
        public string ParentUserId { get; set; } = string.Empty;
        public string ChildId { get; set; } = string.Empty;
    }

    private sealed class DoctorChildLinkFormModel
    {
        public string DoctorUserId { get; set; } = string.Empty;
        public string ChildId { get; set; } = string.Empty;
    }

    private enum StatusTone
    {
        Info,
        Success,
        Danger
    }
}
