@page "/admin/users"
@attribute [Authorize(Roles = Roles.Admin + "," + Roles.SupportAdmin)]
@implements IDisposable

@using Microsoft.AspNetCore.Authorization
@using SugarGuard.Shared.Constants
@using SugarGuard.Web.ViewModels

@inject SugarGuardApiService Api

<PageTitle>Пользователи — SugarGuard Admin</PageTitle>

<div class="admin-users-page">
    <PageHeader Eyebrow="Admin / Users"
                Title="Пользователи и связи"
                Subtitle="Управление ролями, быстрый поиск по базе и ручное создание связей между родителями, врачами и детьми.">
        <TrailingContent>
            <button class="sg-btn sg-btn-soft"
                    type="button"
                    @onclick="LoadUsersAsync"
                    disabled="@_isRefreshing">
                @(_isRefreshing ? "Обновление..." : "Обновить")
            </button>
        </TrailingContent>
    </PageHeader>

    @if (!string.IsNullOrWhiteSpace(_statusMessage))
    {
        <div class="sg-alert @GetStatusClass()">
            @_statusMessage
        </div>
    }

    @if (_isLoading)
    {
        <section class="sg-panel sg-loading-panel">
            <div class="sg-spinner"></div>
            <p>Загружаем пользователей...</p>
        </section>
    }
    else
    {
        <section class="sg-stats-grid">
            <StatCard Label="Всего пользователей"
                      Value="@_users.Count.ToString()"
                      Subtitle="Лимит загрузки: 500"
                      Status="neutral" />

            <StatCard Label="Активные"
                      Value="@_users.Count(x => x.IsActive).ToString()"
                      Subtitle="Не деактивированы"
                      Status="safe" />

            <StatCard Label="Подтверждённые родители"
                      Value="@_users.Count(IsVerifiedParent).ToString()"
                      Subtitle="Без тестовых аккаунтов"
                      Status="neutral" />

            <StatCard Label="Врачи / админы"
                      Value="@_users.Count(x => IsDoctorLinkRole(x.Role)).ToString()"
                      Subtitle="Доступны для doctor-child"
                      Status="neutral" />
        </section>

        <section class="sg-main-layout">
            <div class="sg-main-column">
                <section class="sg-panel">
                    <SectionHeader Title="Список пользователей"
                                   Description="Фильтрация выполняется на странице, роли обновляются через API.">
                        <TrailingContent>
                            <span class="sg-pill sg-pill-neutral">
                                Показано: @FilteredUsers.Count()
                            </span>
                        </TrailingContent>
                    </SectionHeader>

                    <div class="sg-toolbar">
                        <div class="sg-field">
                            <label class="sg-label" for="users-search">Поиск</label>
                            <input id="users-search"
                                   class="sg-input"
                                   type="search"
                                   value="@_searchTerm"
                                   @oninput="OnSearchChanged"
                                   placeholder="Email, Telegram ID, GUID, роль" />
                        </div>

                        <div class="sg-field sg-field-compact">
                            <label class="sg-label" for="users-role-filter">Роль</label>
                            <select id="users-role-filter"
                                    class="sg-select"
                                    value="@_selectedRoleFilter"
                                    @onchange="OnRoleFilterChanged">
                                <option value="">Все роли</option>
                                @foreach (var role in _assignableRoles)
                                {
                                    <option value="@role">@role</option>
                                }
                            </select>
                        </div>
                    </div>

                    @if (!FilteredUsers.Any())
                    {
                        <div class="sg-empty-state">
                            <div class="sg-empty-icon">∅</div>
                            <h3>Ничего не найдено</h3>
                            <p>Измените строку поиска или снимите фильтр по роли.</p>
                        </div>
                    }
                    else
                    {
                        <div class="sg-users-list">
                            @foreach (var user in FilteredUsers)
                            {
                                <article class="sg-user-row" @key="user.UserId">
                                    <div class="sg-user-main">
                                        <div class="sg-user-identity">
                                            <div class="sg-user-avatar" aria-hidden="true">
                                                @if (!string.IsNullOrWhiteSpace(user.PhotoUrl))
                                                {
                                                    <img src="@user.PhotoUrl" alt="" />
                                                }
                                                else
                                                {
                                                    @GetUserInitials(user)
                                                }
                                            </div>

                                            <div class="sg-user-identity-copy">
                                                <div class="sg-user-title-row">
                                                    <h3>@GetUserTitle(user)</h3>

                                                    <div class="sg-user-badges">
                                                        @if (user.IsAutomationAccount)
                                                        {
                                                            <span class="sg-pill sg-pill-neutral">Тестовый</span>
                                                        }
                                                        <span class="sg-pill @GetRolePillClass(user.Role)">
                                                            @user.Role
                                                        </span>

                                                        <span class="sg-pill @(user.IsActive ? "sg-pill-success" : "sg-pill-danger")">
                                                            @(user.IsActive ? "Активен" : "Неактивен")
                                                        </span>
                                                    </div>
                                                </div>

                                                @if (!string.IsNullOrWhiteSpace(user.Specialty) || !string.IsNullOrWhiteSpace(user.LicenseNumber))
                                                {
                                                    <div class="sg-user-professional">
                                                        @if (!string.IsNullOrWhiteSpace(user.Specialty))
                                                        {
                                                            <span>@user.Specialty</span>
                                                        }
                                                        @if (!string.IsNullOrWhiteSpace(user.LicenseNumber))
                                                        {
                                                            <span>Лицензия: @user.LicenseNumber</span>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        </div>

                                        <div class="sg-user-meta">
                                            <span><strong>ID:</strong> @user.UserId</span>
                                            <span><strong>Telegram:</strong> @(user.TelegramId?.ToString() ?? "—")</span>
                                            <span><strong>Создан:</strong> @FormatUtc(user.CreatedAt)</span>
                                        </div>
                                    </div>

                                    <div class="sg-user-actions">
                                        <div class="sg-field sg-field-grow">
                                            <label class="sg-label" for="@($"role-{user.UserId}")">Новая роль</label>
                                            <select id="@($"role-{user.UserId}")"
                                                    class="sg-select"
                                                    value="@GetDraftRole(user.UserId, user.Role)"
                                                    @onchange="args => OnRoleDraftChanged(user.UserId, args)">
                                                @foreach (var role in _assignableRoles)
                                                {
                                                    <option value="@role">@role</option>
                                                }
                                            </select>
                                        </div>

                                        <button class="sg-btn sg-btn-primary"
                                                type="button"
                                                @onclick="() => UpdateRoleAsync(user)"
                                                disabled="@(!CanSaveRole(user))">
                                            @(_roleSavingUserId == user.UserId ? "Сохраняем..." : "Сохранить роль")
                                        </button>
                                    </div>
                                </article>
                            }
                        </div>
                    }
                </section>
            </div>

            <aside class="sg-side-column">
                <section class="sg-panel">
                    <SectionHeader Title="Связать родителя"
                                   Description="Создаёт запись в ParentChildLinks.">
                        <TrailingContent>
                            <span class="sg-pill sg-pill-neutral">
                                Parent → Child
                            </span>
                        </TrailingContent>
                    </SectionHeader>

                    <div class="sg-form-grid">
                        <div class="sg-field">
                            <label class="sg-label" for="parent-user-select">Родитель</label>
                            <select id="parent-user-select"
                                    class="sg-select"
                                    @bind="_parentLinkForm.ParentUserId">
                                <option value="">Выберите пользователя</option>
                                @foreach (var parent in ParentCandidates)
                                {
                                    <option value="@parent.UserId.ToString()">@GetUserOptionText(parent)</option>
                                }
                            </select>
                        </div>

                        <div class="sg-field">
                            <label class="sg-label" for="parent-child-id">ChildId</label>
                            <input id="parent-child-id"
                                   class="sg-input"
                                   type="text"
                                   @bind="_parentLinkForm.ChildId"
                                   @bind:event="oninput"
                                   placeholder="GUID ребёнка" />
                        </div>

                        <button class="sg-btn sg-btn-primary"
                                type="button"
                                @onclick="CreateParentChildLinkAsync"
                                disabled="@_isParentLinkSubmitting">
                            @(_isParentLinkSubmitting ? "Создаём..." : "Создать связь")
                        </button>
                    </div>
                </section>

                <section class="sg-panel">
                    <SectionHeader Title="Связать врача"
                                   Description="Создаёт запись в DoctorChildLinks.">
                        <TrailingContent>
                            <span class="sg-pill sg-pill-neutral">
                                Doctor → Child
                            </span>
                        </TrailingContent>
                    </SectionHeader>

                    <div class="sg-form-grid">
                        <div class="sg-field">
                            <label class="sg-label" for="doctor-user-select">Врач / админ</label>
                            <select id="doctor-user-select"
                                    class="sg-select"
                                    @bind="_doctorLinkForm.DoctorUserId">
                                <option value="">Выберите пользователя</option>
                                @foreach (var doctor in DoctorCandidates)
                                {
                                    <option value="@doctor.UserId.ToString()">@GetUserOptionText(doctor)</option>
                                }
                            </select>
                        </div>

                        <div class="sg-field">
                            <label class="sg-label" for="doctor-child-id">ChildId</label>
                            <input id="doctor-child-id"
                                   class="sg-input"
                                   type="text"
                                   @bind="_doctorLinkForm.ChildId"
                                   @bind:event="oninput"
                                   placeholder="GUID ребёнка" />
                        </div>

                        <button class="sg-btn sg-btn-primary"
                                type="button"
                                @onclick="CreateDoctorChildLinkAsync"
                                disabled="@_isDoctorLinkSubmitting">
                            @(_isDoctorLinkSubmitting ? "Создаём..." : "Создать связь")
                        </button>
                    </div>
                </section>

                <section class="sg-panel">
                    <SectionHeader Title="Подсказки"
                                   Description="Чтобы избежать конфликтов в админке." />

                    <ul class="sg-hints-list">
                        <li>Для parent-child выбирайте только пользователей с ролью <strong>Parent</strong>.</li>
                        <li>Для doctor-child допустимы роли <strong>Doctor</strong>, <strong>Admin</strong> и <strong>SupportAdmin</strong>.</li>
                        <li>ChildId вводится вручную GUID-значением ребёнка.</li>
                        <li>После смены роли список кандидатов в формах обновляется автоматически.</li>
                    </ul>
                </section>
            </aside>
        </section>
    }
</div>

<style>
    .admin-users-page {
        display: grid;
        gap: 20px;
        color: var(--sg-text, #16213E);
    }

    .sg-panel {
        position: relative;
        overflow: hidden;
        border-radius: 24px;
        border: 1px solid var(--sg-border, rgba(22, 33, 62, 0.10));
        background: var(--sg-surface, rgba(255, 255, 255, 0.84));
        box-shadow: var(--shadow-md, 0 24px 48px rgba(18, 31, 58, 0.11));
        backdrop-filter: blur(24px);
        -webkit-backdrop-filter: blur(24px);
        padding: 24px;
    }

    .admin-users-hero {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 20px;
        background:
            radial-gradient(circle at top left, rgba(86, 208, 191, 0.16), transparent 28%),
            radial-gradient(circle at top right, rgba(109, 174, 255, 0.12), transparent 24%),
            var(--sg-surface, rgba(255, 255, 255, 0.84));
    }

    .hero-copy {
        display: grid;
        gap: 12px;
        max-width: 720px;
    }

    .hero-copy h1 {
        margin: 0;
        font-size: clamp(30px, 4vw, 46px);
        line-height: 1;
        font-family: "Space Grotesk", "Manrope", system-ui, sans-serif;
        letter-spacing: -0.03em;
    }

    .hero-copy p {
        margin: 0;
        color: var(--sg-text-muted, #667694);
        font-size: 15px;
        line-height: 1.65;
        max-width: 64ch;
    }

    .hero-label {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        width: fit-content;
        padding: 8px 12px;
        border-radius: 999px;
        border: 1px solid var(--sg-border, rgba(22, 33, 62, 0.10));
        background: var(--sg-surface-2, rgba(255, 255, 255, 0.95));
        color: var(--sg-text-muted, #667694);
        font-size: 12px;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .hero-label-dot {
        width: 8px;
        height: 8px;
        border-radius: 999px;
        background: linear-gradient(135deg, var(--sg-primary, #1B8E8B), var(--sg-primary-alt, #2678D9));
        box-shadow: 0 0 0 4px rgba(27, 142, 139, 0.12);
    }

    .hero-actions {
        display: flex;
        justify-content: flex-end;
        align-items: flex-start;
        flex-shrink: 0;
    }

    .sg-stats-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 16px;
    }

    .sg-stat-card {
        display: grid;
        gap: 8px;
        padding: 20px;
        border-radius: 22px;
        border: 1px solid var(--sg-border, rgba(22, 33, 62, 0.10));
        background: var(--sg-surface, rgba(255, 255, 255, 0.84));
        box-shadow: var(--shadow-sm, 0 12px 28px rgba(18, 31, 58, 0.07));
    }

    .sg-stat-label {
        color: var(--sg-text-faint, #96A2B8);
        font-size: 12px;
        font-weight: 800;
        letter-spacing: 0.1em;
        text-transform: uppercase;
    }

    .sg-stat-value {
        font-size: clamp(28px, 3vw, 38px);
        line-height: 1;
        font-family: "Space Grotesk", "Manrope", system-ui, sans-serif;
    }

    .sg-stat-hint {
        color: var(--sg-text-muted, #667694);
        font-size: 13px;
    }

    .sg-main-layout {
        display: grid;
        grid-template-columns: minmax(0, 1.6fr) minmax(320px, 0.95fr);
        gap: 20px;
        align-items: start;
    }

    .sg-main-column,
    .sg-side-column {
        display: grid;
        gap: 20px;
    }

    .sg-section-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 12px;
        margin-bottom: 18px;
    }

    .sg-section-header h2 {
        margin: 0 0 6px 0;
        font-size: 24px;
        line-height: 1.1;
        font-family: "Space Grotesk", "Manrope", system-ui, sans-serif;
    }

    .sg-section-header p {
        margin: 0;
        color: var(--sg-text-muted, #667694);
        font-size: 14px;
        line-height: 1.6;
    }

    .sg-toolbar {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 220px;
        gap: 14px;
        margin-bottom: 18px;
    }

    .sg-field {
        display: grid;
        gap: 8px;
    }

    .sg-field-compact {
        min-width: 0;
    }

    .sg-field-grow {
        min-width: 220px;
        flex: 1 1 220px;
    }

    .sg-label {
        color: var(--sg-text-faint, #96A2B8);
        font-size: 12px;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .sg-input,
    .sg-select {
        width: 100%;
        min-height: 48px;
        padding: 12px 14px;
        border-radius: 16px;
        border: 1px solid var(--sg-border, rgba(22, 33, 62, 0.10));
        background: var(--sg-surface-2, rgba(255, 255, 255, 0.95));
        color: var(--sg-text, #16213E);
        font: inherit;
        outline: none;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.45);
        transition: border-color 0.18s ease, box-shadow 0.18s ease, transform 0.18s ease;
    }

    .sg-input:focus,
    .sg-select:focus {
        border-color: rgba(27, 142, 139, 0.45);
        box-shadow: 0 0 0 4px rgba(27, 142, 139, 0.12);
    }

    .sg-users-list {
        display: grid;
        gap: 14px;
    }

    .sg-user-row {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 18px;
        align-items: center;
        padding: 18px;
        border-radius: 20px;
        border: 1px solid var(--sg-border, rgba(22, 33, 62, 0.10));
        background: var(--sg-surface-2, rgba(255, 255, 255, 0.95));
        box-shadow: var(--shadow-sm, 0 12px 28px rgba(18, 31, 58, 0.07));
    }

    .sg-user-main {
        display: grid;
        gap: 10px;
        min-width: 0;
    }

    .sg-user-title-row {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
    }

    .sg-user-title-row h3 {
        margin: 0;
        font-size: 17px;
        line-height: 1.3;
        word-break: break-word;
    }

    .sg-user-badges {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .sg-user-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 10px 16px;
        color: var(--sg-text-muted, #667694);
        font-size: 13px;
        line-height: 1.5;
    }

    .sg-user-identity {
        display: flex;
        align-items: flex-start;
        gap: 14px;
        min-width: 0;
    }

    .sg-user-avatar {
        width: 48px;
        height: 48px;
        flex: 0 0 48px;
        display: grid;
        place-items: center;
        overflow: hidden;
        border-radius: 14px;
        color: #fff;
        background: linear-gradient(135deg, var(--sg-primary, #1B8E8B), var(--sg-primary-alt, #2678D9));
        font-size: 14px;
        font-weight: 900;
    }

    .sg-user-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .sg-user-identity-copy {
        min-width: 0;
        flex: 1;
    }

    .sg-user-professional {
        display: flex;
        flex-wrap: wrap;
        gap: 6px 14px;
        margin-top: 6px;
        color: var(--sg-text-muted, #667694);
        font-size: 13px;
    }

    .sg-user-actions {
        display: flex;
        align-items: end;
        gap: 12px;
        flex-wrap: wrap;
        min-width: min(100%, 360px);
        justify-content: flex-end;
    }

    .sg-btn {
        min-height: 48px;
        padding: 12px 18px;
        border: 0;
        border-radius: 999px;
        font: inherit;
        font-weight: 800;
        cursor: pointer;
        transition: transform 0.18s ease, opacity 0.18s ease, box-shadow 0.18s ease;
        white-space: nowrap;
    }

    .sg-btn:hover:not(:disabled) {
        transform: translateY(-1px);
    }

    .sg-btn:disabled {
        cursor: default;
        opacity: 0.65;
        transform: none;
    }

    .sg-btn-primary {
        color: #ffffff;
        background: linear-gradient(135deg, var(--sg-primary, #1B8E8B), var(--sg-primary-alt, #2678D9));
        box-shadow: var(--shadow-sm, 0 12px 28px rgba(18, 31, 58, 0.07));
    }

    .sg-btn-soft {
        color: var(--sg-primary, #1B8E8B);
        background: rgba(27, 142, 139, 0.12);
        border: 1px solid var(--sg-border, rgba(22, 33, 62, 0.10));
    }

    .sg-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 32px;
        padding: 6px 12px;
        border-radius: 999px;
        border: 1px solid transparent;
        font-size: 12px;
        font-weight: 800;
        letter-spacing: 0.01em;
        white-space: nowrap;
    }

    .sg-pill-neutral {
        color: var(--sg-text-muted, #667694);
        background: var(--sg-surface-2, rgba(255, 255, 255, 0.95));
        border-color: var(--sg-border, rgba(22, 33, 62, 0.10));
    }

    .sg-pill-success {
        color: var(--sg-success, #37A563);
        background: rgba(55, 165, 99, 0.14);
    }

    .sg-pill-danger {
        color: var(--sg-danger, #DB5967);
        background: rgba(219, 89, 103, 0.14);
    }

    .sg-pill-parent {
        color: var(--sg-primary, #1B8E8B);
        background: rgba(27, 142, 139, 0.12);
    }

    .sg-pill-doctor {
        color: var(--sg-primary-alt, #2678D9);
        background: rgba(38, 120, 217, 0.12);
    }

    .sg-pill-admin {
        color: #7D4BDB;
        background: rgba(125, 75, 219, 0.12);
    }

    .sg-pill-support {
        color: #D97706;
        background: rgba(217, 119, 6, 0.12);
    }

    .sg-form-grid {
        display: grid;
        gap: 14px;
    }

    .sg-hints-list {
        margin: 0;
        padding-left: 18px;
        display: grid;
        gap: 10px;
        color: var(--sg-text-muted, #667694);
        line-height: 1.6;
        font-size: 14px;
    }

    .sg-alert {
        padding: 14px 16px;
        border-radius: 18px;
        border: 1px solid transparent;
        font-size: 14px;
        font-weight: 700;
        line-height: 1.5;
        box-shadow: var(--shadow-sm, 0 12px 28px rgba(18, 31, 58, 0.07));
    }

    .sg-alert-info {
        color: var(--sg-primary-alt, #2678D9);
        background: rgba(38, 120, 217, 0.12);
        border-color: rgba(38, 120, 217, 0.18);
    }

    .sg-alert-success {
        color: var(--sg-success, #37A563);
        background: rgba(55, 165, 99, 0.14);
        border-color: rgba(55, 165, 99, 0.20);
    }

    .sg-alert-danger {
        color: var(--sg-danger, #DB5967);
        background: rgba(219, 89, 103, 0.14);
        border-color: rgba(219, 89, 103, 0.20);
    }

    .sg-loading-panel {
        display: grid;
        place-items: center;
        gap: 12px;
        min-height: 180px;
        color: var(--sg-text-muted, #667694);
    }

    .sg-spinner {
        width: 34px;
        height: 34px;
        border-radius: 999px;
        border: 3px solid rgba(38, 120, 217, 0.14);
        border-top-color: var(--sg-primary-alt, #2678D9);
        animation: sg-spin 0.9s linear infinite;
    }

    .sg-empty-state {
        display: grid;
        place-items: center;
        text-align: center;
        gap: 10px;
        min-height: 220px;
        border-radius: 20px;
        border: 1px dashed var(--sg-border, rgba(22, 33, 62, 0.10));
        background: rgba(255, 255, 255, 0.35);
        color: var(--sg-text-muted, #667694);
    }

    .sg-empty-state h3 {
        margin: 0;
        color: var(--sg-text, #16213E);
        font-size: 18px;
    }

    .sg-empty-state p {
        margin: 0;
        max-width: 42ch;
    }

    .sg-empty-icon {
        width: 52px;
        height: 52px;
