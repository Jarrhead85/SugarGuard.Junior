@code {
    // Перечисление шагов 
    /// <summary>
    /// Три визуальных шага страницы восстановления пароля
    /// </summary>
    private enum ForgotStep
    {
        RequestEmail,
        EnterCode,
        Success
    }

    // Модель шага 1 
    private sealed class EmailModel
    {
        [Required(ErrorMessage = "Введите email")]
        [EmailAddress(ErrorMessage = "Некорректный формат email")]
        [MaxLength(256, ErrorMessage = "Email не должен превышать 256 символов")]
        public string Email { get; set; } = string.Empty;
    }

    // Модель шага 2 

    private sealed class ResetModel
    {
        [Required(ErrorMessage = "Введите код из письма")]
        [StringLength(9, MinimumLength = 8)]
        [ConnectionCode]
        public string Code { get; set; } = string.Empty;

        [Required(ErrorMessage = "Введите новый пароль")]
        [MinLength(8, ErrorMessage = "Пароль должен содержать не менее 8 символов")]
        [MaxLength(128, ErrorMessage = "Пароль не должен превышать 128 символов")]
        public string NewPassword { get; set; } = string.Empty;

        [Required(ErrorMessage = "Повторите новый пароль")]
        [Compare(nameof(NewPassword), ErrorMessage = "Пароли не совпадают")]
        public string ConfirmPassword { get; set; } = string.Empty;
    }

    // Состояние
    private readonly EmailModel _emailModel = new();
    private readonly ResetModel _resetModel = new();

    private ForgotStep _step = ForgotStep.RequestEmail;
    private string? _errorMessage;
    private bool _isLoading;
    private bool _showPassword;

    /// <summary>
    /// Кулдаун повторной отправки кода (секунды)
    /// </summary>
    private int _resendCooldown;
    private System.Threading.Timer? _cooldownTimer;

    // Вычисляемые свойства: индикатор силы пароля 
    /// <summary>
    /// Вычисляет мощность пароля по длине и наличию категорий символов
    /// </summary>
    private int PasswordStrength
    {
        get
        {
            var pw = _resetModel.NewPassword;
            if (string.IsNullOrEmpty(pw)) return 0;

            var score = 0;
            if (pw.Length >= 8) score++;
            if (pw.Length >= 12) score++;
            if (pw.Any(char.IsDigit) && pw.Any(char.IsLetter)) score++;
            if (pw.Any(c => !char.IsLetterOrDigit(c))) score++;

            return score;
        }
    }

    /// <summary>
    /// CSS-класс для полоски силы пароля
    /// </summary>
    private string PasswordStrengthClass => PasswordStrength switch
    {
        0 or 1 => "weak",
        2 => "fair",
        3 => "good",
        _ => "strong"
    };

    /// <summary>
    /// Текстовая метка силы пароля
    /// </summary>
    private string PasswordStrengthLabel => PasswordStrength switch
    {
        0 or 1 => "Слабый",
        2 => "Средний",
        3 => "Хороший",
        _ => "Надёжный"
    };

    /// <summary>
    /// Ширина полоски в процентах 
    /// </summary>
    private int PasswordStrengthPercent => PasswordStrength switch
    {
        0 or 1 => 25,
        2 => 50,
        3 => 75,
        _ => 100
    };

    private static bool IsVerificationCodeReady(string code)
        => ConnectionCodeFormat.IsValid(code, normalize: true);

    //  запрос кода 
    /// <summary>
    /// Отправляет запрос на генерацию кода сброса пароля для указанного email
    /// </summary>
    private async Task HandleRequestEmailAsync()
    {
        _errorMessage = null;
        _isLoading = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            var sent = await AuthApi.SendPasswordResetCodeAsync(
                _emailModel.Email.Trim().ToLowerInvariant());

            if (!sent)
            {
                _errorMessage = "Не удалось отправить код. Проверьте email или попробуйте позже.";
                return;
            }

            _resetModel.Code = string.Empty;
            _resetModel.NewPassword = string.Empty;
            _resetModel.ConfirmPassword = string.Empty;
            _step = ForgotStep.EnterCode;
            StartResendCooldown(60);
        }
        catch (Exception)
        {
            _errorMessage = "Ошибка соединения. Проверьте подключение к интернету и попробуйте ещё раз.";
        }
        finally
        {
            _isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    // сброс пароля
    /// <summary>
    /// Проверяет код и устанавливает новый пароль через API
    /// </summary>
    private async Task HandleResetPasswordAsync()
    {
        _errorMessage = null;
        _isLoading = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            var result = await AuthApi.ResetPasswordAsync(
                _emailModel.Email.Trim().ToLowerInvariant(),
                _resetModel.Code.Trim(),
                _resetModel.NewPassword);

            if (!result.IsSuccess)
            {
                if (result.Message?.Contains("expired", StringComparison.OrdinalIgnoreCase) == true
                    || result.Message?.Contains("истёк", StringComparison.OrdinalIgnoreCase) == true)
                {
                    _errorMessage = "Код устарел. Запросите новый код с помощью кнопки ниже.";
                    StopResendCooldown();
                    _resendCooldown = 0;
                    return;
                }

                _errorMessage = result.Message ?? "Неверный код. Проверьте и попробуйте ещё раз.";
                return;
            }

            StopResendCooldown();
            _step = ForgotStep.Success;
        }
        catch (Exception)
        {
            _errorMessage = "Ошибка соединения. Попробуйте ещё раз.";
        }
        finally
        {
            _isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    // Повторная отправка кода
    /// <summary>
    /// Повторно отправляет код сброса пароля
    /// </summary>
    private async Task HandleResendCodeAsync()
    {
        _errorMessage = null;
        _isLoading = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            var sent = await AuthApi.SendPasswordResetCodeAsync(
                _emailModel.Email.Trim().ToLowerInvariant());

            if (!sent)
            {
                _errorMessage = "Не удалось отправить код. Попробуйте позже.";
                return;
            }

            StartResendCooldown(60);
        }
        catch (Exception)
        {
            _errorMessage = "Ошибка соединения. Попробуйте ещё раз.";
        }
        finally
        {
            _isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    // Навигация 
    private void BackToEmail()
    {
        StopResendCooldown();
        _errorMessage = null;
        _step = ForgotStep.RequestEmail;
    }

    private void GoToLogin()
        => Navigation.NavigateTo("/login", replace: true);

    private void TogglePasswordVisibility()
        => _showPassword = !_showPassword;

    // Кулдаун
    /// <summary>
    /// Запускает обратный отсчёт 
    /// </summary>
    private void StartResendCooldown(int seconds)
    {
        _resendCooldown = seconds;
        StopResendCooldown();

        _cooldownTimer = new System.Threading.Timer(_ =>
        {
            if (_resendCooldown > 0)
            {
                _resendCooldown--;
                InvokeAsync(StateHasChanged);
            }
            else
            {
                StopResendCooldown();
            }
        }, null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
    }

    private void StopResendCooldown()
    {
        _cooldownTimer?.Dispose();
        _cooldownTimer = null;
    }

    // Освобождение ресурсов 
    /// <inheritdoc/>
    public void Dispose()
        => StopResendCooldown();
}
