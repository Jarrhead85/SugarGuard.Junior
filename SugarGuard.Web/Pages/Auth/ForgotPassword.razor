@* Страница восстановления пароля *@

@page "/forgot-password"
@rendermode InteractiveServer
@layout SugarGuard.Web.Components.Layout.EmptyLayout

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization
@using SugarGuard.Shared.Constants
@using SugarGuard.Shared.Validation
@using SugarGuard.Web.Services

@attribute [AllowAnonymous]

@inject NavigationManager Navigation
@inject IAuthApiClient AuthApi

@implements IDisposable

<PageTitle>Восстановление пароля — SugarGuard</PageTitle>

<div class="forgot-shell" role="main">

    @* Логотип *@
    <div class="login-logo" aria-label="SugarGuard">
        <div class="login-logo__icon" aria-hidden="true">
            <img src="/images/sugarguard-icon.png" alt="" />
        </div>
        <div class="login-logo__text">
            <strong>SugarGuard</strong>
            <span>Управление диабетом</span>
        </div>
    </div>

    @* Карточка  *@
    <div class="login-card" role="region" aria-label="Восстановление пароля">

        @* Ввод email *@
        @if (_step == ForgotStep.RequestEmail)
        {
            <div class="forgot-icon-wrap" aria-hidden="true">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="1.6">
                    <rect x="3" y="11" width="18" height="11" rx="2" />
                    <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                </svg>
            </div>

            <h1 class="login-card__title">Забыли пароль?</h1>
            <p class="login-card__subtitle">
                Введите email, который вы использовали при регистрации.
                Мы отправим код формата ABCD-1234 для сброса пароля.
            </p>

            @if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <div class="state-banner state-banner--error" role="alert" aria-live="assertive">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <circle cx="12" cy="12" r="10" />
                        <line x1="12" y1="8" x2="12" y2="12" />
                        <line x1="12" y1="16" x2="12.01" y2="16" />
                    </svg>
                    <span>@_errorMessage</span>
                </div>
            }

            <EditForm Model="_emailModel" FormName="forgot-password-email" novalidate>
                <DataAnnotationsValidator />

                <div class="input-group">
                    <label class="input-label" for="forgot-email">Email</label>
                    <div class="input-wrap">
                        <span class="input-icon" aria-hidden="true">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="2">
                                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                                <polyline points="22,6 12,13 2,6" />
                            </svg>
                        </span>
                        <input id="forgot-email"
                               @bind="_emailModel.Email"
                               @bind:event="oninput"
                               class="input-field input-field--icon"
                               type="email"
                               inputmode="email"
                               autocomplete="email"
                               placeholder="example@mail.ru"
                               disabled="@_isLoading" />
                    </div>
                    <ValidationMessage For="@(() => _emailModel.Email)"
                                       class="input-helper input-helper--error" />
                </div>

                <button type="button"
                        class="btn btn--primary btn--full"
                        @onclick="HandleRequestEmailAsync"
                        disabled="@_isLoading"
                        aria-busy="@_isLoading">
                    @if (_isLoading)
                    {
                        <span class="btn__spinner" aria-hidden="true"></span>
                        <span>Отправляем…</span>
                    }
                    else
                    {
                        <span>Отправить код</span>
                    }
                </button>
            </EditForm>

            <div class="forgot-back">
                <a href="/login" class="link link--muted">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                        <polyline points="15 18 9 12 15 6" />
                    </svg>
                    Вернуться ко входу
                </a>
            </div>
        }

        @* Ввод кода и нового пароля *@
        @if (_step == ForgotStep.EnterCode)
        {
            <div class="forgot-icon-wrap forgot-icon-wrap--teal" aria-hidden="true">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="1.6">
                    <rect x="2" y="4" width="20" height="16" rx="2" />
                    <path d="m2 7 10 7 10-7" />
                </svg>
            </div>

            <h1 class="login-card__title">Введите код</h1>
            <p class="login-card__subtitle">
                Отправили код на
                <strong class="verify-email-highlight">@_emailModel.Email</strong>.<br />
                Также задайте новый пароль.
            </p>

            @if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <div class="state-banner state-banner--error" role="alert" aria-live="assertive">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <circle cx="12" cy="12" r="10" />
                        <line x1="12" y1="8" x2="12" y2="12" />
                        <line x1="12" y1="16" x2="12.01" y2="16" />
                    </svg>
                    <span>@_errorMessage</span>
                </div>
            }

            <EditForm Model="_resetModel" FormName="forgot-password-reset" novalidate>
                <DataAnnotationsValidator />

                @* Поле кода *@
                <div class="input-group">
                    <label class="input-label" for="reset-code">Код подтверждения</label>
                    <div class="input-wrap">
                        <input id="reset-code"
                               @bind="_resetModel.Code"
                               @bind:event="oninput"
                               class="input-field input-field--code"
                               type="text"
                               inputmode="text"
                               autocomplete="one-time-code"
                               placeholder="ABCD-1234"
                               maxlength="9"
                               disabled="@_isLoading" />
                    </div>
                    <ValidationMessage For="@(() => _resetModel.Code)"
                                       class="input-helper input-helper--error" />
                    <span class="input-helper">Код действителен 15 минут</span>
                </div>

                @* Новый пароль *@
                <div class="input-group">
                    <label class="input-label" for="reset-password">Новый пароль</label>
                    <div class="input-wrap">
                        <input id="reset-password"
                               @bind="_resetModel.NewPassword"
                               @bind:event="oninput"
                               class="input-field input-field--icon-right"
                               type="@(_showPassword ? "text" : "password")"
                               autocomplete="new-password"
                               placeholder="Минимум 8 символов"
                               disabled="@_isLoading" />
                        <button type="button"
                                class="input-icon-btn"
                                @onclick="TogglePasswordVisibility"
                                tabindex="-1"
                                aria-label="@(_showPassword ? "Скрыть пароль" : "Показать пароль")">
                            @if (_showPassword)
                            {
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                     stroke="currentColor" stroke-width="2" aria-hidden="true">
                                    <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94" />
                                    <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19" />
                                    <line x1="1" y1="1" x2="23" y2="23" />
                                </svg>
                            }
                            else
                            {
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                     stroke="currentColor" stroke-width="2" aria-hidden="true">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                    <circle cx="12" cy="12" r="3" />
                                </svg>
                            }
                        </button>
                    </div>
                    <ValidationMessage For="@(() => _resetModel.NewPassword)"
                                       class="input-helper input-helper--error" />
                    @* Полоска силы пароля *@
                    @if (!string.IsNullOrEmpty(_resetModel.NewPassword))
                    {
                        <div class="password-strength" role="status"
                             aria-label="Надёжность пароля: @PasswordStrengthLabel">
                            <div class="password-strength__bar">
                                <div class="password-strength__fill password-strength__fill--@PasswordStrengthClass"
                                     style="width: @(PasswordStrengthPercent)%">
                                </div>
                            </div>
                            <span class="password-strength__label password-strength__label--@PasswordStrengthClass">
                                @PasswordStrengthLabel
                            </span>
                        </div>
                    }
                </div>

                @* Подтверждение пароля *@
                <div class="input-group">
                    <label class="input-label" for="reset-confirm">Повторите пароль</label>
                    <div class="input-wrap">
                        <input id="reset-confirm"
                               @bind="_resetModel.ConfirmPassword"
                               @bind:event="oninput"
                               class="input-field input-field--icon-right"
                               type="@(_showPassword ? "text" : "password")"
                               autocomplete="new-password"
                               placeholder="Повторите новый пароль"
                               disabled="@_isLoading" />
                    </div>
                    <ValidationMessage For="@(() => _resetModel.ConfirmPassword)"
                                       class="input-helper input-helper--error" />
                    @if (!string.IsNullOrWhiteSpace(_resetModel.ConfirmPassword)
                                    && _resetModel.ConfirmPassword == _resetModel.NewPassword)
                    {
                        <span class="input-helper input-helper--success">Пароли совпадают</span>
                    }
                </div>

                <button type="button"
                        class="btn btn--primary btn--full"
                        @onclick="HandleResetPasswordAsync"
                        disabled="@(_isLoading || !IsVerificationCodeReady(_resetModel.Code))"
                        aria-busy="@_isLoading">
                    @if (_isLoading)
                    {
                        <span class="btn__spinner" aria-hidden="true"></span>
                        <span>Сохраняем…</span>
                    }
                    else
                    {
                        <span>Сменить пароль</span>
                    }
                </button>
            </EditForm>

            @* Повторная отправка кода *@
            <div class="verify-resend">
                <span class="link--muted-text">Не получили письмо?</span>
                @if (_resendCooldown > 0)
                {
                    <span class="link--muted-text">
                        Отправить повторно через <strong>@_resendCooldown</strong> с.
                    </span>
                }
                else
                {
                    <button type="button"
                            class="btn-link"
                            @onclick="HandleResendCodeAsync"
                            disabled="@_isLoading">
                        Отправить повторно
                    </button>
                }
            </div>

            <div class="forgot-back">
                <button type="button"
                        class="link link--muted"
                        @onclick="BackToEmail">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                        <polyline points="15 18 9 12 15 6" />
                    </svg>
                    Изменить email
                </button>
            </div>
        }

        @* Успех *@
        @if (_step == ForgotStep.Success)
        {
            <div class="success-state" role="status" aria-live="polite">
                <div class="success-state__icon" aria-hidden="true">
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2">
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
                        <polyline points="22 4 12 14.01 9 11.01" />
                    </svg>
                </div>
                <h1 class="login-card__title">Пароль изменён!</h1>
                <p class="login-card__subtitle">
                    Ваш пароль успешно обновлён. Теперь вы можете войти с новым паролем.
                </p>
                <button type="button"
                        class="btn btn--primary btn--full"
                        @onclick="GoToLogin">
                    Войти в систему
                </button>
            </div>
        }

    </div>

    @* Подвал *@
    <footer class="login-footer" aria-label="Подвал">
        <span>© 2026 SugarGuard</span>
        <span>·</span>
        <a href="/privacy" class="link link--faint" target="_blank" rel="noopener noreferrer">
            Политика конфиденциальности
        </a>
    </footer>

</div>

<style>
    /* Оболочка */
    .forgot-shell {
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: var(--space-24) var(--space-16);
        background:
            radial-gradient(circle at 12% 18%, rgba(86, 208, 191, .20) 0, transparent 32%),
            radial-gradient(circle at 88% 14%, rgba(209, 153, 0, .10) 0, transparent 26%),
            radial-gradient(circle at 50% 100%, rgba(27, 142, 139, .14) 0, transparent 28%),
            var(--color-bg);
        gap: var(--space-8);
        overflow-y: auto;
    }

    /* Логотип */
    .login-logo {
        display: flex;
        align-items: center;
        gap: var(--space-4);
        margin-bottom: var(--space-4);
    }

    .login-logo__icon {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        background: var(--color-surface);
        display: grid;
        place-items: center;
        box-shadow: 0 10px 24px rgba(27,142,139,.18);
        flex-shrink: 0;
        overflow: hidden;
    }

    .login-logo__icon img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .login-logo__text strong {
        display: block;
        font-family: var(--font-display);
        font-size: 1.15rem;
        font-weight: 700;
        color: var(--color-text);
        letter-spacing: -.01em;
    }

    .login-logo__text span {
        display: block;
        font-size: 12px;
        color: var(--color-text-muted);
    }

    /* Карточка */
    .login-card {
        width: 100%;
        max-width: 440px;
        max-height: calc(100dvh - 128px);
        overflow-y: auto;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        padding: var(--space-32);
        box-shadow: var(--shadow-card);
        display: flex;
        flex-direction: column;
        gap: var(--space-20);
    }

    .login-card__title {
        font-family: var(--font-display);
        font-size: clamp(1.4rem, 3vw, 1.85rem);
        font-weight: 700;
        color: var(--color-text);
        margin: 0;
        line-height: 1.15;
    }

    .login-card__subtitle {
        font-size: 14px;
        color: var(--color-text-muted);
        margin: calc(-1 * var(--space-12)) 0 0;
        line-height: 1.55;
    }

    /* Иконка-заголовок */
    .forgot-icon-wrap {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background: rgba(219, 89, 103, .09);
        border: 2px solid rgba(219, 89, 103, .18);
        display: grid;
        place-items: center;
        color: var(--color-glucose-danger, #DB5967);
        align-self: center;
    }

    .forgot-icon-wrap--teal {
        background: rgba(27, 142, 139, .09);
        border-color: rgba(27, 142, 139, .18);
        color: var(--color-primary);
    }

    /* Баннер ошибки */
    .state-banner {
        display: flex;
        align-items: center;
        gap: var(--space-8);
        padding: var(--space-12) var(--space-16);
        border-radius: var(--radius-sm);
        font-size: 13px;
        font-weight: 500;
        border: 1px solid transparent;
    }

    .state-banner--error {
        background: rgba(219, 89, 103, .10);
        border-color: rgba(219, 89, 103, .22);
        color: var(--color-glucose-danger, #DB5967);
    }

    .state-banner svg {
        flex-shrink: 0;
    }

    /* Поля ввода */
    .input-group {
        display: flex;
        flex-direction: column;
        gap: var(--space-4);
    }

    .input-label {
        font-size: 13px;
        font-weight: 600;
        color: var(--color-text-muted);
        display: block;
    }

    .input-wrap {
        position: relative;
    }

    .input-field {
        width: 100%;
        min-height: 48px;
        padding: 12px 16px;
        background: var(--color-surface-2, rgba(255,255,255,.95));
        border: 1.5px solid var(--color-input-border, rgba(22,33,62,0.15));
        border-radius: var(--radius-sm);
        font-family: var(--font-body);
        font-size: 15px;
        color: var(--color-text);
        transition: border-color var(--transition), box-shadow var(--transition);
        outline: none;
        box-sizing: border-box;
    }

        .input-field::placeholder {
            color: var(--color-text-faint);
        }

        .input-field:focus {
            border-color: var(--color-input-border-focus);
            box-shadow: 0 0 0 3px var(--color-input-shadow-focus);
        }

        .input-field:disabled {
            opacity: .55;
            cursor: not-allowed;
        }

    /* Поле с иконкой слева */
    .input-field--icon {
        padding-left: 42px;
    }

    /* Поле с кнопкой справа */
    .input-field--icon-right {
        padding-right: 42px;
    }

    /* Крупный код */
    .input-field--code {
        font-size: clamp(18px, 5.5vw, 28px);
        font-weight: 700;
        letter-spacing: clamp(.14em, 2.5vw, .45em);
        text-align: center;
        padding: 14px clamp(10px, 3vw, 16px);
        text-transform: uppercase;
    }

    /* Иконка внутри поля (слева) */
    .input-icon {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--color-text-faint);
        pointer-events: none;
        display: flex;
        align-items: center;
    }

    /* Кнопка «показать/скрыть пароль» (справа) */
    .input-icon-btn {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        color: var(--color-text-faint);
        cursor: pointer;
        padding: 4px;
        display: flex;
        align-items: center;
        border-radius: var(--radius-sm);
        transition: color var(--transition);
    }

        .input-icon-btn:hover {
            color: var(--color-text-muted);
        }

        .input-icon-btn:focus-visible {
            outline: 2px solid var(--color-primary);
            outline-offset: 2px;
        }

    .input-helper {
        font-size: 12px;
        color: var(--color-text-faint);
        margin: 0;
    }

    .input-helper--error {
        font-size: 12px;
        color: var(--color-glucose-danger, #DB5967);
        margin: 0;
    }

    .input-helper--success {
        font-size: 12px;
        color: var(--color-primary);
        margin: 0;
    }

    /* Индикатор силы пароля */
    .password-strength {
        display: flex;
        align-items: center;
        gap: var(--space-8);
        margin-top: var(--space-2);
    }

    .password-strength__bar {
        flex: 1;
        height: 4px;
        background: var(--color-surface-offset, #f3f0ec);
        border-radius: var(--radius-full);
        overflow: hidden;
    }

    .password-strength__fill {
        height: 100%;
        border-radius: var(--radius-full);
        transition: width .35s ease, background .35s ease;
    }

    .password-strength__fill--weak {
        background: var(--color-glucose-danger, #DB5967);
    }

    .password-strength__fill--fair {
        background: var(--color-gold, #d19900);
    }

    .password-strength__fill--good {
        background: var(--color-primary);
    }

    .password-strength__fill--strong {
        background: var(--color-success, #437a22);
    }

    .password-strength__label {
        font-size: 12px;
        font-weight: 600;
        white-space: nowrap;
    }

    .password-strength__label--weak {
        color: var(--color-glucose-danger, #DB5967);
    }

    .password-strength__label--fair {
        color: var(--color-gold, #d19900);
    }

    .password-strength__label--good {
        color: var(--color-primary);
    }

    .password-strength__label--strong {
        color: var(--color-success, #437a22);
    }

    /* Email-выделение */
    .verify-email-highlight {
        display: inline-block;
        margin-top: var(--space-2);
        color: var(--color-text);
        font-size: 13px;
        background: var(--color-surface-offset, #f3f0ec);
        padding: 2px 8px;
        border-radius: var(--radius-full);
        font-family: monospace;
    }

    /* Кнопки */
    .btn {
        min-height: 44px;
        border-radius: var(--radius-md);
        padding: 10px 20px;
        font-family: var(--font-body);
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        border: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: var(--space-8);
        transition: all var(--transition);
    }

    .btn--primary {
        background: var(--color-primary);
        color: #fff;
    }

        .btn--primary:hover:not(:disabled) {
            background: var(--color-primary-hover);
            transform: translateY(-1px);
            box-shadow: 0 8px 20px rgba(27,142,139,.28);
        }

        .btn--primary:active:not(:disabled) {
            transform: translateY(0);
            box-shadow: none;
        }

        .btn--primary:disabled {
            opacity: .6;
            cursor: not-allowed;
        }

    .btn--full {
        width: 100%;
    }

    .btn__spinner {
        width: 16px;
        height: 16px;
        border: 2px solid rgba(255,255,255,.35);
        border-top-color: #fff;
        border-radius: 50%;
        animation: btn-spin .7s linear infinite;
        flex-shrink: 0;
    }

    @@keyframes btn-spin {
        to {
            transform: rotate(360deg);
        }
    }

    .btn-link {
        background: none;
        border: none;
        cursor: pointer;
        font-size: 13px;
        color: var(--color-primary);
        font-weight: 600;
        padding: 0;
        transition: color var(--transition);
    }

        .btn-link:hover {
            color: var(--color-primary-hover);
        }

        .btn-link:disabled {
            opacity: .5;
            cursor: not-allowed;
        }

    /* Повторная отправка */
    .verify-resend {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: var(--space-4);
        flex-wrap: wrap;
        margin-top: calc(-1 * var(--space-8));
    }

    .link--muted-text {
        font-size: 13px;
        color: var(--color-text-muted);
    }

    /* Назад */
    .forgot-back {
        display: flex;
        justify-content: center;
        margin-top: calc(-1 * var(--space-8));
    }

    .link--muted {
        font-size: 13px;
        color: var(--color-text-muted);
        text-decoration: none;
        background: none;
        border: none;
        cursor: pointer;
        font-family: var(--font-body);
        display: inline-flex;
        align-items: center;
        gap: var(--space-4);
        transition: color var(--transition);
    }

        .link--muted:hover {
            color: var(--color-text);
