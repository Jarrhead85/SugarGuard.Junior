@page "/auth/reset-password"
@using Microsoft.AspNetCore.Components.Authorization
@using SugarGuard.Shared.Constants
@using SugarGuard.Web.Services
@using System.ComponentModel.DataAnnotations
@attribute [AllowAnonymous]
@inject IAuthApiClient AuthApiClient
@inject NavigationManager Navigation

<PageTitle>Новый пароль — SugarGuard</PageTitle>

<div class="auth-page">
    <div class="auth-card">

        <!-- Логотип -->
        <div class="auth-logo" aria-label="SugarGuard">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" width="28" height="28" aria-hidden="true">
                <path d="M12 3c3.1 0 5.5 2.4 5.5 5.6 0 4.5-5.5 12.4-5.5 12.4S6.5 13.1 6.5 8.6C6.5 5.4 8.9 3 12 3Z" />
                <path d="M9 9.5c1.2-1.7 4.8-1.7 6 0" />
            </svg>
        </div>

        @if (_step == Step.Form)
        {
            <!-- Форма нового пароля -->
            <div class="auth-header">
                <h1 class="auth-title">Новый пароль</h1>
                <p class="auth-subtitle">Придумайте надёжный пароль для вашего аккаунта</p>
            </div>

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="auth-alert auth-alert--error" role="alert" aria-live="polite">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" aria-hidden="true">
                        <circle cx="12" cy="12" r="10" />
                        <path d="M12 8v4M12 16h.01" />
                    </svg>
                    <span>@_errorMessage</span>
                </div>
            }

            <EditForm Model="_model" OnValidSubmit="HandleSubmitAsync" novalidate>
                <DataAnnotationsValidator />

                <!-- Email -->
                <div class="form-group">
                    <label class="form-label" for="rp-email">Email</label>
                    <div class="input-wrapper">
                        <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18" aria-hidden="true">
                            <rect x="2" y="4" width="20" height="16" rx="2" />
                            <path d="m2 7 10 7 10-7" />
                        </svg>
                        <input id="rp-email"
                               type="email"
                               class="form-input"
                               value="@_email"
                               readonly
                               aria-label="Email адрес"
                               autocomplete="email" />
                    </div>
                </div>

                <!-- Новый пароль -->
                <div class="form-group">
                    <label class="form-label" for="rp-password">Новый пароль</label>
                    <div class="input-wrapper">
                        <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18" aria-hidden="true">
                            <rect x="3" y="11" width="18" height="11" rx="2" />
                            <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                        </svg>
                        <InputText id="rp-password"
                                   type="@(_showPassword ? "text" : "password")"
                                   class="form-input form-input--padded-right"
                                   @bind-Value="_model.NewPassword"
                                   placeholder="Минимум 8 символов"
                                   autocomplete="new-password"
                                   aria-required="true"
                                   aria-describedby="rp-password-strength" />
                        <button type="button"
                                class="input-toggle"
                                @onclick="TogglePasswordVisibility"
                                aria-label="@(_showPassword ? "Скрыть пароль" : "Показать пароль")">
                            @if (_showPassword)
                            {
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18" aria-hidden="true">
                                    <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94" />
                                    <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19" />
                                    <line x1="1" y1="1" x2="23" y2="23" />
                                </svg>
                            }
                            else
                            {
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18" aria-hidden="true">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                    <circle cx="12" cy="12" r="3" />
                                </svg>
                            }
                        </button>
                    </div>
                    <ValidationMessage For="@(() => _model.NewPassword)" class="form-error" />

                    <!-- Индикатор надёжности пароля -->
                    <div id="rp-password-strength" class="password-strength" aria-live="polite">
                        <div class="strength-bars">
                            <div class="strength-bar @GetStrengthClass(1)"></div>
                            <div class="strength-bar @GetStrengthClass(2)"></div>
                            <div class="strength-bar @GetStrengthClass(3)"></div>
                        </div>
                        @if (!string.IsNullOrEmpty(_model.NewPassword))
                        {
                            <span class="strength-label strength-label--@_strengthLevel.ToString().ToLower()">
                                @_strengthLabel
                            </span>
                        }
                    </div>
                </div>

                <!-- Подтверждение пароля -->
                <div class="form-group">
                    <label class="form-label" for="rp-confirm">Подтвердите пароль</label>
                    <div class="input-wrapper">
                        <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18" aria-hidden="true">
                            <rect x="3" y="11" width="18" height="11" rx="2" />
                            <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                        </svg>
                        <InputText id="rp-confirm"
                                   type="@(_showConfirm ? "text" : "password")"
                                   class="form-input form-input--padded-right"
                                   @bind-Value="_model.ConfirmPassword"
                                   placeholder="Повторите пароль"
                                   autocomplete="new-password"
                                   aria-required="true" />
                        <button type="button"
                                class="input-toggle"
                                @onclick="ToggleConfirmVisibility"
                                aria-label="@(_showConfirm ? "Скрыть пароль" : "Показать пароль")">
                            @if (_showConfirm)
                            {
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18" aria-hidden="true">
                                    <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94" />
                                    <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19" />
                                    <line x1="1" y1="1" x2="23" y2="23" />
                                </svg>
                            }
                            else
                            {
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18" aria-hidden="true">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                    <circle cx="12" cy="12" r="3" />
                                </svg>
                            }
                        </button>
                    </div>
                    <ValidationMessage For="@(() => _model.ConfirmPassword)" class="form-error" />
                    @if (!string.IsNullOrEmpty(_model.ConfirmPassword) &&
                                    _model.NewPassword != _model.ConfirmPassword)
                    {
                        <span class="form-error" role="alert">Пароли не совпадают</span>
                    }
                </div>

                <button type="submit"
                        class="btn btn--primary btn--full @(_isLoading ? "btn--loading" : "")"
                        disabled="@(_isLoading || !CanSubmit)">
                    @if (_isLoading)
                    {
                        <span class="spinner" aria-hidden="true"></span>
                        <span>Сохранение…</span>
                    }
                    else
                    {
                        <span>Сохранить пароль</span>
                    }
                </button>
            </EditForm>

            <div class="auth-footer">
                <a href="/login" class="auth-link">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14" aria-hidden="true">
                        <path d="M19 12H5M12 19l-7-7 7-7" />
                    </svg>
                    Вернуться ко входу
                </a>
            </div>
        }
        else if (_step == Step.InvalidLink)
        {
            <!-- Недействительная или истёкшая ссылка -->
            <div class="auth-state auth-state--error">
                <div class="auth-state__icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="32" height="32">
                        <circle cx="12" cy="12" r="10" />
                        <path d="M12 8v4M12 16h.01" />
                    </svg>
                </div>
                <h2 class="auth-state__title">Ссылка недействительна</h2>
                <p class="auth-state__text">
                    Ссылка для сброса пароля устарела или уже была использована.
                    Запросите новое письмо.
                </p>
                <a href="/forgot-password" class="btn btn--primary">
                    Запросить новую ссылку
                </a>
                <a href="/login" class="auth-link" style="margin-top: var(--space-3)">
                    Вернуться ко входу
                </a>
            </div>
        }
        else if (_step == Step.Success)
        {
            <!-- Успех -->
            <div class="auth-state auth-state--success">
                <div class="auth-state__icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="32" height="32">
                        <circle cx="12" cy="12" r="10" />
                        <path d="m9 12 2 2 4-4" />
                    </svg>
                </div>
                <h2 class="auth-state__title">Пароль изменён</h2>
                <p class="auth-state__text">
                    Ваш пароль успешно обновлён. Теперь вы можете войти в систему.
                </p>
                <button type="button" class="btn btn--primary" @onclick="GoToLogin">
                    Войти в систему
                </button>
            </div>
        }

    </div>
</div>

<style>
    /* ─────────────────────────────────────────
           Auth Page — SugarGuard Design System
           Соответствует variables.css / UIKit v2
        ───────────────────────────────────────── */

    .auth-page {
        min-height: 100dvh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: var(--space-4);
        background: var(--color-bg);
    }

    .auth-card {
        width: 100%;
        max-width: 420px;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-xl);
        padding: var(--space-8) var(--space-8) var(--space-6);
        box-shadow: var(--shadow-md);
        display: flex;
        flex-direction: column;
        gap: var(--space-5);
    }

    /* Логотип */
    .auth-logo {
        width: 52px;
        height: 52px;
        border-radius: var(--radius-md);
        background: linear-gradient(135deg, var(--color-primary), color-mix(in oklch, var(--color-primary) 70%, var(--color-blue)));
        display: grid;
        place-items: center;
        color: #fff;
        box-shadow: 0 8px 24px oklch(from var(--color-primary) l c h / 0.28);
        margin-bottom: var(--space-1);
    }

    /* Заголовок */
    .auth-header {
        display: flex;
        flex-direction: column;
        gap: var(--space-1);
    }

    .auth-title {
        font-family: var(--font-display, var(--font-body, sans-serif));
        font-size: var(--text-xl);
        font-weight: 600;
        letter-spacing: -0.02em;
        color: var(--color-text);
        margin: 0;
    }

    .auth-subtitle {
        font-size: var(--text-sm);
        color: var(--color-text-muted);
        margin: 0;
        line-height: 1.5;
    }

    /* Алерт */
    .auth-alert {
        display: flex;
        align-items: flex-start;
        gap: var(--space-2);
        padding: var(--space-3) var(--space-4);
        border-radius: var(--radius-md);
        font-size: var(--text-sm);
        line-height: 1.45;
    }

    .auth-alert--error {
        background: var(--color-error-highlight, #e0ced7);
        color: var(--color-error);
        border: 1px solid oklch(from var(--color-error) l c h / 0.2);
    }

    .auth-alert svg {
        flex-shrink: 0;
        margin-top: 1px;
    }

    /* Форма */
    .form-group {
        display: flex;
        flex-direction: column;
        gap: var(--space-1);
    }

    .form-label {
        font-size: var(--text-sm);
        font-weight: 500;
        color: var(--color-text);
    }

    .input-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }

    .input-icon {
        position: absolute;
        left: var(--space-3);
        color: var(--color-text-faint);
        pointer-events: none;
        flex-shrink: 0;
    }

    .form-input {
        width: 100%;
        height: 44px;
        padding: 0 var(--space-3) 0 calc(var(--space-3) + 18px + var(--space-2));
        background: var(--color-surface-2, var(--color-surface));
        border: 1px solid var(--color-border);
        border-radius: var(--radius-md);
        font-size: var(--text-base);
        color: var(--color-text);
        transition: border-color 180ms cubic-bezier(.16,1,.3,1), box-shadow 180ms cubic-bezier(.16,1,.3,1);
        outline: none;
    }

    .form-input--padded-right {
        padding-right: calc(var(--space-3) + 18px + var(--space-2));
    }

    .form-input:focus {
        border-color: var(--color-primary);
        box-shadow: 0 0 0 3px oklch(from var(--color-primary) l c h / 0.12);
    }

    .form-input[readonly] {
        background: var(--color-surface-offset, var(--color-surface));
        color: var(--color-text-muted);
        cursor: default;
    }

    .input-toggle {
        position: absolute;
        right: var(--space-3);
        display: grid;
        place-items: center;
        color: var(--color-text-faint);
        background: none;
        border: none;
        cursor: pointer;
        padding: var(--space-1);
        border-radius: var(--radius-sm);
        transition: color 180ms ease;
        min-width: 28px;
        min-height: 28px;
    }

        .input-toggle:hover {
            color: var(--color-text-muted);
        }

        .input-toggle:focus-visible {
            outline: 2px solid var(--color-primary);
            outline-offset: 2px;
        }

    .form-error {
        font-size: var(--text-xs);
        color: var(--color-error);
        margin-top: var(--space-1);
        display: block;
    }

    /* Индикатор надёжности */
    .password-strength {
        display: flex;
        align-items: center;
        gap: var(--space-3);
        margin-top: var(--space-2);
    }

    .strength-bars {
        display: flex;
        gap: var(--space-1);
        flex: 1;
    }

    .strength-bar {
        height: 4px;
        flex: 1;
        border-radius: var(--radius-full, 9999px);
        background: var(--color-border);
        transition: background 300ms ease;
    }

    .strength-bar--weak {
        background: var(--color-error);
    }

    .strength-bar--fair {
        background: var(--color-warning);
    }

    .strength-bar--strong {
        background: var(--color-success);
    }

    .strength-label {
        font-size: var(--text-xs);
        font-weight: 500;
        white-space: nowrap;
    }

    .strength-label--weak {
        color: var(--color-error);
    }

    .strength-label--fair {
        color: var(--color-warning);
    }

    .strength-label--strong {
        color: var(--color-success);
    }

    /* Кнопка */
    .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: var(--space-2);
        height: 44px;
        padding: 0 var(--space-6);
        border-radius: var(--radius-md);
        font-size: var(--text-sm);
        font-weight: 500;
        border: none;
        cursor: pointer;
        transition: background 180ms cubic-bezier(.16,1,.3,1), transform 180ms cubic-bezier(.16,1,.3,1), box-shadow 180ms cubic-bezier(.16,1,.3,1);
        text-decoration: none;
    }

    .btn--primary {
        background: var(--color-primary);
        color: #fff;
        box-shadow: 0 4px 12px oklch(from var(--color-primary) l c h / 0.22);
    }

        .btn--primary:hover:not(:disabled) {
            background: var(--color-primary-hover, var(--color-primary));
            transform: translateY(-1px);
            box-shadow: 0 6px 18px oklch(from var(--color-primary) l c h / 0.28);
        }

        .btn--primary:active:not(:disabled) {
            transform: translateY(0);
        }

        .btn--primary:disabled {
            opacity: 0.55;
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
        }

    .btn--full {
        width: 100%;
    }

    .btn--loading {
        cursor: wait;
    }

    /* Спиннер */
    .spinner {
        width: 16px;
        height: 16px;
        border: 2px solid rgba(255,255,255,0.3);
        border-top-color: #fff;
        border-radius: 50%;
        animation: spin 0.65s linear infinite;
    }

    @@keyframes spin {
        to

    {
        transform: rotate(360deg);
    }

    }

    /* State screens */
    .auth-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: var(--space-3);
        padding: var(--space-4) 0;
    }

    .auth-state__icon {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        display: grid;
        place-items: center;
        margin-bottom: var(--space-1);
    }

    .auth-state--success .auth-state__icon {
        background: var(--color-success-highlight, #d4dfcc);
        color: var(--color-success);
    }

    .auth-state--error .auth-state__icon {
        background: var(--color-error-highlight, #e0ced7);
        color: var(--color-error);
    }

    .auth-state__title {
        font-family: var(--font-display, var(--font-body, sans-serif));
        font-size: var(--text-xl);
        font-weight: 600;
        letter-spacing: -0.02em;
        color: var(--color-text);
        margin: 0;
    }

    .auth-state__text {
        font-size: var(--text-sm);
        color: var(--color-text-muted);
        max-width: 32ch;
        margin: 0;
        line-height: 1.55;
    }

    /* Футер */
    .auth-footer {
        display: flex;
        justify-content: center;
        padding-top: var(--space-1);
    }

    .auth-link {
        display: inline-flex;
        align-items: center;
        gap: var(--space-1);
        font-size: var(--text-sm);
        color: var(--color-text-muted);
        text-decoration: none;
        transition: color 180ms ease;
        border-radius: var(--radius-sm);
        padding: var(--space-1) var(--space-2);
    }

        .auth-link:hover {
            color: var(--color-primary);
        }

        .auth-link:focus-visible {
            outline: 2px solid var(--color-primary);
            outline-offset: 2px;
        }

    /* Адаптив */
    @@media (max-width: 480px) {
        .auth-card

    {
        padding: var(--space-6) var(--space-5) var(--space-5);
        border-radius: var(--radius-lg);
    }

    }

    /* Respect reduced motion */
    @@media (prefers-reduced-motion: reduce) {
        .spinner

    {
        animation-duration: 1.5s;
    }

    }
</style>

@code {
    // Шаги формы
    private enum Step { Form, InvalidLink, Success }
    private enum StrengthLevel { None, Weak, Fair, Strong }

    // Состояние
    private Step _step = Step.Form;
    private bool _isLoading;
    private string? _errorMessage;
    private bool _showPassword;
    private bool _showConfirm;
    private StrengthLevel _strengthLevel = StrengthLevel.None;
    private string _strengthLabel = string.Empty;

    // Параметры, переданные из URL
    private string _email = string.Empty;
    private string _code = string.Empty;

    private readonly ResetPasswordModel _model = new();

    // Lifecycle
    protected override void OnInitialized()
    {
        var uri = new Uri(Navigation.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        _email = query["email"]?.Trim() ?? string.Empty;
        _code = query["code"]?.Trim() ?? string.Empty;

        if (string.IsNullOrWhiteSpace(_email) || !ConnectionCodeFormat.IsValid(_code, normalize: true))
        {
            _step = Step.InvalidLink;
        }
    }

    // Handlers
    /// <summary>
    /// Отправка формы
    /// </summary>
    private async Task HandleSubmitAsync()
    {
        // Дополнительная клиентская валидация
        if (_model.NewPassword != _model.ConfirmPassword)
        {
            _errorMessage = "Пароли не совпадают.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        _isLoading = true;
        _errorMessage = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            var result = await AuthApiClient.ResetPasswordAsync(
                _email,
                _code,
                _model.NewPassword);

            if (result.IsSuccess)
            {
                _step = Step.Success;
            }
            else
            {
                // Сервер вернул ошибку 
                _errorMessage = result.Message switch
                {
                    var m when m?.Contains("expired", StringComparison.OrdinalIgnoreCase) == true
                        => "Ссылка устарела. Запросите новое письмо.",
                    var m when m?.Contains("invalid", StringComparison.OrdinalIgnoreCase) == true ||
                               m?.Contains("incorrect", StringComparison.OrdinalIgnoreCase) == true
                        => "Код подтверждения неверен. Запросите новое письмо.",
                    var m when m?.Contains("notfound", StringComparison.OrdinalIgnoreCase) == true ||
                               m?.Contains("not found", StringComparison.OrdinalIgnoreCase) == true
                        => "Пользователь не найден.",
                    _ => result.Message ?? "Не удалось сменить пароль. Попробуйте ещё раз."
                };
            }
        }
        catch (Exception)
        {
            _errorMessage = "Ошибка сети. Проверьте подключение и попробуйте ещё раз.";
        }
        finally
        {
            _isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void TogglePasswordVisibility() => _showPassword = !_showPassword;
    private void ToggleConfirmVisibility() => _showConfirm = !_showConfirm;

    private void GoToLogin() => Navigation.NavigateTo("/login", forceLoad: false);

    // Индикатор надёжности
    /// <summary>
    /// Пересчитывает уровень надёжности при изменении поля пароля
    /// </summary>
    private string NewPasswordValue
    {
        get => _model.NewPassword;
        set
        {
            _model.NewPassword = value;
            RecalculateStrength(value);
        }
    }

    private void RecalculateStrength(string? password)
    {
        if (string.IsNullOrEmpty(password))
        {
            _strengthLevel = StrengthLevel.None;
            _strengthLabel = string.Empty;
            return;
        }

        var score = 0;
        if (password.Length >= 8) score++;
        if (password.Length >= 12) score++;
        if (password.Any(char.IsUpper) && password.Any(char.IsLower)) score++;
        if (password.Any(char.IsDigit)) score++;
        if (password.Any(c => !char.IsLetterOrDigit(c))) score++;

        (_strengthLevel, _strengthLabel) = score switch
        {
            <= 2 => (StrengthLevel.Weak, "Слабый"),
            <= 3 => (StrengthLevel.Fair, "Средний"),
            _ => (StrengthLevel.Strong, "Надёжный")
        };
    }

    /// <summary>
    /// Возвращает CSS-класс для полоски индикатора надёжности
    /// </summary>
    private string GetStrengthClass(int bar) => (_strengthLevel, bar) switch
    {
        (StrengthLevel.None, _) => string.Empty,
        (StrengthLevel.Weak, 1) => "strength-bar--weak",
        (StrengthLevel.Fair, 1) => "strength-bar--fair",
        (StrengthLevel.Fair, 2) => "strength-bar--fair",
        (StrengthLevel.Strong, _) => "strength-bar--strong",
        _ => string.Empty
    };

    // Вычисляемые свойства
    /// <summary>
    /// Кнопка активна только если оба поля заполнены и совпадают
    /// </summary>
    private bool CanSubmit =>
        !string.IsNullOrWhiteSpace(_model.NewPassword) &&
        !string.IsNullOrWhiteSpace(_model.ConfirmPassword) &&
        _model.NewPassword.Trim() == _model.ConfirmPassword.Trim() &&
        _strengthLevel != StrengthLevel.None;

    // ViewModel
    /// <summary>
    /// Модель формы сброса пароля
    /// </summary>
    private sealed class ResetPasswordModel
    {
        [Required(ErrorMessage = "Введите новый пароль.")]
        [MinLength(8, ErrorMessage = "Пароль должен содержать минимум 8 символов.")]
        public string NewPassword { get; set; } = string.Empty;

        [Required(ErrorMessage = "Подтвердите пароль.")]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
