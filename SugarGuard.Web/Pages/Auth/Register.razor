@code {
    // Модели форм 
    private sealed class RegisterModel
    {
        [Required(ErrorMessage = "Введите email")]
        [EmailAddress(ErrorMessage = "Некорректный формат email")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Введите пароль")]
        [MinLength(8, ErrorMessage = "Пароль должен содержать не менее 8 символов")]
        public string Password { get; set; } = string.Empty;

        [Required(ErrorMessage = "Подтвердите пароль")]
        [Compare(nameof(Password), ErrorMessage = "Пароли не совпадают")]
        public string ConfirmPassword { get; set; } = string.Empty;

        [Required]
        public string Role { get; set; } = "Parent";
    }

    private sealed class VerifyModel
    {
        [Required(ErrorMessage = "Введите код подтверждения")]
        [StringLength(9, MinimumLength = 8)]
        [ConnectionCode]
        public string Code { get; set; } = string.Empty;
    }

    // Состояние
    private readonly RegisterModel _registerModel = new();
    private readonly VerifyModel _verifyModel = new();

    /// <summary>
    /// Текущий шаг: 1 — форма, 2 — подтверждение, 3 — успех
    /// </summary>
    private int _step = 1;

    private string? _errorMessage;
    private bool _isLoading;
    private bool _showPassword;

    private bool _passwordTooWeak = true; // Пароль слабый (score меньше 2) — кнопка «Зарегистрироваться» отключена

    /// <summary>
    /// Кулдаун повторной отправки кода 
    /// </summary>
    private int _resendCooldown;
    private System.Threading.Timer? _cooldownTimer;

    // Обработчики
    /// <summary>
    /// отправляет регистрационный запрос на API
    /// </summary>
    private async Task HandleRegisterAsync()
    {
        _errorMessage = null;
        _isLoading = true;

        try
        {
            var result = await AuthApi.RegisterAsync(
                _registerModel.Email.Trim().ToLowerInvariant(),
                _registerModel.Password,
                _registerModel.Role);

            if (!result.Success)
            {
                _errorMessage = result.ErrorMessage ?? "Ошибка регистрации. Попробуйте позже.";
                return;
            }

            if (result.RequiresEmailVerification)
            {
                _step = 2;
                StartResendCooldown(60);
            }
            else
            {
                _step = 3;
                StopResendCooldown();
            }
        }
        finally
        {
            _isLoading = false;
        }
    }

    /// <summary>
    /// проверяет 8-значный код подтверждения
    /// </summary>
    private async Task HandleVerifyAsync()
    {
        _errorMessage = null;
        _isLoading = true;

        try
        {
            var result = await AuthApi.VerifyEmailAsync(
                _registerModel.Email.Trim().ToLowerInvariant(),
                _verifyModel.Code.Trim());

            if (!result.IsValid)
            {
                _errorMessage = result.Message ?? "Неверный или истёкший код. Попробуйте ещё раз.";
                return;
            }

            _step = 3;
            StopResendCooldown();
        }
        finally
        {
            _isLoading = false;
        }
    }

    /// <summary>
    /// Повторно отправляет код верификации на email
    /// </summary>
    private async Task HandleResendCodeAsync()
    {
        _errorMessage = null;
        _isLoading = true;

        try
        {
            var sent = await AuthApi.SendEmailVerificationCodeAsync(
                _registerModel.Email.Trim().ToLowerInvariant());

            if (!sent)
            {
                _errorMessage = "Не удалось отправить код. Попробуйте позже.";
                return;
            }

            StartResendCooldown(60);
        }
        finally
        {
            _isLoading = false;
        }
    }

    /// <summary>
    /// Обновляет пароль в модели при каждом нажатии клавиши
    /// </summary>
    private void OnPasswordInput(ChangeEventArgs e)
    {
        _registerModel.Password = e.Value?.ToString() ?? string.Empty;
    }

    /// <summary>
    /// Получает текущий score 
    /// </summary>
    private void OnPasswordScoreChanged(int score)
    {
        _passwordTooWeak = score < 2;
    }

    private void TogglePasswordVisibility()
        => _showPassword = !_showPassword;

    private void SelectRole(string role)
        => _registerModel.Role = role;

    private void GoToLogin()
        => Navigation.NavigateTo("/login", replace: true);

    private static bool IsVerificationCodeReady(string code)
        => ConnectionCodeFormat.IsValid(code, normalize: true);

    // Кулдаун повторной отправки
    /// <summary>
    /// Запускает обратный отсчёт
    /// </summary>
    private void StartResendCooldown(int seconds)
    {
        _resendCooldown = seconds;
        StopResendCooldown();

        _cooldownTimer = new System.Threading.Timer(_ =>
        {
            if (_resendCooldown > 0)
            {
                _resendCooldown--;
                InvokeAsync(StateHasChanged);
            }
            else
            {
                StopResendCooldown();
            }
        }, null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
    }

    private void StopResendCooldown()
    {
        _cooldownTimer?.Dispose();
        _cooldownTimer = null;
    }

    // Освобождение ресурсов 
    public void Dispose()
        => StopResendCooldown();
}
