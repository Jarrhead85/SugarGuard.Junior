@page "/doctor/alerts"
@attribute [Authorize(Roles = "Doctor,Admin,SupportAdmin")]
@rendermode InteractiveServer
@implements IDisposable

@using Microsoft.AspNetCore.Authorization
@using SugarGuard.Web.Services
@using static SugarGuard.Web.Services.SugarGuardApiService

@inject SugarGuardApiService ApiService
@inject NavigationManager Navigation
@inject ILogger<Alerts> Logger

<PageTitle>Группы риска — SugarGuard</PageTitle>

<section class="doctor-simple-page">
    <header class="doctor-simple-hero">
        <div>
            <span class="doctor-simple-eyebrow">Рабочее пространство</span>
            <h1>Группы риска</h1>
            <p>Пациенты, которым сейчас нужно внимание врача: критические значения, низкий TIR или отсутствие свежих измерений.</p>
        </div>
        <span class="doctor-live-state">Данные обновляются автоматически</span>
    </header>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="doctor-simple-alert" role="alert">@_error</div>
    }

    @if (_isLoading)
    {
        <div class="doctor-simple-card">Загружаем список риска...</div>
    }
    else if (AlertPatients.Count == 0)
    {
        <div class="doctor-simple-empty">
            <strong>Срочных оповещений нет</strong>
            <span>По доступным данным все прикреплённые пациенты сейчас без критических признаков.</span>
        </div>
    }
    else
    {
        <div class="doctor-risk-grid">
            @foreach (var patient in AlertPatients)
            {
                var severity = GetSeverity(patient);
                <article class="doctor-risk-card @severity.CssClass">
                    <div class="doctor-risk-card__top">
                        <span class="doctor-risk-avatar">@GetInitials(patient)</span>
                        <div>
                            <h2>@GetFullName(patient)</h2>
                            <p>@GetReason(patient)</p>
                        </div>
                        <strong>@severity.Label</strong>
                    </div>

                    <dl class="doctor-risk-metrics">
                        <div>
                            <dt>Глюкоза</dt>
                            <dd>@FormatGlucose(patient)</dd>
                        </div>
                        <div>
                            <dt>TIR 7 дней</dt>
                            <dd>@patient.TimeInTargetRange.ToString("0.#")%</dd>
                        </div>
                        <div>
                            <dt>Измерений</dt>
                            <dd>@patient.MeasurementsLast7Days</dd>
                        </div>
                    </dl>

                    <button class="doctor-simple-button doctor-simple-button--soft"
                            type="button"
                            @onclick="() => NavigateToPatient(patient.ChildId)">
                        Открыть карточку
                    </button>
                </article>
            }
        </div>
    }
</section>

@code {
    private bool _isLoading = true;
    private string? _error;
    private List<DoctorPatientSummaryVm> _patients = [];
    private readonly CancellationTokenSource _disposeCts = new();
    private readonly SemaphoreSlim _refreshGate = new(1, 1);
    private Task? _refreshTask;

    private List<DoctorPatientSummaryVm> AlertPatients => _patients
        .Where(IsAlertPatient)
        .OrderByDescending(p => p.CriticalEventsLast7Days)
        .ThenBy(p => p.TimeInTargetRange)
        .ThenBy(p => p.LatestMeasurementTime ?? DateTime.MinValue)
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        _refreshTask = RunLiveRefreshAsync(_disposeCts.Token);
    }

    private Task LoadAsync() => RefreshAsync(showLoading: true);

    private async Task RefreshAsync(bool showLoading)
    {
        if (!await _refreshGate.WaitAsync(0, _disposeCts.Token))
        {
            return;
        }

        if (showLoading)
        {
            _isLoading = true;
            _error = null;
        }

        try
        {
            _patients = await ApiService.GetDoctorPatientsAsync("lastmeasurement", _disposeCts.Token);
        }
        catch (Exception ex)
        {
            if (showLoading)
            {
                Logger.LogError(ex, "Не удалось загрузить врачебные оповещения.");
                _error = "Не удалось загрузить оповещения. Проверьте доступ к API и попробуйте ещё раз.";
            }
            else
            {
                Logger.LogWarning(ex, "Не удалось автоматически обновить группы риска.");
            }
        }
        finally
        {
            if (showLoading)
            {
                _isLoading = false;
            }

            _refreshGate.Release();
        }
    }

    private async Task RunLiveRefreshAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(15));

        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                await InvokeAsync(async () =>
                {
                    await RefreshAsync(showLoading: false);
                    StateHasChanged();
                });
            }
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
        {
        }
    }

    private static bool IsAlertPatient(DoctorPatientSummaryVm patient)
        => patient.CriticalEventsLast7Days > 0
            || patient.LatestGlucoseUiState is "Critical" or "Danger"
            || patient.TimeInTargetRange is > 0 and < 70
            || patient.MeasurementsLast7Days == 0
            || patient.LatestMeasurementTime is null
            || patient.LatestMeasurementTime.Value < DateTime.UtcNow.AddHours(-24);

    private static string GetFullName(DoctorPatientSummaryVm patient)
        => string.IsNullOrWhiteSpace(patient.FullName)
            ? "Пациент без имени"
            : patient.FullName.Trim();

    private static string GetInitials(DoctorPatientSummaryVm patient)
    {
        var parts = GetFullName(patient).Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{char.ToUpperInvariant(parts[0][0])}{char.ToUpperInvariant(parts[1][0])}"
            : char.ToUpperInvariant(parts[0][0]).ToString();
    }

    private static string GetReason(DoctorPatientSummaryVm patient)
    {
        if (patient.CriticalEventsLast7Days > 0)
        {
            return $"Критических эпизодов за 7 дней: {patient.CriticalEventsLast7Days}.";
        }

        if (patient.LatestGlucoseUiState is "Critical" or "Danger")
        {
            return "Последнее измерение в критическом диапазоне.";
        }

        if (patient.MeasurementsLast7Days == 0)
        {
            return "Нет измерений за последние 7 дней.";
        }

        if (patient.LatestMeasurementTime is null || patient.LatestMeasurementTime.Value < DateTime.UtcNow.AddHours(-24))
        {
            return "Нет свежего измерения за последние 24 часа.";
        }

        return "TIR ниже целевого уровня, стоит проверить дневник измерений.";
    }

    private static (string Label, string CssClass) GetSeverity(DoctorPatientSummaryVm patient)
        => patient.CriticalEventsLast7Days > 0 || patient.LatestGlucoseUiState is "Critical" or "Danger"
            ? ("Критично", "doctor-risk-card--danger")
            : ("Внимание", "doctor-risk-card--warning");

    private static string FormatGlucose(DoctorPatientSummaryVm patient)
        => patient.LatestGlucose is null
            ? "—"
            : $"{patient.LatestGlucose.Value:0.0} ммоль/л";

    private void NavigateToPatient(Guid childId)
        => Navigation.NavigateTo($"/doctor/patients/{childId:D}");

    public void Dispose()
    {
        _disposeCts.Cancel();
        _disposeCts.Dispose();
    }
}

<style>
    .doctor-simple-page {
        display: grid;
        gap: 22px;
    }

    .doctor-simple-hero {
        display: flex;
        justify-content: space-between;
        gap: 18px;
        align-items: flex-start;
        padding: 18px 0 20px;
        border-bottom: 1px solid rgba(148, 163, 184, .22);
    }

    .doctor-simple-eyebrow {
        color: #8a97ad;
        font-size: 12px;
        font-weight: 900;
        letter-spacing: .08em;
        text-transform: uppercase;
    }

    .doctor-simple-hero h1 {
        margin: 8px 0 8px;
        color: #16213e;
        font-size: 34px;
        line-height: 1.05;
    }

    .doctor-simple-hero p {
        max-width: 720px;
        margin: 0;
        color: #667694;
    }

    .doctor-simple-button {
        border: 0;
        border-radius: 18px;
        padding: 12px 18px;
        background: linear-gradient(135deg, #1b8e8b, #2678d9);
        color: #fff;
        font-weight: 900;
        cursor: pointer;
    }

    .doctor-simple-button--soft {
        background: rgba(27, 142, 139, .12);
        color: #1b8e8b;
    }

    .doctor-simple-alert,
    .doctor-simple-card,
    .doctor-simple-empty,
    .doctor-risk-card {
        border: 1px solid rgba(148, 163, 184, .18);
        border-radius: 22px;
        background: rgba(255, 255, 255, .86);
        box-shadow: 0 18px 48px rgba(31, 48, 80, .08);
    }

    .doctor-simple-alert {
        padding: 14px 16px;
        color: #db5967;
        background: rgba(219, 89, 103, .09);
    }

    .doctor-simple-card,
    .doctor-simple-empty {
        padding: 28px;
    }

    .doctor-simple-empty {
        display: grid;
        place-items: center;
        gap: 8px;
        min-height: 180px;
        text-align: center;
        color: #667694;
    }

    .doctor-simple-empty strong {
        color: #16213e;
        font-size: 20px;
    }

    .doctor-risk-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 16px;
    }

    .doctor-risk-card {
        display: grid;
        gap: 18px;
        padding: 20px;
    }

    .doctor-risk-card--danger {
        border-color: rgba(219, 89, 103, .32);
    }

    .doctor-risk-card--warning {
        border-color: rgba(227, 163, 43, .36);
    }

    .doctor-risk-card__top {
        display: grid;
        grid-template-columns: auto 1fr auto;
        gap: 12px;
        align-items: start;
    }

    .doctor-risk-card h2 {
        margin: 0;
        font-size: 18px;
        color: #16213e;
    }

    .doctor-risk-card p {
        margin: 4px 0 0;
        color: #667694;
    }

    .doctor-risk-card strong {
        color: #db5967;
    }

    .doctor-risk-avatar {
        width: 42px;
        height: 42px;
        border-radius: 16px;
        display: grid;
        place-items: center;
        background: rgba(27, 142, 139, .13);
        color: #1b8e8b;
        font-weight: 900;
    }

    .doctor-risk-metrics {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 12px;
        margin: 0;
    }

    .doctor-risk-metrics div {
        padding: 12px;
        border-radius: 16px;
        background: rgba(244, 247, 251, .92);
    }

    .doctor-risk-metrics dt {
        color: #96a2b8;
        font-size: 11px;
        font-weight: 900;
        letter-spacing: .05em;
        text-transform: uppercase;
    }

    .doctor-risk-metrics dd {
        margin: 4px 0 0;
        color: #16213e;
        font-weight: 900;
    }
</style>
