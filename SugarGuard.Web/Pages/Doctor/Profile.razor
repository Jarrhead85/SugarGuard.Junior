@page "/doctor/profile"
@attribute [Authorize(Roles = "Doctor,Admin,SupportAdmin")]
@rendermode InteractiveServer

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using SugarGuard.Web.Services
@using SugarGuard.Web.ViewModels

@inject AuthenticationStateProvider AuthStateProvider
@inject SugarGuardApiService ApiService
@inject ILogger<Profile> Logger

<PageTitle>Профиль врача — SugarGuard</PageTitle>

<section class="doctor-profile-page">
    <header class="doctor-profile-hero">
        <div>
            <span class="doctor-profile-eyebrow">Профиль и настройки</span>
            <h1>Профиль врача</h1>
            <p>Данные текущей учётной записи и рабочая сводка по прикреплённым пациентам.</p>
        </div>
    </header>

    @if (_isLoading)
    {
        <div class="doctor-profile-card">Загружаем профиль...</div>
    }
    else
    {
        <section class="doctor-profile-card doctor-profile-card--identity">
            <div class="doctor-profile-avatar">
                @if (!string.IsNullOrWhiteSpace(_profile?.PhotoUrl))
                {
                    <img src="@_profile.PhotoUrl" alt="Фотография врача" />
                }
                else
                {
                    @Initials
                }
            </div>
            <div>
                <span>Учётная запись</span>
                <h2>@DisplayName</h2>
                <p>@Email</p>
                @if (!string.IsNullOrWhiteSpace(_profile?.Specialty))
                {
                    <p>@_profile.Specialty</p>
                }
            </div>
            <div class="doctor-profile-identity-actions">
                <strong>@FormatRole(Role)</strong>
                <button class="doctor-profile-button doctor-profile-button--soft" type="button" @onclick="BeginEdit">Редактировать</button>
            </div>
        </section>

        @if (_isEditing)
        {
            <section class="doctor-profile-card doctor-profile-editor" aria-label="Редактирование профиля врача">
                <h2>Данные врача</h2>
                <div class="doctor-profile-form-grid">
                    <label><span>Имя</span><input maxlength="80" @bind="_firstName" /></label>
                    <label><span>Фамилия</span><input maxlength="80" @bind="_lastName" /></label>
                    <label><span>Специальность</span><input maxlength="200" @bind="_specialty" placeholder="Эндокринолог" /></label>
                    <label><span>Номер лицензии</span><input maxlength="120" @bind="_licenseNumber" /></label>
                </div>
                <label class="doctor-photo-picker">
                    <span>Фотография JPEG, PNG или WebP до 5 МБ</span>
                    <InputFile OnChange="UploadPhotoAsync" accept="image/jpeg,image/png,image/webp" />
                </label>
                @if (!string.IsNullOrWhiteSpace(_profileError))
                {
                    <p class="doctor-profile-error" role="alert">@_profileError</p>
                }
                <div class="doctor-profile-editor-actions">
                    <button class="doctor-profile-button doctor-profile-button--soft" type="button" @onclick="CancelEdit">Отмена</button>
                    <button class="doctor-profile-button" type="button" @onclick="SaveProfileAsync" disabled="@_isSaving">
                        @(_isSaving ? "Сохраняем..." : "Сохранить")
                    </button>
                </div>
            </section>
        }

        <section class="doctor-profile-grid" aria-label="Рабочая сводка врача">
            <article class="doctor-profile-card">
                <span>Пациенты</span>
                <strong>@_patientsCount</strong>
                <p>активно прикреплены к вашей учётной записи</p>
            </article>
            <article class="doctor-profile-card">
                <span>Критические сегодня</span>
                <strong>@_criticalToday</strong>
                <p>пациентов с критическими эпизодами</p>
            </article>
            <article class="doctor-profile-card">
                <span>Средний TIR</span>
                <strong>@(_averageTir?.ToString("0.#") ?? "—")%</strong>
                <p>по доступным данным за 7 дней</p>
            </article>
        </section>

        <section class="doctor-profile-card">
            <span>Безопасность</span>
            <h2>Доступ ограничен ролью врача</h2>
            <p>Врач видит только пациентов, для которых создана активная связь Doctor → Child. Административные операции выполняются в кабинете администратора.</p>
        </section>
    }
</section>

@code {
    private bool _isLoading = true;
    private string DisplayName = "Врач SugarGuard";
    private string Email = "—";
    private string Role = "Doctor";
    private int _patientsCount;
    private int _criticalToday;
    private double? _averageTir;
    private AccountProfileVm? _profile;
    private bool _isEditing;
    private bool _isSaving;
    private string _firstName = string.Empty;
    private string _lastName = string.Empty;
    private string _specialty = string.Empty;
    private string _licenseNumber = string.Empty;
    private string? _profileError;
    private readonly CancellationTokenSource _profileRefreshCts = new();
    private Task? _profileRefreshTask;

    private string Initials => string.IsNullOrWhiteSpace(Email) || Email == "—"
        ? "DR"
        : Email[0].ToString().ToUpperInvariant();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        _profileRefreshTask = RunProfileRefreshAsync(_profileRefreshCts.Token);
    }

    private async Task LoadAsync(bool showLoading = true)
    {
        if (showLoading)
        {
            _isLoading = true;
        }

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            Email = user.FindFirst(ClaimTypes.Email)?.Value
                ?? user.FindFirst("email")?.Value
                ?? user.Identity?.Name
                ?? "—";
            Role = user.FindFirst(ClaimTypes.Role)?.Value ?? "Doctor";
            DisplayName = user.Identity?.Name is { Length: > 0 } name && !name.Contains('@', StringComparison.Ordinal)
                ? name
                : Email;

            _profile = await ApiService.GetAccountProfileAsync();
            if (_profile is not null)
            {
                DisplayName = _profile.DisplayName;
                Email = _profile.Email;
                Role = _profile.Role;
            }

            var cohort = await ApiService.GetDoctorCohortSummaryAsync();
            if (cohort is not null)
            {
                _patientsCount = cohort.TotalPatients;
                _criticalToday = cohort.PatientsWithCriticalToday;
                _averageTir = cohort.AverageTimeInTargetRange;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Не удалось загрузить профиль врача.");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task RunProfileRefreshAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(30));
        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                if (_isEditing || _isSaving)
                {
                    continue;
                }

                await InvokeAsync(() => LoadAsync(showLoading: false));
            }
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
        {
        }
    }

    private void BeginEdit()
    {
        _firstName = _profile?.FirstName ?? string.Empty;
        _lastName = _profile?.LastName ?? string.Empty;
        _specialty = _profile?.Specialty ?? string.Empty;
        _licenseNumber = _profile?.LicenseNumber ?? string.Empty;
        _profileError = null;
        _isEditing = true;
    }

    private void CancelEdit()
    {
        _isEditing = false;
        _profileError = null;
    }

    private async Task SaveProfileAsync()
    {
        if (string.IsNullOrWhiteSpace(_firstName))
        {
            _profileError = "Укажите имя врача.";
            return;
        }

        _isSaving = true;
        _profileError = null;
        try
        {
            _profile = await ApiService.UpdateAccountProfileAsync(new UpdateAccountProfileVmRequest
            {
                FirstName = _firstName.Trim(),
                LastName = _lastName.Trim(),
                Specialty = _specialty.Trim(),
                LicenseNumber = _licenseNumber.Trim()
            });
            DisplayName = _profile.DisplayName;
            _isEditing = false;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Не удалось сохранить профиль врача.");
            _profileError = "Не удалось сохранить профиль. Проверьте данные и повторите попытку.";
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task UploadPhotoAsync(InputFileChangeEventArgs args)
    {
        var file = args.File;
        _profileError = null;
        try
        {
            await using var stream = file.OpenReadStream(5L * 1024 * 1024);
            var photoUrl = await ApiService.UploadAccountPhotoAsync(stream, file.Name, file.ContentType);
            if (_profile is not null)
            {
                _profile = new AccountProfileVm
                {
                    UserId = _profile.UserId,
                    Email = _profile.Email,
                    Role = _profile.Role,
                    FirstName = _profile.FirstName,
                    LastName = _profile.LastName,
                    DisplayName = _profile.DisplayName,
                    PhotoUrl = photoUrl,
                    Specialty = _profile.Specialty,
                    LicenseNumber = _profile.LicenseNumber
                };
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Не удалось загрузить фотографию врача.");
            _profileError = "Не удалось загрузить фотографию. Используйте JPEG, PNG или WebP до 5 МБ.";
        }
    }

    private static string FormatRole(string role) => role switch
    {
        "Doctor" => "Врач",
        "Admin" => "Администратор",
        "SupportAdmin" => "Поддержка",
        _ => role
    };
}

<style>
    .doctor-profile-page {
        display: grid;
        gap: 22px;
    }

    .doctor-profile-hero {
        display: flex;
        justify-content: space-between;
        gap: 18px;
        align-items: flex-start;
        padding: 18px 0 20px;
        border-bottom: 1px solid rgba(148, 163, 184, .22);
    }

    .doctor-profile-eyebrow {
        color: #8a97ad;
        font-size: 12px;
        font-weight: 900;
        letter-spacing: .08em;
        text-transform: uppercase;
    }

    .doctor-profile-hero h1 {
        margin: 8px 0;
        color: #16213e;
        font-size: 34px;
        line-height: 1.05;
    }

    .doctor-profile-hero p,
    .doctor-profile-card p {
        margin: 0;
        color: #667694;
    }

    .doctor-profile-button {
        border: 0;
        border-radius: 18px;
        padding: 12px 18px;
        background: linear-gradient(135deg, #1b8e8b, #2678d9);
        color: #fff;
        font-weight: 900;
        cursor: pointer;
    }

    .doctor-profile-card {
        border: 1px solid rgba(148, 163, 184, .18);
        border-radius: 22px;
        padding: 22px;
        background: rgba(255, 255, 255, .86);
        box-shadow: 0 18px 48px rgba(31, 48, 80, .08);
    }

    .doctor-profile-card--identity {
        display: grid;
        grid-template-columns: auto 1fr auto;
        gap: 18px;
        align-items: center;
    }

    .doctor-profile-avatar {
        width: 70px;
        height: 70px;
        border-radius: 24px;
        display: grid;
        place-items: center;
        background: linear-gradient(135deg, #1b8e8b, #2678d9);
        color: #fff;
        font-size: 22px;
        font-weight: 900;
    }

    .doctor-profile-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: inherit;
    }

    .doctor-profile-identity-actions,
    .doctor-profile-editor-actions {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 10px;
    }

    .doctor-profile-button--soft {
        color: #1b8e8b;
        background: rgba(27, 142, 139, .12);
    }

    .doctor-profile-editor {
        display: grid;
        gap: 16px;
    }

    .doctor-profile-form-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px;
    }

    .doctor-profile-form-grid label,
    .doctor-photo-picker {
        display: grid;
        gap: 7px;
        color: #667694;
        font-size: 13px;
        font-weight: 700;
    }

    .doctor-profile-form-grid input,
    .doctor-photo-picker input {
        min-height: 44px;
        border: 1px solid rgba(148, 163, 184, .3);
        border-radius: 12px;
        padding: 9px 12px;
        background: var(--color-surface);
        color: var(--color-text);
    }

    .doctor-profile-error { color: #c43d4d !important; }

    .doctor-profile-card span {
        color: #96a2b8;
        font-size: 12px;
        font-weight: 900;
        letter-spacing: .05em;
        text-transform: uppercase;
    }

    .doctor-profile-card h2 {
        margin: 4px 0;
        color: #16213e;
    }

    .doctor-profile-card strong {
        color: #16213e;
        font-size: 30px;
    }

    .doctor-profile-card--identity strong {
        font-size: 14px;
        color: #1b8e8b;
        padding: 8px 12px;
        border-radius: 999px;
        background: rgba(27, 142, 139, .12);
    }

    .doctor-profile-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 16px;
    }

    @@media (max-width: 860px) {
        .doctor-profile-card--identity,
        .doctor-profile-grid,
        .doctor-profile-form-grid {
            grid-template-columns: 1fr;
        }

        .doctor-profile-hero,
        .doctor-profile-identity-actions,
        .doctor-profile-editor-actions {
            flex-direction: column;
            align-items: stretch;
        }

        .doctor-profile-button {
            width: 100%;
        }
    }
</style>
