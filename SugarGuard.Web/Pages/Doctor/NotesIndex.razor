@page "/doctor/notes"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Doctor,Admin,SupportAdmin")]

@using System.Globalization
@using System.Text
@using Microsoft.AspNetCore.Authorization
@using SugarGuard.Web.Services
@using SugarGuard.Web.ViewModels

@inject SugarGuardApiService ApiService
@inject NavigationManager Navigation
@inject ILogger<NotesIndex> Logger

<PageTitle>Записки врача - SugarGuard</PageTitle>

<section class="doctor-notes-page" aria-labelledby="doctorNotesTitle">
    <header class="doctor-notes-topbar">
        <div>
            <h1 id="doctorNotesTitle">Записки врача</h1>
            <span class="doctor-live-state">Данные обновляются автоматически</span>
        </div>
        <div class="doctor-notes-actions">
            <a class="doctor-notes-button doctor-notes-button--soft @(Notes.Count == 0 ? "disabled" : null)"
               href="@NotesCsvHref" download="sugarguard-doctor-notes.csv">Экспорт</a>
            <button class="doctor-notes-button" type="button" @onclick="FocusEditor">+ Новая записка</button>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="doctor-notes-alert" role="alert">@_error</div>
    }

    <div class="doctor-notes-layout">
        <section class="doctor-notes-panel" aria-label="Все записки">
            <div class="doctor-notes-panel-heading">
                <div>
                    <h2>Все записки</h2>
                    <p>Клинические заметки по прикреплённым пациентам</p>
                </div>
                <span class="doctor-notes-count">@Notes.Count</span>
            </div>

            @if (_isLoading && Notes.Count == 0)
            {
                <div class="doctor-notes-loading">Загружаем записки...</div>
            }
            else if (Notes.Count == 0)
            {
                <div class="doctor-notes-empty">
                    <strong>Записей пока нет</strong>
                    <span>Выберите пациента справа и добавьте первую заметку.</span>
                </div>
            }
            else
            {
                <div class="doctor-notes-list">
                    @foreach (var item in Notes)
                    {
                        <article class="doctor-note-row @(item.Note.IsImportant ? "important" : null)" @key="item.Note.NoteId">
                            <div class="doctor-note-row-head">
                                <span class="doctor-note-avatar">@GetInitials(item.Patient.FullName)</span>
                                <div>
                                    <strong>@GetPatientName(item.Patient)</strong>
                                    <time>@FormatDateTime(item.Note.CreatedAt)</time>
                                </div>
                                @if (item.Note.IsImportant)
                                {
                                    <span class="doctor-note-important">Важно</span>
                                }
                            </div>
                            <p>@item.Note.NoteText</p>
                            <button type="button" @onclick="() => OpenPatient(item.Patient.ChildId)">Открыть карту</button>
                        </article>
                    }
                </div>
            }
        </section>

        <section class="doctor-notes-panel doctor-notes-editor" id="doctorNotesEditor" aria-label="Новая записка">
            <div class="doctor-notes-panel-heading">
                <div>
                    <h2>Новая записка</h2>
                    <p>Записка сохраняется в карте ребёнка</p>
                </div>
            </div>

            <label>
                <span>Пациент</span>
                <select @bind="_selectedChildIdText">
                    <option value="">Выберите пациента</option>
                    @foreach (var patient in _patients.OrderBy(patient => patient.FullName))
                    {
                        <option value="@patient.ChildId">@GetPatientName(patient)</option>
                    }
                </select>
            </label>

            <label>
                <span>Текст клинической записки</span>
                <textarea @bind="_noteText" maxlength="4000"
                          placeholder="Введите наблюдение, рекомендацию или изменение терапии..."></textarea>
            </label>

            <div class="doctor-note-tags" aria-label="Категория записки">
                @foreach (var tag in NoteTags)
                {
                    <button class="@(string.Equals(_selectedTag, tag, StringComparison.Ordinal) ? "active" : null)"
                            type="button" @onclick="() => SelectTag(tag)">@tag</button>
                }
            </div>

            <label class="doctor-note-important-toggle">
                <input type="checkbox" @bind="_isImportant" />
                <span>Важная записка</span>
            </label>

            <div class="doctor-note-editor-footer">
                <span>@_noteText.Length / 4000</span>
                <button class="doctor-notes-button" type="button" @onclick="SaveNoteAsync" disabled="@(!CanSave)">
                    @(_isSaving ? "Сохраняем..." : "Сохранить")
                </button>
            </div>
        </section>
    </div>
</section>

<style>
    .doctor-notes-page { display:grid; gap:22px; color:var(--color-text,#16213e); }
    .doctor-notes-topbar { display:flex; align-items:center; justify-content:space-between; gap:18px; }
    .doctor-notes-topbar h1 { margin:0 0 6px; font-size:28px; }
    .doctor-notes-actions { display:flex; gap:10px; }
    .doctor-notes-button { min-height:42px; padding:10px 18px; border:0; border-radius:999px; color:#fff; background:linear-gradient(100deg,#159a96,#2d7ee2); font-weight:800; text-decoration:none; cursor:pointer; }
    .doctor-notes-button--soft { color:#087f7d; background:rgba(27,142,139,.12); }
    .doctor-notes-button.disabled, .doctor-notes-button:disabled { opacity:.5; pointer-events:none; }
    .doctor-notes-alert { padding:13px 16px; border:1px solid rgba(219,89,103,.25); border-radius:14px; color:#b63446; background:rgba(219,89,103,.1); }
    .doctor-notes-layout { display:grid; grid-template-columns:minmax(0,1.55fr) minmax(340px,.85fr); gap:20px; align-items:start; }
    .doctor-notes-panel { padding:22px; border:1px solid rgba(22,33,62,.08); border-radius:22px; background:rgba(255,255,255,.92); box-shadow:0 16px 38px rgba(18,31,58,.07); }
    .doctor-notes-panel-heading { display:flex; align-items:flex-start; justify-content:space-between; gap:12px; margin-bottom:18px; }
    .doctor-notes-panel-heading h2 { margin:0 0 4px; font-size:18px; }
    .doctor-notes-panel-heading p { margin:0; color:#667694; font-size:13px; }
    .doctor-notes-count { min-width:28px; padding:5px 9px; border-radius:999px; color:#087f7d; background:rgba(27,142,139,.12); text-align:center; font-weight:800; }
    .doctor-notes-list { display:grid; gap:12px; max-height:650px; overflow:auto; padding-right:3px; }
    .doctor-note-row { padding:16px; border:1px solid rgba(22,33,62,.08); border-radius:17px; background:#f5f8fc; }
    .doctor-note-row.important { border-color:rgba(227,163,43,.32); background:rgba(255,248,230,.76); }
    .doctor-note-row-head { display:grid; grid-template-columns:auto minmax(0,1fr) auto; gap:11px; align-items:center; }
    .doctor-note-avatar { width:34px; height:34px; display:grid; place-items:center; border-radius:50%; color:#fff; background:linear-gradient(135deg,#159a96,#2d7ee2); font-size:12px; font-weight:900; }
    .doctor-note-row-head div { display:flex; align-items:baseline; justify-content:space-between; gap:10px; min-width:0; }
    .doctor-note-row time { color:#8a98b2; font-size:12px; white-space:nowrap; }
    .doctor-note-important { padding:4px 8px; border-radius:999px; color:#a56b00; background:rgba(227,163,43,.16); font-size:11px; font-weight:800; }
    .doctor-note-row p { margin:12px 0; color:#435575; line-height:1.55; white-space:pre-wrap; }
    .doctor-note-row > button { padding:0; border:0; color:#087f7d; background:none; font-weight:750; cursor:pointer; }
    .doctor-notes-editor { display:grid; gap:15px; position:sticky; top:82px; }
    .doctor-notes-editor label:not(.doctor-note-important-toggle) { display:grid; gap:7px; color:#667694; font-size:12px; font-weight:800; text-transform:uppercase; letter-spacing:.04em; }
    .doctor-notes-editor select, .doctor-notes-editor textarea { box-sizing:border-box; width:100%; padding:13px 14px; border:1px solid rgba(22,33,62,.12); border-radius:14px; color:#16213e; background:#fff; font:inherit; text-transform:none; letter-spacing:0; }
    .doctor-notes-editor textarea { min-height:145px; resize:vertical; }
    .doctor-note-tags { display:flex; flex-wrap:wrap; gap:8px; }
    .doctor-note-tags button { padding:7px 11px; border:1px solid rgba(22,33,62,.1); border-radius:999px; color:#5e7091; background:#f2f6fb; font-size:12px; cursor:pointer; }
    .doctor-note-tags button.active { color:#087f7d; border-color:rgba(27,142,139,.25); background:rgba(27,142,139,.12); font-weight:800; }
    .doctor-note-important-toggle { display:flex; align-items:center; gap:9px; color:#435575; font-size:13px; }
    .doctor-note-editor-footer { display:flex; align-items:center; justify-content:space-between; gap:12px; color:#8a98b2; font-size:12px; }
    .doctor-notes-loading, .doctor-notes-empty { min-height:240px; display:grid; place-content:center; gap:7px; text-align:center; color:#667694; }
    [data-theme="dark"] .doctor-notes-panel { background:rgba(17,24,37,.94); border-color:rgba(237,244,255,.1); }
    [data-theme="dark"] .doctor-note-row, [data-theme="dark"] .doctor-notes-editor select, [data-theme="dark"] .doctor-notes-editor textarea { color:#edf4ff; background:#172030; border-color:rgba(237,244,255,.1); }
    [data-theme="dark"] .doctor-note-row p { color:#b8c5de; }
    @@media (max-width:980px) { .doctor-notes-layout { grid-template-columns:1fr; } .doctor-notes-editor { position:static; } }
    @@media (max-width:640px) { .doctor-notes-topbar { align-items:flex-start; flex-direction:column; } .doctor-notes-actions { width:100%; } .doctor-notes-actions > * { flex:1; text-align:center; } .doctor-notes-panel { padding:17px; border-radius:17px; } }
</style>

@code {
    private static readonly CultureInfo RuCulture = CultureInfo.GetCultureInfo("ru-RU");
    private static readonly string[] NoteTags = ["Коррекция дозы", "Паттерн гипо", "Питание", "Физ. нагрузка", "Наблюдение"];
    private readonly CancellationTokenSource _cts = new();
    private List<DoctorPatientSummaryVm> _patients = [];
    private List<DoctorNoteListItemVm> Notes { get; set; } = [];
    private Task? _refreshTask;
    private string _selectedChildIdText = string.Empty;
    private string _noteText = string.Empty;
    private string _selectedTag = "Наблюдение";
    private string? _error;
    private bool _isImportant;
    private bool _isLoading = true;
    private bool _isSaving;

    private bool CanSave => !_isSaving
                            && Guid.TryParse(_selectedChildIdText, out _)
                            && !string.IsNullOrWhiteSpace(_noteText);

    private string NotesCsvHref => Notes.Count == 0
        ? "#"
        : $"data:text/csv;charset=utf-8,{Uri.EscapeDataString("\uFEFF" + BuildCsv())}";

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync(showLoading: true);
        _refreshTask = RunLiveRefreshAsync(_cts.Token);
    }

    private async Task RefreshAsync(bool showLoading)
    {
        if (showLoading)
        {
            _isLoading = true;
        }

        try
        {
            var patients = await ApiService.GetDoctorPatientsAsync("lastmeasurement", _cts.Token);
            var noteGroups = await Task.WhenAll(patients.Select(async patient =>
            {
                var result = await ApiService.GetDoctorNotesAsync(patient.ChildId, 1, 100, false, _cts.Token);
                return result.Items.Select(note => new DoctorNoteListItemVm(patient, note));
            }));

            _patients = patients;
            Notes = noteGroups.SelectMany(items => items)
                .OrderByDescending(item => item.Note.CreatedAt)
                .ToList();

            if (string.IsNullOrWhiteSpace(_selectedChildIdText) && _patients.Count == 1)
            {
                _selectedChildIdText = _patients[0].ChildId.ToString();
            }

            _error = null;
        }
        catch (OperationCanceledException) when (_cts.IsCancellationRequested)
        {
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Не удалось загрузить заметки врача");
            _error = "Не удалось обновить заметки. Данные на экране сохранены.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SaveNoteAsync()
    {
        if (!CanSave || !Guid.TryParse(_selectedChildIdText, out var childId))
        {
            return;
        }

        try
        {
            _isSaving = true;
            var text = string.IsNullOrWhiteSpace(_selectedTag)
                ? _noteText.Trim()
                : $"[{_selectedTag}] {_noteText.Trim()}";

            await ApiService.CreateDoctorNoteAsync(childId, text, _isImportant, cancellationToken: _cts.Token);
            _noteText = string.Empty;
            _isImportant = false;
            _error = null;
            await RefreshAsync(showLoading: false);
        }
        catch (Exception ex) when (ex is not OperationCanceledException)
        {
            Logger.LogError(ex, "Не удалось сохранить заметку для ChildId={ChildId}", childId);
            _error = "Не удалось сохранить заметку.";
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task RunLiveRefreshAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(15));
        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                await InvokeAsync(() => RefreshAsync(showLoading: false));
            }
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
        {
        }
    }

    private void SelectTag(string tag) => _selectedTag = tag;
    private void FocusEditor() => Navigation.NavigateTo("/doctor/notes#doctorNotesEditor", replace: true);
    private void OpenPatient(Guid childId) => Navigation.NavigateTo($"/doctor/patients/{childId:D}");

    private static string GetPatientName(DoctorPatientSummaryVm patient) =>
        string.IsNullOrWhiteSpace(patient.FullName) ? "Пациент без имени" : patient.FullName.Trim();

    private static string GetInitials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[1][0]}".ToUpper(RuCulture)
            : name[..Math.Min(1, name.Length)].ToUpper(RuCulture);
    }

    private static string FormatDateTime(DateTime value)
    {
        var utc = value.Kind == DateTimeKind.Utc ? value : DateTime.SpecifyKind(value, DateTimeKind.Utc);
        var zone = TimeZoneInfo.FindSystemTimeZoneById(
            OperatingSystem.IsWindows() ? "Russian Standard Time" : "Europe/Moscow");
        return TimeZoneInfo.ConvertTimeFromUtc(utc, zone).ToString("dd.MM.yyyy HH:mm", RuCulture);
    }

    private string BuildCsv()
    {
        var csv = new StringBuilder("Пациент;Дата;Важная;Текст\r\n");
        foreach (var item in Notes)
        {
            csv.Append(Csv(GetPatientName(item.Patient))).Append(';')
                .Append(Csv(FormatDateTime(item.Note.CreatedAt))).Append(';')
                .Append(item.Note.IsImportant ? "Да" : "Нет").Append(';')
                .AppendLine(Csv(item.Note.NoteText));
        }

        return csv.ToString();
    }

    private static string Csv(string value) =>
        string.Concat('"', value.Replace("\"", "\"\"", StringComparison.Ordinal), '"');

}
