@page "/doctor/patients/{ChildId:guid}"
@using System.Globalization
@using Microsoft.AspNetCore.Authorization
@using SugarGuard.Web.Models.Analytics
@using SugarGuard.Web.Services
@using SugarGuard.Web.ViewModels
@using DoctorNoteVm = SugarGuard.Web.ViewModels.DoctorNoteVm
@using static SugarGuard.Web.Services.SugarGuardApiService
@attribute [Authorize(Roles = "Doctor,Admin,SupportAdmin")]
@inject SugarGuardApiService ApiService
@inject NavigationManager Navigation
@inject ILogger<PatientDetail> Logger
@implements IDisposable

<PageTitle>@PatientPageTitle</PageTitle>

<section class="doctor-detail" aria-labelledby="doctorPatientTitle">
    @if (_isLoading)
    {
        <div class="doctor-detail-card doctor-detail-card--loading" role="status">
            <div class="doctor-skeleton-line doctor-skeleton-line--title"></div>
            <div class="doctor-detail-metrics">
                <div class="doctor-skeleton-metric"></div>
                <div class="doctor-skeleton-metric"></div>
                <div class="doctor-skeleton-metric"></div>
            </div>
            <div class="doctor-skeleton-chart"></div>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(_loadError))
    {
        <div class="doctor-detail-error" role="alert">
            <div>
                <h1>Не удалось открыть пациента</h1>
                <p>@_loadError</p>
            </div>
            <div class="doctor-detail-error__actions">
                <button class="doctor-detail-btn doctor-detail-btn--soft" type="button" @onclick="LoadAllAsync">
                    Повторить
                </button>
                <button class="doctor-detail-btn doctor-detail-btn--ghost" type="button" @onclick="GoBack">
                    Назад
                </button>
            </div>
        </div>
    }
    else if (_patient is not null)
    {
        <div class="doctor-detail-backdrop" aria-hidden="true"></div>

        <article class="doctor-detail-card">
            <header class="doctor-detail-header">
                <div class="doctor-detail-person">
                    <span class="doctor-detail-avatar @GetStatusTone(_patient)" aria-hidden="true">@GetInitials(_patient)</span>
                    <div>
                        <h1 id="doctorPatientTitle">@GetFullName(_patient)</h1>
                        <p>@PatientMeta</p>
                    </div>
                </div>

                <div class="doctor-detail-actions">
                    <span class="doctor-detail-status @GetStatusTone(_patient)">
                        @GetPatientStatusLabel(_patient)
                    </span>
                    <button class="doctor-detail-close" type="button" @onclick="GoBack" aria-label="Вернуться к списку пациентов">
                        ×
                    </button>
                </div>
            </header>

            <div class="doctor-detail-metrics" aria-label="Ключевые показатели пациента">
                <article class="doctor-detail-metric">
                    <span>TIR 7 дней</span>
                    <strong>@FormatPercent(_patient.TimeInTargetRange)</strong>
                    <small>@GetTirCaption(_patient.TimeInTargetRange)</small>
                </article>
                <article class="doctor-detail-metric">
                    <span>Последнее измерение</span>
                    <strong>@FormatLatestMeasurement(_patient)</strong>
                    <small>@FormatGlucose(_patient.LatestGlucose)</small>
                </article>
                <article class="doctor-detail-metric">
                    <span>Гипо / гипер за неделю</span>
                    <strong>@HypoHyperLabel</strong>
                    <small>@(_patient.CriticalEventsLast7Days == 0 ? "критичных эпизодов нет" : "есть критичные эпизоды")</small>
                </article>
            </div>

            <section class="doctor-chart-card" aria-labelledby="chartTitle">
                <div class="doctor-chart-card__header">
                    <div>
                        <h2 id="chartTitle">График глюкозы за 24 часа</h2>
                        <p>@ChartSubtitle</p>
                    </div>
                    <div class="doctor-period-pills" aria-label="Период графика">
                        <span class="doctor-period-pill active">24ч</span>
                        <span class="doctor-period-pill">7д</span>
                        <span class="doctor-period-pill">30д</span>
                    </div>
                </div>

                <div class="doctor-chart">
                    @if (ChartPoints.Count >= 2)
                    {
                        <svg class="doctor-chart-svg" viewBox="0 0 560 180" role="img" aria-label="Линия измерений глюкозы">
                            <defs>
                                <linearGradient id="doctorGlucoseArea" x1="0" x2="0" y1="0" y2="1">
                                    <stop offset="0%" stop-color="#1b8e8b" stop-opacity="0.26" />
                                    <stop offset="100%" stop-color="#1b8e8b" stop-opacity="0.02" />
                                </linearGradient>
                            </defs>
                            <rect x="40" y="34" width="480" height="86" rx="10" fill="#e9f7ef" opacity="0.55" />
                            <line x1="40" y1="34" x2="520" y2="34" class="doctor-chart-limit" />
                            <line x1="40" y1="120" x2="520" y2="120" class="doctor-chart-limit" />
                            <path d="@ChartAreaPath" fill="url(#doctorGlucoseArea)" />
                            <polyline points="@ChartPolyline" class="doctor-chart-line" />
                            @foreach (var point in ChartPoints)
                            {
                                <circle cx="@point.XText" cy="@point.YText" r="4" class="doctor-chart-point @point.Tone" />
                            }
                        </svg>
                    }
                    else
                    {
                        <div class="doctor-chart-empty">
                            <strong>Пока мало данных для графика</strong>
                            <span>Когда ребёнок внесёт несколько измерений, линия появится здесь.</span>
                        </div>
                    }
                </div>
            </section>

            <section class="doctor-notes-card" aria-labelledby="notesTitle">
                <div class="doctor-notes-card__header">
                    <div>
                        <h2 id="notesTitle">Заметки врача</h2>
                        <p>Заметки сохраняются в карте пациента и видны в кабинете врача.</p>
                    </div>
                    <button class="doctor-detail-btn doctor-detail-btn--soft" type="button" @onclick="ToggleNotesList">
                        @(_showNotesList ? "Скрыть историю" : "История")
                    </button>
                </div>

                <label class="doctor-note-field" for="doctorNoteText">
                    <span>Новая заметка</span>
                    <textarea id="doctorNoteText"
                              rows="4"
                              maxlength="4000"
                              placeholder="Добавить заметку к этому пациенту..."
                              @bind="_noteText"
                              @bind:event="oninput"></textarea>
                </label>

                <div class="doctor-note-footer">
                    <label class="doctor-important">
                        <input type="checkbox" @bind="_noteIsImportant" />
                        <span>Важная заметка</span>
                    </label>
                    <span>@_noteText.Length / 4000</span>
                    <button class="doctor-detail-btn doctor-detail-btn--primary"
                            type="button"
                            disabled="@(_isNoteSubmitting || string.IsNullOrWhiteSpace(_noteText))"
                            @onclick="SubmitNoteAsync">
                        @(_isNoteSubmitting ? "Сохраняем..." : "Сохранить")
                    </button>
                </div>

                @if (!string.IsNullOrWhiteSpace(_noteError))
                {
                    <div class="doctor-inline-error" role="alert">@_noteError</div>
                }

                @if (_showNotesList)
                {
                    <div class="doctor-notes-list" role="list" aria-label="История заметок">
                        @if (_isNotesLoading)
                        {
                            <div class="doctor-skeleton-line"></div>
                            <div class="doctor-skeleton-line"></div>
                        }
                        else if (_notes.Count == 0)
                        {
                            <p class="doctor-notes-empty">Заметок пока нет.</p>
                        }
                        else
                        {
                            @foreach (var note in _notes.Take(5))
                            {
                                <article class="doctor-note-item @(note.IsImportant ? "important" : null)" role="listitem">
                                    <div>
                                        <strong>@(note.IsImportant ? "Важная заметка" : "Заметка")</strong>
                                        <time>@FormatDateTime(note.CreatedAt)</time>
                                    </div>
                                    <p>@note.NoteText</p>
                                </article>
                            }
                        }
                    </div>
                }
            </section>
        </article>
    }
</section>

@code {
    [Parameter] public Guid ChildId { get; set; }

    private static readonly CultureInfo RuCulture = CultureInfo.GetCultureInfo("ru-RU");
    private readonly CancellationTokenSource _cts = new();

    private bool _isLoading = true;
    private string? _loadError;
    private DoctorPatientSummaryVm? _patient;
    private List<MeasurementVm> _measurements = [];
    private List<DoctorNoteVm> _notes = [];
    private bool _isNotesLoading;
    private bool _showNotesList;
    private string _noteText = string.Empty;
    private bool _noteIsImportant;
    private bool _isNoteSubmitting;
    private string? _noteError;

    private string PatientPageTitle => _patient is null
        ? "Пациент — SugarGuard"
        : $"{GetFullName(_patient)} — SugarGuard";

    private string PatientMeta => _patient is null
        ? string.Empty
        : $"{FormatDiabetesType(_patient.DiabetesType)} · {FormatAge(_patient.DateOfBirth)} · последнее измерение: {FormatMeasurementTime(_patient.LatestMeasurementTime)}";

    private string HypoHyperLabel => _measurements.Count == 0
        ? "— / —"
        : $"{_measurements.Count(m => m.GlucoseValue < 3.9m)} / {_measurements.Count(m => m.GlucoseValue > 10m)}";

    private string ChartSubtitle => ChartPoints.Count >= 2
        ? $"{ChartPoints.Count} точек за выбранный период"
        : "Недостаточно измерений для линии";

    private IReadOnlyList<ChartPoint> ChartPoints => BuildChartPoints();

    private string ChartPolyline => string.Join(" ", ChartPoints.Select(p => $"{p.XText},{p.YText}"));

    private string ChartAreaPath
    {
        get
        {
            var points = ChartPoints;
            if (points.Count == 0)
            {
                return string.Empty;
            }

            var path = string.Join(" L ", points.Select(p => $"{p.XText} {p.YText}"));
            return $"M {points[0].XText} 150 L {path} L {points[^1].XText} 150 Z";
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadAllAsync();
    }

    private async Task LoadAllAsync()
    {
        _isLoading = true;
        _loadError = null;
        _noteError = null;

        try
        {
            var patients = await ApiService.GetDoctorPatientsAsync("lastmeasurement", _cts.Token);
            _patient = patients.FirstOrDefault(p => p.ChildId == ChildId);

            if (_patient is null)
            {
                _loadError = "Пациент не найден или у вас нет доступа к его данным.";
                return;
            }

            var to = DateTime.UtcNow;
            var from = to.AddHours(-24);
            var measurementsTask = ApiService.GetMeasurementsAsync(ChildId, from, to, _cts.Token);
            var notesTask = LoadNotesCoreAsync();

            _measurements = (await measurementsTask)
                .OrderBy(m => m.MeasurementTime)
                .ToList();

            await notesTask;
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Ошибка загрузки детальной карточки пациента {ChildId}.", ChildId);
            _loadError = "Не удалось загрузить данные пациента. Попробуйте обновить страницу.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadNotesCoreAsync()
    {
        _isNotesLoading = true;

        try
        {
            var result = await ApiService.GetDoctorNotesAsync(
                ChildId,
                page: 1,
                pageSize: 20,
                onlyImportant: false,
                cancellationToken: _cts.Token);

            _notes = result.Items;
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Не удалось загрузить заметки пациента {ChildId}.", ChildId);
            _notes = [];
        }
        finally
        {
            _isNotesLoading = false;
        }
    }

    private async Task SubmitNoteAsync()
    {
        if (string.IsNullOrWhiteSpace(_noteText))
        {
            return;
        }

        _isNoteSubmitting = true;
        _noteError = null;

        try
        {
            await ApiService.CreateDoctorNoteAsync(
                new CreateDoctorNoteVmRequest
                {
                    ChildId = ChildId,
                    NoteText = _noteText.Trim(),
                    IsImportant = _noteIsImportant
                },
                _cts.Token);

            _noteText = string.Empty;
            _noteIsImportant = false;
            _showNotesList = true;
            await LoadNotesCoreAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Не удалось сохранить заметку пациента {ChildId}.", ChildId);
            _noteError = "Не удалось сохранить заметку. Попробуйте ещё раз.";
        }
        finally
        {
            _isNoteSubmitting = false;
        }
    }

    private void ToggleNotesList()
    {
        _showNotesList = !_showNotesList;
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/doctor/patients");
    }

    private IReadOnlyList<ChartPoint> BuildChartPoints()
    {
        var source = _measurements
            .OrderBy(m => m.MeasurementTime)
            .TakeLast(32)
            .ToList();

        if (source.Count == 0)
        {
            return Array.Empty<ChartPoint>();
        }

        const double minGlucose = 2.5;
        const double maxGlucose = 16.0;
        const double left = 40;
        const double width = 480;
        const double top = 18;
        const double height = 132;
        var denominator = Math.Max(1, source.Count - 1);

        return source.Select((measurement, index) =>
        {
            var normalized = ((double)measurement.GlucoseValue - minGlucose) / (maxGlucose - minGlucose);
            var y = top + (1 - Math.Clamp(normalized, 0, 1)) * height;
            var x = left + width * index / denominator;
            return new ChartPoint(
                x,
                y,
                measurement.GlucoseValue,
                measurement.MeasurementTime,
                GetToneForGlucose(measurement.GlucoseValue));
        }).ToList();
    }

    private static string GetFullName(DoctorPatientSummaryVm patient)
    {
        var name = patient.FullName.Trim();
        return string.IsNullOrWhiteSpace(name) ? "Пациент без имени" : name;
    }

    private static string GetInitials(DoctorPatientSummaryVm patient)
    {
        var parts = GetFullName(patient)
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        if (parts.Length >= 2)
        {
            return $"{char.ToUpper(parts[0][0], RuCulture)}{char.ToUpper(parts[1][0], RuCulture)}";
        }

        return parts.Length == 0 ? "?" : char.ToUpper(parts[0][0], RuCulture).ToString();
    }

    private static string FormatDiabetesType(string diabetesType)
    {
        if (string.IsNullOrWhiteSpace(diabetesType))
        {
            return "тип диабета не указан";
        }

        return diabetesType.Contains("type", StringComparison.OrdinalIgnoreCase)
            ? diabetesType.Replace("Type", "СД ", StringComparison.OrdinalIgnoreCase).Trim()
            : diabetesType;
    }

    private static string FormatAge(DateOnly dateOfBirth)
    {
        if (dateOfBirth == default)
        {
            return "возраст не указан";
        }

        var today = DateOnly.FromDateTime(DateTime.Today);
        var age = today.Year - dateOfBirth.Year;
        if (dateOfBirth > today.AddYears(-age))
        {
            age--;
        }

        return $"{age} лет";
    }

    private static string FormatGlucose(decimal? glucose)
    {
        return glucose.HasValue
            ? $"{glucose.Value.ToString("0.0", RuCulture)} ммоль/л"
            : "нет данных";
    }

    private static string FormatPercent(double value)
    {
        return $"{Math.Round(value, 1).ToString("0.#", RuCulture)}%";
    }

    private static string FormatLatestMeasurement(DoctorPatientSummaryVm patient)
    {
        if (patient.LatestMeasurementTime is null)
        {
            return "нет данных";
        }

        var diff = DateTime.UtcNow - EnsureUtc(patient.LatestMeasurementTime.Value);
        if (diff.TotalMinutes < 1)
        {
            return "только что";
        }

        if (diff.TotalHours < 1)
        {
            return $"{(int)diff.TotalMinutes} мин";
        }

        if (diff.TotalDays < 1)
        {
            return $"{(int)diff.TotalHours} ч";
        }

        return $"{(int)diff.TotalDays} дн";
    }

    private static string FormatMeasurementTime(DateTime? time)
    {
        return time.HasValue
            ? EnsureUtc(time.Value).ToLocalTime().ToString("dd.MM.yyyy HH:mm", RuCulture)
            : "нет данных";
    }

    private static string FormatDateTime(DateTime time)
    {
        return EnsureUtc(time).ToLocalTime().ToString("dd.MM.yyyy HH:mm", RuCulture);
    }

    private static DateTime EnsureUtc(DateTime value)
    {
        return value.Kind == DateTimeKind.Utc
            ? value
            : DateTime.SpecifyKind(value, DateTimeKind.Utc);
    }

    private static string GetTirCaption(double tir)
    {
        if (tir >= 70)
        {
            return "стабильно";
        }

        if (tir >= 50)
        {
            return "нужно наблюдение";
        }

        return "требует внимания";
    }

    private static string GetPatientStatusLabel(DoctorPatientSummaryVm patient)
    {
        if (IsCriticalPatient(patient))
        {
            return "Критично";
        }

        if (IsAttentionPatient(patient))
        {
            return "Внимание";
        }

        return "Стабильно";
    }

    private static string GetStatusTone(DoctorPatientSummaryVm patient)
    {
        if (IsCriticalPatient(patient))
        {
            return "danger";
        }

        return IsAttentionPatient(patient) ? "warning" : "success";
    }

    private static bool IsCriticalPatient(DoctorPatientSummaryVm patient)
    {
        return patient.CriticalEventsLast7Days > 0
            || IsUiState(patient.LatestGlucoseUiState, "Danger", "Critical")
            || patient.LatestGlucose is < 3.0m or > 13.9m;
    }

    private static bool IsAttentionPatient(DoctorPatientSummaryVm patient)
    {
        return IsUiState(patient.LatestGlucoseUiState, "Warning", "Attention")
            || patient.LatestGlucose is < 3.9m or > 10m
            || patient.TimeInTargetRange is > 0 and < 70
            || patient.MeasurementsLast7Days == 0;
    }

    private static bool IsUiState(string? value, params string[] accepted)
    {
        return accepted.Any(item => string.Equals(value, item, StringComparison.OrdinalIgnoreCase));
    }

    private static string GetToneForGlucose(decimal value)
    {
        if (value is < 3.0m or > 13.9m)
        {
            return "danger";
        }

        if (value is < 3.9m or > 10m)
        {
            return "warning";
        }

        return "success";
    }

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }

    private readonly record struct ChartPoint(
        double X,
        double Y,
        decimal Value,
        DateTime Time,
        string Tone)
    {
        public string XText => X.ToString("0.##", CultureInfo.InvariantCulture);
        public string YText => Y.ToString("0.##", CultureInfo.InvariantCulture);
    }
}
