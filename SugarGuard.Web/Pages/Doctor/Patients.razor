@page "/doctor/patients"
@using System.Globalization
@using System.Text
@using Microsoft.AspNetCore.Authorization
@using SugarGuard.Web.Services
@using DoctorNoteVm = SugarGuard.Web.ViewModels.DoctorNoteVm
@using static SugarGuard.Web.Services.SugarGuardApiService
@attribute [Authorize(Roles = "Doctor,Admin,SupportAdmin")]
@implements IDisposable
@inject SugarGuardApiService ApiService
@inject NavigationManager Nav
@inject ILogger<Patients> Logger

<PageTitle>Мои пациенты — SugarGuard</PageTitle>

<section class="doctor-portal" aria-labelledby="doctorPatientsTitle">
    <header class="doctor-hero">
        <div>
            <div class="doctor-eyebrow">Кабинет врача</div>
            <h1 id="doctorPatientsTitle">Мои пациенты</h1>
            <p>Список детей, прикреплённых к вашей учётной записи. Все показатели рассчитаны по реальным данным системы.</p>
        </div>

        <div class="doctor-hero-actions">
            <span class="doctor-sync-pill">
                <span class="doctor-sync-dot" aria-hidden="true"></span>
                @_lastUpdatedLabel
            </span>
            <a class="doctor-btn doctor-btn--soft @(ExportDisabled ? "is-disabled" : null)"
               href="@PatientsCsvHref"
               download="sugarguard-doctor-patients.csv"
               aria-disabled="@ExportDisabled"
               @onclick:preventDefault="ExportDisabled">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                    <polyline points="7 10 12 15 17 10" />
                    <line x1="12" y1="15" x2="12" y2="3" />
                </svg>
                Экспорт
            </a>
            <button class="doctor-btn doctor-btn--primary"
                    type="button"
                    disabled="@(!_patients.Any())"
                    @onclick="OpenFirstPatientNote">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <line x1="12" y1="5" x2="12" y2="19" />
                    <line x1="5" y1="12" x2="19" y2="12" />
                </svg>
                Новая записка
            </button>
        </div>
    </header>

    @if (_isLoading)
    {
        <div class="doctor-skeleton" role="status" aria-label="Загрузка пациентов">
            <div class="doctor-kpi-grid">
                @for (var i = 0; i < 4; i++)
                {
                    <div class="doctor-kpi-card doctor-skeleton-card">
                        <span></span>
                        <strong></strong>
                        <small></small>
                    </div>
                }
            </div>
            <div class="doctor-table-card">
                @for (var i = 0; i < 4; i++)
                {
                    <div class="doctor-skeleton-row"></div>
                }
            </div>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <div class="doctor-alert doctor-alert--danger" role="alert">
            <div>
                <strong>Не удалось загрузить пациентов</strong>
                <p>@_errorMessage</p>
            </div>
            <button class="doctor-btn doctor-btn--soft" type="button" @onclick="() => LoadDataAsync()">
                Повторить
            </button>
        </div>
    }
    else
    {
        <div class="doctor-kpi-grid" aria-label="Сводка по пациентам">
            <article class="doctor-kpi-card">
                <span class="doctor-kpi-label">Всего пациентов</span>
                <strong class="doctor-kpi-value">@TotalPatients</strong>
                <small class="doctor-kpi-caption doctor-kpi-caption--success">активно прикреплены к врачу</small>
            </article>
            <article class="doctor-kpi-card">
                <span class="doctor-kpi-label">Средний TIR группы</span>
                <strong class="doctor-kpi-value">@FormatPercent(AverageTir)</strong>
                <small class="doctor-kpi-caption doctor-kpi-caption--success">за последние 7 дней</small>
            </article>
            <article class="doctor-kpi-card">
                <span class="doctor-kpi-label">Требуют внимания</span>
                <strong class="doctor-kpi-value doctor-kpi-value--warning">@AttentionPatientsCount</strong>
                <small class="doctor-kpi-caption doctor-kpi-caption--warning">низкий TIR или нет свежих данных</small>
            </article>
            <article class="doctor-kpi-card">
                <span class="doctor-kpi-label">Критических алертов</span>
                <strong class="doctor-kpi-value doctor-kpi-value--danger">@CriticalAlertsCount</strong>
                <small class="doctor-kpi-caption doctor-kpi-caption--danger">за последние 24 часа</small>
            </article>
        </div>

        <div class="doctor-toolbar">
            <label class="doctor-search" for="doctorPatientSearch">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <circle cx="11" cy="11" r="8" />
                    <line x1="21" y1="21" x2="16.65" y2="16.65" />
                </svg>
                <input id="doctorPatientSearch"
                       type="search"
                       placeholder="Поиск пациента..."
                       value="@_searchQuery"
                       @oninput="OnSearchChanged" />
            </label>

            <div class="doctor-filters" role="group" aria-label="Фильтр пациентов">
                <button class="doctor-filter-chip @(IsFilterActive(FilterAll) ? "active" : null)"
                        type="button"
                        @onclick="() => SetStatusFilter(FilterAll)">
                    Все
                </button>
                <button class="doctor-filter-chip @(IsFilterActive(FilterCritical) ? "active" : null)"
                        type="button"
                        @onclick="() => SetStatusFilter(FilterCritical)">
                    <span class="doctor-filter-dot doctor-filter-dot--danger" aria-hidden="true"></span>
                    Критично
                </button>
                <button class="doctor-filter-chip @(IsFilterActive(FilterAttention) ? "active" : null)"
                        type="button"
                        @onclick="() => SetStatusFilter(FilterAttention)">
                    <span class="doctor-filter-dot doctor-filter-dot--warning" aria-hidden="true"></span>
                    Внимание
                </button>
                <button class="doctor-filter-chip @(IsFilterActive(FilterStable) ? "active" : null)"
                        type="button"
                        @onclick="() => SetStatusFilter(FilterStable)">
                    <span class="doctor-filter-dot doctor-filter-dot--success" aria-hidden="true"></span>
                    Стабильно
                </button>
            </div>

            <label class="doctor-sort" for="doctorSortSelect">
                <span class="sr-only">Сортировка</span>
                <select id="doctorSortSelect"
                        @bind="_sortBy"
                        @bind:after="OnSortChangedAsync">
                    <option value="lastmeasurement">По последнему измерению</option>
                    <option value="tir">По TIR</option>
                    <option value="name">По имени</option>
                </select>
            </label>
        </div>

        @if (FilteredPatients.Count == 0)
        {
            <div class="doctor-empty">
                <div class="doctor-empty-icon" aria-hidden="true">∅</div>
                <h2>@(_patients.Count == 0 ? "Пока нет прикреплённых пациентов" : "Пациенты не найдены")</h2>
                <p>
                    @(_patients.Count == 0
                        ? "Когда администратор или родитель прикрепит ребёнка к врачу, он появится в этом списке."
                        : "Измените поисковую строку или фильтр статуса.")
                </p>
                @if (_patients.Count > 0)
                {
                    <button class="doctor-btn doctor-btn--soft" type="button" @onclick="ClearSearchAndFilters">
                        Сбросить фильтры
                    </button>
                }
            </div>
        }
        else
        {
            <div class="doctor-table-card">
                <table class="doctor-table" aria-label="Список пациентов врача">
                    <thead>
                        <tr>
                            <th>Пациент</th>
                            <th>Возраст</th>
                            <th class="num">TIR 7д</th>
                            <th>Прогресс</th>
                            <th>Последн. измер.</th>
                            <th>Гипо / гипер</th>
                            <th>Статус</th>
                            <th class="actions"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var patient in FilteredPatients)
                        {
                            var status = GetPatientStatus(patient);
                            <tr @key="patient.ChildId">
                                <td>
                                    <div class="doctor-patient-name">
                                        <span class="doctor-avatar"
                                              style="background:@GetAvatarGradient(patient)"
                                              aria-hidden="true">
                                            @GetInitials(patient)
                                        </span>
                                        <div>
                                            <strong>@GetFullName(patient)</strong>
                                            <small>@FormatDiabetesType(patient.DiabetesType)</small>
                                        </div>
                                    </div>
                                </td>
                                <td>@FormatAge(patient.DateOfBirth)</td>
                                <td class="num @GetTirTextClass(patient.TimeInTargetRange)">@FormatPercent(patient.TimeInTargetRange)</td>
                                <td>
                                    <div class="doctor-progress" aria-label="TIR @FormatPercent(patient.TimeInTargetRange)">
                                        <span class="@GetTirFillClass(patient.TimeInTargetRange)"
                                              style="width:@FormatProgressWidth(patient.TimeInTargetRange)">
                                        </span>
                                    </div>
                                </td>
                                <td class="muted">@FormatMeasurementTime(patient.LatestMeasurementTime)</td>
                                <td>@FormatHypoHyper(patient)</td>
                                <td>
                                    <span class="doctor-chip @status.CssClass">
                                        <span class="doctor-chip-dot" aria-hidden="true"></span>
                                        @status.Label
                                    </span>
                                </td>
                                <td>
                                    <div class="doctor-row-actions">
                                        <button class="doctor-row-button"
                                                type="button"
                                                @onclick="() => NavigateToPatient(patient.ChildId)">
                                            Открыть
                                        </button>
                                        <button class="doctor-row-button doctor-row-button--soft"
                                                type="button"
                                                @onclick="() => OpenAddNoteModal(patient)"
                                                aria-label="Добавить заметку для @GetFullName(patient)">
                                            + Заметка
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
</section>

@if (_isNoteModalOpen && _selectedPatient is not null)
{
    <div class="doctor-modal-backdrop"
         role="dialog"
         aria-modal="true"
         aria-labelledby="noteModalTitle"
         @onclick="CloseNoteModal">
        <div class="doctor-modal" @onclick:stopPropagation="true">
            <header class="doctor-modal-header">
                <div>
                    <h2 id="noteModalTitle">Заметка для @GetFullName(_selectedPatient)</h2>
                    <p>Клиническая заметка сохранится в карте пациента.</p>
                </div>
                <button class="doctor-modal-close"
                        type="button"
                        @onclick="CloseNoteModal"
                        aria-label="Закрыть">
                    ×
                </button>
            </header>
            <div class="doctor-modal-body">
                <label class="doctor-field" for="noteText">
                    <span>Текст заметки</span>
                    <textarea id="noteText"
                              rows="5"
                              maxlength="4000"
                              placeholder="Например: обсудить ночные гипо, скорректировать перекус перед тренировкой..."
                              @bind="_noteText"
                              @bind:event="oninput">
                    </textarea>
                </label>
                <div class="doctor-note-meta">
                    <label class="doctor-checkbox">
                        <input type="checkbox" @bind="_noteIsImportant" />
                        <span>Важная заметка</span>
                    </label>
                    <span>@_noteText.Length / 4000</span>
                </div>
                @if (!string.IsNullOrWhiteSpace(_noteError))
                {
                    <div class="doctor-inline-error" role="alert">@_noteError</div>
                }
            </div>
            <footer class="doctor-modal-footer">
                <button class="doctor-btn doctor-btn--ghost"
                        type="button"
                        disabled="@_isNoteSubmitting"
                        @onclick="CloseNoteModal">
                    Отмена
                </button>
                <button class="doctor-btn doctor-btn--primary"
                        type="button"
                        disabled="@(_isNoteSubmitting || string.IsNullOrWhiteSpace(_noteText))"
                        @onclick="SubmitNoteAsync">
                    @(_isNoteSubmitting ? "Сохраняем..." : "Сохранить")
                </button>
            </footer>
        </div>
    </div>
}

@code {
    private static readonly CultureInfo RuCulture = CultureInfo.GetCultureInfo("ru-RU");
    private static readonly TimeZoneInfo MoscowTimeZone = ResolveMoscowTimeZone();
    private const string FilterAll = "all";
    private const string FilterCritical = "critical";
    private const string FilterAttention = "attention";
    private const string FilterStable = "stable";

    private static readonly string[] AvatarGradients =
    [
        "linear-gradient(135deg,#DB5967,#FF8FA0)",
        "linear-gradient(135deg,#E3A32B,#F4BC56)",
        "linear-gradient(135deg,#1B8E8B,#56D0BF)",
        "linear-gradient(135deg,#2678D9,#6DAEFF)",
        "linear-gradient(135deg,#37A563,#62D889)"
    ];

    private readonly CancellationTokenSource _cts = new();
    private readonly SemaphoreSlim _refreshGate = new(1, 1);
    private Task? _refreshTask;

    private bool _isLoading = true;
    private string? _errorMessage;
    private DateTime? _lastLoadedAt;

    private List<DoctorPatientSummaryVm> _patients = [];
    private DoctorCohortSummaryVm? _cohortSummary;
    private Dictionary<Guid, DoctorNoteVm?> _notesByChild = [];

    private string _searchQuery = string.Empty;
    private string _sortBy = "lastmeasurement";
    private string _statusFilter = FilterAll;

    private bool _isNoteModalOpen;
    private DoctorPatientSummaryVm? _selectedPatient;
    private string _noteText = string.Empty;
    private bool _noteIsImportant;
    private bool _isNoteSubmitting;
    private string? _noteError;

    private string _lastUpdatedLabel =>
        _lastLoadedAt is null
            ? "Данные загружаются"
            : $"Данные обновлены: {_lastLoadedAt.Value:HH:mm}";

    private int TotalPatients => _cohortSummary?.TotalPatients ?? _patients.Count;

    private double AverageTir => _cohortSummary?.AverageTimeInTargetRange
        ?? (_patients.Count == 0 ? 0 : Math.Round(_patients.Average(p => p.TimeInTargetRange), 1));

    private int AttentionPatientsCount => _patients.Count(p => IsCriticalPatient(p) || IsAttentionPatient(p));

    private int CriticalAlertsCount => _cohortSummary?.PatientsWithCriticalToday
        ?? _patients.Count(IsCriticalPatient);

    private bool ExportDisabled => FilteredPatients.Count == 0;

    private string PatientsCsvHref => ExportDisabled
        ? "#"
        : $"data:text/csv;charset=utf-8,{Uri.EscapeDataString("\uFEFF" + BuildPatientsCsv())}";

    private List<DoctorPatientSummaryVm> FilteredPatients => _patients
        .Where(MatchesSearch)
        .Where(MatchesStatusFilter)
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
        _refreshTask = RunLiveRefreshAsync(_cts.Token);
    }

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }

    private async Task LoadDataAsync(bool showLoading = true)
    {
        if (!await _refreshGate.WaitAsync(0, _cts.Token))
        {
            return;
        }

        if (showLoading)
        {
            _isLoading = true;
            _errorMessage = null;
        }

        try
        {
            var patientsTask = ApiService.GetDoctorPatientsAsync(_sortBy, _cts.Token);
            var cohortTask = ApiService.GetDoctorCohortSummaryAsync(_cts.Token);

            await Task.WhenAll(patientsTask, cohortTask);

            _patients = (await patientsTask).ToList();
            _cohortSummary = await cohortTask;
            _lastLoadedAt = ToMoscowTime(_cohortSummary?.GeneratedAt ?? DateTime.UtcNow);

            await LoadLatestNotesAsync();
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception ex)
        {
            if (showLoading)
            {
                _errorMessage = ex.Message;
            }
            else
            {
                Logger.LogWarning(ex, "Не удалось автоматически обновить список пациентов врача.");
            }
        }
        finally
        {
            if (showLoading)
            {
                _isLoading = false;
            }

            _refreshGate.Release();
        }
    }

    private async Task RunLiveRefreshAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(15));

        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                await InvokeAsync(async () =>
                {
                    await LoadDataAsync(showLoading: false);
                    StateHasChanged();
                });
            }
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
        {
        }
    }

    private async Task LoadLatestNotesAsync()
    {
        _notesByChild.Clear();
        if (_patients.Count == 0)
        {
            return;
        }

        var latestNotes = await Task.WhenAll(_patients.Select(async patient =>
        {
            try
            {
                var notes = await ApiService.GetDoctorNotesAsync(
                    patient.ChildId,
                    page: 1,
                    pageSize: 1,
                    onlyImportant: false,
                    cancellationToken: _cts.Token);

                return (patient.ChildId, note: notes.Items.FirstOrDefault());
            }
            catch
            {
                return (patient.ChildId, note: null);
            }
        }));

        foreach (var (childId, note) in latestNotes)
        {
            _notesByChild[childId] = note;
        }
    }

    private async Task OnSortChangedAsync()
    {
        await LoadDataAsync();
    }

    private void SetStatusFilter(string filter)
    {
        _statusFilter = filter;
    }

    private bool IsFilterActive(string filter) => string.Equals(_statusFilter, filter, StringComparison.Ordinal);

    private void ClearSearchAndFilters()
    {
        _searchQuery = string.Empty;
        _statusFilter = FilterAll;
    }

    private void NavigateToPatient(Guid childId)
    {
        Nav.NavigateTo($"/doctor/patients/{childId:D}");
    }

    private void OpenFirstPatientNote()
    {
        var patient = FilteredPatients.FirstOrDefault() ?? _patients.FirstOrDefault();
        if (patient is not null)
        {
            OpenAddNoteModal(patient);
        }
    }

    private void OpenAddNoteModal(DoctorPatientSummaryVm patient)
    {
        _selectedPatient = patient;
        _noteText = string.Empty;
        _noteIsImportant = false;
        _noteError = null;
        _isNoteSubmitting = false;
        _isNoteModalOpen = true;
    }

    private void CloseNoteModal()
    {
        if (_isNoteSubmitting)
        {
            return;
        }

        _isNoteModalOpen = false;
        _selectedPatient = null;
    }

    private async Task SubmitNoteAsync()
    {
        if (_selectedPatient is null || string.IsNullOrWhiteSpace(_noteText))
        {
            return;
        }

        _isNoteSubmitting = true;
        _noteError = null;

        try
        {
            await ApiService.CreateDoctorNoteAsync(
                new CreateDoctorNoteVmRequest
                {
                    ChildId = _selectedPatient.ChildId,
                    NoteText = _noteText.Trim(),
                    IsImportant = _noteIsImportant
                },
                _cts.Token);

            var notes = await ApiService.GetDoctorNotesAsync(
                _selectedPatient.ChildId,
                page: 1,
                pageSize: 1,
                onlyImportant: false,
                cancellationToken: _cts.Token);

            _notesByChild[_selectedPatient.ChildId] = notes.Items.FirstOrDefault();
            _isNoteModalOpen = false;
            _selectedPatient = null;
        }
        catch (Exception ex)
        {
            _noteError = $"Не удалось сохранить заметку: {ex.Message}";
        }
        finally
        {
            _isNoteSubmitting = false;
        }
    }

    private bool MatchesSearch(DoctorPatientSummaryVm patient)
    {
        var query = _searchQuery.Trim();
        if (query.Length == 0)
        {
            return true;
        }

        return GetFullName(patient).Contains(query, StringComparison.OrdinalIgnoreCase)
            || patient.ChildId.ToString("D").Contains(query, StringComparison.OrdinalIgnoreCase);
    }

    private bool MatchesStatusFilter(DoctorPatientSummaryVm patient) => _statusFilter switch
    {
        FilterCritical => IsCriticalPatient(patient),
        FilterAttention => !IsCriticalPatient(patient) && IsAttentionPatient(patient),
        FilterStable => !IsCriticalPatient(patient) && !IsAttentionPatient(patient),
        _ => true
    };

    private static (string Label, string CssClass) GetPatientStatus(DoctorPatientSummaryVm patient)
    {
        if (IsCriticalPatient(patient))
        {
            return ("Критично", "doctor-chip--danger");
        }

        if (IsAttentionPatient(patient))
        {
            return ("Внимание", "doctor-chip--warning");
        }

        return ("Стабильно", "doctor-chip--success");
    }

    private static bool IsCriticalPatient(DoctorPatientSummaryVm patient)
    {
        if (patient.CriticalEventsLast7Days > 0)
        {
            return true;
        }

        return string.Equals(patient.LatestGlucoseUiState, "Danger", StringComparison.OrdinalIgnoreCase)
            || (patient.LatestGlucose is < 3.0m or > 13.9m);
    }

    private static bool IsAttentionPatient(DoctorPatientSummaryVm patient)
    {
        if (patient.TimeInTargetRange is > 0 and < 70)
        {
            return true;
        }

        if (!HasFreshMeasurement(patient))
        {
            return true;
        }

        return string.Equals(patient.LatestGlucoseUiState, "Warning", StringComparison.OrdinalIgnoreCase)
            || patient.LatestGlucose is < 4.0m or > 10m;
    }

    private static bool HasFreshMeasurement(DoctorPatientSummaryVm patient)
    {
        return patient.LatestMeasurementTime is not null
            && patient.LatestMeasurementTime.Value >= DateTime.UtcNow.AddHours(-24);
    }

    private static string GetFullName(DoctorPatientSummaryVm patient)
    {
        var fullName = patient.FullName.Trim();
        return string.IsNullOrWhiteSpace(fullName) ? "Пациент без имени" : fullName;
    }

    private static string GetInitials(DoctorPatientSummaryVm patient)
    {
        var name = GetFullName(patient);
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
        {
            return $"{char.ToUpperInvariant(parts[0][0])}{char.ToUpperInvariant(parts[1][0])}";
        }

        return char.ToUpperInvariant(parts[0][0]).ToString();
    }

    private static string GetAvatarGradient(DoctorPatientSummaryVm patient)
    {
        var index = Math.Abs(patient.ChildId.GetHashCode()) % AvatarGradients.Length;
        return AvatarGradients[index];
    }

    private static string FormatDiabetesType(string diabetesType)
    {
        if (string.IsNullOrWhiteSpace(diabetesType))
        {
            return "тип диабета не указан";
        }

        return diabetesType.Trim().ToLowerInvariant() switch
        {
            "type1" => "СД1",
            "type2" => "СД2",
            "gestational" => "Гестационный диабет",
            _ => diabetesType.Trim()
        };
    }

    private static string FormatAge(DateOnly dateOfBirth)
    {
        if (dateOfBirth == default)
        {
            return "—";
        }

        var today = DateOnly.FromDateTime(DateTime.Today);
        var age = today.Year - dateOfBirth.Year;
        if (dateOfBirth > today.AddYears(-age))
        {
            age--;
        }

        return $"{age} лет";
    }

    private static string FormatPercent(double value)
    {
        return $"{Math.Round(value, 1).ToString("0.#", RuCulture)}%";
    }

    private static string FormatProgressWidth(double value)
    {
        var clamped = Math.Clamp(value, 0, 100);
        return $"{clamped.ToString("0.#", CultureInfo.InvariantCulture)}%";
    }

    private static string GetTirTextClass(double tir)
    {
        if (tir >= 70) return "doctor-text-success";
        if (tir >= 50) return "doctor-text-warning";
        return "doctor-text-danger";
    }

    private static string GetTirFillClass(double tir)
    {
        if (tir >= 70) return "doctor-progress-fill doctor-progress-fill--success";
        if (tir >= 50) return "doctor-progress-fill doctor-progress-fill--warning";
        return "doctor-progress-fill doctor-progress-fill--danger";
    }

    private static string FormatMeasurementTime(DateTime? time)
    {
        if (time is null)
        {
            return "нет данных";
        }

        var measurementUtc = time.Value.Kind == DateTimeKind.Local
            ? time.Value.ToUniversalTime()
            : time.Value;

        var diff = DateTime.UtcNow - measurementUtc;
        if (diff.TotalSeconds < 0)
        {
            return ToMoscowTime(measurementUtc).ToString("dd.MM.yyyy HH:mm", RuCulture);
        }

        if (diff.TotalMinutes < 1) return "только что";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes} мин назад";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours} ч назад";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays} дн назад";

        return ToMoscowTime(measurementUtc).ToString("dd.MM.yyyy", RuCulture);
    }

    private void OnSearchChanged(ChangeEventArgs args)
    {
        _searchQuery = args.Value?.ToString() ?? string.Empty;
    }

    private static DateTime ToMoscowTime(DateTime value)
    {
        var utc = value.Kind switch
        {
            DateTimeKind.Utc => value,
            DateTimeKind.Local => value.ToUniversalTime(),
            _ => DateTime.SpecifyKind(value, DateTimeKind.Utc)
        };

        return TimeZoneInfo.ConvertTimeFromUtc(utc, MoscowTimeZone);
    }

    private static TimeZoneInfo ResolveMoscowTimeZone()
    {
        foreach (var id in new[] { "Europe/Moscow", "Russian Standard Time" })
        {
            try
            {
                return TimeZoneInfo.FindSystemTimeZoneById(id);
            }
            catch (TimeZoneNotFoundException)
            {
            }
            catch (InvalidTimeZoneException)
            {
            }
        }

        return TimeZoneInfo.Local;
    }

    private static string FormatHypoHyper(DoctorPatientSummaryVm patient)
    {
        if (patient.LatestGlucose is null)
        {
            return "— / —";
        }

        var hypo = patient.LatestGlucose < 4.0m ? 1 : 0;
        var hyper = patient.LatestGlucose > 10m ? 1 : 0;
        return $"{hypo} / {hyper}";
    }

    private string BuildPatientsCsv()
    {
        var rows = new StringBuilder();
        rows.AppendLine("Пациент;Возраст;TIR 7д;Последнее измерение;Гипо / гипер;Статус;Глюкоза");

        foreach (var patient in FilteredPatients)
        {
            var status = GetPatientStatus(patient);
            rows.Append(Csv(GetFullName(patient))).Append(';')
                .Append(Csv(FormatAge(patient.DateOfBirth))).Append(';')
                .Append(Csv(FormatPercent(patient.TimeInTargetRange))).Append(';')
                .Append(Csv(FormatMeasurementTime(patient.LatestMeasurementTime))).Append(';')
                .Append(Csv(FormatHypoHyper(patient))).Append(';')
                .Append(Csv(status.Label)).Append(';')
                .AppendLine(Csv(patient.LatestGlucose?.ToString("0.0", RuCulture) ?? "—"));
        }

        return rows.ToString();
    }

    private static string Csv(string value)
    {
        var quote = ((char)34).ToString();
        return string.Concat(quote, value.Replace(quote, quote + quote), quote);
    }

