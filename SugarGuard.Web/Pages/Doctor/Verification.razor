@page "/doctor/verification"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "DoctorPending")]

@using System.ComponentModel.DataAnnotations
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using SugarGuard.Web.Services

@inject SugarGuardApiService Api

<PageTitle>Подтверждение врача — SugarGuard</PageTitle>

<div class="verification-page">
    <PageHeader Eyebrow="КАБИНЕТ ВРАЧА" Title="Подтверждение квалификации"
                Subtitle="До проверки документов кабинет работает в ограниченном режиме: данные пациентов недоступны." />

    @if (_loading)
    {
        <section class="verification-card"><p>Загружаем статус заявки…</p></section>
    }
    else if (_request?.Status == "Submitted")
    {
        <section class="verification-card verification-card--pending">
            <span class="verification-icon">⏳</span>
            <div><h2>Документы отправлены на проверку</h2><p>Администратор проверит квалификацию и откроет доступ к кабинету врача. Мы сообщим о результате на email.</p></div>
            <dl class="request-details"><dt>Специальность</dt><dd>@_request.Specialty</dd><dt>Отправлено</dt><dd>@FormatDate(_request.SubmittedAt)</dd><dt>Документов</dt><dd>@_request.Documents.Count</dd></dl>
        </section>
    }
    else
    {
        <section class="verification-card">
            <div class="verification-intro"><span class="verification-icon">🩺</span><div><h2>Подтвердите, что вы врач</h2><p>Приложите документы, подтверждающие квалификацию. Их увидят только полные администраторы SugarGuard.</p></div></div>
            @if (!string.IsNullOrWhiteSpace(_error)) { <div class="verification-alert verification-alert--error">@_error</div> }
            @if (_request?.Status == "Rejected") { <div class="verification-alert verification-alert--warning"><strong>Предыдущая заявка отклонена.</strong> @_request.ReviewComment Исправьте данные и отправьте документы повторно.</div> }
            <EditForm Model="_model" OnValidSubmit="SubmitAsync" FormName="doctor-verification">
                <DataAnnotationsValidator />
                <div class="verification-grid">
                    <div class="form-field"><label for="specialty">Специальность</label><input id="specialty" @bind="_model.Specialty" placeholder="Например, эндокринолог" /><ValidationMessage For="@(() => _model.Specialty)" /></div>
                    <div class="form-field"><label for="license">Номер сертификата / аккредитации</label><input id="license" @bind="_model.LicenseNumber" placeholder="Укажите номер документа" /><ValidationMessage For="@(() => _model.LicenseNumber)" /></div>
                    <div class="form-field form-field--full"><label for="organization">Место работы <span>необязательно</span></label><input id="organization" @bind="_model.OrganizationName" placeholder="Название медицинской организации" /></div>
                    <div class="form-field form-field--full"><label for="comment">Комментарий <span>необязательно</span></label><textarea id="comment" @bind="_model.Comment" rows="3" placeholder="Например, регион практики или пояснение к документам"></textarea></div>
                    <div class="form-field form-field--full"><label for="documents">Документы</label><InputFile id="documents" OnChange="SelectDocuments" multiple accept="application/pdf,image/jpeg,image/png" /><small>От 1 до 3 файлов: PDF, JPEG или PNG, до 10 МБ каждый.</small>
                        @if (_documents.Count > 0) { <ul class="document-list">@foreach (var document in _documents) { <li>@document.Name <span>@FormatSize(document.Size)</span></li> }</ul> }
                    </div>
                </div>
                <button class="btn btn-primary" type="submit" disabled="@_submitting">@(_submitting ? "Отправляем…" : "Отправить на проверку")</button>
            </EditForm>
        </section>
    }
</div>

<style>
    .verification-page { display:grid; gap:20px; max-width:980px; }
    .verification-card { display:grid; gap:22px; padding:clamp(20px,4vw,36px); background:var(--color-surface); border:1px solid var(--color-border); border-radius:var(--radius-lg); box-shadow:var(--shadow-card); }
    .verification-card--pending { grid-template-columns:auto 1fr; align-items:start; }
    .verification-intro { display:flex; gap:16px; align-items:flex-start; } .verification-intro h2,.verification-card h2{margin:0 0 6px;font-family:var(--font-display);font-size:clamp(1.25rem,3vw,1.65rem)} .verification-card p{margin:0;color:var(--color-text-muted);line-height:1.55}
    .verification-icon { display:grid;place-items:center;width:52px;height:52px;border-radius:16px;background:rgba(27,142,139,.12);font-size:25px;flex:0 0 auto; }
    .verification-grid { display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:16px; } .form-field{display:grid;gap:7px}.form-field--full{grid-column:1/-1}.form-field label{font-size:13px;font-weight:700;color:var(--color-text)}.form-field label span,.form-field small{font-weight:400;color:var(--color-text-muted)}
    .form-field input,.form-field textarea { width:100%;box-sizing:border-box;border:1px solid var(--color-border);border-radius:var(--radius-sm);padding:12px 13px;font:inherit;color:var(--color-text);background:var(--color-surface-2); }.form-field input:focus,.form-field textarea:focus{outline:2px solid rgba(27,142,139,.23);border-color:var(--color-primary)}
    .verification-alert{padding:12px 14px;border-radius:var(--radius-sm);font-size:14px;line-height:1.45}.verification-alert--error{background:rgba(219,89,103,.1);color:#b63948}.verification-alert--warning{background:rgba(220,151,20,.12);color:#805500}.document-list{margin:0;padding:0;list-style:none;display:grid;gap:6px}.document-list li{display:flex;justify-content:space-between;gap:12px;padding:8px 10px;border-radius:9px;background:var(--color-surface-offset);font-size:13px}.document-list span{color:var(--color-text-muted)}
    .request-details{display:grid;grid-template-columns:auto 1fr;gap:8px 18px;margin:0;grid-column:1/-1}.request-details dt{color:var(--color-text-muted);font-size:13px}.request-details dd{margin:0;font-weight:600;font-size:14px}
    @@media(max-width:640px){.verification-card--pending{grid-template-columns:1fr}.verification-grid{grid-template-columns:1fr}.form-field--full{grid-column:auto}.verification-page{gap:14px}.verification-card{padding:20px}.document-list li{align-items:flex-start;flex-direction:column;gap:2px}}
</style>

@code {
    private readonly VerificationModel _model = new();
    private readonly List<IBrowserFile> _documents = [];
    private VerificationResponse? _request;
    private bool _loading = true;
    private bool _submitting;
    private string? _error;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            using var response = await Api.GetMyDoctorVerificationAsync();
            if (response.IsSuccessStatusCode) _request = await response.Content.ReadFromJsonAsync<VerificationResponse>();
            else if (response.StatusCode != System.Net.HttpStatusCode.NotFound) _error = "Не удалось загрузить статус заявки. Обновите страницу.";
        }
        finally { _loading = false; }
    }

    private void SelectDocuments(InputFileChangeEventArgs args)
    {
        _documents.Clear();
        _documents.AddRange(args.GetMultipleFiles(3));
        _error = _documents.Any(file => file.Size > 10L * 1024 * 1024) ? "Размер каждого документа не должен превышать 10 МБ." : null;
    }

    private async Task SubmitAsync()
    {
        if (_documents.Count is < 1 or > 3) { _error = "Приложите от одного до трёх документов."; return; }
        if (_documents.Any(file => file.Size > 10L * 1024 * 1024)) { _error = "Размер каждого документа не должен превышать 10 МБ."; return; }
        _submitting = true; _error = null;
        try
        {
            using var response = await Api.SubmitDoctorVerificationAsync(_model.Specialty.Trim(), _model.LicenseNumber.Trim(), _model.OrganizationName, _model.Comment, _documents);
            if (!response.IsSuccessStatusCode) { _error = await ReadErrorAsync(response); return; }
            _request = await response.Content.ReadFromJsonAsync<VerificationResponse>();
        }
        catch (Exception) { _error = "Не удалось отправить заявку. Проверьте подключение и повторите попытку."; }
        finally { _submitting = false; }
    }

    private static async Task<string> ReadErrorAsync(HttpResponseMessage response)
    {
        try { var error = await response.Content.ReadFromJsonAsync<ApiError>(); return error?.Message ?? "Не удалось отправить заявку."; } catch { return "Не удалось отправить заявку."; }
    }
    private static string FormatSize(long value) => value < 1024 * 1024 ? $"{value / 1024d:0} КБ" : $"{value / 1024d / 1024d:0.0} МБ";
    private static string FormatDate(DateTime? value) => value?.ToLocalTime().ToString("dd.MM.yyyy HH:mm") ?? "—";
    private sealed class VerificationModel { [Required(ErrorMessage="Укажите специальность"), StringLength(200, MinimumLength=2)] public string Specialty {get;set;}=string.Empty; [Required(ErrorMessage="Укажите номер документа"), StringLength(120, MinimumLength=3)] public string LicenseNumber {get;set;}=string.Empty; public string? OrganizationName {get;set;} public string? Comment {get;set;} }
    private sealed class VerificationResponse { public string Status {get;set;}=string.Empty; public string Specialty {get;set;}=string.Empty; public DateTime? SubmittedAt {get;set;} public string? ReviewComment {get;set;} public List<Document> Documents {get;set;}=[]; }
    private sealed class Document { public string FileName {get;set;}=string.Empty; }
    private sealed class ApiError { public string? Message {get;set;} }
}
