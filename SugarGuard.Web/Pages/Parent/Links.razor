@page "/parent/children/{ChildId:guid}/links"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.JSInterop
@using SugarGuard.Domain.Enums
@using SugarGuard.Shared.Constants
@using static SugarGuard.Web.Services.SugarGuardApiService
@using InviteCodeVm = SugarGuard.Web.ViewModels.InviteCodeVm
@using LinkedAccessUserVm = SugarGuard.Web.ViewModels.LinkedAccessUserVm
@attribute [Authorize(Roles = Roles.Parent)]
@inject SugarGuardApiService ApiService
@inject NavigationManager NavigationManager
@inject IJSRuntime Js


<PageTitle>Доступ к ребёнку — SugarGuard</PageTitle>

@* Breadcrumb *@
<PageHeader Title="Управление доступом"
            Subtitle="@($"Выдайте инвайт-код врачу или другому родителю, чтобы они могли видеть данные {_childName}.")"
            Breadcrumbs="@(new List<BreadcrumbItem> { new("Дашборд", "/parent/dashboard"), new("Управление доступом", null) })" />

@if (_loadError is not null)
{
    <div class="sg-alert sg-alert--danger" role="alert">
        <svg class="sg-alert__icon" viewBox="0 0 20 20" fill="none"
             stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <circle cx="10" cy="10" r="8"/>
            <line x1="10" y1="6" x2="10" y2="10"/>
            <circle cx="10" cy="13.5" r="0.8" fill="currentColor" stroke="none"/>
        </svg>
        @_loadError
    </div>
}

@* Блок «Пригласить» *@
<div class="sg-cards-grid">

    @* Карточка: пригласить родителя *@
    <section class="sg-card sg-card--glass" aria-labelledby="invite-parent-title">
        <div class="sg-card__head">
            <div class="sg-card__icon sg-card__icon--primary" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                    <circle cx="9" cy="7" r="4"/>
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                    <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
            </div>
            <div>
                <h2 id="invite-parent-title" class="sg-card__title">Родитель</h2>
                <p class="sg-card__subtitle">Полный доступ к данным и уведомлениям</p>
            </div>
        </div>

        @if (_activeParentCode is not null)
        {
            @* Активный код *@
            <div class="sg-code-display" role="region" aria-label="Активный инвайт-код для родителя">
                <div class="sg-code-display__label">Активный код</div>
                <div class="sg-code-display__value" aria-live="polite">
                    @FormatCode(_activeParentCode.Code)
                </div>
                <p class="sg-code-display__hint">
                    Действует до&nbsp;<time datetime="@(_activeParentCode.ExpiresAt?.ToString("yyyy-MM-ddTHH:mm:ssZ") ?? string.Empty)">
                        @FormatExpiry(_activeParentCode.ExpiresAt)
                    </time>
                </p>
                <div class="sg-code-display__actions">
                    <button class="sg-btn sg-btn--soft sg-btn--sm"
                            @onclick="() => CopyCodeAsync(_activeParentCode.Code)"
                            aria-label="Скопировать код для родителя">
                        <svg viewBox="0 0 20 20" fill="none" stroke="currentColor"
                             stroke-width="1.8" aria-hidden="true">
                            <rect x="7" y="7" width="10" height="12" rx="2"/>
                            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                        </svg>
                        @(_copiedRole == UserRole.Parent ? "Скопировано!" : "Скопировать")
                    </button>
                    <button class="sg-btn sg-btn--ghost sg-btn--sm"
                            @onclick="() => RevokeCodeAsync(_activeParentCode.InviteCodeId, UserRole.Parent)"
                            disabled="@_isRevoking"
                            aria-label="Отозвать код для родителя">
                        <svg viewBox="0 0 20 20" fill="none" stroke="currentColor"
                             stroke-width="1.8" aria-hidden="true">
                            <line x1="5" y1="5" x2="15" y2="15"/>
                            <line x1="15" y1="5" x2="5" y2="15"/>
                        </svg>
                        Отозвать
                    </button>
                </div>
            </div>
        }
        else
        {
            <div class="sg-code-empty" role="status">
                <p class="sg-code-empty__text">Активных кодов нет</p>
                <button class="sg-btn sg-btn--primary sg-btn--sm"
                        @onclick="() => GenerateCodeAsync(UserRole.Parent)"
                        disabled="@_isGenerating"
                        aria-busy="@_isGenerating">
                    @if (_isGenerating && _generatingRole == UserRole.Parent)
                    {
                        <span class="sg-spinner sg-spinner--sm" aria-hidden="true"></span>
                        <span>Генерация…</span>
                    }
                    else
                    {
                        <svg viewBox="0 0 20 20" fill="none" stroke="currentColor"
                             stroke-width="1.8" aria-hidden="true">
                            <circle cx="10" cy="10" r="8"/>
                            <line x1="10" y1="6" x2="10" y2="14"/>
                            <line x1="6" y1="10" x2="14" y2="10"/>
                        </svg>
                        <span>Выдать код</span>
                    }
                </button>
            </div>
        }

        @if (_generateError is not null && _generatingRole == UserRole.Parent)
        {
            <p class="sg-field-error" role="alert">@_generateError</p>
        }
    </section>

    @* Карточка: пригласить врача *@
    <section class="sg-card sg-card--glass" aria-labelledby="invite-doctor-title">
        <div class="sg-card__head">
            <div class="sg-card__icon sg-card__icon--teal" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M8 21v-1a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v1"/>
                    <circle cx="14" cy="10" r="4"/>
                    <path d="M2 21v-1a4 4 0 0 1 2.5-3.7"/>
                    <path d="M7 8a4 4 0 0 0 0 4"/>
                </svg>
            </div>
            <div>
                <h2 id="invite-doctor-title" class="sg-card__title">Врач</h2>
                <p class="sg-card__subtitle">Просмотр данных, заметки, аналитика</p>
            </div>
        </div>

        @if (_activeDoctorCode is not null)
        {
            <div class="sg-code-display" role="region" aria-label="Активный инвайт-код для врача">
                <div class="sg-code-display__label">Активный код</div>
                <div class="sg-code-display__value" aria-live="polite">
                    @FormatCode(_activeDoctorCode.Code)
                </div>
                <p class="sg-code-display__hint">
                    Действует до&nbsp;<time datetime="@(_activeDoctorCode.ExpiresAt?.ToString("yyyy-MM-ddTHH:mm:ssZ") ?? string.Empty)">
                        @FormatExpiry(_activeDoctorCode.ExpiresAt)
                    </time>
                </p>
                <div class="sg-code-display__actions">
                    <button class="sg-btn sg-btn--soft sg-btn--sm"
                            @onclick="() => CopyCodeAsync(_activeDoctorCode.Code)"
                            aria-label="Скопировать код для врача">
                        <svg viewBox="0 0 20 20" fill="none" stroke="currentColor"
                             stroke-width="1.8" aria-hidden="true">
                            <rect x="7" y="7" width="10" height="12" rx="2"/>
                            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                        </svg>
                        @(_copiedRole == UserRole.Doctor ? "Скопировано!" : "Скопировать")
                    </button>
                    <button class="sg-btn sg-btn--ghost sg-btn--sm"
                            @onclick="() => RevokeCodeAsync(_activeDoctorCode.InviteCodeId, UserRole.Doctor)"
                            disabled="@_isRevoking"
                            aria-label="Отозвать код для врача">
                        <svg viewBox="0 0 20 20" fill="none" stroke="currentColor"
                             stroke-width="1.8" aria-hidden="true">
                            <line x1="5" y1="5" x2="15" y2="15"/>
                            <line x1="15" y1="5" x2="5" y2="15"/>
                        </svg>
                        Отозвать
                    </button>
                </div>
            </div>
        }
        else
        {
            <div class="sg-code-empty" role="status">
                <p class="sg-code-empty__text">Активных кодов нет</p>
                <button class="sg-btn sg-btn--primary sg-btn--sm"
                        @onclick="() => GenerateCodeAsync(UserRole.Doctor)"
                        disabled="@_isGenerating"
                        aria-busy="@_isGenerating">
                    @if (_isGenerating && _generatingRole == UserRole.Doctor)
                    {
                        <span class="sg-spinner sg-spinner--sm" aria-hidden="true"></span>
                        <span>Генерация…</span>
                    }
                    else
                    {
                        <svg viewBox="0 0 20 20" fill="none" stroke="currentColor"
                             stroke-width="1.8" aria-hidden="true">
                            <circle cx="10" cy="10" r="8"/>
                            <line x1="10" y1="6" x2="10" y2="14"/>
                            <line x1="6" y1="10" x2="14" y2="10"/>
                        </svg>
                        <span>Выдать код</span>
                    }
                </button>
            </div>
        }

        @if (_generateError is not null && _generatingRole == UserRole.Doctor)
        {
            <p class="sg-field-error" role="alert">@_generateError</p>
        }
    </section>

</div>

@* Блок «Текущие связки» *@
<section class="sg-card sg-card--glass sg-links-section" aria-labelledby="linked-users-title">
    <div class="sg-card__head">
        <div class="sg-card__icon sg-card__icon--muted" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M16 11a4 4 0 1 0-4-4 4 4 0 0 0 4 4z"/>
                <path d="M8 11a4 4 0 1 0-4-4 4 4 0 0 0 4 4z"/>
                <path d="M16 13c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                <path d="M8 13c-.29 0-.62.02-.97.05C4.24 13.27 2 14.39 2 17v2h4"/>
            </svg>
        </div>
        <div>
            <h2 id="linked-users-title" class="sg-card__title">Текущие связки</h2>
            <p class="sg-card__subtitle">
                Здесь отображаются все пользователи, у которых уже есть доступ к данным <strong>@_childName</strong>.
            </p>
        </div>
    </div>

    @if (_unlinkError is not null)
    {
        <p class="sg-field-error" role="alert">@_unlinkError</p>
    }

    <div class="sg-linked-groups">
        <div class="sg-linked-group">
            <h3 class="sg-linked-group__title">Родители</h3>
            @if (_parentLinks.Count == 0)
            {
                <p class="sg-linked-empty">Пока нет активных родительских связок.</p>
            }
            else
            {
                <div class="sg-linked-list">
                    @foreach (var link in _parentLinks)
                    {
                        <article class="sg-linked-item">
                            <div class="sg-linked-item__content">
                                <p class="sg-linked-item__title">@GetLinkedUserTitle(link)</p>
                                <p class="sg-linked-item__meta">
                                    Роль: @link.UserRole · Привязан @FormatLinkedAt(link.LinkedAt)
                                </p>
                            </div>
                            <button class="sg-btn sg-btn--ghost sg-btn--sm"
                                    @onclick="() => UnlinkParentAsync(link)"
                                    disabled="@(_unlinkingLinkId == link.LinkId)"
                                    aria-busy="@(_unlinkingLinkId == link.LinkId)">
                                @if (_unlinkingLinkId == link.LinkId)
                                {
                                    <span class="sg-spinner sg-spinner--sm" aria-hidden="true"></span>
                                    <span>Отвязка…</span>
                                }
                                else
                                {
                                    <span>Отвязать</span>
                                }
                            </button>
                        </article>
                    }
                </div>
            }
        </div>

        <div class="sg-linked-group">
            <h3 class="sg-linked-group__title">Врачи</h3>
            @if (_doctorLinks.Count == 0)
            {
                <p class="sg-linked-empty">Пока нет активных врачебных связок.</p>
            }
            else
            {
                <div class="sg-linked-list">
                    @foreach (var link in _doctorLinks)
                    {
                        <article class="sg-linked-item">
                            <div class="sg-linked-item__content">
                                <p class="sg-linked-item__title">@GetLinkedUserTitle(link)</p>
                                <p class="sg-linked-item__meta">
                                    Роль: @link.UserRole · Привязан @FormatLinkedAt(link.LinkedAt)
                                </p>
                            </div>
                            <button class="sg-btn sg-btn--ghost sg-btn--sm"
                                    @onclick="() => UnlinkDoctorAsync(link)"
                                    disabled="@(_unlinkingLinkId == link.LinkId)"
                                    aria-busy="@(_unlinkingLinkId == link.LinkId)">
                                @if (_unlinkingLinkId == link.LinkId)
                                {
                                    <span class="sg-spinner sg-spinner--sm" aria-hidden="true"></span>
                                    <span>Отвязка…</span>
                                }
                                else
                                {
                                    <span>Отвязать</span>
                                }
                            </button>
                        </article>
                    }
                </div>
            }
        </div>
    </div>
</section>

@* Блок «Активировать чужой код» *@
<section class="sg-card sg-card--glass sg-claim-section"
         aria-labelledby="claim-title">
    <div class="sg-card__head">
        <div class="sg-card__icon sg-card__icon--muted" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M20 12V22H4V12"/>
                <path d="M22 7H2v5h20V7z"/>
                <path d="M12 22V7"/>
                <path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/>
                <path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/>
            </svg>
        </div>
        <div>
            <h2 id="claim-title" class="sg-card__title">Активировать код</h2>
            <p class="sg-card__subtitle">
                Введите код, который вам прислал другой родитель или врач
            </p>
        </div>
    </div>

    <div class="sg-claim-form">
        <div class="sg-field">
            <label class="sg-label" for="claim-input">Инвайт-код</label>
            <input id="claim-input"
                   class="sg-input @(_claimError is not null ? "sg-input--error" : "")"
                   type="text"
                   maxlength="9"
                   placeholder="ABCD-1234"
                   @bind="ClaimCodeInput"
                   @bind:event="oninput"
                   autocomplete="off"
                   spellcheck="false"
                   aria-describedby="@(_claimError is not null ? "claim-error" : null)"
                   aria-invalid="@(_claimError is not null ? "true" : null)" />
            @if (_claimError is not null)
            {
                <p id="claim-error" class="sg-field-error" role="alert">@_claimError</p>
            }
            @if (_claimSuccess is not null)
            {
                <p class="sg-field-success" role="status">@_claimSuccess</p>
            }
        </div>
        <button class="sg-btn sg-btn--primary"
                @onclick="ClaimCodeAsync"
                disabled="@(_isClaiming || string.IsNullOrWhiteSpace(_claimCodeInput))"
                aria-busy="@_isClaiming">
                @if (_isClaiming)
                {
                <span class="sg-spinner sg-spinner--sm" aria-hidden="true"></span>
                <span>Активация…</span>
            }
            else
            {
                <span>Активировать</span>
            }
        </button>
    </div>
</section>

@* Skeleton при загрузке *@
@if (_isLoading)
{
    <div class="sg-skeleton-overlay" aria-busy="true" aria-label="Загрузка данных…">
        <div class="sg-skeleton sg-skeleton--card"></div>
        <div class="sg-skeleton sg-skeleton--card"></div>
    </div>
}

<style>
    /* Layout */
    .sg-page-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: var(--space-4);
        margin-bottom: var(--space-8);
    }

    .sg-page-title {
        font-family: var(--font-display);
        font-size: var(--text-xl);
        font-weight: 600;
        letter-spacing: -0.03em;
        color: var(--color-text);
        margin: 0 0 var(--space-2);
    }

    .sg-page-subtitle {
        font-size: var(--text-sm);
        color: var(--color-text-muted);
        margin: 0;
        max-width: 60ch;
    }

    .sg-cards-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: var(--space-6);
        margin-bottom: var(--space-6);
    }

    @@media (max-width: 720px) {
        .sg-cards-grid {
            grid-template-columns: 1fr;
        }
    }

    /* Card */
    .sg-card {
        border-radius: var(--radius-xl);
        padding: var(--space-6);
        border: 1px solid var(--color-border);
        background: var(--color-surface);
        box-shadow: var(--shadow-sm);
        display: flex;
        flex-direction: column;
        gap: var(--space-5);
    }

    .sg-card--glass {
        backdrop-filter: blur(18px);
        background: color-mix(in oklab, var(--color-surface) 84%, transparent);
    }

    .sg-card__head {
        display: flex;
        align-items: center;
        gap: var(--space-4);
    }

    .sg-card__icon {
        width: 48px;
        height: 48px;
        border-radius: var(--radius-md);
        display: grid;
        place-items: center;
        flex-shrink: 0;
    }

    .sg-card__icon svg {
        width: 22px;
        height: 22px;
    }

    .sg-card__icon--primary {
        background: color-mix(in oklab, var(--color-primary) 12%, transparent);
        color: var(--color-primary);
    }

    .sg-card__icon--teal {
        background: color-mix(in oklab, var(--color-primary) 10%, transparent);
        color: var(--color-primary);
    }

    .sg-card__icon--muted {
        background: var(--color-surface-offset);
        color: var(--color-text-muted);
    }

    .sg-card__title {
        font-size: var(--text-base);
        font-weight: 600;
        color: var(--color-text);
        margin: 0 0 var(--space-1);
    }

    .sg-card__subtitle {
        font-size: var(--text-sm);
        color: var(--color-text-muted);
        margin: 0;
    }

    /* Code display */
    .sg-code-display {
        background: var(--color-surface-offset);
        border-radius: var(--radius-lg);
        padding: var(--space-5) var(--space-6);
        display: flex;
        flex-direction: column;
        gap: var(--space-3);
    }

    .sg-code-display__label {
        font-size: var(--text-xs);
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--color-text-muted);
    }

    .sg-code-display__value {
        font-family: var(--font-display, monospace);
        font-size: clamp(1.6rem, 3vw, 2.2rem);
        font-weight: 700;
        letter-spacing: 0.15em;
        color: var(--color-primary);
        line-height: 1;
    }

    .sg-code-display__hint {
        font-size: var(--text-xs);
        color: var(--color-text-muted);
        margin: 0;
    }

    .sg-code-display__actions {
        display: flex;
        gap: var(--space-3);
        flex-wrap: wrap;
    }

    /* Code empty state */
    .sg-code-empty {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: var(--space-3);
    }

    .sg-code-empty__text {
        font-size: var(--text-sm);
        color: var(--color-text-faint);
        margin: 0;
    }

    /* Linked users section */
    .sg-links-section {
        margin-bottom: var(--space-6);
    }

    .sg-linked-groups {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: var(--space-5);
    }

    .sg-linked-group {
        display: flex;
        flex-direction: column;
        gap: var(--space-3);
    }

    .sg-linked-group__title {
        margin: 0;
        font-size: var(--text-sm);
        font-weight: 600;
        color: var(--color-text);
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    .sg-linked-empty {
        margin: 0;
        font-size: var(--text-sm);
        color: var(--color-text-muted);
        background: var(--color-surface-offset);
        border-radius: var(--radius-md);
        padding: var(--space-3) var(--space-4);
    }

    .sg-linked-list {
        display: flex;
        flex-direction: column;
        gap: var(--space-3);
    }

    .sg-linked-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--space-3);
        padding: var(--space-4);
        border-radius: var(--radius-lg);
        border: 1px solid var(--color-border);
        background: var(--color-surface-offset);
    }

    .sg-linked-item__content {
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: var(--space-1);
    }

    .sg-linked-item__title {
        margin: 0;
        font-size: var(--text-sm);
        color: var(--color-text);
        font-weight: 600;
        overflow-wrap: anywhere;
    }

    .sg-linked-item__meta {
        margin: 0;
        font-size: var(--text-xs);
        color: var(--color-text-muted);
    }

    /* Claim section */
    .sg-claim-section {
        margin-top: var(--space-2);
    }

    .sg-claim-form {
        display: flex;
        align-items: flex-end;
        gap: var(--space-4);
        flex-wrap: wrap;
    }

    .sg-field {
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
        flex: 1 1 220px;
    }

    .sg-label {
        font-size: var(--text-sm);
        font-weight: 500;
        color: var(--color-text);
    }

    .sg-input {
        height: 44px;
        padding: 0 var(--space-4);
        border-radius: var(--radius-md);
        border: 1px solid var(--color-border);
        background: var(--color-surface-2);
        color: var(--color-text);
        font-size: var(--text-base);
        font-family: var(--font-body);
        letter-spacing: 0.06em;
        transition: border-color var(--transition-interactive),
                    box-shadow var(--transition-interactive);
    }

    .sg-input:focus-visible {
        outline: none;
        border-color: var(--color-primary);
        box-shadow: 0 0 0 3px color-mix(in oklab, var(--color-primary) 20%, transparent);
    }

    .sg-input--error {
        border-color: var(--color-danger);
    }

    .sg-input--error:focus-visible {
        box-shadow: 0 0 0 3px color-mix(in oklab, var(--color-danger) 20%, transparent);
    }

    /* Buttons */
    .sg-btn {
        min-height: 44px;
        padding: 0 var(--space-6);
        border-radius: var(--radius-full);
        font-size: var(--text-sm);
        font-weight: 600;
        font-family: var(--font-body);
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        cursor: pointer;
        border: none;
        transition: transform var(--transition-interactive),
                    background var(--transition-interactive),
                    box-shadow var(--transition-interactive),
                    opacity var(--transition-interactive);
        white-space: nowrap;
    }

    .sg-btn:hover:not(:disabled) {
        transform: translateY(-1px);
    }

    .sg-btn:active:not(:disabled) {
        transform: translateY(0);
    }

    .sg-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .sg-btn--sm {
        min-height: 36px;
        padding: 0 var(--space-4);
        font-size: var(--text-xs);
    }

    .sg-btn--primary {
        background: var(--color-primary);
        color: #fff;
        box-shadow: 0 4px 12px color-mix(in oklab, var(--color-primary) 30%, transparent);
    }

    .sg-btn--primary:hover:not(:disabled) {
        background: var(--color-primary-hover);
    }

    .sg-btn--soft {
        background: color-mix(in oklab, var(--color-primary) 12%, transparent);
        color: var(--color-primary);
        border: 1px solid color-mix(in oklab, var(--color-primary) 20%, transparent);
    }

    .sg-btn--soft:hover:not(:disabled) {
        background: color-mix(in oklab, var(--color-primary) 18%, transparent);
    }

    .sg-btn--ghost {
        background: transparent;
        color: var(--color-text-muted);
        border: 1px solid var(--color-border);
    }

    .sg-btn--ghost:hover:not(:disabled) {
        background: var(--color-surface-offset);
        color: var(--color-text);
    }

    .sg-btn svg {
        width: 16px;
        height: 16px;
    }

    /* Alerts & messages */
    .sg-alert {
        display: flex;
        align-items: center;
        gap: var(--space-3);
        padding: var(--space-4) var(--space-5);
        border-radius: var(--radius-md);
        font-size: var(--text-sm);
        margin-bottom: var(--space-6);
    }

    .sg-alert--danger {
        background: color-mix(in oklab, var(--color-danger) 10%, transparent);
        border: 1px solid color-mix(in oklab, var(--color-danger) 25%, transparent);
        color: var(--color-danger);
    }

    .sg-alert__icon {
        width: 20px;
        height: 20px;
        flex-shrink: 0;
    }

    .sg-field-error {
        font-size: var(--text-xs);
        color: var(--color-danger);
        margin: 0;
    }

    .sg-field-success {
        font-size: var(--text-xs);
        color: var(--color-success);
        margin: 0;
    }

    /* Breadcrumb */
    .sg-breadcrumb {
        display: flex;
        align-items: center;
        gap: var(--space-2);
        font-size: var(--text-xs);
        color: var(--color-text-muted);
        margin-bottom: var(--space-6);
    }

    .sg-breadcrumb a {
        color: var(--color-primary);
        text-decoration: none;
    }

    .sg-breadcrumb a:hover {
        text-decoration: underline;
    }

    .sg-breadcrumb__sep {
        color: var(--color-text-faint);
    }

    /* Spinner */
    .sg-spinner {
        display: inline-block;
        border-radius: 50%;
        border: 2px solid color-mix(in oklab, currentColor 25%, transparent);
        border-top-color: currentColor;
        animation: sg-spin 0.7s linear infinite;
    }

    .sg-spinner--sm {
        width: 14px;
        height: 14px;
    }

    @@keyframes sg-spin {
        to { transform: rotate(360deg); }
    }

    /* Skeleton */
    .sg-skeleton-overlay {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: var(--space-6);
        margin-bottom: var(--space-6);
    }

    .sg-skeleton--card {
        height: 220px;
        border-radius: var(--radius-xl);
        background: linear-gradient(
            90deg,
            var(--color-surface-offset) 25%,
            var(--color-surface-2) 50%,
            var(--color-surface-offset) 75%
        );
        background-size: 200% 100%;
        animation: sg-shimmer 1.5s ease-in-out infinite;
    }

    @@keyframes sg-shimmer {
        0%   { background-position: -200% 0; }
        100% { background-position:  200% 0; }
    }

    @@media (prefers-reduced-motion: reduce) {
        .sg-spinner, .sg-skeleton--card {
            animation: none;
        }
    }

    @@media (max-width: 860px) {
        .sg-linked-groups {
            grid-template-columns: 1fr;
        }
    }
</style>

@code {
    [Parameter]
    public Guid ChildId { get; set; }// ID ребёнка, для которого управляем доступом

    // Состояние загрузки 
    private bool _isLoading = true;
    private string? _loadError;

    // Имя ребёнка для заголовка 
    private string _childName = "ребёнка";

    // Активные коды 
    private InviteCodeVm? _activeParentCode;
    private InviteCodeVm? _activeDoctorCode;

    // Текущие связки 
    private List<LinkedAccessUserVm> _parentLinks = [];
    private List<LinkedAccessUserVm> _doctorLinks = [];
    private Guid? _unlinkingLinkId;
    private string? _unlinkError;

    // Генерация кода 
    private bool _isGenerating;
    private UserRole? _generatingRole;
    private string? _generateError;

    // Отзыв кода 
    private bool _isRevoking;

    // Копирование 
    private UserRole? _copiedRole;
    private System.Threading.CancellationTokenSource? _copyCts;

    // Claim кода 
    private string _claimCodeInput = string.Empty;
    private bool _isClaiming;
    private string? _claimError;
    private string? _claimSuccess;
    private string ClaimCodeInput
    {
        get => _claimCodeInput;
        set
        {
            if (string.Equals(_claimCodeInput, value, StringComparison.Ordinal))
            {
                return;
            }

            _claimCodeInput = value;
            _claimError = null;
            _claimSuccess = null;
        }
    }

    // Lifecycle 
    /// <inheritdoc />
    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    // Загрузка данных 
    /// <summary>
    /// Загружает профиль ребёнка и список активных инвайт-кодов
    /// </summary>
    private async Task LoadAsync()
    {
        _isLoading = true;
        _loadError = null;

        try
        {
            // Профиль ребёнка
            var child = await ApiService.GetChildAsync(ChildId);
            if (child is not null && child.ChildId != Guid.Empty)
                _childName = GetChildDisplayName(child);

            // Активные коды
            var codes = await ApiService.GetActiveInviteCodesAsync(ChildId);
            if (codes is not null)
            {
                _activeParentCode = codes.FirstOrDefault(c =>
                    IsTargetRole(c.TargetRole, UserRole.Parent));

                _activeDoctorCode = codes.FirstOrDefault(c =>
                    IsTargetRole(c.TargetRole, UserRole.Doctor));
            }

            await LoadLinksAsync();
        }
        catch (Exception ex) when (ex is HttpRequestException or TaskCanceledException)
        {
            _loadError = "Не удалось загрузить данные. Проверьте подключение и обновите страницу.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    /// <summary>
    /// Загружает текущие связки «родители/врачи» для выбранного ребёнка
    /// </summary>
    private async Task LoadLinksAsync()
    {
        var snapshot = await ApiService.GetChildAccessLinksAsync(ChildId);

        if (snapshot is null)
        {
            _parentLinks = [];
            _doctorLinks = [];
            return;
        }

        _parentLinks = snapshot.ParentLinks
            .OrderByDescending(x => x.LinkedAt)
            .ToList();

        _doctorLinks = snapshot.DoctorLinks
            .OrderByDescending(x => x.LinkedAt)
            .ToList();
    }

    // Генерация кода
    /// <summary>
    /// Запрашивает генерацию нового инвайт-кода для указанной роли
    /// </summary>
    private async Task GenerateCodeAsync(UserRole targetRole)
    {
        _isGenerating = true;
        _generatingRole = targetRole;
        _generateError = null;

        try
        {
            var result = await ApiService.GenerateInviteCodeAsync(ChildId, targetRole);

            if (result is null)
            {
                _generateError = "Ошибка при генерации кода. Попробуйте ещё раз.";
                return;
            }

            if (targetRole == UserRole.Parent)
                _activeParentCode = result;
            else
                _activeDoctorCode = result;
        }
        catch (Exception ex) when (ex is HttpRequestException or TaskCanceledException)
        {
            _generateError = "Не удалось создать код. Проверьте подключение.";
        }
        finally
        {
            _isGenerating = false;
            _generatingRole = null;
        }
    }

    // Отзыв кода
    /// <summary>
    /// Отзывает активный инвайт-код
    /// </summary>
    private async Task RevokeCodeAsync(Guid inviteCodeId, UserRole targetRole)
    {
        _isRevoking = true;
        _loadError = null;

        try
        {
            var ok = await ApiService.RevokeInviteCodeAsync(inviteCodeId);

            if (ok)
            {
                if (targetRole == UserRole.Parent)
                    _activeParentCode = null;
                else
                    _activeDoctorCode = null;
            }
            else
            {
                _loadError = "Не удалось отозвать код. Попробуйте ещё раз.";
            }
        }
        catch (Exception ex) when (ex is HttpRequestException or TaskCanceledException)
        {
            _loadError = "Ошибка соединения при отзыве кода.";
        }
        finally
        {
            _isRevoking = false;
        }
    }

    // Копирование
    /// <summary>
    /// Копирует код в буфер обмена и показывает подтверждение на 2 секунды
    /// </summary>
    private async Task CopyCodeAsync(string rawCode)
    {
        var formatted = FormatCode(rawCode);

        try
        {
            await Js.InvokeVoidAsync("navigator.clipboard.writeText", formatted);
        }
        catch
        {
            return;
        }

        // Определяем роль скопированного кода
        _copiedRole = rawCode == _activeParentCode?.Code
            ? UserRole.Parent
            : UserRole.Doctor;

        // Сбрасываем через 2 секунды
        _copyCts?.Cancel();
        _copyCts = new System.Threading.CancellationTokenSource();
        var token = _copyCts.Token;

        StateHasChanged();

        await Task.Delay(2000, token).ContinueWith(_ =>
        {
            if (!token.IsCancellationRequested)
            {
                _copiedRole = null;
                InvokeAsync(StateHasChanged);
            }
        }, TaskContinuationOptions.OnlyOnRanToCompletion);
    }

    // Claim кода 
    /// <summary>
    /// Активирует инвайт-код другого родителя/врача
    /// </summary>
    private async Task ClaimCodeAsync()
    {
        var raw = _claimCodeInput.Trim();

        if (string.IsNullOrEmpty(raw))
        {
            _claimError = "Введите код.";
            return;
        }

        _isClaiming = true;
        _claimError = null;
        _claimSuccess = null;

        try
        {
            var result = await ApiService.ClaimInviteCodeAsync(raw);

            if (result is null)
            {
                _claimError = "Не удалось активировать код. Попробуйте ещё раз.";
                return;
            }

            if (!result.Success)
            {
                _claimError = result.ErrorCode switch
                {
                    "code_not_found" or "codenotfound" => "Код не найден. Проверьте и попробуйте снова.",
                    "code_expired" or "codeexpired" => "Срок действия кода истёк. Попросите новый.",
                    "code_already_used" or "codealreadyused" => "Этот код уже был использован.",
                    "role_mismatch" or "rolemismatch" => "Код предназначен для другой роли.",
                    _ => result.ErrorMessage ?? "Неизвестная ошибка."
                };
                return;
            }

            _claimSuccess = "Доступ успешно подключён!";
            _claimCodeInput = string.Empty;
            await LoadLinksAsync();
        }
        catch (Exception ex) when (ex is HttpRequestException or TaskCanceledException)
        {
            _claimError = "Ошибка соединения. Проверьте подключение.";
        }
        finally
        {
            _isClaiming = false;
        }
    }

    // Управление связками 
    /// <summary>
    /// Обёртка для отвязки родителя
    /// </summary>
    private Task UnlinkParentAsync(LinkedAccessUserVm link) =>
        UnlinkAsync("parent", link);

    /// <summary>
    /// Обёртка для отвязки врача
    /// </summary>
    private Task UnlinkDoctorAsync(LinkedAccessUserVm link) =>
        UnlinkAsync("doctor", link);

    /// <summary>
    /// Отвязывает пользователя от данных ребёнка
    /// </summary>
    private async Task UnlinkAsync(string linkType, LinkedAccessUserVm link)
    {
        _unlinkError = null;

        var confirmationText = $"Отвязать \"{GetLinkedUserTitle(link)}\" от данных {_childName}?";
        var confirmed = await Js.InvokeAsync<bool>("confirm", confirmationText);

        if (!confirmed)
            return;

        _unlinkingLinkId = link.LinkId;

        try
        {
            var ok = await ApiService.UnlinkChildAccessAsync(ChildId, linkType, link.LinkId);
            if (!ok)
            {
                _unlinkError = "Связка не найдена или уже удалена.";
                return;
            }

            if (string.Equals(linkType, "parent", StringComparison.OrdinalIgnoreCase))
            {
                _parentLinks = _parentLinks
                    .Where(x => x.LinkId != link.LinkId)
                    .ToList();
            }
            else
            {
                _doctorLinks = _doctorLinks
                    .Where(x => x.LinkId != link.LinkId)
                    .ToList();
            }
        }
        catch (Exception ex) when (ex is HttpRequestException or TaskCanceledException)
        {
            _unlinkError = "Не удалось отвязать пользователя. Проверьте подключение.";
        }
        finally
        {
            _unlinkingLinkId = null;
        }
    }

    // Вспомогательные методы 
    /// <summary>
    /// Форматирует 8-символьный код в вид ABCD-1234.
    /// </summary>
    private static string FormatCode(string? raw)
    {
        if (raw is null || raw.Length != InviteCodeLimits.CodeLength)
            return raw ?? string.Empty;

        return string.Join(
            InviteCodeLimits.GroupSeparator,
            Enumerable.Range(0, InviteCodeLimits.CodeLength / InviteCodeLimits.GroupSize)
                      .Select(i => raw.Substring(
                          i * InviteCodeLimits.GroupSize,
                          InviteCodeLimits.GroupSize)));
    }

    /// <summary>
    /// Возвращает локализованную строку срока действия кода
    /// </summary>
    private static string FormatExpiry(DateTime? expiresAt)
    {
        if (!expiresAt.HasValue)
            return "неизвестно";

        var value = expiresAt.Value;
        var remaining = value - DateTime.UtcNow;

        if (remaining <= TimeSpan.Zero)
            return "истёк";

        if (remaining.TotalHours < InviteCodeLimits.ShowMinutesThresholdHours)
        {
            var mins = (int)remaining.TotalMinutes;
            return $"через {mins} мин";
        }

        return value.ToLocalTime().ToString("d MMM HH:mm",
            new System.Globalization.CultureInfo("ru-RU"));
    }

    /// <summary>
    /// Преобразует профиль ребёнка в строку для заголовка страницы
    /// </summary>
    private static string GetChildDisplayName(ChildProfileVm child)
    {
        var fullName = $"{child.FirstName} {child.LastName}".Trim();
        return string.IsNullOrWhiteSpace(fullName)
            ? "ребёнка"
            : fullName;
    }

    /// <summary>
    /// Проверяет соответствие роли в инвайт-коде ожидаемой роли
    /// </summary>
    private static bool IsTargetRole(UserRole targetRole, UserRole expectedRole)
    {
        return targetRole == expectedRole;
    }

    /// <summary>
    /// Формирует читаемое имя привязанного пользователя
    /// </summary>
    private static string GetLinkedUserTitle(LinkedAccessUserVm link)
    {
        if (!string.IsNullOrWhiteSpace(link.EmailForLogin))
            return link.EmailForLogin;

        if (link.TelegramId.HasValue)
            return $"Telegram {link.TelegramId.Value}";

        return $"Пользователь {link.UserId.ToString("N")[..8]}";
    }

    /// <summary>
    /// Форматирует дату привязки в локальном часовом поясе
    /// </summary>
    private static string FormatLinkedAt(DateTime linkedAtUtc)
    {
        return linkedAtUtc
            .ToLocalTime()
            .ToString("d MMM yyyy HH:mm", new System.Globalization.CultureInfo("ru-RU"));
    }
}
