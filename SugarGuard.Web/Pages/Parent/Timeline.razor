</style>

@code {
    [Parameter]
    public Guid ChildId { get; set; }

    // Состояние
    private bool _isLoading;
    private string? _errorMessage;

    private List<TimelineEventDto>? _events; // Полный список событий

    // Параметры фильтрации 
    private DateTime _fromDate = DateTime.Today.AddDays(-7);
    private DateTime _toDate   = DateTime.Today;
    private string   _filterType = string.Empty;
    private int      _limit = 50;

    // Производные вычисляемые свойства 
    /// <summary>
    /// События после применения клиентского фильтра по типу
    /// </summary>
    private List<TimelineEventDto>? _filteredEvents =>
        _events is null
            ? null
            : string.IsNullOrEmpty(_filterType)
                ? _events
                : _events
                    .Where(e => e.EventType.ToString() == _filterType)
                    .ToList();

    private int _measurementsCount =>
        _filteredEvents?.Count(e => e.EventType == TimelineEventType.GlucoseMeasurement) ?? 0;

    private int _criticalCount =>
        _filteredEvents?.Count(e => e.EventType == TimelineEventType.Alert) ?? 0;

    private int _snacksCount =>
        _filteredEvents?.Count(e => e.EventType == TimelineEventType.Meal) ?? 0;

    private decimal? _avgGlucose
    {
        get
        {
            var glucoseValues = _filteredEvents?
                .Where(e => e.GlucoseValue.HasValue)
                .Select(e => e.GlucoseValue!.Value)
                .ToList();

            return glucoseValues != null && glucoseValues.Count > 0
                ? Math.Round(glucoseValues.Average(), 1)
                : null;
        }
    }

    // Жизненный цикл
    /// <inheritdoc />
    protected override async Task OnInitializedAsync()
    {
        await LoadTimelineAsync();
    }

    /// <inheritdoc />
    protected override async Task OnParametersSetAsync()
    {
        // Если ChildId изменился (переключение ребёнка), перезагружаем.
        if (_events is not null && !_isLoading)
        {
            await LoadTimelineAsync();
        }
    }

    // Загрузка данных
    /// <summary>
    /// Запрашивает временную ленту
    /// </summary>
    private async Task LoadTimelineAsync()
    {
        _isLoading    = true;
        _errorMessage = null;

        try
        {
            var from = _fromDate.ToUniversalTime();
            var to   = _toDate.Date.AddDays(1).AddSeconds(-1).ToUniversalTime();

            var events = await ApiService.GetTimelineAsync(
                ChildId,
                from,
                to,
                CancellationToken.None);

            _events = events
                .OrderByDescending(e => e.OccurredAt)
                .Take(_limit)
                .ToList();
        }
        catch (HttpRequestException ex)
        {
            _errorMessage = $"Не удалось загрузить ленту событий: {ex.Message}";
            _events ??= new List<TimelineEventDto>();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Произошла ошибка: {ex.Message}";
            _events ??= new List<TimelineEventDto>();
        }
        finally
        {
            _isLoading = false;
        }
    }

    // Вспомогательные методы 
    /// <summary>
    /// Возвращает CSS-класс карточки в зависимости от типа и статуса события
    /// </summary>
    private static string GetEventCardClass(TimelineEventDto evt) =>
        evt.EventType switch
        {
            TimelineEventType.Alert                     => "event-card--critical",
            TimelineEventType.GlucoseMeasurement when evt.IsImportant  => "event-card--warning",
            _                                                    => string.Empty,
        };

    /// <summary>
    /// Возвращает CSS-класс значка события
    /// </summary>
    private static string GetBadgeClass(TimelineEventDto evt) =>
        evt.EventType switch
        {
            TimelineEventType.GlucoseMeasurement   => "event-badge--measurement",
            TimelineEventType.Meal => "event-badge--snack",
            TimelineEventType.Alert => "event-badge--critical",
            TimelineEventType.Note    => "event-badge--doctor",
            _                               => "event-badge--measurement",
        };

    /// <summary>
    /// Возвращает CSS-класс текста для значения глюкозы
    /// </summary>
    private static string GetGlucoseClass(decimal value)
    {
        if (value < 3.9m)
            return "text-danger";

        if (value >= 10.0m)
            return "text-warning";

        return "text-success";
    }

    /// <summary>
    /// Возвращает SVG-иконку типа события для inline-рендера
    /// </summary>
    private static MarkupString GetEventIcon(TimelineEventDto evt) => evt.EventType switch
    {
        TimelineEventType.GlucoseMeasurement => new MarkupString("<svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" aria-hidden=\"true\"><path d=\"M22 12h-4l-3 9L9 3l-3 9H2\" /></svg>"),
        TimelineEventType.Meal => new MarkupString("<svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" aria-hidden=\"true\"><path d=\"M18 8h1a4 4 0 0 1 0 8h-1\" /><path d=\"M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z\" /><path d=\"M6 1v3M10 1v3M14 1v3\" /></svg>"),
        TimelineEventType.Alert => new MarkupString("<svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" aria-hidden=\"true\"><path d=\"M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z\" /><path d=\"M12 9v4M12 17h.01\" /></svg>"),
        TimelineEventType.Note => new MarkupString("<svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" aria-hidden=\"true\"><path d=\"M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z\" /></svg>"),
        _ => new MarkupString("<svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\" /><path d=\"M12 8v4M12 16h.01\" /></svg>"),
    };

    /// <summary>
    /// Возвращает заголовок события для отображения в ленте
    /// </summary>
    private static string GetEventTitle(TimelineEventDto evt) => evt.EventType switch
    {
        TimelineEventType.GlucoseMeasurement   => "Измерение глюкозы",
        TimelineEventType.Meal => $"Перекус: {evt.SnackName ?? "без названия"}",
        TimelineEventType.Alert => evt.GlucoseValue < 3.9m
                                            ? "⚠ Критически низкая глюкоза"
                                            : "⚠ Критически высокая глюкоза",
        TimelineEventType.Note    => "Заметка врача",
        _                               => "Событие",
    };

    /// <summary>
    /// Возвращает описательный текст события
    /// </summary>
    private string GetEventDescription(TimelineEventDto evt) => evt.EventType switch
    {
        TimelineEventType.GlucoseMeasurement when evt.GlucoseValue.HasValue =>
            $"Уровень глюкозы {evt.GlucoseValue.Value:F1} ммоль/л" +
            (evt.GlucoseUiState is not null ? $" · {GetUiStateLabel(evt.GlucoseUiState)}" : string.Empty),

        TimelineEventType.Meal when evt.BreadUnits.HasValue =>
            $"{evt.BreadUnits.Value:F1} ХЕ" +
            (!string.IsNullOrWhiteSpace(evt.SnackName) ? $" · {evt.SnackName}" : string.Empty),

        TimelineEventType.Alert when evt.GlucoseValue.HasValue =>
            $"Значение {evt.GlucoseValue.Value:F1} ммоль/л требует немедленного внимания",

        TimelineEventType.Note =>
            !string.IsNullOrWhiteSpace(evt.Notes)
                ? evt.Notes.Length > 90 ? evt.Notes[..90] + "…" : evt.Notes
                : "Врач оставил заметку",

        _ => string.Empty,
    };

    /// <summary>
    /// Возвращает читаемое название источника данных
    /// </summary>
    private static string GetSourceLabel(string? dataSource) => dataSource switch
    {
        "mobileapp"  => "Приложение",
        "telegram"   => "Telegram",
        "manual"     => "Вручную",
        "sensor"     => "Сенсор",
        _            => dataSource ?? string.Empty,
    };

    /// <summary>
    /// Возвращает читаемое название UI-статуса глюкозы
    /// </summary>
    private static string GetUiStateLabel(string? uiState) => uiState switch
    {
        "Normal"  => "норма",
        "Warning" => "внимание",
        "Danger"  => "опасно",
        _         => uiState ?? string.Empty,
    };

    /// <summary>
    /// Возвращает aria-label для карточки события 
    /// </summary>
    private static string GetEventAriaLabel(TimelineEventDto evt)
    {
        var time = evt.OccurredAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm");
        return $"{GetEventAriaType(evt.EventType)}, {time}" +
               (evt.GlucoseValue.HasValue
                   ? $", глюкоза {evt.GlucoseValue.Value:F1} ммоль/л"
                   : string.Empty);
    }

    private static string GetEventAriaType(TimelineEventType type) => type switch
    {
        TimelineEventType.GlucoseMeasurement   => "Измерение глюкозы",
        TimelineEventType.Meal => "Перекус",
        TimelineEventType.Alert => "Критический алерт",
        TimelineEventType.Note    => "Заметка врача",
        _                               => "Событие",
    };

    /// <summary>
    /// Форматирует дату группы для разделителей в ленте
    /// </summary>
    private static string FormatGroupDate(DateTime date)
    {
        var today    = DateTime.Today;
        var yesterday = today.AddDays(-1);

        if (date == today)    return "Сегодня";
        if (date == yesterday) return "Вчера";

        return date.ToString(date.Year == today.Year ? "d MMMM" : "d MMMM yyyy",
                             new System.Globalization.CultureInfo("ru-RU"));
    }
}
