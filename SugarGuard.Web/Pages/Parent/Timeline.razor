@page "/parent/timeline/{ChildId:guid}"
@using Microsoft.AspNetCore.Authorization
@using SugarGuard.Web.Services
@using SugarGuard.Web.ViewModels
@using static SugarGuard.Web.Services.SugarGuardApiService
@attribute [Authorize(Roles = "Parent")]
@inject SugarGuardApiService ApiService
@inject ICurrentUserService CurrentUserService
@inject NavigationManager NavigationManager

<PageTitle>Лента событий — SugarGuard</PageTitle>

<div class="sg-page">

    <PageHeader Title="Лента событий"
                Subtitle="Измерения, перекусы и критические события за выбранный период"
                Breadcrumbs="@(new List<BreadcrumbItem> { new("Главная", $"/parent/dashboard/{ChildId}"), new("Лента событий", null) })" />

    <!-- Фильтры -->
    <section class="filters-bar glass" aria-label="Фильтры периода">
        <div class="filters-inner">
            <div class="filter-group">
                <label class="filter-label" for="filter-from">С</label>
                <input id="filter-from"
                       type="date"
                       class="sg-input"
                       @bind="_fromDate"
                       @bind:event="oninput"
                       max="@_toDate.ToString("yyyy-MM-dd")" />
            </div>
            <div class="filter-group">
                <label class="filter-label" for="filter-to">По</label>
                <input id="filter-to"
                       type="date"
                       class="sg-input"
                       @bind="_toDate"
                       @bind:event="oninput"
                       min="@_fromDate.ToString("yyyy-MM-dd")"
                       max="@DateTime.Today.ToString("yyyy-MM-dd")" />
            </div>
            <div class="filter-group">
                <label class="filter-label" for="filter-type">Тип события</label>
                <select id="filter-type" class="sg-input" @bind="_filterType">
                    <option value="">Все события</option>
                    <option value="Measurement">Измерения</option>
                    <option value="SnackConsumed">Перекусы</option>
                    <option value="CriticalAlert">Критические алерты</option>
                    <option value="DoctorNote">Заметки врача</option>
                </select>
            </div>
            <div class="filter-group">
                <label class="filter-label" for="filter-limit">Записей</label>
                <select id="filter-limit" class="sg-input" @bind="_limit">
                    <option value="25">25</option>
                    <option value="50">50</option>
                    <option value="100">100</option>
                    <option value="200">200</option>
                </select>
            </div>
            <button class="sg-btn sg-btn-primary" @onclick="LoadTimelineAsync" disabled="@_isLoading">
                @if (_isLoading)
                {
                    <span class="spinner" aria-hidden="true"></span>
                    <span>Загрузка…</span>
                }
                else
                {
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2.2" aria-hidden="true">
                        <circle cx="11" cy="11" r="8" />
                        <path d="M21 21l-4.35-4.35" />
                    </svg>
                    <span>Обновить</span>
                }
            </button>
        </div>
    </section>

    <!-- Ошибка загрузки -->
    @if (_errorMessage is not null)
    {
        <div class="sg-alert sg-alert-error" role="alert">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" aria-hidden="true">
                <circle cx="12" cy="12" r="10" />
                <path d="M12 8v4M12 16h.01" />
            </svg>
            <span>@_errorMessage</span>
            <button class="sg-alert-close" @onclick="() => _errorMessage = null" aria-label="Закрыть">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <path d="M18 6L6 18M6 6l12 12" />
                </svg>
            </button>
        </div>
    }

    <!-- Основной контент -->
    <main id="main-content">

        @if (_isLoading && _events is null)
        {
            <!-- Скелетон при первоначальной загрузке -->
            <div class="timeline" aria-busy="true" aria-label="Загрузка ленты событий">
                @for (int i = 0; i < 6; i++)
                {
                    <div class="event-card event-card--skeleton">
                        <div class="event-badge skeleton"></div>
                        <div class="event-body">
                            <div class="skeleton skeleton-heading"></div>
                            <div class="skeleton skeleton-text"></div>
                            <div class="skeleton skeleton-text" style="width: 55%"></div>
                        </div>
                        <div class="event-time-col">
                            <div class="skeleton skeleton-text" style="width: 60px"></div>
                        </div>
                    </div>
                }
            </div>
        }
        else if (_filteredEvents is null || _filteredEvents.Count == 0)
        {
            <!-- Пустое состояние -->
            <div class="empty-state" role="status">
                <svg class="empty-state-icon" width="48" height="48" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2" />
                    <rect x="9" y="3" width="6" height="4" rx="1" />
                </svg>
                <h2 class="empty-state-title">Событий не найдено</h2>
                <p class="empty-state-text">
                    За выбранный период нет данных. Попробуйте расширить диапазон дат
                    или сменить фильтр типа событий.
                </p>
            </div>
        }
        else if (_filteredEvents is not null)
        {
            <!-- Статистика периода -->
            <div class="period-stats glass" aria-label="Краткая статистика периода">
                <div class="period-stat">
                    <span class="period-stat-value">@_filteredEvents.Count</span>
                    <span class="period-stat-label">Событий</span>
                </div>
                <div class="period-stat-divider" aria-hidden="true"></div>
                <div class="period-stat">
                    <span class="period-stat-value">@_measurementsCount</span>
                    <span class="period-stat-label">Измерений</span>
                </div>
                <div class="period-stat-divider" aria-hidden="true"></div>
                <div class="period-stat">
                    <span class="period-stat-value text-danger">@_criticalCount</span>
                    <span class="period-stat-label">Критических</span>
                </div>
                <div class="period-stat-divider" aria-hidden="true"></div>
                <div class="period-stat">
                    <span class="period-stat-value text-warning">@_snacksCount</span>
                    <span class="period-stat-label">Перекусов</span>
                </div>
                @if (_avgGlucose.HasValue)
                {
                    <div class="period-stat-divider" aria-hidden="true"></div>
                    <div class="period-stat">
                        <span class="period-stat-value @GetGlucoseClass(_avgGlucose.Value)">
                            @_avgGlucose.Value.ToString("F1")
                        </span>
                        <span class="period-stat-label">Средняя глюкоза, ммоль/л</span>
                    </div>
                }
            </div>

            <!-- Лента событий -->
            <ol class="timeline" aria-label="Лента событий">
                @{
                    // Группируем по дате для отображения разделителей
                    var grouped = _filteredEvents
                        .GroupBy(e => e.OccurredAt.ToLocalTime().Date)
                        .OrderByDescending(g => g.Key);
                }
                @foreach (var group in grouped)
                {
                    <li class="timeline-date-separator" role="presentation">
                        <span class="date-pill">@FormatGroupDate(group.Key)</span>
                    </li>

                    @foreach (var evt in group.OrderByDescending(e => e.OccurredAt))
                    {
                        <li class="event-card @GetEventCardClass(evt)"
                            aria-label="@GetEventAriaLabel(evt)">

                            <!-- Значок типа события -->
                            <div class="event-badge @GetBadgeClass(evt)" aria-hidden="true">
                                @GetEventIcon(evt)
                            </div>

                            <!-- Основное содержимое -->
                            <div class="event-body">
                                <strong class="event-title">@GetEventTitle(evt)</strong>
                                <p class="event-description">@GetEventDescription(evt)</p>
                                @if (evt.IsImportant)
                                {
                                    <span class="event-important-badge" role="status">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"
                                             aria-hidden="true">
                                            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                                        </svg>
                                        Важное
                                    </span>
                                }
                                @if (!string.IsNullOrWhiteSpace(evt.Notes))
                                {
                                    <p class="event-notes">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none"
                                             stroke="currentColor" stroke-width="2" aria-hidden="true">
                                            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
                                        </svg>
                                        @evt.Notes
                                    </p>
                                }
                            </div>

                            <!-- Время и значение глюкозы -->
                            <div class="event-time-col">
                                @if (evt.GlucoseValue.HasValue)
                                {
                                    <span class="glucose-value @GetGlucoseClass(evt.GlucoseValue.Value)">
                                        @evt.GlucoseValue.Value.ToString("F1")
                                        <span class="glucose-unit">ммоль/л</span>
                                    </span>
                                }
                                <time class="event-time"
                                      datetime="@evt.OccurredAt.ToString("o")"
                                      title="@evt.OccurredAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")">
                                    @evt.OccurredAt.ToLocalTime().ToString("HH:mm")
                                </time>
                                @if (!string.IsNullOrWhiteSpace(evt.DataSource))
                                {
                                    <span class="event-source">@GetSourceLabel(evt.DataSource)</span>
                                }
                            </div>
                        </li>
                    }
                }
            </ol>
        }
    </main>
</div>

<!-- Стили -->
<style>
    /* ── Переменные страницы ─────────────────────────────────────────── */
    :root {
        --color-bg:             #f6f7fb;
        --color-surface:        rgba(255,255,255,0.78);
        --color-surface-2:      rgba(255,255,255,0.92);
        --color-surface-offset: #eef2fb;
        --color-border:         rgba(24,32,58,0.10);
        --color-divider:        rgba(24,32,58,0.08);
        --color-text:           #18203a;
        --color-text-muted:     #61708d;
        --color-text-faint:     #95a0b8;
        --color-primary:        #147a82;
        --color-primary-soft:   rgba(20,122,130,0.12);
        --color-success:        #3b9556;
        --color-success-soft:   rgba(59,149,86,0.13);
        --color-warning:        #d69416;
        --color-warning-soft:   rgba(214,148,22,0.13);
        --color-danger:         #d14d58;
        --color-danger-soft:    rgba(209,77,88,0.13);
        --shadow-sm:  0 8px 24px rgba(23,34,67,0.06);
        --shadow-md:  0 18px 40px rgba(23,34,67,0.09);
        --radius-sm:  0.75rem;
        --radius-md:  1rem;
        --radius-lg:  1.5rem;
        --radius-full: 999px;
        --font-body:  Satoshi, system-ui, sans-serif;
        --text-xs:    clamp(0.75rem,  0.72rem + 0.2vw, 0.875rem);
        --text-sm:    clamp(0.875rem, 0.84rem + 0.2vw, 1rem);
        --text-base:  clamp(1rem,     0.96rem + 0.2vw, 1.1rem);
        --text-lg:    clamp(1.125rem, 1rem    + 0.7vw, 1.45rem);
        --text-xl:    clamp(1.5rem,   1.2rem  + 1vw,   2.1rem);
    }

    [data-theme="dark"] {
        --color-bg:             #0d111b;
        --color-surface:        rgba(18,24,36,0.72);
        --color-surface-2:      rgba(18,24,36,0.9);
        --color-surface-offset: #11182a;
        --color-border:         rgba(202,219,255,0.09);
        --color-divider:        rgba(202,219,255,0.08);
        --color-text:           #edf3ff;
        --color-text-muted:     #9aa9c4;
        --color-text-faint:     #6f7b92;
        --color-primary:        #58c4b7;
        --color-primary-soft:   rgba(88,196,183,0.12);
        --color-success:        #5dcf80;
        --color-success-soft:   rgba(93,207,128,0.13);
        --color-warning:        #f7b84a;
        --color-warning-soft:   rgba(247,184,74,0.13);
        --color-danger:         #ff7480;
        --color-danger-soft:    rgba(255,116,128,0.13);
        --shadow-sm:  0 12px 30px rgba(0,0,0,0.28);
        --shadow-md:  0 18px 48px rgba(0,0,0,0.35);
    }

    /* ── Базовый сброс ───────────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    .sg-page {
        font-family: var(--font-body);
        color: var(--color-text);
        max-width: 900px;
        margin: 0 auto;
        padding: 0 var(--space-4, 1rem) 5rem;
    }

    /* ── Хлебные крошки ─────────────────────────────────────────────── */
    .breadcrumb {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 1.25rem 0 0.75rem;
        font-size: var(--text-xs);
        color: var(--color-text-faint);
    }

    .breadcrumb-link {
        color: var(--color-primary);
        text-decoration: none;
        transition: opacity 180ms ease;
    }

    .breadcrumb-link:hover { opacity: 0.75; }
    .breadcrumb-sep { font-size: 1rem; }
    .breadcrumb-current { color: var(--color-text-muted); }

    /* ── Заголовок страницы ─────────────────────────────────────────── */
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
        padding: 1.5rem 0 1.25rem;
    }

    .page-title {
        font-size: var(--text-xl);
        font-weight: 700;
        letter-spacing: -0.03em;
        line-height: 1.1;
    }

    .page-subtitle {
        margin-top: 0.4rem;
        font-size: var(--text-sm);
        color: var(--color-text-muted);
        max-width: 55ch;
    }

    /* ── Glassmorphism-карточка ─────────────────────────────────────── */
    .glass {
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        box-shadow: var(--shadow-sm);
    }

    /* ── Панель фильтров ─────────────────────────────────────────────── */
    .filters-bar {
        border-radius: var(--radius-lg);
        padding: 1.25rem 1.5rem;
        margin-bottom: 1.5rem;
    }

    .filters-inner {
        display: flex;
        flex-wrap: wrap;
        align-items: flex-end;
        gap: 1rem;
    }

    .filter-group {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
        flex: 1 1 140px;
        min-width: 120px;
    }

    .filter-label {
        font-size: var(--text-xs);
        color: var(--color-text-muted);
        font-weight: 500;
    }

    .sg-input {
        height: 40px;
        padding: 0 0.875rem;
        border-radius: var(--radius-sm);
        border: 1px solid var(--color-border);
        background: var(--color-surface-2);
        color: var(--color-text);
        font-size: var(--text-sm);
        font-family: var(--font-body);
        transition: border-color 180ms ease, box-shadow 180ms ease;
        outline: none;
    }

    .sg-input:focus {
        border-color: var(--color-primary);
        box-shadow: 0 0 0 3px var(--color-primary-soft);
    }

    /* ── Кнопки ─────────────────────────────────────────────────────── */
    .sg-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        height: 44px;
        padding: 0 1.25rem;
        border-radius: var(--radius-full);
        border: none;
        cursor: pointer;
        font-family: var(--font-body);
        font-size: var(--text-sm);
        font-weight: 600;
        transition: transform 180ms cubic-bezier(.16,1,.3,1),
                    box-shadow 180ms ease,
                    opacity 180ms ease;
        white-space: nowrap;
    }

    .sg-btn:hover:not(:disabled) { transform: translateY(-2px); }
    .sg-btn:active:not(:disabled) { transform: translateY(0); }
    .sg-btn:disabled { opacity: 0.55; cursor: not-allowed; }

    .sg-btn-primary {
        background: linear-gradient(135deg, var(--color-primary), #0d5c8a);
        color: #fff;
        box-shadow: 0 12px 28px rgba(40,148,186,0.22);
    }

    /* ── Спиннер ─────────────────────────────────────────────────────── */
    .spinner {
        width: 16px;
        height: 16px;
        border: 2px solid rgba(255,255,255,0.3);
        border-top-color: #fff;
        border-radius: 50%;
        animation: spin 0.7s linear infinite;
        flex-shrink: 0;
    }

    @@keyframes spin { to { transform: rotate(360deg); } }

    /* ── Алерт ───────────────────────────────────────────────────────── */
    .sg-alert {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.875rem 1rem;
        border-radius: var(--radius-md);
        font-size: var(--text-sm);
        margin-bottom: 1rem;
    }

    .sg-alert-error {
        background: var(--color-danger-soft);
        border: 1px solid rgba(209,77,88,0.25);
        color: var(--color-danger);
    }

    .sg-alert-close {
        margin-left: auto;
        background: transparent;
        border: none;
        cursor: pointer;
        color: inherit;
        opacity: 0.7;
        padding: 4px;
        border-radius: 4px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: opacity 180ms ease;
    }

    .sg-alert-close:hover { opacity: 1; }

    /* ── Статистика периода ─────────────────────────────────────────── */
    .period-stats {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0;
        border-radius: var(--radius-lg);
        padding: 1rem 1.5rem;
        margin-bottom: 1.5rem;
    }

    .period-stat {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.25rem;
        padding: 0.5rem 1.25rem;
        flex: 1 1 80px;
    }

    .period-stat-value {
        font-size: var(--text-lg);
        font-weight: 700;
        letter-spacing: -0.03em;
    }

    .period-stat-label {
        font-size: var(--text-xs);
        color: var(--color-text-muted);
        text-align: center;
    }

    .period-stat-divider {
        width: 1px;
        height: 36px;
        background: var(--color-divider);
        flex-shrink: 0;
    }

    .text-danger { color: var(--color-danger); }
    .text-warning { color: var(--color-warning); }
    .text-success { color: var(--color-success); }
    .text-primary { color: var(--color-primary); }
    .text-muted   { color: var(--color-text-muted); }

    /* ── Лента событий ───────────────────────────────────────────────── */
    .timeline {
        list-style: none;
        display: grid;
        gap: 0.875rem;
    }

    /* Разделитель по дате */
    .timeline-date-separator {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-top: 0.5rem;
    }

    .timeline-date-separator::before,
    .timeline-date-separator::after {
        content: '';
        flex: 1;
        height: 1px;
        background: var(--color-divider);
    }

    .date-pill {
        font-size: var(--text-xs);
        color: var(--color-text-muted);
        padding: 4px 12px;
        border-radius: var(--radius-full);
        border: 1px solid var(--color-border);
        background: var(--color-surface-offset);
        white-space: nowrap;
        font-weight: 500;
    }

    /* Карточка события */
    .event-card {
        display: grid;
        grid-template-columns: auto 1fr auto;
        align-items: center;
        gap: 1rem;
        padding: 1rem 1.25rem;
        border-radius: var(--radius-lg);
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        box-shadow: var(--shadow-sm);
        transition: transform 180ms cubic-bezier(.16,1,.3,1),
                    box-shadow 180ms ease;
    }

    .event-card:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-md);
    }

    /* Цветовые акценты по типу */
    .event-card--critical {
        border-color: rgba(209,77,88,0.28);
        background: linear-gradient(
            135deg,
            var(--color-danger-soft),
            var(--color-surface)
        );
    }

    .event-card--warning {
        border-color: rgba(214,148,22,0.25);
    }

    /* Значок */
    .event-badge {
        width: 44px;
        height: 44px;
        border-radius: 14px;
        display: grid;
        place-items: center;
        flex-shrink: 0;
        font-weight: 700;
        font-size: var(--text-sm);
    }

    .event-badge--measurement {
        background: var(--color-primary-soft);
        color: var(--color-primary);
    }

    .event-badge--snack {
        background: var(--color-warning-soft);
        color: var(--color-warning);
    }

    .event-badge--critical {
        background: var(--color-danger-soft);
        color: var(--color-danger);
    }

    .event-badge--doctor {
        background: var(--color-success-soft);
        color: var(--color-success);
    }

    /* Тело события */
    .event-body {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        min-width: 0;
    }

    .event-title {
        font-size: var(--text-base);
        font-weight: 600;
        color: var(--color-text);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .event-description {
        font-size: var(--text-sm);
        color: var(--color-text-muted);
        margin: 0;
    }

    .event-notes {
        display: flex;
        align-items: flex-start;
        gap: 5px;
        font-size: var(--text-xs);
        color: var(--color-text-faint);
        font-style: italic;
        margin: 0;
        max-width: 52ch;
    }

    .event-important-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: var(--text-xs);
        padding: 3px 8px;
        border-radius: var(--radius-full);
        background: rgba(209,77,88,0.12);
        color: var(--color-danger);
        font-weight: 600;
        width: fit-content;
    }

    /* Колонка времени и глюкозы */
    .event-time-col {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 0.25rem;
        flex-shrink: 0;
    }

    .glucose-value {
