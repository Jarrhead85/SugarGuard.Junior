    private async Task SaveParentProfileAsync()
    {
        if (string.IsNullOrWhiteSpace(_parentProfileForm.DisplayName))
        {
            _parentProfileError = "Введите имя родителя.";
            return;
        }

        if (string.IsNullOrWhiteSpace(_parentProfileForm.Email) || !_parentProfileForm.Email.Contains('@'))
        {
            _parentProfileError = "Введите корректный email.";
            return;
        }

        _parentProfile = _parentProfileForm.ToProfile();

        try
        {
            await JS.InvokeVoidAsync(
                "localStorage.setItem",
                ParentProfileStorageKey,
                JsonSerializer.Serialize(_parentProfile));
            ShowNotice("Данные родителя сохранены.");
            CancelParentProfileEdit();
        }
        catch (JSException ex)
        {
            Logger.LogWarning(ex, "Не удалось сохранить профиль родителя в localStorage.");
            _parentProfileError = "Не удалось сохранить данные в браузере.";
        }
    }

