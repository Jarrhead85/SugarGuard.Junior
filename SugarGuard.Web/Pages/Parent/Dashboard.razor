    private static string GetPositionWord(int n) => n switch
    {
        1 => "позиция",
        2 or 3 or 4 => "позиции",
        _ => "позиций"
    };

    private static string GetDisplayName(string? email, long? telegramId)
        => !string.IsNullOrWhiteSpace(email)
            ? email
            : telegramId.HasValue ? $"Telegram {telegramId.Value}" : "Пользователь";

    private static string GetInitials(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return "?";

        if (value.Contains('@'))
            return value[0].ToString().ToUpperInvariant();

        var parts = value.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[1][0]}".ToUpperInvariant()
            : parts[0][0].ToString().ToUpperInvariant();
    }

