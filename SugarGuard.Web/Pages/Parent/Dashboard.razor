    private void OpenAddBackpackItem()
    {
        _editingBackpackItemId = null;
        _backpackForm = BackpackItemForm.FromTemplate(BackpackTemplates[0]);
        _backpackFormError = null;
        _isBackpackEditorOpen = true;
    }

    private void EditBackpackItem(BackpackItem item)
    {
        _editingBackpackItemId = item.Id;
        _backpackForm = BackpackItemForm.FromItem(item);
        _backpackFormError = null;
        _isBackpackEditorOpen = true;
    }

    private void CancelBackpackEdit()
    {
        _isBackpackEditorOpen = false;
        _editingBackpackItemId = null;
        _backpackFormError = null;
    }

    private void OnBackpackTemplateChanged(ChangeEventArgs args)
    {
        var key = args.Value?.ToString() ?? BackpackTemplates[0].Key;
        var template = BackpackTemplates.FirstOrDefault(t => t.Key == key) ?? BackpackTemplates[0];
        _backpackForm = BackpackItemForm.FromTemplate(template);
        _backpackFormError = null;
    }

    private async Task SaveBackpackItemAsync()
    {
        if (string.IsNullOrWhiteSpace(_backpackForm.Name))
        {
            _backpackFormError = "Введите название позиции.";
            return;
        }

        if (_backpackForm.Quantity < 0)
        {
            _backpackFormError = "Количество не может быть отрицательным.";
            return;
        }

        var item = _backpackForm.ToItem(_editingBackpackItemId);
        var index = _editingBackpackItemId is null
            ? -1
            : _backpackItems.FindIndex(i => i.Id == _editingBackpackItemId);

        if (index >= 0)
        {
            _backpackItems[index] = item;
            ShowNotice("Позиция рюкзака обновлена.");
        }
        else
        {
            _backpackItems.Insert(0, item);
            ShowNotice("Позиция добавлена в рюкзак.");
        }

        await SaveBackpackAsync();
        CancelBackpackEdit();
    }

    private async Task RemoveBackpackItemAsync(string itemId)
    {
        var item = _backpackItems.FirstOrDefault(i => i.Id == itemId);
        if (item is null)
        {
            return;
        }

        _backpackItems.Remove(item);
        await SaveBackpackAsync();
        ShowNotice($"Позиция «{item.Name}» удалена из рюкзака.");
    }

    private async Task SaveBackpackAsync()
    {
        try
        {
            await JS.InvokeVoidAsync(
                "localStorage.setItem",
                BackpackStorageKey,
                JsonSerializer.Serialize(_backpackItems));
        }
        catch (JSException ex)
        {
            Logger.LogWarning(ex, "Не удалось сохранить рюкзак в localStorage.");
            ShowNotice("Позиция изменена, но браузер не разрешил сохранить её локально.");
        }
    }

