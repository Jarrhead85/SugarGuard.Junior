    private sealed class BackpackItem
    {
        public string Id { get; set; } = Guid.NewGuid().ToString("N");
        public List<Guid> ItemIds { get; set; } = [];
        public string Name { get; set; } = string.Empty;
        public string Category { get; set; } = "Другое";
        public string Icon { get; set; } = "+";
        public string Description { get; set; } = string.Empty;
        public int Quantity { get; set; }
        public string Unit { get; set; } = "шт.";
        public decimal BreadUnits { get; set; }

        public static BackpackItem FromApi(BackpackItemVm item)
        {
            var template = BackpackTemplates.FirstOrDefault(t =>
                item.SnackName.Contains(t.Name, StringComparison.OrdinalIgnoreCase));

            return new BackpackItem
            {
                Id = item.BackpackItemId.ToString("D"),
                ItemIds = [item.BackpackItemId],
                Name = item.SnackName,
                Category = template?.Category ?? "Другое",
                Icon = template?.Icon ?? "+",
                Description = GetBackpackItemDescription(item),
                Quantity = 1,
                Unit = "шт.",
                BreadUnits = item.BreadUnits
            };
        }

        public static BackpackItem FromApiGroup(IGrouping<string, BackpackItemVm> group)
        {
            var first = FromApi(group.First());
            first.ItemIds = group.Select(item => item.BackpackItemId).ToList();
            first.Id = first.ItemIds[0].ToString("D");
            first.Quantity = first.ItemIds.Count;
            return first;
        }

        private static string GetBackpackItemDescription(BackpackItemVm item)
        {
            var addedBy = item.AddedBy?.StartsWith("userId:", StringComparison.OrdinalIgnoreCase) == true
                ? "Добавлено пользователем"
                : item.AddedBy ?? "Добавлено в рюкзак";

            return $"{addedBy} · {ToDisplayTime(item.CreatedAt):dd.MM.yyyy HH:mm}";
        }

        public string Status => Quantity switch
        {
            <= 0 => "Нет",
            <= 2 => "Мало",
            _ => "Достаточно"
        };

        public string StatusClass => Quantity switch
        {
            <= 0 => "empty",
            <= 2 => "low",
            _ => "ok"
        };
    }

