@code {
    // Состояние навигации
    private string _activeTab = "overview";
    private int _chartRange = 12;
    private bool _hasChild;
    private string? _noticeMessage;

    // Состояние фильтров
    private string _alertFilter = "";
    private string _measStatusFilter = "";
    private DateTime _measFilterDate = DateTime.Today;
    private int _measPage = 1;
    private const int MeasPageSize = 10;
    private const string BackpackStorageKey = "sg-parent-backpack-v1";
    private const string ParentProfileStorageKey = "sg-parent-profile-v1";

    // Живые данные
    private double _currentGlucose;
    private string _currentGlucoseClass = "normal";
    private int _tirNormal;
    private int _tirHigh;
    private int _tirLow;
    private string _avgGlucose = "—";
    private int _totalMeas;
    private int _newMeasurementsCount => _measurements.Count(m => m.IsNew);
    private int _criticalAlertsCount => _allAlerts.Count(a => a.Type == "danger" && a.IsUnread);
    private int _lowStockCount => _backpackItems.Count(i => i.StatusClass is "low" or "empty");
    private bool _browserStateLoaded;
    private bool _isBackpackEditorOpen;
    private string? _editingBackpackItemId;
    private string? _backpackFormError;
    private BackpackItemForm _backpackForm = new();
    private bool _isParentProfileEditorOpen;
    private string? _parentProfileError;
    private ParentProfileForm _parentProfileForm = new();
    private ParentProfile _parentProfile = new();

    // Вкладки / панели
    private string TabClass(string tab) => _activeTab == tab ? "active" : "";
    private string PaneClass(string tab) => _activeTab == tab ? "active" : "";

    private void SwitchTab(string tab)
    {
        _activeTab = tab;
        var url = tab == "overview"
            ? "/parent/dashboard"
            : $"/parent/dashboard?tab={tab}";
        Navigation.NavigateTo(url, forceLoad: false);
    }

    // Инициализация
    protected override void OnInitialized()
    {
        SyncTabFromUri();
    }

    protected override void OnParametersSet()
    {
        SyncTabFromUri();
    }

    private void SyncTabFromUri()
    {
        var uri = new Uri(Navigation.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        var tab = query["tab"]?.ToLowerInvariant();
        _activeTab = string.IsNullOrEmpty(tab) ? "overview" : tab;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardDataAsync();
    }

    private async Task LoadDashboardDataAsync()
    {
        try
        {
            var children = await Api.GetMyChildrenAsync(CancellationToken.None);
            var childId = children.FirstOrDefault()?.ChildId ?? Guid.Empty;

            if (childId == Guid.Empty)
            {
                _hasChild = false;
                ResetChildData();
                return;
            }

            _hasChild = true;

            var summaryTask = Api.GetDashboardSummaryAsync(childId, CancellationToken.None);
            var profileTask = Api.GetChildProfileAsync(childId, CancellationToken.None);
            var statsTask = Api.GetStatisticsVmAsync(childId, "7d", CancellationToken.None);
            var timelineTask = Api.GetTimelineAsync(childId, DateTime.UtcNow.AddDays(-7), DateTime.UtcNow, CancellationToken.None);
            var measurementsTask = Api.GetMeasurementsAsync(childId, DateTime.UtcNow.AddDays(-1), DateTime.UtcNow, CancellationToken.None);

            await Task.WhenAll(summaryTask, profileTask, statsTask, timelineTask, measurementsTask);

            var summary = summaryTask.Result;
            var profile = profileTask.Result;
            var stats = statsTask.Result;

            // Метрики из сводки
            if (summary.LatestGlucose.HasValue)
            {
                _currentGlucose = (double)summary.LatestGlucose.Value;
                _currentGlucoseClass = summary.LatestGlucoseUiState switch
                {
                    "Critical" or "Danger" => "danger",
                    "Warning" or "Elevated" => "warn",
                    _ => "normal"
                };
            }

            _totalMeas = summary.TotalMeasurements;

            // Метрики из статистики
            if (stats is not null)
            {
                _tirNormal = (int)Math.Round(stats.TimeInTargetRange);
                _tirHigh = (int)Math.Round(stats.TimeAboveRange + stats.TimeCriticallyHigh);
                _tirLow = (int)Math.Round(stats.TimeBelowRange + stats.TimeCriticallyLow);
                _avgGlucose = stats.AverageGlucose.ToString("F1");
                _totalMeas = stats.TotalMeasurements;
            }

            // Профиль ребёнка
            if (profile is not null)
            {
                var age = DateTime.Today.Year - profile.DateOfBirth.Year;
                if (profile.DateOfBirth > DateOnly.FromDateTime(DateTime.Today).AddYears(-age)) age--;

                _childProfile.Name = profile.FullName;
                _childProfile.Age = age.ToString();
                _childProfile.DiabetesType = profile.DiabetesType;
            }

            // Уведомления из таймлайна
            var alerts = timelineTask.Result;
            if (alerts.Count > 0)
            {
                _allAlerts = alerts
                    .Where(e => e.EventType == TimelineEventType.Alert)
                    .Select(e => new AlertItem(
                        e.Title ?? "Событие",
                        e.Description ?? $"Глюкоза: {e.GlucoseValue?.ToString("F1") ?? "—"} ммоль/л",
                        GetRelativeTime(e.OccurredAt),
                        e.GlucoseUiState switch
                        {
                            "Critical" or "Danger" => "danger",
                            "Warning" => "warn",
                            _ => "info"
                        },
                        e.GlucoseUiState == "Critical" ? "!" : "•",
                        e.IsImportant
                    ))
                    .ToList();

                _recentAlerts = _allAlerts.Take(5).ToList();
            }

            _measurements.Clear();
            _measurements.AddRange(measurementsTask.Result
                .OrderByDescending(m => m.MeasurementTime)
                .Select(m => new MeasurementItem(
                    m.MeasurementTime.ToLocalTime().ToString("HH:mm"),
                    m.GlucoseValue.ToString("F1"),
                    GetTrendIcon(m.GlucoseUiState),
                    string.IsNullOrWhiteSpace(m.Notes) ? "Без заметки" : m.Notes,
                    GetMeasurementStatus(m.GlucoseUiState),
                    GetMeasurementStatusClass(m.GlucoseUiState),
                    m.MeasurementTime > DateTime.UtcNow.AddHours(-1))));
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Ошибка загрузки данных дашборда");
        }
    }

    private static string GetRelativeTime(DateTime utcTime)
    {
        var diff = DateTime.UtcNow - utcTime;
        if (diff.TotalMinutes < 1) return "только что";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes} мин назад";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours} ч назад";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays} дн назад";
        return utcTime.ToString("dd.MM");
    }

    private static string GetMeasurementStatusClass(string? state) => state switch
    {
        "Critical" or "Danger" => "danger",
        "Warning" or "Elevated" => "warn",
        _ => "normal"
    };

    private static string GetMeasurementStatus(string? state) => GetMeasurementStatusClass(state) switch
    {
        "danger" => "Критично",
        "warn" => "Выше нормы",
        _ => "Норма"
    };

    private static string GetTrendIcon(string? state) => GetMeasurementStatusClass(state) switch
    {
        "danger" => "↓↓",
        "warn" => "↑",
        _ => "→"
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        await LoadBrowserStateAsync();

        if (_activeTab == "overview")
            await RenderChartAsync();

        try
        {
            var vapidPublicKey = Configuration["Vapid:PublicKey"] ?? string.Empty;
            var apiBaseUrl = Configuration["ApiBaseUrl"] ?? string.Empty;
            var token = await TokenStore.GetTokenAsync();

            if (!string.IsNullOrEmpty(vapidPublicKey) && !string.IsNullOrEmpty(token))
            {
                await JS.InvokeVoidAsync(
                    "registerPushSubscription",
                    vapidPublicKey,
                    apiBaseUrl,
                    token);
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Не удалось зарегистрировать Push-подписку.");
        }
    }

    private async Task LoadBrowserStateAsync()
    {
        if (_browserStateLoaded)
        {
            return;
        }

        _browserStateLoaded = true;

        try
        {
            var storedBackpack = await JS.InvokeAsync<string?>("localStorage.getItem", BackpackStorageKey);
            var backpackItems = string.IsNullOrWhiteSpace(storedBackpack)
                ? null
                : JsonSerializer.Deserialize<List<BackpackItem>>(storedBackpack);

            _backpackItems.Clear();
            if (backpackItems is { Count: > 0 })
            {
                _backpackItems.AddRange(backpackItems);
            }

            var storedProfile = await JS.InvokeAsync<string?>("localStorage.getItem", ParentProfileStorageKey);
            var profile = string.IsNullOrWhiteSpace(storedProfile)
                ? null
                : JsonSerializer.Deserialize<ParentProfile>(storedProfile);
            if (profile is not null)
            {
                _parentProfile = profile;
            }

            StateHasChanged();
        }
        catch (Exception ex) when (ex is JSException or JsonException or InvalidOperationException)
        {
            Logger.LogWarning(ex, "Не удалось загрузить локальное состояние кабинета родителя.");
        }
    }

    private async Task RenderChartAsync()
    {
        try
        {
            var points = _measurements
                .Select(m => new
                {
                    Label = m.Time,
                    Value = double.TryParse(m.Value, out var value) ? value : 0d
                })
                .ToList();

            await JS.InvokeVoidAsync(
                "SugarGuard.renderGlucoseChart",
                "glucoseChart",
                JsonSerializer.Serialize(points.Select(p => p.Label)),
                JsonSerializer.Serialize(points.Select(p => p.Value)),
                "#0694a2");
        }
        catch (JSException)
        {
        }
    }

