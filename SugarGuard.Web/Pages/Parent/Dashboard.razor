@page "/parent/dashboard"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Parent")]
@implements IDisposable
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.JSInterop
@using SugarGuard.Domain.Enums
@using SugarGuard.Shared.Enums
@using SugarGuard.Web.Services
@using SugarGuard.Web.ViewModels
@using SugarGuard.Web.Components.Pages.Parent
@using SugarGuard.Web.Components.Shared
@using System.Text.Json
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IConfiguration Configuration
@inject ITokenStore TokenStore
@inject ILogger<Dashboard> Logger
@inject SugarGuardApiService Api
@inject ICurrentUserService CurrentUser

<PageTitle>Кабинет родителя — SugarGuard</PageTitle>

@* Dashboard родителя *@

@* Информер о ребёнке (вверху, всегда виден) *@
<div class="child-banner">
    @if (_hasChild)
    {
        <div class="child-banner-avatar" aria-hidden="true">🧒</div>
        <div class="child-banner-info">
            <span class="child-banner-name">@_childProfile.Name</span>
            <span class="child-banner-sub">@_childProfile.Age лет</span>
            @if (_availableChildren.Count > 1)
            {
                <select class="child-banner-select"
                        value="@_selectedChildId"
                        aria-label="Выбрать ребёнка"
                        @onchange="OnSelectedChildChangedAsync">
                    @foreach (var child in _availableChildren)
                    {
                        <option value="@child.ChildId">@GetChildDisplayName(child)</option>
                    }
                </select>
            }
        </div>
        <div class="child-banner-glucose @_currentGlucoseClass" aria-label="Текущий уровень глюкозы">
            <span class="pulse-dot" aria-hidden="true"></span>
            <span class="child-banner-glucose-val">@_currentGlucose.ToString("F1")</span>
            <span class="child-banner-glucose-unit">ммоль/л</span>
        </div>
        <button class="btn btn--ghost btn--sm" @onclick='() => Navigation.NavigateTo("/parent/link-child")'>
            Привязать ещё
        </button>
    }
    else
    {
        <div class="child-banner-avatar" aria-hidden="true">+</div>
        <div class="child-banner-info">
            <span class="child-banner-name">Ребёнок ещё не привязан</span>
            <span class="child-banner-sub">Создайте код в мобильном приложении ребёнка и привяжите его здесь</span>
        </div>
        <button class="btn btn--primary btn--sm" @onclick='() => Navigation.NavigateTo("/parent/link-child")'>
            Привязать ребёнка
        </button>
    }
</div>

@if (!string.IsNullOrWhiteSpace(_noticeMessage))
{
    <div class="state-banner state-banner--info" role="status">
        <span>@_noticeMessage</span>
        <button class="btn btn--ghost btn--sm" style="margin-left:auto" @onclick="ClearNotice">Закрыть</button>
    </div>
}

@* Вкладки *@
<nav class="tabs" role="tablist" aria-label="Разделы дашборда">
    <button class="tab @TabClass("overview")" role="tab"
            aria-selected="@(_activeTab == "overview")"
            aria-controls="pane-overview"
            @onclick='() => SwitchTab("overview")'>Обзор</button>

    <button class="tab @TabClass("measurements")" role="tab"
            aria-selected="@(_activeTab == "measurements")"
            aria-controls="pane-measurements"
            @onclick='() => SwitchTab("measurements")'>
        Измерения
        @if (_newMeasurementsCount > 0)
        {
            <span class="tab-badge ok" aria-label="@_newMeasurementsCount новых">@_newMeasurementsCount</span>
        }
    </button>

    <button class="tab @TabClass("alerts")" role="tab"
            aria-selected="@(_activeTab == "alerts")"
            aria-controls="pane-alerts"
            @onclick='() => SwitchTab("alerts")'>
        Уведомления
        @if (_unreadNotificationsCount > 0)
        {
            <span class="tab-badge danger" aria-label="@_unreadNotificationsCount непрочитанных">@_unreadNotificationsCount</span>
        }
    </button>

    <button class="tab @TabClass("backpack")" role="tab"
            aria-selected="@(_activeTab == "backpack")"
            aria-controls="pane-backpack"
            @onclick='() => SwitchTab("backpack")'>
        Рюкзак
        @if (_lowStockCount > 0)
        {
            <span class="tab-badge warn" aria-label="@_lowStockCount позиций мало">@_lowStockCount</span>
        }
    </button>

    <button class="tab @TabClass("nutrition")" role="tab"
            aria-selected="@(_activeTab == "nutrition")"
            aria-controls="pane-nutrition"
            @onclick='() => SwitchTab("nutrition")'>Дневник питания</button>

    <button class="tab @TabClass("doctor")" role="tab"
            aria-selected="@(_activeTab == "doctor")"
            aria-controls="pane-doctor"
            @onclick='() => SwitchTab("doctor")'>Записки врача</button>

    <button class="tab @TabClass("profile")" role="tab"
            aria-selected="@(_activeTab == "profile")"
            aria-controls="pane-profile"
            @onclick='() => SwitchTab("profile")'>Профиль ребёнка</button>

    <button class="tab @TabClass("settings")" role="tab"
            aria-selected="@(_activeTab == "settings")"
            aria-controls="pane-settings"
            @onclick='() => SwitchTab("settings")'>Настройки</button>
</nav>

@* ОБЗОР *@
<div class="tab-pane @PaneClass("overview")" id="pane-overview" role="tabpanel">

    @* Основные показатели *@
    <div class="kpi-grid">
        <StatCard Label="Глюкоза сейчас"
                  Value="@_currentGlucose.ToString("F1")"
                  Unit="ммоль/л"
                  Subtitle="@($"цель: {_targetMin:0.0}–{_targetMax:0.0}")"
                  Delta="@_glucoseDeltaText"
                  DeltaLabel="к предыдущему"
                  Variant="glucose" />
        <StatCard Label="Время в диапазоне"
                  Value="@_tirNormal.ToString()"
                  Unit="%"
                  Subtitle="за последние 7 дней"
                  Status="safe"
                  Variant="kpi" />
        <StatCard Label="Ниже нормы"
                  Value="@_tirLow.ToString()"
                  Unit="%"
                  Subtitle="@($"ниже {_targetMin:0.0} ммоль/л")"
                  Status="danger"
                  Variant="kpi" />
        <StatCard Label="Выше нормы"
                  Value="@_tirHigh.ToString()"
                  Unit="%"
                  Subtitle="@($"выше {_targetMax:0.0} ммоль/л")"
                  Status="warning"
                  Variant="kpi" />
    </div>

    @* График + Последние события *@
    <div class="grid-2">
        <div class="card">
            <div class="card-head">
                <div>
                    <div class="card-title">График глюкозы</div>
                    <div class="card-sub">Данные мониторинга</div>
                </div>
                <div class="btn-group" role="group" aria-label="Диапазон графика">
                    <button class="btn btn--ghost btn--sm @(_chartRange == 6 ? "btn--soft" : "")"
                            @onclick='() => SetChartRange(6)'>6ч</button>
                    <button class="btn btn--ghost btn--sm @(_chartRange == 12 ? "btn--soft" : "")"
                            @onclick='() => SetChartRange(12)'>12ч</button>
                    <button class="btn btn--ghost btn--sm @(_chartRange == 24 ? "btn--soft" : "")"
                            @onclick='() => SetChartRange(24)'>24ч</button>
                </div>
            </div>
            <div class="chart-wrap" id="glucoseChartWrap">
                <GlucoseChart Points="@_chartPoints"
                              HeightPx="200"
                              TargetMin="@((double)_targetMin)"
                              TargetMax="@((double)_targetMax)"
                              ShowHeader="false"
                              ShowLegend="false" />
            </div>
            <div class="chart-legend" aria-hidden="true">
                <span class="legend-item">
                    <span class="legend-dot" style="background:var(--color-glucose-normal)"></span>
                    Норма
                </span>
                <span class="legend-item">
                    <span class="legend-dot" style="background:var(--color-glucose-warning)"></span>
                    Выше нормы
                </span>
                <span class="legend-item">
                    <span class="legend-dot" style="background:var(--color-glucose-low, #3b82f6)"></span>
                    Ниже нормы
                </span>
                <span class="legend-item">
                    <span class="legend-dot" style="background:var(--color-glucose-danger)"></span>
                    Критично
                </span>
            </div>
        </div>

        <div class="card">
            <div class="card-head">
                <div>
                    <div class="card-title">Недавние события</div>
                    <div class="card-sub">Последние уведомления</div>
                </div>
                @if (_unreadNotificationsCount > 0)
                {
                    <span class="badge badge--danger" aria-label="@_unreadNotificationsCount непрочитанных">
                        @_unreadNotificationsCount
                    </span>
                }
            </div>
            @if (_allAlerts.Count == 0)
            {
                <div class="empty-state" role="status">
                    <div class="empty-state__icon">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
                            <polyline points="22 4 12 14.01 9 11.01" />
                        </svg>
                    </div>
                    <p class="empty-state__text">Всё в порядке — событий нет</p>
                </div>
            }
            else
            {
                <div class="alert-list" role="list">
                    @foreach (var alert in _pagedRecentAlerts)
                    {
                        <div class="alert-item" role="listitem">
                            <span class="alert-item__indicator alert-item__indicator--@alert.Type"
                                  aria-hidden="true"></span>
                            <div class="alert-icon @alert.Type" aria-hidden="true">@alert.Icon</div>
                            <div class="alert-body">
                                <div class="alert-title">@alert.Title</div>
                                <div class="alert-desc">@alert.Description</div>
                            </div>
                            <time class="alert-time">@alert.Time</time>
                        </div>
                    }
                </div>
                <div class="event-pagination" role="navigation" aria-label="Страницы недавних событий">
                    <span>@(_recentEventPage) из @_recentEventTotalPages</span>
                    <div class="btn-group">
                        <button class="btn btn--ghost btn--sm"
                                disabled="@(_recentEventPage <= 1)"
                                @onclick="PrevRecentEventPage"
                                aria-label="Предыдущие события">←</button>
                        <button class="btn btn--ghost btn--sm"
                                disabled="@(_recentEventPage >= _recentEventTotalPages)"
                                @onclick="NextRecentEventPage"
                                aria-label="Следующие события">→</button>
                    </div>
                </div>
            }
        </div>
    </div>

    @* Быстрая статистика + Инсулин сегодня *@
    <div class="grid-3">
        <div class="card card--sm">
            <div class="card-title" style="font-size:var(--font-size-sm);margin-bottom:var(--spacing-3)">
                Статистика за 7 дней
            </div>
            <div class="stats-list">
                <div class="stats-row">
                    <span class="stats-label">Средняя глюкоза</span>
                    <strong>@_avgGlucose ммоль/л</strong>
                </div>
                <div class="stats-row">
                    <span class="stats-label">TIR</span>
                    <strong style="color:var(--color-glucose-normal)">@_tirNormal%</strong>
                </div>
                <div class="stats-row">
                    <span class="stats-label">Гипо (%)</span>
                    <strong style="color:var(--color-glucose-danger)">@_tirLow%</strong>
                </div>
                <div class="stats-row">
                    <span class="stats-label">Гипер (%)</span>
                    <strong style="color:var(--color-glucose-warning)">@_tirHigh%</strong>
                </div>
                <div class="stats-row">
                    <span class="stats-label">Измерений</span>
                    <strong>@_totalMeas</strong>
                </div>
            </div>
        </div>

        <div class="card card--sm">
            <div class="card-title" style="font-size:var(--font-size-sm);margin-bottom:var(--spacing-3)">
                Инсулин сегодня
            </div>
            <div class="ins-list" role="list">
                @foreach (var ins in _insulinLog.Take(4))
                {
                    <div class="ins-row" role="listitem">
                        <span class="ins-dot @ins.Type"
                              aria-label="@(ins.Type == "bolus" ? "Болюс" : "Базальный")"
                              title="@(ins.Type == "bolus" ? "Болюс" : "Базальный")"></span>
                        <div class="ins-info">
                            <span class="ins-name">@ins.Name</span>
                            <span class="ins-time">@ins.Time</span>
                        </div>
                        <strong class="ins-dose">@ins.Dose</strong>
                    </div>
                }
            </div>
        </div>

        <div class="card card--sm">
            <div class="card-title" style="font-size:var(--font-size-sm);margin-bottom:var(--spacing-3)">
                Параметры цели
            </div>
            <div class="stats-list">
                <div class="stats-row">
                    <span class="stats-label">Целевой диапазон</span>
                    <strong>@_targetMin.ToString("0.0")–@_targetMax.ToString("0.0")</strong>
                </div>
                <div class="stats-row">
                    <span class="stats-label">HbA1c (оценка)</span>
                    <strong>@_childProfile.HbA1c%</strong>
                </div>
                <div class="stats-row">
                    <span class="stats-label">Гипо порог</span>
                    <strong style="color:var(--color-glucose-danger)">&lt;@_targetMin.ToString("0.0")</strong>
                </div>
                <div class="stats-row">
                    <span class="stats-label">Гипер порог</span>
                    <strong style="color:var(--color-glucose-warning)">&gt;@_targetMax.ToString("0.0")</strong>
                </div>
                <div class="stats-row">
                    <span class="stats-label">Коэффициент углеводов</span>
                    <strong>1:@_carbRatio.ToString("0.#")</strong>
                </div>
            </div>
            <button class="btn btn--soft btn--sm" style="margin-top:var(--spacing-3);width:100%"
                    @onclick="OpenTargetEditor">
                Изменить цели
            </button>
            @if (_isTargetEditorOpen)
            {
                <div class="inline-editor inline-editor--compact" role="region" aria-label="Редактор целевых параметров">
                    <div class="editor-grid">
                        <div class="input-wrap">
                            <label class="form-label" for="targetMin">Нижняя граница</label>
                            <input id="targetMin" class="form-input" type="number" min="2" max="15" step="0.1"
                                   @bind="_targetForm.Min" />
                        </div>
                        <div class="input-wrap">
                            <label class="form-label" for="targetMax">Верхняя граница</label>
                            <input id="targetMax" class="form-input" type="number" min="2" max="20" step="0.1"
                                   @bind="_targetForm.Max" />
                        </div>
                        <div class="input-wrap">
                            <label class="form-label" for="targetSensitivity">Чувствительность</label>
                            <input id="targetSensitivity" class="form-input" type="number" min="0.1" max="20" step="0.1"
                                   @bind="_targetForm.InsulinSensitivity" />
                        </div>
                        <div class="input-wrap">
                            <label class="form-label" for="targetCarb">Углеводный коэффициент</label>
                            <input id="targetCarb" class="form-input" type="number" min="0.1" max="50" step="0.1"
                                   @bind="_targetForm.CarbRatio" />
                        </div>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(_targetFormError))
                    {
                        <div class="form-error">@_targetFormError</div>
                    }
                    <div class="editor-actions">
                        <button class="btn btn--primary btn--sm" @onclick="SaveTargetSettingsAsync">Сохранить</button>
                        <button class="btn btn--ghost btn--sm" @onclick="CancelTargetEdit">Отмена</button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@* ИЗМЕРЕНИЯ *@
<div class="tab-pane @PaneClass("measurements")" id="pane-measurements" role="tabpanel">

    @* Фильтры *@
    <div class="card" style="margin-bottom:0">
        <div class="filter-row">
            <div class="input-wrap">
                <label class="form-label" for="measDate">Дата</label>
                <input id="measDate" class="form-input" type="date"
                       @bind="_measFilterDate"
                       max="@DateTime.Today.ToString("yyyy-MM-dd")"
                       aria-label="Выбрать дату" />
            </div>
            <div class="input-wrap">
                <label class="form-label" for="measStatus">Статус</label>
                <select id="measStatus" class="form-select" @bind="_measStatusFilter"
                        aria-label="Фильтр по статусу">
                    <option value="">Все статусы</option>
                    <option value="normal">В норме</option>
                    <option value="warn">Выше нормы</option>
                    <option value="danger">Критично</option>
                </select>
            </div>
            <div class="filter-actions">
                <button class="btn btn--primary"
                        @onclick="ApplyMeasFilterAsync"
                        aria-label="Применить фильтры">Применить</button>
                <button class="btn btn--ghost"
                        @onclick="ResetMeasFilterAsync"
                        aria-label="Сбросить фильтры">Сегодня</button>
                <button class="btn btn--ghost"
                        @onclick="ExportCsvAsync"
                        aria-label="Экспорт в CSV">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                        <polyline points="7 10 12 15 17 10" />
                        <line x1="12" y1="15" x2="12" y2="3" />
                    </svg>
                    CSV
                </button>
            </div>
        </div>
    </div>

    @* Таблица *@
    <div class="card" style="padding:0;overflow:hidden">
        <table class="data-table" aria-label="История измерений глюкозы">
            <thead>
                <tr>
                    <th scope="col">Время</th>
                    <th scope="col">Глюкоза</th>
                    <th scope="col">Тренд</th>
                    <th scope="col">Заметка</th>
                    <th scope="col">Статус</th>
                </tr>
            </thead>
            <tbody>
                @if (_filteredMeasurements.Count == 0)
                {
                    <tr>
                        <td colspan="5" style="text-align:center;padding:var(--spacing-8);color:var(--color-text-muted)">
                            Нет измерений за выбранный период
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var m in _filteredMeasurements)
                    {
                        <tr>
                            <td class="tabular-nums" style="white-space:nowrap">@m.Time</td>
                            <td>
                                <span class="glucose-chip @m.StatusClass"
                                      aria-label="@m.Value ммоль/л, статус: @m.Status">
                                    <span class="pulse-dot @m.StatusClass" aria-hidden="true"></span>
                                    @m.Value
                                </span>
                            </td>
                            <td class="trend-cell" aria-label="Тренд: @m.Trend">@m.TrendIcon</td>
                            <td style="color:var(--color-text-muted);font-size:var(--font-size-xs)">@m.Note</td>
                            <td><span class="status-label @m.StatusClass">@m.Status</span></td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @* Пагинация *@
    <div class="pagination-row" role="navigation" aria-label="Пагинация">
        <span class="pagination-info">
            Показано @_filteredMeasurements.Count из @_totalMeas записей
        </span>
        <div class="btn-group">
            <button class="btn btn--ghost btn--sm"
                    disabled="@(_measPage <= 1)"
                    @onclick="PrevMeasPage"
                    aria-label="Предыдущая страница">← Назад</button>
            <span class="pagination-page" aria-current="page">@_measPage</span>
            <button class="btn btn--ghost btn--sm"
                    @onclick="NextMeasPage"
                    aria-label="Следующая страница">Вперёд →</button>
        </div>
    </div>
</div>

@* УВЕДОМЛЕНИЯ *@
<div class="tab-pane @PaneClass("alerts")" id="pane-alerts" role="tabpanel">

    <div class="filter-chips" role="group" aria-label="Фильтры уведомлений">
        <button class="chip @(_alertFilter == "" ? "chip-active" : "")"
                @onclick='() => SetAlertFilter("")'>
            Все <span class="chip-count">@_allAlerts.Count</span>
        </button>
        <button class="chip @(_alertFilter == "danger" ? "chip-active chip-danger" : "")"
                @onclick='() => SetAlertFilter("danger")'>
            Критические <span class="chip-count">@_allAlerts.Count(a => a.Type == "danger")</span>
        </button>
        <button class="chip @(_alertFilter == "warn" ? "chip-active chip-warn" : "")"
                @onclick='() => SetAlertFilter("warn")'>
            Предупреждения <span class="chip-count">@_allAlerts.Count(a => a.Type == "warn")</span>
        </button>
        <button class="chip @(_alertFilter == "info" ? "chip-active" : "")"
                @onclick='() => SetAlertFilter("info")'>
            Инфо <span class="chip-count">@_allAlerts.Count(a => a.Type == "info")</span>
        </button>
        <button class="chip @(_alertFilter == "ok" ? "chip-active chip-ok" : "")"
                @onclick='() => SetAlertFilter("ok")'>
            Решено <span class="chip-count">@_allAlerts.Count(a => a.Type == "ok")</span>
        </button>
        @if (_allAlerts.Any(a => a.IsUnread))
        {
            <button class="btn btn--ghost btn--sm" style="margin-left:auto"
                    @onclick="MarkAllAlertsRead">Прочитать все</button>
        }
    </div>

    <div class="alert-list" role="list">
        @if (_filteredAlertCount == 0)
        {
            <div class="empty-state" role="status">
                <div class="empty-state__icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
                        <polyline points="22 4 12 14.01 9 11.01" />
                    </svg>
                </div>
                <h4 class="empty-state__title">Нет событий</h4>
                <p class="empty-state__text">По выбранному фильтру событий не найдено</p>
            </div>
        }
        else
        {
            @foreach (var alert in _pagedAlerts)
            {
                 <div class="alert-item @(alert.IsUnread ? "alert-item--unread" : "")"
                     role="listitem">
                    <span class="alert-item__indicator alert-item__indicator--@alert.Type"
                          aria-hidden="true"></span>
                    <div class="alert-icon @alert.Type" aria-hidden="true">@alert.Icon</div>
                    <div class="alert-body">
                        <div class="alert-title">@alert.Title</div>
                        <div class="alert-desc">@alert.Description</div>
                    </div>
                    <div class="alert-meta">
                        <time class="alert-time">@alert.Time</time>
                        <button class="btn btn--icon alert-dismiss"
                                @onclick="() => DismissAlert(alert)"
                                aria-label="Скрыть уведомление «@alert.Title»"
                                title="Скрыть">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="2" aria-hidden="true">
                                <line x1="18" y1="6" x2="6" y2="18" />
                                <line x1="6" y1="6" x2="18" y2="18" />
                            </svg>
                        </button>
                    </div>
                </div>
            }
        }
    </div>
    @if (_filteredAlertCount > 0)
    {
        <div class="pagination-row" role="navigation" aria-label="Страницы уведомлений">
            <span class="pagination-info">
                Показано @_pagedAlerts.Count из @_filteredAlertCount уведомлений
            </span>
            <div class="btn-group">
                <button class="btn btn--ghost btn--sm"
                        disabled="@(_alertPage <= 1)"
                        @onclick="PrevAlertPage">← Назад</button>
                <span class="pagination-page" aria-current="page">@_alertPage</span>
                <button class="btn btn--ghost btn--sm"
                        disabled="@(_alertPage >= _alertTotalPages)"
                        @onclick="NextAlertPage">Вперёд →</button>
            </div>
        </div>
    }
</div>

@* РЮКЗАК *@
<div class="tab-pane @PaneClass("backpack")" id="pane-backpack" role="tabpanel">

    <div class="card">
        <div class="card-head">
            <div>
                <div class="card-title">Расходники и препараты</div>
                <div class="card-sub">Актуальный остаток</div>
            </div>
            <button class="btn btn--primary btn--sm"
                    @onclick="OpenAddBackpackItem">+ Добавить позицию</button>
        </div>

        @if (_isBackpackEditorOpen)
        {
            <div class="inline-editor" role="region" aria-label="Редактор позиции рюкзака">
                <div class="editor-grid">
                    <div class="input-wrap">
                        <label class="form-label" for="bpTemplate">Готовый шаблон</label>
                        <select id="bpTemplate" class="form-select"
                                value="@_backpackForm.TemplateKey"
                                @onchange="OnBackpackTemplateChanged">
                            @foreach (var template in BackpackTemplates)
                            {
                                <option value="@template.Key">@template.Name</option>
                            }
                        </select>
                    </div>
                    <div class="input-wrap">
                        <label class="form-label" for="bpName">Название</label>
                        <input id="bpName" class="form-input" @bind="_backpackForm.Name" />
                    </div>
                    <div class="input-wrap">
                        <label class="form-label" for="bpCategory">Категория</label>
                        <select id="bpCategory" class="form-select" @bind="_backpackForm.Category">
                            <option>Перекус</option>
                            <option>Измерения</option>
                            <option>Инсулин</option>
                            <option>Экстренно</option>
                            <option>Другое</option>
                        </select>
                    </div>
                    <div class="input-wrap">
                        <label class="form-label" for="bpQuantity">Количество</label>
                        <input id="bpQuantity" class="form-input" type="number" min="0" max="999"
                               @bind="_backpackForm.Quantity" />
                    </div>
                    <div class="input-wrap">
                        <label class="form-label" for="bpUnit">Единица</label>
                        <input id="bpUnit" class="form-input" @bind="_backpackForm.Unit" />
                    </div>
                    <div class="input-wrap">
                        <label class="form-label" for="bpCarbs">ХЕ</label>
                        <input id="bpCarbs" class="form-input" type="number" min="0" max="99" step="0.1"
                               @bind="_backpackForm.BreadUnits" />
                    </div>
                    <div class="input-wrap editor-span">
                        <label class="form-label" for="bpDescription">Описание</label>
                        <input id="bpDescription" class="form-input" @bind="_backpackForm.Description" />
                    </div>
                </div>
                @if (!string.IsNullOrWhiteSpace(_backpackFormError))
                {
                    <div class="form-error">@_backpackFormError</div>
                }
                <div class="editor-actions">
                    <button class="btn btn--primary btn--sm" @onclick="SaveBackpackItemAsync">
                        @(_editingBackpackItemId is null ? "Добавить" : "Сохранить")
                    </button>
                    <button class="btn btn--ghost btn--sm" @onclick="CancelBackpackEdit">Отмена</button>
                </div>
            </div>
        }

        <div class="backpack-grid" role="list">
            @if (_backpackItems.Count == 0)
            {
                <div class="empty-state" role="status">
                    <h4 class="empty-state__title">Рюкзак пока пуст</h4>
                    <p class="empty-state__text">Добавьте перекусы, полоски, глюкометр, инсулин или экстренные позиции.</p>
                </div>
            }
            else
            {
                @foreach (var item in _backpackItems)
                {
                    <div class="bp-item @(item.StatusClass == "empty" ? "bp-item--empty" : "")"
                         role="listitem">
                        <div class="bp-icon" aria-hidden="true">@item.Icon</div>
                        <div class="bp-info">
                            <div class="bp-name">@item.Name</div>
                            <div class="bp-sub">@item.Description</div>
                            <div class="bp-meta">@item.Category@if (item.BreadUnits > 0) { <span> · @item.BreadUnits.ToString("0.#") ХЕ</span> }</div>
                        </div>
                        <div class="bp-qty" aria-label="Количество: @item.Quantity @item.Unit">
                            <span>@item.Quantity</span>
                            <small>@item.Unit</small>
                        </div>
                        <span class="bp-status @item.StatusClass" role="status">@item.Status</span>
                        <div class="bp-actions">
                            <button class="btn btn--ghost btn--sm" @onclick="() => EditBackpackItem(item)">Изменить</button>
                            <button class="btn btn--ghost btn--sm" @onclick="() => RemoveBackpackItemAsync(item.Id)">Удалить</button>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    @if (_lowStockCount > 0)
    {
        <div class="state-banner state-banner--warn" role="alert">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
                <line x1="12" y1="9" x2="12" y2="13" />
                <line x1="12" y1="17" x2="12.01" y2="17" />
            </svg>
            <span>@_lowStockCount @(GetPositionWord(_lowStockCount)) требуют пополнения</span>
        </div>
    }
</div>

@* ДНЕВНИК ПИТАНИЯ *@
<div class="tab-pane @PaneClass("nutrition")" id="pane-nutrition" role="tabpanel">
    <ParentNutrition Embedded="true" ChildId="_selectedChildId" />
</div>

@* ВРАЧ *@
<div class="tab-pane @PaneClass("doctor")" id="pane-doctor" role="tabpanel">

    <div class="grid-2">
        @* Записки врача *@
        <div class="card">
            <div class="card-head">
                <div>
                    <div class="card-title">Записки врача</div>
                    <div class="card-sub">Рекомендации и назначения</div>
                </div>
                <button class="btn btn--primary btn--sm"
                        @onclick="NavigateToAccessLinks">Управлять доступом</button>
            </div>
            <div class="note-list" role="list">
                @if (_doctorNotes.Count == 0)
                {
                    <div class="empty-state empty-state--compact" role="status">
                        Назначения появятся здесь после записей врача в кабинете SugarGuard.
                    </div>
                }
                else
                {
                    @foreach (var note in _doctorNotes)
                    {
                        <div class="note" role="listitem">
                            <div class="note-head">
                                <span class="note-doctor">@note.Doctor</span>
                                <time class="note-date">@note.Date</time>
                            </div>
                            <div class="note-tags" aria-label="Ребёнок">
                                <span class="note-tag">@_childProfile.Name</span>
                            </div>
                            <p class="note-text">@note.Text</p>
                            <div class="note-tags" aria-label="Теги записки">
                                @foreach (var tag in note.Tags)
                                {
                                    <span class="note-tag">@tag</span>
                                }
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        @* Связанные врачи *@
        <div>
            <div class="card" style="margin-bottom:var(--spacing-4)">
                <div class="card-head">
                    <div>
                        <div class="card-title">Доступ родителей</div>
                        <div class="card-sub">Кто может управлять профилем ребёнка</div>
                    </div>
                    <button class="btn btn--soft btn--sm" @onclick="NavigateToAccessLinks">Коды доступа</button>
                </div>
                @if (_linkedParents.Count == 0)
                {
                    <div class="empty-state empty-state--compact" role="status">
                        Родительские связи не найдены. Обновите данные или создайте код доступа.
                    </div>
                }
                else
                {
                    <div class="settings-group" role="list">
                        @foreach (var parent in _linkedParents)
                        {
                            <div class="setting-row" role="listitem">
                                <div class="doctor-avatar" aria-hidden="true">
                                    @GetInitials(string.IsNullOrWhiteSpace(parent.DisplayName) ? parent.EmailForLogin : parent.DisplayName)
                                </div>
                                <div class="setting-text">
                                    <div class="setting-label">@(string.IsNullOrWhiteSpace(parent.DisplayName) ? GetDisplayName(parent.EmailForLogin, parent.TelegramId) : parent.DisplayName)</div>
                                    <div class="setting-desc">Подключён @ToDisplayTime(parent.LinkedAt).ToString("dd.MM.yyyy HH:mm")</div>
                                </div>
                                <button class="btn btn--ghost btn--sm" @onclick="() => UnlinkParentAsync(parent.LinkId)">Отвязать</button>
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="card" style="margin-bottom:var(--spacing-4)">
                <div class="card-head">
                    <div>
                        <div class="card-title">Доступ врачей</div>
                        <div class="card-sub">Кто видит профиль ребёнка</div>
                    </div>
                    <button class="btn btn--soft btn--sm" @onclick="NavigateToAccessLinks">Коды доступа</button>
                </div>
                @if (_linkedDoctors.Count == 0)
                {
                    <div class="empty-state empty-state--compact" role="status">
                        Врач пока не привязан. Выдайте код врачу в разделе доступа.
                    </div>
                }
                else
                {
                    <div class="settings-group" role="list">
                        @foreach (var doctor in _linkedDoctors)
                        {
                            <div class="setting-row" role="listitem">
                                <div class="doctor-avatar" aria-hidden="true">
                                    @if (!string.IsNullOrWhiteSpace(doctor.PhotoUrl))
                                    {
                                        <img src="@doctor.PhotoUrl" alt="" />
                                    }
                                    else
                                    {
                                        @GetInitials(string.IsNullOrWhiteSpace(doctor.DisplayName) ? doctor.EmailForLogin : doctor.DisplayName)
                                    }
                                </div>
                                <div class="setting-text">
                                    <div class="setting-label">@(string.IsNullOrWhiteSpace(doctor.DisplayName) ? GetDisplayName(doctor.EmailForLogin, doctor.TelegramId) : doctor.DisplayName)</div>
                                    <div class="setting-desc">
                                        @if (!string.IsNullOrWhiteSpace(doctor.Specialty))
                                        {
                                            <span>@doctor.Specialty · </span>
                                        }
                                        Подключён @ToDisplayTime(doctor.LinkedAt).ToString("dd.MM.yyyy HH:mm")
                                    </div>
                                </div>
                                <button class="btn btn--ghost btn--sm" @onclick="() => UnlinkDoctorAsync(doctor.LinkId)">Отвязать</button>
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="card">
                <div class="card-title" style="margin-bottom:var(--spacing-3)">Как подключить врача</div>
                <p class="card-sub" style="line-height:1.55">
                    Откройте раздел доступа, создайте код для роли «Врач» и передайте его специалисту.
                    После активации врач увидит измерения, рюкзак и сможет оставлять рекомендации.
                </p>
                <button class="btn btn--primary btn--sm" style="margin-top:var(--spacing-4)"
                        @onclick="NavigateToAccessLinks">Открыть доступы</button>
            </div>
        </div>
    </div>
</div>

@* ПРОФИЛЬ РЕБЁНКА *@
<div class="tab-pane @PaneClass("profile")" id="pane-profile" role="tabpanel">

    <div class="profile-hero" aria-label="Профиль ребёнка">
        <div class="avatar-lg" aria-hidden="true">
            @if (!string.IsNullOrWhiteSpace(_childProfile.PhotoUrl))
            {
                <img src="@_childProfile.PhotoUrl" alt="" />
            }
            else
            {
                <span>🧒</span>
            }
        </div>
        <div class="profile-info">
            <h2 class="profile-name">@_childProfile.Name</h2>
            <p class="profile-sub">
                @_childProfile.Age лет · Диагноз: @_childProfile.DiagnosisDate
            </p>
            <div class="profile-chips">
                <span class="pchip">🏥 @_childProfile.Endocrinologist</span>
                <span class="pchip">📞 @_childProfile.Contact</span>
                <span class="pchip">📧 @_childProfile.Email</span>
            </div>
        </div>
        <button class="btn btn--soft btn--sm" @onclick="OpenChildProfileEditor">Редактировать</button>
    </div>

    @if (_isChildProfileEditorOpen)
    {
        <div class="card" style="margin-bottom:var(--spacing-4)">
            <div class="card-head">
                <div>
                    <div class="card-title">Редактирование профиля ребёнка</div>
                    <div class="card-sub">Основные данные и фотография</div>
                </div>
                <button class="btn btn--ghost btn--sm" @onclick="CancelChildProfileEdit">Закрыть</button>
            </div>
            <div class="editor-grid">
                <div class="input-wrap">
                    <label class="form-label" for="childFirstName">Имя</label>
                    <input id="childFirstName" class="form-input" @bind="_childProfileForm.FirstName" />
                </div>
                <div class="input-wrap">
                    <label class="form-label" for="childLastName">Фамилия</label>
                    <input id="childLastName" class="form-input" @bind="_childProfileForm.LastName" />
                </div>
                <div class="input-wrap">
                    <label class="form-label" for="childBirthDate">Дата рождения</label>
                    <input id="childBirthDate" class="form-input" type="date" @bind="_childProfileForm.DateOfBirth" />
                </div>
                <div class="input-wrap">
                    <label class="form-label" for="childDiabetesType">Тип диабета</label>
                    <select id="childDiabetesType" class="form-select" @bind="_childProfileForm.DiabetesType">
                        <option value="Type1">СД1</option>
                        <option value="Type2">СД2</option>
                        <option value="Other">Другой</option>
                    </select>
                </div>
                <div class="input-wrap">
                    <label class="form-label" for="childWeight">Вес, кг</label>
                    <input id="childWeight" class="form-input" type="number" min="5" max="200" step="0.1" @bind="_childProfileForm.Weight" />
                </div>
                <div class="input-wrap">
                    <label class="form-label" for="childHeight">Рост, см</label>
                    <input id="childHeight" class="form-input" type="number" min="50" max="250" step="0.1" @bind="_childProfileForm.Height" />
                </div>
                <div class="input-wrap">
                    <label class="form-label" for="childDiagnosisDate">Дата диагноза</label>
                    <input id="childDiagnosisDate" class="form-input" type="date" @bind="_childProfileForm.DiagnosisDate" />
                </div>
                <div class="input-wrap">
                    <label class="form-label" for="childTimeZone">Часовой пояс</label>
                    <input id="childTimeZone" class="form-input" @bind="_childProfileForm.TimeZoneId" />
                </div>
            </div>
            <div class="input-wrap" style="margin-top:var(--spacing-3)">
                <label class="form-label" for="childInsulinScheme">Схема инсулина</label>
                <textarea id="childInsulinScheme" class="form-input" rows="3" @bind="_childProfileForm.InsulinScheme"></textarea>
            </div>
            <div class="input-wrap" style="margin-top:var(--spacing-3)">
                <label class="form-label">Фотография</label>
                <InputFile OnChange="UploadChildProfilePhotoAsync" accept="image/jpeg,image/png,image/webp" />
            </div>
            @if (!string.IsNullOrWhiteSpace(_childProfileError))
            {
                <div class="form-error">@_childProfileError</div>
            }
            <div class="editor-actions">
                <button class="btn btn--primary btn--sm" @onclick="SaveChildProfileAsync">Сохранить</button>
                <button class="btn btn--ghost btn--sm" @onclick="CancelChildProfileEdit">Отмена</button>
            </div>
        </div>
    }

    <div class="grid-2">
        @* Журнал инсулина *@
        <div class="card">
            <div class="card-head">
                <div>
                    <div class="card-title">Журнал инсулина</div>
                    <div class="card-sub">Последние введения из мобильного приложения ребёнка</div>
                </div>
            </div>
            <div class="ins-list" role="list">
                @if (_insulinLog.Count == 0)
                {
                    <div class="empty-state empty-state--compact" role="status">
                        Данные появятся после ввода инсулина в мобильном приложении ребёнка.
                    </div>
                }
                else
                {
                    @foreach (var ins in _insulinLog)
                    {
                        <div class="ins-row" role="listitem">
                            <span class="ins-dot @ins.Type"
                                  aria-label="@(ins.Type == "bolus" ? "Болюс" : "Базальный")"></span>
                            <div class="ins-info">
                                <span class="ins-name">@ins.Name</span>
                                <span class="ins-time">@ins.Time</span>
                            </div>
                            <strong class="ins-dose">@ins.Dose</strong>
                        </div>
                    }
                }
            </div>
        </div>

        @* Основные показатели *@
        <div class="card">
            <div class="card-head">
                <div class="card-title">Основные показатели</div>
            </div>
            <table class="data-table" aria-label="Основные показатели здоровья ребёнка">
                <tbody>
                    <tr>
                        <td>Целевой диапазон</td>
                        <td style="font-weight:600;text-align:right">@_targetMin.ToString("0.0")–@_targetMax.ToString("0.0") ммоль/л</td>
                    </tr>
                    <tr>
                        <td>Средняя глюкоза (7 дней)</td>
                        <td class="tabular-nums" style="font-weight:600;text-align:right">
                            @_avgGlucose ммоль/л
                        </td>
                    </tr>
                    <tr>
                        <td>HbA1c (оценка)</td>
                        <td class="tabular-nums" style="font-weight:600;text-align:right">
                            @_childProfile.HbA1c%
                        </td>
                    </tr>
                    <tr>
                        <td>Коэффициент чувствительности</td>
                        <td style="font-weight:600;text-align:right">1:@_insulinSensitivity.ToString("0.#")</td>
                    </tr>
                    <tr>
                        <td>Углеводный коэффициент</td>
                        <td style="font-weight:600;text-align:right">1:@_carbRatio.ToString("0.#") г/ед</td>
                    </tr>
                    <tr>
                        <td>TIR за 7 дней</td>
                        <td class="tabular-nums"
                            style="font-weight:600;text-align:right;color:var(--color-glucose-normal)">
                            @_tirNormal%
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

@* НАСТРОЙКИ *@
<div class="tab-pane @PaneClass("settings")" id="pane-settings" role="tabpanel">
    <div class="grid-2">
        @* Уведомления *@
        <div class="card">
            <div class="card-head">
                <div class="card-title">Уведомления</div>
            </div>
            <div class="settings-group" role="list">
                @foreach (var s in _notifSettings)
                {
                    <div class="setting-row" role="listitem">
                        <div class="setting-text">
                            <div class="setting-label">@s.Label</div>
                            <div class="setting-desc">@s.Description</div>
                        </div>
                        <button class="toggle-sw @(s.Enabled ? "on" : "")"
                                role="switch"
                                aria-checked="@s.Enabled.ToString().ToLower()"
                                aria-label="@s.Label"
                                @onclick="() => ToggleSetting(s)">
                        </button>
                    </div>
                }
            </div>

            <section class="telegram-connect" aria-labelledby="telegramConnectTitle">
                <div class="telegram-connect__head">
                    <div>
                        <div class="setting-label" id="telegramConnectTitle">Telegram-бот</div>
                        <div class="setting-desc">
                            @(_telegramConnected
                                ? "Подключён: уведомления будут приходить в Telegram"
                                : "Подключите бота, чтобы получать критические уведомления и сводки")
                        </div>
                    </div>
                    <span class="telegram-connect__status @(_telegramConnected ? "connected" : "")">
                        @(_telegramConnected ? "Подключён" : "Не подключён")
                    </span>
                </div>

                @if (_telegramConnectionCode is not null && !_telegramConnected)
                {
                    <div class="telegram-code" role="status">
                        <code>@_telegramConnectionCode.Code</code>
                        <span>Действует до @_telegramConnectionCode.ExpiresAt.ToLocalTime().ToString("HH:mm")</span>
                    </div>
                    <p class="telegram-connect__command">
                        Отправьте боту команду <strong>@TelegramConnectCommand</strong>
                    </p>
                }

                @if (!string.IsNullOrWhiteSpace(_telegramConnectionError))
                {
                    <div class="form-error" role="alert">@_telegramConnectionError</div>
                }

                <div class="telegram-connect__actions">
                    @if (!_telegramConnected)
                    {
                        <button class="btn btn--primary btn--sm"
                                disabled="@_isCreatingTelegramCode"
                                @onclick="CreateTelegramConnectionCodeAsync">
                            @(_isCreatingTelegramCode ? "Создаём код..." : "Получить код")
                        </button>
                    }
                    @if (_telegramConnectionCode is not null && !_telegramConnected)
                    {
                        <button class="btn btn--soft btn--sm" @onclick="CopyTelegramCommandAsync">
                            Копировать команду
                        </button>
                    }
                    <a class="btn btn--ghost btn--sm"
                       href="https://t.me/SugarGuardBot"
                       target="_blank"
                       rel="noopener noreferrer">Открыть бота</a>
                </div>
            </section>
        </div>

        @* Устройства *@
        <div class="card">
            <div class="card-head">
                <div class="card-title">Устройства</div>
            </div>
            <div class="settings-group" role="list">
                @foreach (var d in _devices)
                {
                    <div class="setting-row" role="listitem">
                        <div class="setting-text">
                            <div class="setting-label">@d.Name</div>
                            <div class="setting-desc">@d.Description</div>
                        </div>
                        <button class="btn btn--soft btn--sm"
                                aria-label="Подключить @d.Name"
                                disabled="@d.IsConnected"
                                @onclick="() => ConnectDevice(d)">@(d.IsConnected ? "Подключено" : "Подключить")</button>
                    </div>
                }
            </div>

            <div style="margin-top:var(--spacing-5);padding-top:var(--spacing-4);border-top:1px solid var(--color-divider)">
                <div class="card-title" style="font-size:var(--font-size-sm);margin-bottom:var(--spacing-3)">
                    Профиль родителя
                </div>
                <div class="settings-group">
                    <div class="setting-row">
                        <div class="setting-text">
                            <div class="setting-label">Мои данные</div>
                            <div class="setting-desc">@_parentProfile.DisplayName · @_parentProfile.Email · @_parentProfile.Phone</div>
                        </div>
                        <button class="btn btn--ghost btn--sm"
                                @onclick="OpenParentProfileEditor">Редактировать</button>
                    </div>
                    @if (_isParentProfileEditorOpen)
                    {
                        <div class="inline-editor">
                            <div class="editor-grid">
                                <div class="input-wrap">
                                    <label class="form-label" for="parentName">Имя</label>
                                    <input id="parentName" class="form-input" @bind="_parentProfileForm.DisplayName" />
                                </div>
                                <div class="input-wrap">
                                    <label class="form-label" for="parentEmail">Email</label>
                                    <input id="parentEmail" class="form-input" type="email" @bind="_parentProfileForm.Email" />
                                </div>
                                <div class="input-wrap">
                                    <label class="form-label" for="parentPhone">Телефон</label>
                                    <input id="parentPhone" class="form-input" @bind="_parentProfileForm.Phone" />
                                </div>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(_parentProfileError))
                            {
                                <div class="form-error">@_parentProfileError</div>
                            }
                            <div class="editor-actions">
                                <button class="btn btn--primary btn--sm" @onclick="SaveParentProfileAsync">Сохранить</button>
                                <button class="btn btn--ghost btn--sm" @onclick="CancelParentProfileEdit">Отмена</button>
                            </div>
                        </div>
                    }
                    <div class="setting-row">
                        <div class="setting-text">
                            <div class="setting-label">Доступ другим</div>
                            <div class="setting-desc">Коды привязки для второго родителя или врача</div>
                        </div>
                        <button class="btn btn--ghost btn--sm"
                                @onclick="NavigateToAccessLinks">Открыть</button>
                    </div>
                    <div class="setting-row">
                        <div class="setting-text">
                            <div class="setting-label">Смена пароля</div>
                            <div class="setting-desc">Отправить письмо для восстановления доступа</div>
                        </div>
                        <button class="btn btn--ghost btn--sm"
                                @onclick='() => Navigation.NavigateTo("/forgot-password")'>Изменить</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    // Состояние навигации
    private string _activeTab = "overview";
    private int _chartRange = 24;
    private bool _hasChild;
    private Guid _selectedChildId;
    private string? _noticeMessage;
    private List<ChildProfileVm> _availableChildren = new();

    // Состояние фильтров
    private string _alertFilter = "";
    private string _measStatusFilter = "";
    private DateTime _measFilterDate = MoscowNow.Date;
    private int _measPage = 1;
    private int _recentEventPage = 1;
    private int _alertPage = 1;
    private const int MeasPageSize = 10;
    private const int EventPageSize = 5;
    private static readonly TimeSpan LiveRefreshInterval = TimeSpan.FromSeconds(10);
    private const string ParentProfileStorageKey = "sg-parent-profile-v1";
    private readonly SemaphoreSlim _refreshGate = new(1, 1);
    private readonly HashSet<Guid> _readAlertIds = [];
    private readonly HashSet<Guid> _dismissedAlertIds = [];
    private CancellationTokenSource? _refreshCts;
    private Task? _refreshTask;

    // Живые данные
    private double _currentGlucose;
    private string? _glucoseDeltaText;
    private string _currentGlucoseClass = "normal";
    private int _tirNormal;
    private int _tirHigh;
    private int _tirLow;
    private string _avgGlucose = "—";
    private int _totalMeas;
    private int _newMeasurementsCount => _activeTab == "measurements" ? 0 : _measurements.Count(m => m.IsNew);
    private int _unreadNotificationsCount;
    private int _lowStockCount => _backpackItems.Count(i => i.StatusClass is "low" or "empty");
    private bool _browserStateLoaded;
    private bool _isBackpackEditorOpen;
    private string? _editingBackpackItemId;
    private string? _backpackFormError;
    private BackpackItemForm _backpackForm = new();
    private bool _isParentProfileEditorOpen;
    private string? _parentProfileError;
    private ParentProfileForm _parentProfileForm = new();
    private ParentProfile _parentProfile = new();
    private bool _isChildProfileEditorOpen;
    private string? _childProfileError;
    private ChildProfileForm _childProfileForm = new();
    private bool _isTargetEditorOpen;
    private string? _targetFormError;
    private TargetSettingsForm _targetForm = new();
    private decimal _targetMin = 4.0m;
    private decimal _targetMax = 10.0m;
    private decimal _insulinSensitivity = 2.5m;
    private decimal _carbRatio = 10.0m;
    private readonly List<LinkedAccessUserVm> _linkedParents = new();
    private readonly List<LinkedAccessUserVm> _linkedDoctors = new();
    private TelegramConnectionCodeVm? _telegramConnectionCode;
    private string? _telegramConnectionError;
    private bool _isCreatingTelegramCode;
    private bool _telegramConnected => _linkedParents.Any(link => link.TelegramId.HasValue);
    private string TelegramConnectCommand => _telegramConnectionCode is null
        ? string.Empty
        : $"/connect {_telegramConnectionCode.Code}";

    // Вкладки / панели
    private string TabClass(string tab) => _activeTab == tab ? "active" : "";
    private string PaneClass(string tab) => _activeTab == tab ? "active" : "";

    private void SwitchTab(string tab)
    {
        _activeTab = tab;
        var query = new List<string>();
        if (_selectedChildId != Guid.Empty)
        {
            query.Add($"childId={_selectedChildId}");
        }

        if (tab != "overview")
        {
            query.Add($"tab={Uri.EscapeDataString(tab)}");
        }

        var url = query.Count == 0
            ? "/parent/dashboard"
            : $"/parent/dashboard?{string.Join('&', query)}";
        Navigation.NavigateTo(url, forceLoad: false, replace: false);
    }

    // Инициализация
    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
        SyncTabFromUri();
    }

    protected override void OnParametersSet()
    {
        SyncTabFromUri();
    }

    private void SyncTabFromUri()
    {
        var uri = new Uri(Navigation.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        var tab = query["tab"]?.ToLowerInvariant();
        _activeTab = string.IsNullOrEmpty(tab) ? "overview" : tab;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs args)
    {
        SyncTabFromUri();
        var requestedChildId = GetRequestedChildId();
        if (requestedChildId.HasValue && requestedChildId.Value != _selectedChildId)
        {
            _ = InvokeAsync(LoadDashboardDataAsync);
            return;
        }

        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
        _refreshCts?.Cancel();
        _refreshCts?.Dispose();
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardDataAsync();
    }

    private async Task LoadDashboardDataAsync()
    {
        try
        {
            var children = await Api.GetMyChildrenAsync(CancellationToken.None);
            _availableChildren = children;
            var requestedChildId = GetRequestedChildId();
            var selectedChild = requestedChildId.HasValue
                ? children.FirstOrDefault(c => c.ChildId == requestedChildId.Value)
                : null;

            selectedChild ??= children.FirstOrDefault();
            var childId = selectedChild?.ChildId ?? Guid.Empty;

            if (childId == Guid.Empty)
            {
                _hasChild = false;
                ResetChildData();
                return;
            }

            _hasChild = true;
            _selectedChildId = childId;
            ApplyChildProfile(selectedChild!);

            await LoadParentProfileFromClaimsAsync();

            // Профиль ребёнка: грузим первым, чтобы шапка не оставалась с дефолтным текстом.
            var profile = await Api.GetChildProfileAsync(childId, CancellationToken.None);
            if (profile is not null)
                ApplyChildProfile(profile);

            var diabetesSettings = await Api.GetDiabetesSettingsAsync(childId, CancellationToken.None);
            if (diabetesSettings is not null)
            {
                ApplyDiabetesSettings(diabetesSettings);
            }

            await RefreshLiveDataAsync(childId, CancellationToken.None, resetPages: true);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Ошибка загрузки данных дашборда");
        }
    }

    private async Task RefreshLiveDataAsync(
        Guid childId,
        CancellationToken cancellationToken,
        bool resetPages = false)
    {
        if (!await _refreshGate.WaitAsync(0, cancellationToken))
        {
            return;
        }

        try
        {
            var summary = await Api.GetDashboardSummaryAsync(childId, cancellationToken);
            if (summary.LatestGlucose.HasValue)
            {
                _currentGlucose = (double)summary.LatestGlucose.Value;
                _currentGlucoseClass = summary.LatestGlucoseUiState switch
                {
                    "Critical" or "Danger" => "danger",
                    "Warning" or "Elevated" => "warn",
                    _ => "normal"
                };
            }

            _totalMeas = summary.TotalMeasurements;

            var stats = await Api.GetStatisticsVmAsync(childId, "7d", cancellationToken);
            if (stats is not null)
            {
                _tirNormal = (int)Math.Round(stats.TimeInTargetRange);
                _tirHigh = (int)Math.Round(stats.TimeAboveRange + stats.TimeCriticallyHigh);
                _tirLow = (int)Math.Round(stats.TimeBelowRange + stats.TimeCriticallyLow);
                _avgGlucose = stats.AverageGlucose.ToString("F1");
                _totalMeas = stats.TotalMeasurements;
            }

            var alerts = await Api.GetTimelineAsync(
                childId,
                DateTime.UtcNow.AddDays(-7),
                DateTime.UtcNow,
                cancellationToken);
            _allAlerts = RemoveDuplicateCriticalAlerts(alerts)
                .Where(entry => !_dismissedAlertIds.Contains(entry.EventId))
                .Select(MapTimelineEvent)
                .ToList();

            foreach (var alert in _allAlerts)
            {
                alert.IsUnread = !_readAlertIds.Contains(alert.EventId);
            }

            var notifications = await Api.GetNotificationsAsync(cancellationToken);
            _unreadNotificationsCount = notifications.Count(notification => notification.IsUnread);

            if (resetPages || _activeTab == "overview")
            {
                await LoadMeasurementsAsync(
                    childId,
                    DateTime.UtcNow.AddHours(-_chartRange),
                    DateTime.UtcNow,
                    resetPage: resetPages,
                    cancellationToken: cancellationToken);
            }
            await LoadBackpackFromApiAsync(childId);
            await LoadAccessLinksAsync(childId, cancellationToken);
            await LoadDoctorNotesAsync(childId, cancellationToken);
            await LoadInsulinLogAsync(childId, cancellationToken);

            _recentEventPage = Math.Clamp(_recentEventPage, 1, _recentEventTotalPages);
            _alertPage = Math.Clamp(_alertPage, 1, _alertTotalPages);
        }
        finally
        {
            _refreshGate.Release();
        }
    }

    private async Task LoadParentProfileFromClaimsAsync()
    {
        var snapshot = await CurrentUser.GetSnapshotAsync(CancellationToken.None);
        if (snapshot is null)
        {
            return;
        }

        _parentProfile = new ParentProfile
        {
            DisplayName = string.IsNullOrWhiteSpace(snapshot.Email) ? "Родитель" : snapshot.Email,
            Email = snapshot.Email ?? "email не указан",
            Phone = "телефон не указан"
        };
    }

    private async Task OnSelectedChildChangedAsync(ChangeEventArgs args)
    {
        if (!Guid.TryParse(args.Value?.ToString(), out var childId) || childId == _selectedChildId)
        {
            return;
        }

        var tabQuery = _activeTab == "overview" ? "" : $"&tab={Uri.EscapeDataString(_activeTab)}";
        Navigation.NavigateTo($"/parent/dashboard?childId={childId}{tabQuery}", forceLoad: false, replace: false);
        await LoadDashboardDataAsync();
    }

    private static string GetChildDisplayName(ChildProfileVm child)
        => string.IsNullOrWhiteSpace(child.FullName) ? "Ребёнок" : child.FullName;

    private void ApplyDiabetesSettings(DiabetesSettingsVm settings)
    {
        _targetMin = settings.TargetGlucoseMin;
        _targetMax = settings.TargetGlucoseMax;
        _insulinSensitivity = settings.InsulinSensitivity;
        _carbRatio = settings.InsulinToCarbRatio;
    }

    private async Task LoadBackpackFromApiAsync(Guid childId)
    {
        try
        {
            var apiItems = await Api.GetBackpackAsync(childId, CancellationToken.None);
            _backpackItems.Clear();
            _backpackItems.AddRange(apiItems
                .GroupBy(
                    item => $"{NormalizeBackpackName(item.SnackName)}|{item.BreadUnits:0.###}",
                    StringComparer.OrdinalIgnoreCase)
                .Select(BackpackItem.FromApiGroup));
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Не удалось загрузить рюкзак ребёнка из API. ChildId={ChildId}", childId);
        }
    }

    private static string NormalizeBackpackName(string value) =>
        string.Join(' ', value.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries))
            .ToUpperInvariant();

    private async Task LoadDoctorNotesAsync(Guid childId, CancellationToken cancellationToken = default)
    {
        try
        {
            var notes = await Api.GetDoctorNotesAsync(
                childId,
                page: 1,
                pageSize: 5,
                onlyImportant: false,
                cancellationToken);

            _doctorNotes.Clear();
            _doctorNotes.AddRange(notes.Items.Select(MapDoctorNote));
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Не удалось загрузить заметки врача. ChildId={ChildId}", childId);
        }
    }

    private async Task LoadInsulinLogAsync(Guid childId, CancellationToken cancellationToken = default)
    {
        try
        {
            var from = MoscowNow.Date;
            var to = from.AddDays(1).AddTicks(-1);
            var entries = await Api.GetNutritionEntriesAsync(childId, from, to, cancellationToken);

            _insulinLog.Clear();
            _insulinLog.AddRange(entries
                .Where(entry => entry.InsulinUnits > 0)
                .OrderByDescending(entry => entry.RecordedAt)
                .Take(6)
                .Select(entry => new InsulinEntry(
                    string.IsNullOrWhiteSpace(entry.MealName) ? MealLabel(entry.MealType) : entry.MealName.Trim(),
                    $"{entry.InsulinUnits:0.##} ед.",
                    ToDisplayTime(entry.RecordedAt).ToString("HH:mm"),
                    MealLabel(entry.MealType))));
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Не удалось загрузить журнал инсулина. ChildId={ChildId}", childId);
            _insulinLog.Clear();
        }
    }

    private static string MealLabel(MealType type) => type switch
    {
        MealType.Breakfast => "Завтрак",
        MealType.Lunch => "Обед",
        MealType.Dinner => "Ужин",
        MealType.Snack => "Перекус",
        _ => "Другое"
    };

    private async Task LoadAccessLinksAsync(Guid childId, CancellationToken cancellationToken = default)
    {
        try
        {
            var links = await Api.GetChildAccessLinksAsync(childId, cancellationToken);
            _linkedParents.Clear();
            _linkedDoctors.Clear();
            if (links is not null)
            {
                _linkedParents.AddRange(links.ParentLinks);
                _linkedDoctors.AddRange(links.DoctorLinks);
                var firstDoctor = _linkedDoctors.FirstOrDefault();
                _childProfile.Endocrinologist = firstDoctor is null
                    ? "Врач не привязан"
                    : string.IsNullOrWhiteSpace(firstDoctor.DisplayName)
                        ? GetDisplayName(firstDoctor.EmailForLogin, firstDoctor.TelegramId)
                        : firstDoctor.DisplayName;

                if (_telegramConnected)
                {
                    _telegramConnectionCode = null;
                    _telegramConnectionError = null;
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Не удалось загрузить связи ребёнка. ChildId={ChildId}", childId);
        }
    }

    private async Task LoadMeasurementsAsync(
        Guid childId,
        DateTime fromUtc,
        DateTime toUtc,
        bool resetPage,
        CancellationToken cancellationToken = default)
    {
        var measurements = await Api.GetMeasurementsAsync(childId, fromUtc, toUtc, cancellationToken);

        _chartPoints = GlucoseChart.FromMeasurements(measurements);

        _measurements.Clear();
        _measurements.AddRange(measurements
            .OrderByDescending(m => m.MeasurementTime)
            .Select(MapMeasurement));

        var latestValues = measurements
            .OrderByDescending(m => m.MeasurementTime)
            .Take(2)
            .Select(m => m.GlucoseValue)
            .ToArray();

        _glucoseDeltaText = latestValues.Length < 2
            ? null
            : FormatGlucoseDelta(latestValues[0] - latestValues[1]);

        if (resetPage)
        {
            _measPage = 1;
        }
    }

    private static string FormatGlucoseDelta(decimal delta) =>
        delta > 0 ? $"+{delta:0.0}" : delta.ToString("0.0");

    private static DoctorNote MapDoctorNote(DoctorNoteVm note)
    {
        var tags = new List<string>();
        if (note.IsImportant)
        {
            tags.Add("важно");
        }

        if (note.MeasurementId.HasValue)
        {
            tags.Add("к измерению");
        }

        return new DoctorNote(
            string.IsNullOrWhiteSpace(note.DoctorName) ? "Врач" : note.DoctorName,
            ToDisplayTime(note.CreatedAt).ToString("dd.MM.yyyy HH:mm"),
            string.IsNullOrWhiteSpace(note.NoteText) ? "Без текста" : note.NoteText,
            tags);
    }

    private AlertItem MapTimelineEvent(TimelineEventDto entry)
    {
        var statusType = entry.GlucoseUiState switch
        {
            "Critical" or "Danger" => "danger",
            "Warning" or "Elevated" => "warn",
            _ => "info"
        };

        return entry.EventType switch
        {
            TimelineEventType.SnackConsumed => new AlertItem(
                entry.EventId,
                "Съеден перекус",
                $"{entry.SnackName ?? "Перекус"}, {entry.BreadUnits?.ToString("0.0") ?? "—"} ХЕ" +
                (entry.GlucoseValue.HasValue ? $" · сахар {entry.GlucoseValue:0.0} ммоль/л" : string.Empty),
                GetRelativeTime(entry.OccurredAt),
                "info",
                "✓",
                true),
            TimelineEventType.Measurement or TimelineEventType.GlucoseMeasurement => new AlertItem(
                entry.EventId,
                GetMeasurementEventTitle(entry.GlucoseValue),
                GetMeasurementEventDescription(entry.GlucoseValue),
                GetRelativeTime(entry.OccurredAt),
                statusType,
                statusType == "danger" ? "!" : "•",
                true),
            TimelineEventType.CriticalAlert or TimelineEventType.Alert => new AlertItem(
                entry.EventId,
                "Критический уровень глюкозы",
                entry.Notes ?? $"Глюкоза {entry.GlucoseValue?.ToString("0.0") ?? "—"} ммоль/л",
                GetRelativeTime(entry.OccurredAt),
                "danger",
                "!",
                true),
            _ => new AlertItem(
                entry.EventId,
                entry.Title ?? "Событие",
                entry.Description ?? entry.Notes ?? "Обновлены данные ребёнка",
                GetRelativeTime(entry.OccurredAt),
                statusType,
                "•",
                entry.IsImportant)
        };
    }

    private static IEnumerable<TimelineEventDto> RemoveDuplicateCriticalAlerts(
        IReadOnlyList<TimelineEventDto> timeline)
    {
        var ordered = timeline.OrderByDescending(entry => entry.OccurredAt).ToList();
        var measurements = ordered
            .Where(entry => entry.EventType is TimelineEventType.Measurement or TimelineEventType.GlucoseMeasurement)
            .ToList();

        return ordered.Where(entry =>
            entry.EventType is not (TimelineEventType.Alert or TimelineEventType.CriticalAlert)
            || !measurements.Any(measurement =>
                measurement.GlucoseValue == entry.GlucoseValue
                && Math.Abs((measurement.OccurredAt - entry.OccurredAt).TotalMinutes) <= 2));
    }

    private string GetMeasurementEventTitle(decimal? value)
    {
        if (!value.HasValue)
        {
            return "Новое измерение";
        }

        if (value.Value < _targetMin)
        {
            return "Глюкоза ниже нормы";
        }

        return value.Value > _targetMax
            ? "Глюкоза выше нормы"
            : "Глюкоза в целевом диапазоне";
    }

    private string GetMeasurementEventDescription(decimal? value)
    {
        if (!value.HasValue)
        {
            return "Получено измерение без числового значения";
        }

        var rangeHint = value.Value < _targetMin
            ? $"ниже цели на {_targetMin - value.Value:0.0}"
            : value.Value > _targetMax
                ? $"выше цели на {value.Value - _targetMax:0.0}"
                : $"цель {_targetMin:0.0}–{_targetMax:0.0}";

        return $"{value.Value:0.0} ммоль/л · {rangeHint}";
    }

    private static MeasurementItem MapMeasurement(MeasurementVm measurement)
        => new(
            ToDisplayTime(measurement.MeasurementTime).ToString("dd.MM HH:mm"),
            measurement.GlucoseValue.ToString("F1"),
            GetTrendIcon(measurement.GlucoseUiState),
            string.IsNullOrWhiteSpace(measurement.Notes) ? "Без заметки" : measurement.Notes,
            GetMeasurementStatus(measurement.GlucoseUiState),
            GetMeasurementStatusClass(measurement.GlucoseUiState),
            measurement.MeasurementTime > DateTime.UtcNow.AddHours(-1));

    private static readonly TimeZoneInfo DisplayTimeZone = ResolveDisplayTimeZone();

    private static DateTime MoscowNow => TimeZoneInfo.ConvertTimeFromUtc(DateTime.UtcNow, DisplayTimeZone);

    private static DateTime ToDisplayTime(DateTime value)
    {
        var utc = value.Kind == DateTimeKind.Utc
            ? value
            : DateTime.SpecifyKind(value, DateTimeKind.Utc);
        return TimeZoneInfo.ConvertTimeFromUtc(utc, DisplayTimeZone);
    }

    private static TimeZoneInfo ResolveDisplayTimeZone()
    {
        try
        {
            return TimeZoneInfo.FindSystemTimeZoneById("Europe/Moscow");
        }
        catch (TimeZoneNotFoundException)
        {
            return TimeZoneInfo.FindSystemTimeZoneById("Russian Standard Time");
        }
    }

    private Guid? GetRequestedChildId()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        return query.TryGetValue("childId", out var value)
               && Guid.TryParse(value.FirstOrDefault(), out var childId)
            ? childId
            : null;
    }

    private void ApplyChildProfile(ChildProfileVm profile)
    {
        var age = DateTime.Today.Year - profile.DateOfBirth.Year;
        if (profile.DateOfBirth > DateOnly.FromDateTime(DateTime.Today).AddYears(-age))
            age--;

        _childProfile.Name = string.IsNullOrWhiteSpace(profile.FullName)
            ? "Ребёнок"
            : profile.FullName;
        _childProfile.Age = age >= 0 ? age.ToString() : "—";
        _childProfile.DiabetesType = string.IsNullOrWhiteSpace(profile.DiabetesType)
            ? "—"
            : profile.DiabetesType;
        _childProfile.PhotoUrl = profile.PhotoUrl;
        _childProfile.DateOfBirth = profile.DateOfBirth;
        _childProfile.FirstName = profile.FirstName;
        _childProfile.LastName = profile.LastName;
        _childProfile.Weight = profile.Weight <= 0 ? 30m : profile.Weight;
        _childProfile.Height = profile.Height <= 0 ? 130m : profile.Height;
        _childProfile.InsulinScheme = profile.InsulinScheme;
        _childProfile.TimeZoneId = string.IsNullOrWhiteSpace(profile.TimeZoneId) ? "Europe/Moscow" : profile.TimeZoneId;
        _childProfile.RawDiabetesType = string.IsNullOrWhiteSpace(profile.DiabetesType) ? "Type1" : profile.DiabetesType;
        _childProfile.RawDiagnosisDate = profile.DiagnosisDate;
        _childProfile.DiagnosisDate = profile.DiagnosisDate?.ToString("dd.MM.yyyy") ?? "—";
    }

    private static string GetRelativeTime(DateTime utcTime)
    {
        var diff = DateTime.UtcNow - utcTime;
        if (diff.TotalMinutes < 1) return "только что";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes} мин назад";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours} ч назад";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays} дн назад";
        return utcTime.ToString("dd.MM");
    }

    private static string GetMeasurementStatusClass(string? state) => state switch
    {
        "Critical" or "Danger" => "danger",
        "Warning" or "Elevated" => "warn",
        _ => "normal"
    };

    private static string GetMeasurementStatus(string? state) => GetMeasurementStatusClass(state) switch
    {
        "danger" => "Критично",
        "warn" => "Выше нормы",
        _ => "Норма"
    };

    private static string GetTrendIcon(string? state) => GetMeasurementStatusClass(state) switch
    {
        "danger" => "↓↓",
        "warn" => "↑",
        _ => "→"
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        await LoadBrowserStateAsync();

        try
        {
            var vapidPublicKey = Configuration["Vapid:PublicKey"] ?? string.Empty;
            var apiBaseUrl = Configuration["ApiBaseUrl"] ?? string.Empty;
            var token = await TokenStore.GetTokenAsync();

            if (!string.IsNullOrEmpty(vapidPublicKey) && !string.IsNullOrEmpty(token))
            {
                await JS.InvokeVoidAsync(
                    "registerPushSubscription",
                    vapidPublicKey,
                    apiBaseUrl,
                    token);
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Не удалось зарегистрировать Push-подписку.");
        }

        _refreshCts = new CancellationTokenSource();
        _refreshTask = RunLiveRefreshAsync(_refreshCts.Token);
    }

    private async Task RunLiveRefreshAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(LiveRefreshInterval);

        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                await InvokeAsync(async () =>
                {
                    if (_selectedChildId == Guid.Empty)
                    {
                        return;
                    }

                    try
                    {
                        await RefreshLiveDataAsync(_selectedChildId, cancellationToken);
                        StateHasChanged();
                    }
                    catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
                    {
                    }
                    catch (Exception ex)
                    {
                        Logger.LogWarning(ex, "Не удалось автоматически обновить родительский дашборд.");
                    }
                });
            }
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
        {
        }
    }

