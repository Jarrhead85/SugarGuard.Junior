    private void ToggleSetting(NotifSetting s)
    {
        s.Enabled = !s.Enabled;
        ShowNotice($"Настройка «{s.Label}» {(s.Enabled ? "включена" : "выключена")}.");
    }

    private void ConnectDevice(DeviceItem device)
    {
        var index = _devices.IndexOf(device);
        if (index < 0)
        {
            return;
        }

        _devices[index] = device with
        {
            Description = "Подключено локально",
            IsConnected = true
        };

        ShowNotice($"{device.Name}: подключение сохранено.");
    }

