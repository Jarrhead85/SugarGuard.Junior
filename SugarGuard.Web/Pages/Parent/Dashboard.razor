    private sealed class AlertItem
    {
        public string Title { get; init; }
        public string Description { get; init; }
        public string Time { get; init; }
        public string Type { get; init; }
        public string Icon { get; init; }
        public bool IsUnread { get; set; }

        public AlertItem(string title, string desc, string time,
                         string type, string icon, bool isUnread)
        {
            Title = title; Description = desc; Time = time;
            Type = type; Icon = icon; IsUnread = isUnread;
        }
    }

    /// <summary>
    /// Строка таблицы измерений глюкозы
    /// </summary>
    private sealed record MeasurementItem(
        string Time, string Value, string Trend, string Note,
        string Status, string StatusClass, bool IsNew)
    {
        public string TrendIcon => Trend switch
        {
            "↑↑" => "⬆⬆",
            "↑"  => "⬆",
            "→"  => "➡",
            "↓"  => "⬇",
            "↓↓" => "⬇⬇",
            _    => Trend
        };
    }

    private sealed class BackpackItem
    {
        public string Id { get; set; } = Guid.NewGuid().ToString("N");
        public string Name { get; set; } = string.Empty;
        public string Category { get; set; } = "Другое";
        public string Icon { get; set; } = "+";
        public string Description { get; set; } = string.Empty;
        public int Quantity { get; set; }
        public string Unit { get; set; } = "шт.";
        public decimal BreadUnits { get; set; }

        public string Status => Quantity switch
        {
            <= 0 => "Нет",
            <= 2 => "Мало",
            _ => "Достаточно"
        };

        public string StatusClass => Quantity switch
        {
            <= 0 => "empty",
            <= 2 => "low",
            _ => "ok"
        };
    }

    private sealed record BackpackTemplate(
        string Key,
        string Name,
        string Category,
        string Type,
        string Unit,
        string Icon,
        string Description,
        decimal BreadUnits);

    private sealed class BackpackItemForm
    {
        public string TemplateKey { get; set; } = "apple";
        public string Name { get; set; } = string.Empty;
        public string Category { get; set; } = "Перекус";
        public string Icon { get; set; } = "+";
        public string Description { get; set; } = string.Empty;
        public int Quantity { get; set; } = 1;
        public string Unit { get; set; } = "шт.";
        public decimal BreadUnits { get; set; }

        public static BackpackItemForm FromTemplate(BackpackTemplate template) => new()
        {
            TemplateKey = template.Key,
            Name = template.Name,
            Category = template.Category,
            Icon = template.Icon,
            Description = template.Description,
            Quantity = 1,
            Unit = template.Unit,
            BreadUnits = template.BreadUnits
        };

        public static BackpackItemForm FromItem(BackpackItem item) => new()
        {
            TemplateKey = "custom",
            Name = item.Name,
            Category = item.Category,
            Icon = item.Icon,
            Description = item.Description,
            Quantity = item.Quantity,
            Unit = item.Unit,
            BreadUnits = item.BreadUnits
        };

        public BackpackItem ToItem(string? existingId) => new()
        {
            Id = existingId ?? Guid.NewGuid().ToString("N"),
            Name = Name.Trim(),
            Category = Category.Trim(),
            Icon = string.IsNullOrWhiteSpace(Icon) ? "+" : Icon.Trim(),
            Description = Description.Trim(),
            Quantity = Quantity,
            Unit = string.IsNullOrWhiteSpace(Unit) ? "шт." : Unit.Trim(),
            BreadUnits = BreadUnits
        };
    }

