    private async Task UploadChildProfilePhotoAsync(InputFileChangeEventArgs args)
    {
        var file = args.File;
        if (_selectedChildId == Guid.Empty || file is null)
        {
            return;
        }

        const long maxPhotoBytes = 5L * 1024 * 1024;
        try
        {
            await using var stream = file.OpenReadStream(maxPhotoBytes);
            var photoUrl = await Api.UploadChildPhotoAsync(
                _selectedChildId,
                stream,
                file.Name,
                string.IsNullOrWhiteSpace(file.ContentType) ? "application/octet-stream" : file.ContentType,
                CancellationToken.None);

            if (string.IsNullOrWhiteSpace(photoUrl))
            {
                _childProfileError = "Не удалось загрузить фото. Проверьте формат PNG, JPG или WEBP.";
                return;
            }

            _childProfileForm.PhotoUrl = photoUrl;
            _childProfile.PhotoUrl = photoUrl;
            ShowNotice("Фото ребёнка обновлено.");
        }
        catch (IOException ex)
        {
            Logger.LogWarning(ex, "Не удалось прочитать фото ребёнка. ChildId={ChildId}", _selectedChildId);
            _childProfileError = "Файл слишком большой или повреждён. Максимальный размер — 5 МБ.";
        }
    }

    private async Task SaveChildProfileAsync()
    {
        if (_selectedChildId == Guid.Empty)
        {
            _childProfileError = "Сначала выберите ребёнка.";
            return;
        }

        if (string.IsNullOrWhiteSpace(_childProfileForm.FirstName)
            || string.IsNullOrWhiteSpace(_childProfileForm.LastName))
        {
            _childProfileError = "Имя и фамилия обязательны.";
            return;
        }

        try
        {
            var updated = await Api.UpdateChildAsync(
                _selectedChildId,
                _childProfileForm.ToRequest(),
                CancellationToken.None);

            if (updated is null)
            {
                _childProfileError = "Не удалось сохранить профиль ребёнка.";
                return;
            }

            ApplyChildProfile(updated);
            _availableChildren = _availableChildren
                .Select(child => child.ChildId == updated.ChildId ? updated : child)
                .ToList();
            CancelChildProfileEdit();
            ShowNotice("Профиль ребёнка сохранён.");
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Не удалось сохранить профиль ребёнка. ChildId={ChildId}", _selectedChildId);
            _childProfileError = "Не удалось сохранить профиль. Попробуйте ещё раз.";
        }
    }

    private async Task UnlinkParentAsync(Guid linkId)
    {
        if (_selectedChildId == Guid.Empty)
        {
            return;
        }

        var confirmed = await JS.InvokeAsync<bool>(
            "confirm",
            "Отвязать родителя от профиля ребёнка? После удаления он потеряет доступ к измерениям, рюкзаку и дневнику.");
        if (!confirmed)
        {
            return;
        }

        try
        {
            var removed = await Api.UnlinkChildAccessAsync(_selectedChildId, "parent", linkId, CancellationToken.None);
            if (!removed)
            {
                ShowNotice("Не удалось отвязать родителя. Обновите данные и попробуйте ещё раз.");
                return;
            }

            _linkedParents.RemoveAll(link => link.LinkId == linkId);
            ShowNotice("Родитель отвязан от профиля ребёнка.");
            await LoadDashboardDataAsync();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Не удалось отвязать родителя. ChildId={ChildId} LinkId={LinkId}", _selectedChildId, linkId);
            ShowNotice("Не удалось отвязать родителя. Попробуйте позже.");
        }
    }

