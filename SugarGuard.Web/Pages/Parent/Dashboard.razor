    // Измерения
    private List<MeasurementItem> _filteredMeasurements =>
        _measurements
            .Where(m => string.IsNullOrEmpty(_measStatusFilter) || m.StatusClass == _measStatusFilter)
            .Skip((_measPage - 1) * MeasPageSize)
            .Take(MeasPageSize)
            .ToList();

    private void ApplyMeasFilter() => _measPage = 1;

    private void ResetMeasFilter()
    {
        _measFilterDate = DateTime.Today;
        _measStatusFilter = "";
        _measPage = 1;
    }

    private void PrevMeasPage() { if (_measPage > 1) _measPage--; }

    private void NextMeasPage()
    {
        if (_measPage * MeasPageSize < _totalMeas) _measPage++;
    }

    private async Task ExportCsvAsync()
    {
        var rows = new System.Text.StringBuilder();
        rows.AppendLine("Время,Глюкоза,Тренд,Статус,Заметка");
        foreach (var m in _measurements)
            rows.AppendLine($"{m.Time},{m.Value},{m.Trend},{m.Status},{m.Note}");

        try
        {
            await JS.InvokeVoidAsync(
                "SugarGuard.downloadCsv",
                "sugarguard-export.csv",
                rows.ToString());
        }
        catch (JSException) { }
    }

