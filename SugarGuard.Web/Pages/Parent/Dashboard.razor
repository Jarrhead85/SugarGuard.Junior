    private async Task SaveBackpackItemAsync()
    {
        if (string.IsNullOrWhiteSpace(_backpackForm.Name))
        {
            _backpackFormError = "Введите название позиции.";
            return;
        }

        if (_backpackForm.Quantity < 0)
        {
            _backpackFormError = "Количество не может быть отрицательным.";
            return;
        }

        if (_selectedChildId == Guid.Empty)
        {
            _backpackFormError = "Сначала привяжите ребёнка к кабинету.";
            return;
        }

        try
        {
            if (_editingBackpackItemId is not null && Guid.TryParse(_editingBackpackItemId, out var itemId))
            {
                var existing = _backpackItems.FirstOrDefault(item => item.Id == _editingBackpackItemId);
                if (existing is null)
                {
                    _backpackFormError = "Позиция уже была изменена. Обновите страницу.";
                    return;
                }

                var update = new UpdateBackpackItemRequest
                {
                    SnackName = _backpackForm.Name.Trim(),
                    BreadUnits = _backpackForm.BreadUnits
                };

                foreach (var existingId in existing.ItemIds)
                    await Api.UpdateBackpackItemAsync(existingId, update, CancellationToken.None);

                var desiredQuantity = Math.Max(1, _backpackForm.Quantity);
                if (desiredQuantity > existing.ItemIds.Count)
                {
                    for (var i = existing.ItemIds.Count; i < desiredQuantity; i++)
                    {
                        await Api.AddBackpackItemAsync(new AddBackpackItemRequest
                        {
                            ChildId = _selectedChildId,
                            SnackName = update.SnackName,
                            BreadUnits = update.BreadUnits
                        }, CancellationToken.None);
                    }
                }
                else if (desiredQuantity < existing.ItemIds.Count)
                {
                    foreach (var excessId in existing.ItemIds.Skip(desiredQuantity))
                        await Api.DeleteBackpackItemAsync(excessId, CancellationToken.None);
                }

                await LoadBackpackFromApiAsync(_selectedChildId);

                ShowNotice("Позиция рюкзака обновлена.");
            }
            else
            {
                var count = Math.Max(1, _backpackForm.Quantity);
                var createdItems = new List<BackpackItem>();
                for (var i = 0; i < count; i++)
                {
                    var created = await Api.AddBackpackItemAsync(
                        new AddBackpackItemRequest
                        {
                            ChildId = _selectedChildId,
                            SnackName = _backpackForm.Name.Trim(),
                            BreadUnits = _backpackForm.BreadUnits
                        },
                        CancellationToken.None);

                    createdItems.Add(BackpackItem.FromApi(created));
                }

                _backpackItems.InsertRange(0, createdItems);
                ShowNotice(count == 1
                    ? "Позиция добавлена в рюкзак."
                    : $"Добавлено позиций: {count}.");
            }

            CancelBackpackEdit();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Не удалось сохранить позицию рюкзака.");
            _backpackFormError = "Не удалось сохранить позицию. Проверьте данные и попробуйте ещё раз.";
        }
    }

    private async Task RemoveBackpackItemAsync(string itemId)
    {
        var item = _backpackItems.FirstOrDefault(i => i.Id == itemId);
        if (item is null)
        {
            return;
        }

        try
        {
            foreach (var existingId in item.ItemIds)
                await Api.DeleteBackpackItemAsync(existingId, CancellationToken.None);
            _backpackItems.Remove(item);
            ShowNotice($"Позиция «{item.Name}» удалена из рюкзака.");
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Не удалось удалить позицию рюкзака. ItemId={ItemId}", item.Id);
            ShowNotice("Не удалось удалить позицию. Обновите страницу и попробуйте ещё раз.");
        }
    }

