<?xml version="1.0" encoding="utf-8" ?>
<pages:SwipeablePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                     xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                     xmlns:pages="clr-namespace:SugarGuard.Junior.Views.Pages"
                     xmlns:components="clr-namespace:SugarGuard.Junior.Views.Components"
                     xmlns:converters="clr-namespace:SugarGuard.Junior.Converters"
                     x:Class="SugarGuard.Junior.Views.Pages.BackpackPage"
                     x:Name="BackpackPageRoot"
                     Title="Рюкзак"
                     BackgroundColor="{DynamicResource BackgroundPage}">

    <pages:SwipeablePage.Resources>
        <ResourceDictionary>
            <converters:InvertedBoolConverter x:Key="InvertedBoolConverter" />

            <Style x:Key="BackpackCard" TargetType="Border">
                <Setter Property="Padding" Value="14" />
                <Setter Property="BackgroundColor" Value="{DynamicResource Surface}" />
                <Setter Property="Stroke" Value="{DynamicResource BorderDefault}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape" Value="RoundRectangle 18" />
            </Style>

            <Style x:Key="BackpackMutedText" TargetType="Label">
                <Setter Property="FontFamily" Value="{StaticResource Satoshi}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="TextColor" Value="{DynamicResource TextSecondary}" />
                <Setter Property="LineBreakMode" Value="WordWrap" />
            </Style>

            <Style x:Key="BackpackTitleText" TargetType="Label">
                <Setter Property="FontFamily" Value="{StaticResource Satoshi}" />
                <Setter Property="FontSize" Value="18" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{DynamicResource TextPrimary}" />
            </Style>

            <Style x:Key="BackpackChip" TargetType="Border">
                <Setter Property="Padding" Value="10,5" />
                <Setter Property="BackgroundColor" Value="{DynamicResource SurfacePrimarySoft}" />
                <Setter Property="StrokeThickness" Value="0" />
                <Setter Property="StrokeShape" Value="RoundRectangle 999" />
            </Style>
        </ResourceDictionary>
    </pages:SwipeablePage.Resources>

    <CollectionView ItemsSource="{Binding BackpackItems}"
                    SelectionMode="None"
                    VerticalScrollBarVisibility="Default"
                    ItemSizingStrategy="MeasureAllItems">

        <CollectionView.Header>
            <VerticalStackLayout Padding="16,12,16,12" Spacing="12">
                <Border Padding="16"
                        BackgroundColor="{DynamicResource Primary}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 22">
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="8">
                        <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="3">
                            <Label Text="Рюкзак"
                                   FontFamily="{StaticResource Satoshi}"
                                   FontSize="24"
                                   FontAttributes="Bold"
                                   TextColor="{DynamicResource TextOnPrimary}" />
                            <Label Text="Перекусы на день и быстрые ХЕ"
                                   FontFamily="{StaticResource Satoshi}"
                                   FontSize="13"
                                   TextColor="{DynamicResource TextOnPrimary}"
                                   Opacity="0.9" />
                        </VerticalStackLayout>

                        <Button Grid.Row="0"
                                Grid.Column="1"
                                Text="+ Добавить"
                                Command="{Binding AddSnackCommand}"
                                BackgroundColor="{DynamicResource Surface}"
                                TextColor="{DynamicResource Primary}"
                                FontFamily="{StaticResource Satoshi}"
                                FontSize="13"
                                FontAttributes="Bold"
                                CornerRadius="16"
                                Padding="12,8"
                                MinimumHeightRequest="40"
                                VerticalOptions="Center" />

                        <Grid Grid.Row="1" Grid.ColumnSpan="2" ColumnDefinitions="*,*,*" ColumnSpacing="8">
                            <Border Grid.Column="0" Style="{StaticResource BackpackChip}" BackgroundColor="#26FFFFFF">
                                <Label Text="{Binding TotalBreadUnitsText}"
                                       FontFamily="{StaticResource Satoshi}"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       HorizontalTextAlignment="Center"
                                       TextColor="{DynamicResource TextOnPrimary}" />
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource BackpackChip}" BackgroundColor="#26FFFFFF">
                                <Label Text="{Binding SnackCount, StringFormat='{}{0} шт.'}"
                                       FontFamily="{StaticResource Satoshi}"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       HorizontalTextAlignment="Center"
                                       TextColor="{DynamicResource TextOnPrimary}" />
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource BackpackChip}" BackgroundColor="#26FFFFFF">
                                <Label Text="{Binding ConsumedToday, StringFormat='Съедено {0:F1}'}"
                                       FontFamily="{StaticResource Satoshi}"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       HorizontalTextAlignment="Center"
                                       TextColor="{DynamicResource TextOnPrimary}" />
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <Border Style="{StaticResource BackpackCard}" IsVisible="{Binding HasError}">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Grid.Column="0" Spacing="3">
                            <Label Text="{Binding ErrorTitle}" Style="{StaticResource BackpackTitleText}" />
                            <Label Text="{Binding ErrorMessage}" Style="{StaticResource BackpackMutedText}" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1"
                                Text="Обновить"
                                Command="{Binding RetryLoadCommand}"
                                Style="{StaticResource SecondaryButton}"
                                VerticalOptions="Center" />
                    </Grid>
                </Border>

                <Label Text="Содержимое"
                       FontFamily="{StaticResource Satoshi}"
                       FontSize="16"
                       FontAttributes="Bold"
                       TextColor="{DynamicResource TextPrimary}"
                       IsVisible="{Binding HasItems}" />
            </VerticalStackLayout>
        </CollectionView.Header>

        <CollectionView.EmptyView>
            <Grid Padding="16,0,16,24"
                  IsVisible="{Binding ShowEmptyState}">
                <components:EmptyStateView
                    Icon="{Binding EmptyStateIcon}"
                    TitleText="{Binding EmptyStateTitle}"
                    Message="{Binding EmptyStateMessage}"
                    HelperText="Нажми «Добавить», чтобы положить первый перекус."
                    HelperTone="Info"
                    IsMascotVisible="False" />
            </Grid>
        </CollectionView.EmptyView>

        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Border Margin="16,0,16,10"
                        Style="{StaticResource BackpackCard}">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" RowDefinitions="Auto,Auto">
                        <Label Grid.Row="0"
                               Grid.Column="0"
                               Text="{Binding SnackName}"
                               FontFamily="{StaticResource Satoshi}"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="{DynamicResource TextPrimary}"
                               LineBreakMode="TailTruncation" />

                        <Border Grid.Row="1"
                                Grid.Column="0"
                                Style="{StaticResource BackpackChip}"
                                HorizontalOptions="Start"
                                Margin="0,6,0,0">
                            <Label Text="{Binding BreadUnits, StringFormat='{}{0:F1} ХЕ'}"
                                   FontFamily="{StaticResource Satoshi}"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="{DynamicResource Primary}" />
                        </Border>

                        <Button Grid.Row="0"
                                Grid.RowSpan="2"
                                Grid.Column="1"
                                Text="Удалить"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type pages:BackpackPage}}, Path=BindingContext.RemoveSnackCommand}"
                                CommandParameter="{Binding BackpackItemId}"
                                BackgroundColor="{DynamicResource DangerSoft}"
                                TextColor="{DynamicResource Danger}"
                                FontFamily="{StaticResource Satoshi}"
                                FontSize="12"
                                FontAttributes="Bold"
                                CornerRadius="14"
                                Padding="10,7"
                                MinimumHeightRequest="38"
                                VerticalOptions="Center" />
                    </Grid>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>

        <CollectionView.Footer>
            <BoxView HeightRequest="18" Opacity="0" />
        </CollectionView.Footer>
    </CollectionView>
</pages:SwipeablePage>
