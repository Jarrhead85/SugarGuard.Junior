<?xml version="1.0" encoding="utf-8" ?>
<pages:SwipeablePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                     xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                     xmlns:pages="clr-namespace:SugarGuard.Junior.Views.Pages"
                     xmlns:components="clr-namespace:SugarGuard.Junior.Views.Components"
                     xmlns:converters="clr-namespace:SugarGuard.Junior.Converters"
                     x:Class="SugarGuard.Junior.Views.Pages.MainPage"
                     Title="Мой сахар"
                     BackgroundColor="{DynamicResource BackgroundPage}">
    <pages:SwipeablePage.Resources>
        <ResourceDictionary>
            <converters:StatusToColorConverter x:Key="StatusToColorConverter" />
            <Style x:Key="HomeCard" TargetType="Border">
                <Setter Property="Padding" Value="16" />
                <Setter Property="BackgroundColor" Value="{DynamicResource Surface}" />
                <Setter Property="Stroke" Value="{DynamicResource BorderDefault}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape" Value="RoundRectangle 20" />
            </Style>
            <Style x:Key="Muted" TargetType="Label">
                <Setter Property="FontFamily" Value="{StaticResource Satoshi}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="TextColor" Value="{DynamicResource TextSecondary}" />
            </Style>
            <Style x:Key="QuickValue" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                <Setter Property="FontSize" Value="16" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="CornerRadius" Value="16" />
                <Setter Property="HeightRequest" Value="44" />
                <Setter Property="Padding" Value="6" />
            </Style>
        </ResourceDictionary>
    </pages:SwipeablePage.Resources>

    <Grid>
        <ScrollView VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Padding="16,30,16,22" Spacing="10">
                <Label Text="Мой сахар"
                       FontFamily="{StaticResource ClashDisplay}"
                       FontSize="30"
                       FontAttributes="Bold"
                       TextColor="{DynamicResource TextPrimary}" />

                <components:SyncBanner IsVisible="{Binding ShowOfflineIndicator}"
                                       PendingCount="{Binding PendingSyncCount}"
                                       IsDismissible="True" />

                <Border Padding="18,12" StrokeThickness="0" StrokeShape="RoundRectangle 22" HeightRequest="156">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#39C7A5" Offset="0" />
                            <GradientStop Color="#2688E8" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid ColumnDefinitions="*,96" ColumnSpacing="10">
                        <VerticalStackLayout Grid.Column="0" Spacing="3" VerticalOptions="Center">
                            <Label Text="{Binding ChildName, StringFormat='Привет, {0}!'}"
                                   FontFamily="{StaticResource ClashDisplay}"
                                   FontSize="23"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   MaxLines="2" />
                            <Label Text="{Binding CurrentDate}" FontSize="13" TextColor="White" Opacity="0.9" />
                            <Button Text="Помощь"
                                    Command="{Binding NavigateToHelpCommand}"
                                    Background="White"
                                    TextColor="#167F82"
                                    FontAttributes="Bold"
                                    FontSize="12"
                                    CornerRadius="14"
                                    HeightRequest="30"
                                    WidthRequest="104"
                                    Padding="8,2"
                                    HorizontalOptions="Start" />
                        </VerticalStackLayout>
                        <Border Grid.Column="1" Margin="2" Padding="3" Background="White"
                                StrokeThickness="0" StrokeShape="RoundRectangle 18">
                            <Image Source="mascot.png" Aspect="AspectFill" />
                        </Border>
                    </Grid>
                </Border>

                <Border Style="{StaticResource HomeCard}">
                    <Grid ColumnDefinitions="54,*,Auto" ColumnSpacing="12">
                        <Border WidthRequest="54" HeightRequest="54" StrokeThickness="0"
                                BackgroundColor="{DynamicResource SurfacePrimarySoft}"
                                StrokeShape="RoundRectangle 27">
                            <Label Text="●" TextColor="{DynamicResource Primary}" FontSize="24"
                                   HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Center">
                            <Label Text="Последний сахар" Style="{StaticResource Muted}" />
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="{Binding LastGlucoseValue}" FontFamily="{StaticResource ClashDisplay}"
                                       FontSize="34" FontAttributes="Bold" TextColor="{DynamicResource TextPrimary}" />
                                <Label Text="ммоль/л" Style="{StaticResource Muted}" VerticalOptions="End" Margin="0,0,0,7" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="2" Spacing="5" VerticalOptions="Center" HorizontalOptions="End">
                            <components:StatusChip UiState="{Binding CurrentGlucoseUiState}" />
                            <Label Text="{Binding LastMeasurementTime}" Style="{StaticResource Muted}" HorizontalTextAlignment="End" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Border Style="{StaticResource HomeCard}">
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Ввести измерение" FontFamily="{StaticResource ClashDisplay}"
                                   FontSize="18" FontAttributes="Bold" TextColor="{DynamicResource TextPrimary}"
                                   VerticalOptions="Center" />
                            <Picker Grid.Column="1" Title="Состояние"
                                    ItemsSource="{Binding ChildStateDisplayNames}"
                                    SelectedIndex="{Binding SelectedChildStateIndex}"
                                    FontSize="12" WidthRequest="120" />
                        </Grid>

                        <Border Padding="14,0" HeightRequest="64" Stroke="{DynamicResource BorderDefault}"
                                BackgroundColor="{DynamicResource SurfaceOffset}" StrokeShape="RoundRectangle 18">
                            <Grid ColumnDefinitions="*,Auto">
                                <Entry x:Name="GlucoseInput" Text="{Binding NewGlucoseValue}"
                                       Placeholder="5.6" Keyboard="Numeric"
                                       FontFamily="{StaticResource ClashDisplay}" FontSize="29"
                                       TextColor="{DynamicResource TextPrimary}" />
                                <Label Grid.Column="1" Text="ммоль/л" Style="{StaticResource Muted}" VerticalOptions="Center" />
                            </Grid>
                        </Border>

                        <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
                            <Button Grid.Column="0" Text="4" Style="{StaticResource QuickValue}" Command="{Binding SetGlucoseShortcutCommand}" CommandParameter="4" />
                            <Button Grid.Column="1" Text="5" Style="{StaticResource QuickValue}" Command="{Binding SetGlucoseShortcutCommand}" CommandParameter="5" />
                            <Button Grid.Column="2" Text="7" Style="{StaticResource QuickValue}" Command="{Binding SetGlucoseShortcutCommand}" CommandParameter="7" />
                            <Button Grid.Column="3" Text="10" Style="{StaticResource QuickValue}" Command="{Binding SetGlucoseShortcutCommand}" CommandParameter="10" />
                        </Grid>

                        <Button Text="Получить совет  ›" Command="{Binding SendMeasurementCommand}"
                                Style="{StaticResource PrimaryButton}" IsEnabled="{Binding IsNotBusy}"
                                HeightRequest="52" FontSize="17" />
                        <Label Text="{Binding ErrorMessage}" IsVisible="{Binding IsErrorVisible}"
                               FontSize="13" TextColor="{DynamicResource Danger}" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource HomeCard}" IsVisible="{Binding ShowRecommendation}">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="{Binding RecommendationUrgency}" FontSize="13" FontAttributes="Bold"
                               TextColor="{Binding UrgencyKey, Converter={StaticResource StatusToColorConverter}}" />
                        <Label Text="{Binding RecommendationText}" FontSize="15" TextColor="{DynamicResource TextPrimary}" />
                    </VerticalStackLayout>
                </Border>
                <GraphicsView x:Name="GlucoseGraphicsMini" HeightRequest="1" IsVisible="False" />
            </VerticalStackLayout>
        </ScrollView>

        <components:EmptyStateView IsVisible="{Binding ShowNoChildSelected}"
                                   Icon="SG" TitleText="Профиль ещё не готов"
                                   Message="Заверши настройку профиля, чтобы вводить сахар."
                                   IsMascotVisible="True" Mascot="SG" />
    </Grid>
</pages:SwipeablePage>
