<?xml version="1.0" encoding="utf-8" ?>
<pages:SwipeablePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                     xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                     xmlns:pages="clr-namespace:SugarGuard.Junior.Views.Pages"
                     xmlns:components="clr-namespace:SugarGuard.Junior.Views.Components"
                     xmlns:converters="clr-namespace:SugarGuard.Junior.Converters"
                     x:Class="SugarGuard.Junior.Views.Pages.MainPage"
                     Title="Мой сахар"
                     BackgroundColor="{DynamicResource BackgroundPage}">

    <pages:SwipeablePage.Resources>
        <ResourceDictionary>
            <converters:StatusToColorConverter x:Key="StatusToColorConverter" />

            <Style x:Key="HomeCard" TargetType="Border">
                <Setter Property="Padding" Value="14" />
                <Setter Property="BackgroundColor" Value="{DynamicResource Surface}" />
                <Setter Property="Stroke" Value="{DynamicResource BorderDefault}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape" Value="RoundRectangle 20" />
            </Style>

            <Style x:Key="HomeLabel" TargetType="Label">
                <Setter Property="FontFamily" Value="{StaticResource Satoshi}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="TextColor" Value="{DynamicResource TextSecondary}" />
            </Style>

            <Style x:Key="HomeValue" TargetType="Label">
                <Setter Property="FontFamily" Value="{StaticResource Satoshi}" />
                <Setter Property="FontSize" Value="18" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{DynamicResource TextPrimary}" />
            </Style>

            <Style x:Key="ShortcutButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                <Setter Property="FontSize" Value="16" />
                <Setter Property="Padding" Value="10,8" />
                <Setter Property="MinimumHeightRequest" Value="40" />
                <Setter Property="CornerRadius" Value="16" />
            </Style>
        </ResourceDictionary>
    </pages:SwipeablePage.Resources>

    <Grid>
        <ScrollView VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Padding="16,12,16,24" Spacing="12">

                <components:SyncBanner
                    IsVisible="{Binding ShowOfflineIndicator}"
                    PendingCount="{Binding PendingSyncCount}"
                    IsDismissible="True" />

                <Border Style="{StaticResource HomeCard}">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="{Binding ChildName}"
                                   FontFamily="{StaticResource ClashDisplay}"
                                   FontSize="28"
                                   FontAttributes="Bold"
                                   TextColor="{DynamicResource TextPrimary}" />
                            <Label Text="{Binding CurrentDate}" Style="{StaticResource HomeLabel}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1"
                                             Spacing="6"
                                             HorizontalOptions="End">
                            <Label Text="{Binding CurrentTime}"
                                   Style="{StaticResource HomeValue}"
                                   HorizontalOptions="End" />
                            <Button Text="Помощь"
                                    Command="{Binding NavigateToHelpCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    Padding="12,8"
                                    MinimumHeightRequest="40"
                                    FontSize="13" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Border Style="{StaticResource HomeCard}">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="Последний сахар" Style="{StaticResource HomeLabel}" />
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="{Binding LastGlucoseValue}"
                                       FontFamily="{StaticResource ClashDisplay}"
                                       FontSize="34"
                                       FontAttributes="Bold"
                                       TextColor="{DynamicResource TextPrimary}" />
                                <Label Text="ммоль/л"
                                       Style="{StaticResource HomeLabel}"
                                       VerticalOptions="End"
                                       Margin="0,0,0,7" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1"
                                             Spacing="8"
                                             HorizontalOptions="End"
                                             VerticalOptions="Center">
                            <components:StatusChip UiState="{Binding CurrentGlucoseUiState}"
                                                   HorizontalOptions="End" />
                            <Label Text="{Binding LastMeasurementTime}"
                                   Style="{StaticResource HomeLabel}"
                                   HorizontalOptions="End" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Border Style="{StaticResource HomeCard}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Ввести измерение"
                               FontFamily="{StaticResource Satoshi}"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="{DynamicResource TextPrimary}" />

                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <Picker Grid.Column="0"
                                    Title="Состояние"
                                    ItemsSource="{Binding ChildStateDisplayNames}"
                                    SelectedIndex="{Binding SelectedChildStateIndex}"
                                    FontSize="14" />
                            <Label Grid.Column="1"
                                   Text="сейчас"
                                   Style="{StaticResource HomeLabel}"
                                   VerticalOptions="Center" />
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <Border Grid.Column="0"
                                    StrokeShape="RoundRectangle 16"
                                    BackgroundColor="{DynamicResource SurfaceOffset}"
                                    Stroke="{DynamicResource BorderDefault}"
                                    StrokeThickness="1"
                                    Padding="12,0">
                                <Entry x:Name="GlucoseInput"
                                       Text="{Binding NewGlucoseValue}"
                                       Placeholder="5.6"
                                       FontFamily="{StaticResource Satoshi}"
                                       FontSize="28"
                                       Keyboard="Numeric"
                                       TextColor="{DynamicResource TextPrimary}"
                                       PlaceholderColor="{DynamicResource TextFaint}" />
                            </Border>
                            <Label Grid.Column="1"
                                   Text="ммоль/л"
                                   Style="{StaticResource HomeLabel}"
                                   VerticalOptions="Center" />
                        </Grid>

                        <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
                            <Button Grid.Column="0" Text="4" Style="{StaticResource ShortcutButton}" Command="{Binding SetGlucoseShortcutCommand}" CommandParameter="4" />
                            <Button Grid.Column="1" Text="5" Style="{StaticResource ShortcutButton}" Command="{Binding SetGlucoseShortcutCommand}" CommandParameter="5" />
                            <Button Grid.Column="2" Text="7" Style="{StaticResource ShortcutButton}" Command="{Binding SetGlucoseShortcutCommand}" CommandParameter="7" />
                            <Button Grid.Column="3" Text="10" Style="{StaticResource ShortcutButton}" Command="{Binding SetGlucoseShortcutCommand}" CommandParameter="10" />
                        </Grid>

                        <Button Text="Получить совет"
                                Command="{Binding SendMeasurementCommand}"
                                Style="{StaticResource PrimaryButton}"
                                IsEnabled="{Binding IsNotBusy}"
                                MinimumHeightRequest="50" />

                        <Label Text="{Binding ErrorMessage}"
                               IsVisible="{Binding IsErrorVisible}"
                               FontFamily="{StaticResource Satoshi}"
                               FontSize="14"
                               TextColor="{DynamicResource Danger}"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource HomeCard}"
                        IsVisible="{Binding ShowRecommendation}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="{Binding RecommendationUrgency}"
                               FontFamily="{StaticResource Satoshi}"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="{Binding UrgencyKey, Converter={StaticResource StatusToColorConverter}}" />
                        <Label Text="{Binding RecommendationText}"
                               FontFamily="{StaticResource Satoshi}"
                               FontSize="16"
                               TextColor="{DynamicResource TextPrimary}"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Border>

                <GraphicsView x:Name="GlucoseGraphicsMini"
                              HeightRequest="1"
                              IsVisible="False" />
            </VerticalStackLayout>
        </ScrollView>

        <components:EmptyStateView
            IsVisible="{Binding ShowNoChildSelected}"
            Icon="🙂"
            TitleText="Профиль ещё не готов"
            Message="Заверши настройку профиля, и здесь появится быстрый ввод сахара."
            IsMascotVisible="True"
            Mascot="SG" />
    </Grid>
</pages:SwipeablePage>
