<?xml version="1.0" encoding="utf-8" ?>
<pages:SwipeablePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                     xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                     xmlns:pages="clr-namespace:SugarGuard.Junior.Views.Pages"
                     xmlns:components="clr-namespace:SugarGuard.Junior.Views.Components"
                     x:Class="SugarGuard.Junior.Views.Pages.HistoryPage"
                     Title="История"
                     BackgroundColor="{DynamicResource BackgroundPage}">
    <pages:SwipeablePage.Resources>
        <ResourceDictionary>
            <Style x:Key="HistoryCard" TargetType="Border">
                <Setter Property="Padding" Value="14" />
                <Setter Property="BackgroundColor" Value="{DynamicResource Surface}" />
                <Setter Property="Stroke" Value="{DynamicResource BorderDefault}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape" Value="RoundRectangle 20" />
            </Style>
            <Style x:Key="FilterButton" TargetType="Button" BasedOn="{StaticResource ButtonBase}">
                <Setter Property="Background" Value="{x:Null}" />
                <Setter Property="BackgroundColor" Value="{DynamicResource SurfaceOffset}" />
                <Setter Property="TextColor" Value="{DynamicResource TextPrimary}" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="CornerRadius" Value="15" />
                <Setter Property="Padding" Value="7,5" />
                <Setter Property="HeightRequest" Value="40" />
            </Style>
        </ResourceDictionary>
    </pages:SwipeablePage.Resources>

    <Grid>
        <RefreshView Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsLoading}">
            <CollectionView ItemsSource="{Binding Measurements}"
                            SelectionMode="None" VerticalScrollBarVisibility="Default">
            <CollectionView.Header>
                <VerticalStackLayout Padding="16,30,16,12" Spacing="12">
                    <Label Text="История" FontFamily="{StaticResource ClashDisplay}" FontSize="30"
                           FontAttributes="Bold" TextColor="{DynamicResource TextPrimary}" />
                    <Label Text="Смотри, как менялся твой сахар" FontSize="14"
                           TextColor="{DynamicResource TextSecondary}" />

                    <Border Style="{StaticResource HistoryCard}" Padding="7">
                        <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="5">
                            <Button Grid.Column="0" Text="Сегодня" Style="{StaticResource FilterButton}" Command="{Binding SelectTodayCommand}">
                                <Button.Triggers><DataTrigger TargetType="Button" Binding="{Binding IsTodaySelected}" Value="True"><Setter Property="BackgroundColor" Value="{DynamicResource Primary}" /><Setter Property="TextColor" Value="White" /></DataTrigger></Button.Triggers>
                            </Button>
                            <Button Grid.Column="1" Text="7 дней" Style="{StaticResource FilterButton}" Command="{Binding SelectLast7DaysCommand}">
                                <Button.Triggers><DataTrigger TargetType="Button" Binding="{Binding IsLast7DaysSelected}" Value="True"><Setter Property="BackgroundColor" Value="{DynamicResource Primary}" /><Setter Property="TextColor" Value="White" /></DataTrigger></Button.Triggers>
                            </Button>
                            <Button Grid.Column="2" Text="30 дней" Style="{StaticResource FilterButton}" Command="{Binding SelectLast30DaysCommand}">
                                <Button.Triggers><DataTrigger TargetType="Button" Binding="{Binding IsLast30DaysSelected}" Value="True"><Setter Property="BackgroundColor" Value="{DynamicResource Primary}" /><Setter Property="TextColor" Value="White" /></DataTrigger></Button.Triggers>
                            </Button>
                            <Button Grid.Column="3" Text="Период" Style="{StaticResource FilterButton}" Command="{Binding SelectCustomRangeCommand}">
                                <Button.Triggers><DataTrigger TargetType="Button" Binding="{Binding IsCustomSelected}" Value="True"><Setter Property="BackgroundColor" Value="{DynamicResource Primary}" /><Setter Property="TextColor" Value="White" /></DataTrigger></Button.Triggers>
                            </Button>
                        </Grid>
                    </Border>

                    <Grid IsVisible="{Binding ShouldShowCustomRange}" ColumnDefinitions="*,*" ColumnSpacing="8">
                        <DatePicker Date="{Binding CustomFrom}" />
                        <DatePicker Grid.Column="1" Date="{Binding CustomTo}" />
                    </Grid>

                    <Border Style="{StaticResource HistoryCard}" IsVisible="{Binding HasMeasurements}">
                        <VerticalStackLayout Spacing="8">
                            <Grid ColumnDefinitions="*,Auto">
                                <VerticalStackLayout Spacing="0">
                                    <Label Text="Среднее показанных" FontSize="13" TextColor="{DynamicResource TextSecondary}" />
                                    <HorizontalStackLayout Spacing="5">
                                        <Label Text="{Binding AverageGlucose}" FontFamily="{StaticResource ClashDisplay}"
                                               FontSize="31" FontAttributes="Bold" TextColor="{DynamicResource TextPrimary}" />
                                        <Label Text="ммоль/л" FontSize="12" TextColor="{DynamicResource TextSecondary}" VerticalOptions="End" Margin="0,0,0,7" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                                <Label Grid.Column="1" Text="Цель 4.0–10.0" FontSize="12" TextColor="{DynamicResource GlucoseNormalColor}" VerticalOptions="Center" />
                            </Grid>
                            <GraphicsView x:Name="HistoryChart" Drawable="{Binding ChartDrawable}"
                                          HeightRequest="224" IsVisible="{Binding HasChart}" />
                            <Grid ColumnDefinitions="Auto,Auto,Auto" ColumnSpacing="12"
                                  IsVisible="{Binding HasChart}">
                                <HorizontalStackLayout Spacing="5">
                                    <BoxView WidthRequest="8" HeightRequest="8" CornerRadius="4"
                                             Color="{DynamicResource GlucoseNormalColor}" VerticalOptions="Center" />
                                    <Label Text="Норма 4.0–10.0" FontSize="10" TextColor="{DynamicResource TextSecondary}" />
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Grid.Column="1" Spacing="5">
                                    <BoxView WidthRequest="8" HeightRequest="8" CornerRadius="4"
                                             Color="{DynamicResource GlucoseWarningColor}" VerticalOptions="Center" />
                                    <Label Text="Вне цели" FontSize="10" TextColor="{DynamicResource TextSecondary}" />
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Grid.Column="2" Spacing="5">
                                    <BoxView WidthRequest="8" HeightRequest="8" CornerRadius="4"
                                             Color="{DynamicResource GlucoseCriticalColor}" VerticalOptions="Center" />
                                    <Label Text="Критично" FontSize="10" TextColor="{DynamicResource TextSecondary}" />
                                </HorizontalStackLayout>
                            </Grid>
                            <Label Text="{Binding ResultsSummaryText}" FontSize="12" TextColor="{DynamicResource TextSecondary}" />
                        </VerticalStackLayout>
                    </Border>

                    <Label Text="Последние измерения" FontFamily="{StaticResource ClashDisplay}" FontSize="21"
                           FontAttributes="Bold" TextColor="{DynamicResource TextPrimary}" IsVisible="{Binding HasMeasurements}" />
                </VerticalStackLayout>
            </CollectionView.Header>

            <CollectionView.EmptyView>
                <Grid Padding="16,20">
                    <components:EmptyStateView TitleText="{Binding EmptyStateTitle}"
                                               Message="{Binding EmptyStateMessage}" />
                </Grid>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="16,0,16,9" Style="{StaticResource HistoryCard}" Padding="13">
                        <Grid ColumnDefinitions="72,*,Auto" ColumnSpacing="10">
                            <VerticalStackLayout Spacing="0" VerticalOptions="Center">
                                <Label Text="{Binding DisplayTime}" FontSize="17" FontAttributes="Bold" TextColor="{DynamicResource TextPrimary}" />
                                <Label Text="{Binding DayLabel}" FontSize="11" TextColor="{DynamicResource TextSecondary}" />
                            </VerticalStackLayout>
                            <HorizontalStackLayout Grid.Column="1" Spacing="5" VerticalOptions="Center">
                                <Label Text="{Binding DisplayValue}" FontFamily="{StaticResource ClashDisplay}" FontSize="25" FontAttributes="Bold" TextColor="{DynamicResource TextPrimary}" />
                                <Label Text="ммоль/л" FontSize="11" TextColor="{DynamicResource TextSecondary}" VerticalOptions="End" Margin="0,0,0,4" />
                            </HorizontalStackLayout>
                            <components:StatusChip Grid.Column="2" UiState="{Binding UiState}" VerticalOptions="Center" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.Footer>
                <VerticalStackLayout Padding="16,6,16,24" Spacing="12">
                    <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="8">
                        <Button Grid.Column="0" Text="← Назад" Style="{StaticResource SecondaryButton}"
                                Command="{Binding LoadPreviousPageCommand}"
                                IsEnabled="{Binding CanGoPreviousPage}" />
                        <Label Grid.Column="1" Text="{Binding PageLabel}" VerticalOptions="Center"
                               TextColor="{DynamicResource TextSecondary}" FontSize="12" />
                        <Button Grid.Column="2" Text="Вперёд →" Style="{StaticResource SecondaryButton}"
                                Command="{Binding LoadNextPageCommand}"
                                IsEnabled="{Binding CanGoNextPage}" />
                    </Grid>

                    <Border IsVisible="{Binding ShowEncouragementBanner}"
                            Padding="14" StrokeThickness="0" StrokeShape="RoundRectangle 20">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="{DynamicResource BrandSecondary}" Offset="0" />
                                <GradientStop Color="{DynamicResource BrandBlue}" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid ColumnDefinitions="72,*" ColumnSpacing="12">
                            <Image Source="{DynamicResource JuniorMascot}"
                                   Aspect="AspectFit" HeightRequest="68" />
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="3">
                                <Label Text="{Binding EncouragementTitle}"
                                       FontFamily="{StaticResource ClashDisplay}"
                                       FontSize="19" FontAttributes="Bold" TextColor="White" />
                                <Label Text="{Binding EncouragementMessage}"
                                       FontSize="13" TextColor="White" Opacity="0.92" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </VerticalStackLayout>
            </CollectionView.Footer>
            </CollectionView>
        </RefreshView>

        <Border IsVisible="{Binding IsLoadErrorVisible}"
                Margin="16,30,16,0"
                Padding="14"
                VerticalOptions="Start"
                BackgroundColor="{DynamicResource DangerSoft}"
                Stroke="{DynamicResource Danger}"
                StrokeShape="RoundRectangle 16"
                ZIndex="2">
            <Label Text="{Binding LoadErrorMessage}"
                   TextColor="{DynamicResource Danger}"
                   FontSize="14" />
        </Border>
    </Grid>
</pages:SwipeablePage>
