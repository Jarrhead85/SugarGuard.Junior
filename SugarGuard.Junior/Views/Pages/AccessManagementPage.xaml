<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ViewModels="clr-namespace:SugarGuard.Junior.ViewModels"
             x:Class="SugarGuard.Junior.Views.Pages.AccessManagementPage"
             Title="Доступ к моим данным"
             BackgroundColor="{DynamicResource BackgroundPage}">

    <ScrollView>
        <VerticalStackLayout Padding="{StaticResource PaddingPage}"
                             Spacing="{StaticResource Spacing20}">

            <VerticalStackLayout Spacing="{StaticResource Spacing8}">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="{StaticResource Spacing12}">
                    <Label Text="Связь с родителем"
                           Style="{StaticResource PageTitleText}"
                           VerticalOptions="Center"
                           MaxLines="2"
                           LineBreakMode="WordWrap" />
                    <Button Text="Закрыть"
                            Command="{Binding CloseCommand}"
                            Style="{StaticResource GhostButton}"
                            HorizontalOptions="End"
                            VerticalOptions="Center"
                            Grid.Column="1" />
                </Grid>
                <Label Text="Выдайте код в приложении, а родитель введёт его в веб-кабинете SugarGuard. После этого он увидит измерения, историю и рюкзак."
                       Style="{StaticResource BodyTextMuted}" />
            </VerticalStackLayout>

            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               Color="{StaticResource Primary}"
                               HorizontalOptions="Center" />

            <Border Style="{StaticResource HeroCard}"
                    Padding="{StaticResource PaddingLg}">
                <VerticalStackLayout Spacing="{StaticResource Spacing16}">
                    <Label Text="Код для родителя"
                           Style="{StaticResource SectionHeadingText}" />

                    <Label Text="Нажмите кнопку, покажите код родителю или отправьте ему. Каждый новый код заменяет предыдущий активный код."
                           Style="{StaticResource CaptionTextFaint}" />

                    <Button Text="Выдать код родителю"
                            Command="{Binding GenerateParentInviteCommand}"
                            Style="{StaticResource PrimaryButton}"
                            IsEnabled="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}" />

                    <Border IsVisible="{Binding ShowInviteCode}"
                            Style="{StaticResource Card}"
                            BackgroundColor="{DynamicResource SurfacePrimarySoft}"
                            Padding="{StaticResource PaddingLg}">
                        <VerticalStackLayout Spacing="{StaticResource Spacing12}"
                                             HorizontalOptions="Center">
                            <Label Text="{Binding InviteCode}"
                                   Style="{StaticResource ValueText}"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   MaxLines="1"
                                   LineBreakMode="NoWrap" />
                            <Label Text="{Binding InviteCodeExpiresText}"
                                   Style="{StaticResource CaptionTextFaint}"
                                   HorizontalTextAlignment="Center" />

                            <Grid ColumnDefinitions="*,*"
                                  ColumnSpacing="{StaticResource Spacing12}">
                                <Button Text="Копировать"
                                        Command="{Binding CopyInviteCodeCommand}"
                                        Style="{StaticResource SoftButton}"
                                        Grid.Column="0" />
                                <Button Text="Скрыть"
                                        Command="{Binding CloseInviteCodeCommand}"
                                        Style="{StaticResource GhostButton}"
                                        Grid.Column="1" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout Spacing="{StaticResource Spacing12}">
                <Label Text="Подключённые родители"
                       Style="{StaticResource SectionHeadingTextMuted}" />

                <BindableLayout.ItemsSource>
                    <Binding Path="ParentLinks" />
                </BindableLayout.ItemsSource>

                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource ListCard}"
                                Padding="{StaticResource PaddingLg}">
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="{StaticResource Spacing12}">
                                <VerticalStackLayout Spacing="{StaticResource Spacing4}">
                                    <Label Text="{Binding ParentEmail, FallbackValue='Родитель'}"
                                           Style="{StaticResource BodyText}" />
                                    <Label Text="{Binding CreatedAt, StringFormat='Подключён {0:dd.MM.yyyy}'}"
                                           Style="{StaticResource CaptionTextFaint}" />
                                </VerticalStackLayout>
                                <Button Text="Отвязать"
                                        Style="{StaticResource GhostButton}"
                                        TextColor="{StaticResource GlucoseDangerColor}"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ViewModels:AccessManagementPageViewModel}}, Path=RemoveParentLinkCommand}"
                                        CommandParameter="{Binding LinkId}"
                                        Grid.Column="1" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>

                <BindableLayout.EmptyView>
                    <Border Style="{StaticResource ListCard}"
                            Padding="{StaticResource PaddingLg}">
                        <Label Text="Пока нет подключённых родителей. Выдайте код и попросите родителя ввести его в веб-кабинете."
                               Style="{StaticResource BodyTextMuted}"
                               HorizontalTextAlignment="Center" />
                    </Border>
                </BindableLayout.EmptyView>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="{StaticResource Spacing12}">
                <Label Text="Врач"
                       Style="{StaticResource SectionHeadingTextMuted}" />

                <BindableLayout.ItemsSource>
                    <Binding Path="DoctorLinks" />
                </BindableLayout.ItemsSource>

                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource ListCard}"
                                Padding="{StaticResource PaddingLg}">
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="{StaticResource Spacing12}">
                                <VerticalStackLayout Spacing="{StaticResource Spacing4}">
                                    <Label Text="{Binding DoctorEmail, FallbackValue='Врач'}"
                                           Style="{StaticResource BodyText}" />
                                    <Label Text="{Binding CreatedAt, StringFormat='Подключён {0:dd.MM.yyyy}'}"
                                           Style="{StaticResource CaptionTextFaint}" />
                                </VerticalStackLayout>
                                <Button Text="Отвязать"
                                        Style="{StaticResource GhostButton}"
                                        TextColor="{StaticResource GlucoseDangerColor}"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ViewModels:AccessManagementPageViewModel}}, Path=RemoveDoctorLinkCommand}"
                                        CommandParameter="{Binding LinkId}"
                                        Grid.Column="1" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>

                <BindableLayout.EmptyView>
                    <Border Style="{StaticResource ListCard}"
                            Padding="{StaticResource PaddingLg}">
                        <Label Text="Врач пока не подключён. Код для врача можно выдать позже."
                               Style="{StaticResource BodyTextMuted}"
                               HorizontalTextAlignment="Center" />
                    </Border>
                </BindableLayout.EmptyView>

                <Button Text="Выдать код врачу"
                        Command="{Binding GenerateDoctorInviteCommand}"
                        Style="{StaticResource SoftButton}"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}" />
            </VerticalStackLayout>

            <Label Text="{Binding SuccessMessage}"
                   Style="{StaticResource CaptionText}"
                   TextColor="{StaticResource Primary}"
                   HorizontalTextAlignment="Center"
                   IsVisible="{Binding SuccessMessage, Converter={StaticResource StringToBoolConverter}}" />

            <Label Text="{Binding ErrorMessage}"
                   Style="{StaticResource CaptionText}"
                   TextColor="{StaticResource GlucoseDangerColor}"
                   HorizontalTextAlignment="Center"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
