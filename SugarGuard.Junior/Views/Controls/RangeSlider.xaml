<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SugarGuard.Junior.Views.Controls.RangeSlider"
             x:Name="rangeSlider">

    <VerticalStackLayout Spacing="8">
        <!-- Метки значений -->
        <Grid ColumnDefinitions="*,*">
            <VerticalStackLayout Grid.Column="0" Spacing="2">
                <Label Text="Мин"
                       Style="{StaticResource CaptionTextFaint}" />
                <Label x:Name="minValueLabel"
                       Style="{StaticResource ValueText}"
                       FontSize="18" />
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="1" Spacing="2"
                                 HorizontalOptions="End">
                <Label Text="Макс"
                       Style="{StaticResource CaptionTextFaint}"
                       HorizontalTextAlignment="End" />
                <Label x:Name="maxValueLabel"
                       Style="{StaticResource ValueText}"
                       FontSize="18"
                       HorizontalTextAlignment="End" />
            </VerticalStackLayout>
        </Grid>

        <!-- Трек и ползунки -->
        <Grid HeightRequest="40">
            <!-- Трек фона -->
            <BoxView HeightRequest="6"
                     CornerRadius="3"
                     BackgroundColor="{StaticResource ProgressTrackBackground}"
                     VerticalOptions="Center"
                     HorizontalOptions="Fill" />

            <!-- Активный трек (между ползунками) -->
            <BoxView x:Name="activeTrack"
                     HeightRequest="6"
                     CornerRadius="3"
                     BackgroundColor="{StaticResource Primary}"
                     VerticalOptions="Center" />

            <!-- Минимальный ползунок -->
            <Slider x:Name="minSlider"
                    Minimum="3.5"
                    Maximum="14.0"
                    Value="4.0"
                    VerticalOptions="Center"
                    ThumbColor="{StaticResource Primary}"
                    MinimumTrackColor="Transparent"
                    MaximumTrackColor="Transparent"
                    ValueChanged="OnMinSliderValueChanged" />

            <!-- Максимальный ползунок -->
            <Slider x:Name="maxSlider"
                    Minimum="3.5"
                    Maximum="14.0"
                    Value="10.0"
                    VerticalOptions="Center"
                    ThumbColor="{StaticResource Primary}"
                    MinimumTrackColor="Transparent"
                    MaximumTrackColor="Transparent"
                    ValueChanged="OnMaxSliderValueChanged" />
        </Grid>

        <!-- Шкала -->
        <Grid ColumnDefinitions="*,*,*,*,*,*,*">
            <Label Grid.Column="0" Text="3.5"
                   Style="{StaticResource CaptionTextFaint}" FontSize="11" />
            <Label Grid.Column="3" Text="8.0"
                   Style="{StaticResource CaptionTextFaint}" FontSize="11"
                   HorizontalTextAlignment="Center" />
            <Label Grid.Column="6" Text="14.0"
                   Style="{StaticResource CaptionTextFaint}" FontSize="11"
                   HorizontalTextAlignment="End" />
        </Grid>
    </VerticalStackLayout>

</ContentView>
