<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SugarGuard.Junior.Views.Controls.PasswordStrengthBar"
             x:Name="strengthBar">

    <VerticalStackLayout Spacing="4">
        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="4" HeightRequest="4">
            <BoxView x:Name="segment1" Grid.Column="0"
                     CornerRadius="2" BackgroundColor="{StaticResource SurfaceOffset}" />
            <BoxView x:Name="segment2" Grid.Column="1"
                     CornerRadius="2" BackgroundColor="{StaticResource SurfaceOffset}" />
            <BoxView x:Name="segment3" Grid.Column="2"
                     CornerRadius="2" BackgroundColor="{StaticResource SurfaceOffset}" />
        </Grid>
        <Label x:Name="strengthLabel"
               Style="{StaticResource CaptionTextFaint}"
               HorizontalTextAlignment="End" />
    </VerticalStackLayout>

</ContentView>
