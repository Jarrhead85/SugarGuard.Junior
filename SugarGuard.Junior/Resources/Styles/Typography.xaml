    <x:String x:Key="Satoshi">SugarGuardBody</x:String>
    <x:String x:Key="OpenSansRegular">OpenSansRegular</x:String>

    <!-- 2. Р Р°Р·РјРµСЂС‹ С‚РµРєСЃС‚Р° -->

    <!-- РЎР°РјС‹Р№ РјР°Р»РµРЅСЊРєРёР№ С‚РµРєСЃС‚: РІСЃРїРѕРјРѕРіР°С‚РµР»СЊРЅС‹Рµ РїРѕРґРїРёСЃРё, metadata -->
