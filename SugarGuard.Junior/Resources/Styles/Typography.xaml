    <x:Double x:Key="LineHeightDefault">1.25</x:Double>
    <x:Double x:Key="LineHeightRelaxed">1.4</x:Double>

    <!-- 4. РўРµРєСЃС‚РѕРІС‹Рµ СЂРѕР»Рё -->

    <!-- РЎР°РјС‹Р№ РєСЂСѓРїРЅС‹Р№ display-С‚РµРєСЃС‚ РґР»СЏ hero Рё РєР»СЋС‡РµРІС‹С… СЌРєСЂР°РЅРѕРІ -->
